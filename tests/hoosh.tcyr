# hoosh.tcyr — hoosh gateway tests (Wave 1: pure logic, no I/O)
# Tests: error types, router, token budget, cache, cost tracker, audit chain, queue
#
# Run: cyrius test tests/hoosh.tcyr
#   or: cyrius build tests/hoosh.tcyr /tmp/hoosh_test && /tmp/hoosh_test

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/chrono.cyr"
include "lib/freelist.cyr"
include "lib/bayan.cyr"
include "lib/ct.cyr"
include "lib/sigil.cyr"
# NOTE: do NOT explicitly `include "lib/syscalls.cyr"` here. `cyrius build`
# auto-injects the cyrius.cyml [deps] stdlib set (tls/sandhi/net/…) ahead of
# this file's explicit includes, in array order. Since 6.2.28 tls_native_conn
# takes `&sys_getrandom`, so the auto-injected `tls` must see `syscalls` first.
# An explicit syscalls include here lands AFTER the prepended `tls` → single-pass
# "undefined variable 'sys_getrandom'". Letting syscalls auto-inject (array idx
# before tls) keeps the order correct. sys_* wrappers are still in scope.
include "lib/assert.cyr"
include "lib/sakshi.cyr"
include "src/vendor/bote-core.cyr"
include "src/lib/logging.cyr"

# ================================================================
# Error types — error code + HTTP status mapping
# ================================================================

# Error codes (enum — zero gvar cost)
enum HooshErr {
    ERR_PROVIDER       = 1;
    ERR_MODEL_NOT_FOUND = 2;
    ERR_RATE_LIMITED   = 3;
    ERR_BUDGET_EXCEEDED = 4;
    ERR_NO_PROVIDER    = 5;
    ERR_TIMEOUT        = 6;
    ERR_CACHE          = 7;
    ERR_DLP_BLOCKED    = 8;
    ERR_HTTP           = 9;
    ERR_INTERNAL       = 10;
}

fn error_http_status(code) {
    if (code == ERR_MODEL_NOT_FOUND || code == ERR_NO_PROVIDER) { return 404; }
    if (code == ERR_RATE_LIMITED || code == ERR_BUDGET_EXCEEDED) { return 429; }
    if (code == ERR_TIMEOUT) { return 408; }
    if (code == ERR_DLP_BLOCKED) { return 403; }
    if (code == ERR_CACHE || code == ERR_PROVIDER) { return 500; }
    if (code == ERR_HTTP) { return 502; }
    return 500;
}

fn error_is_retryable(code) {
    if (code == ERR_RATE_LIMITED || code == ERR_TIMEOUT) { return 1; }
    if (code == ERR_PROVIDER || code == ERR_CACHE) { return 1; }
    return 0;
}

fn error_code_str(code) {
    if (code == ERR_MODEL_NOT_FOUND) { return "model_not_found"; }
    if (code == ERR_NO_PROVIDER) { return "no_provider"; }
    if (code == ERR_RATE_LIMITED) { return "rate_limit_exceeded"; }
    if (code == ERR_BUDGET_EXCEEDED) { return "budget_exceeded"; }
    if (code == ERR_TIMEOUT) { return "timeout"; }
    if (code == ERR_CACHE) { return "cache_error"; }
    if (code == ERR_PROVIDER) { return "provider_error"; }
    if (code == ERR_DLP_BLOCKED) { return "content_blocked"; }
    if (code == ERR_HTTP) { return "upstream_error"; }
    return "internal_error";
}

# ================================================================
# Provider types
# ================================================================

enum Provider {
    PROV_OLLAMA     = 0;
    PROV_LLAMACPP   = 1;
    PROV_SYNAPSE    = 2;
    PROV_LMSTUDIO   = 3;
    PROV_LOCALAI    = 4;
    PROV_OPENAI     = 5;
    PROV_ANTHROPIC  = 6;
    PROV_DEEPSEEK   = 7;
    PROV_MISTRAL    = 8;
    PROV_GOOGLE     = 9;
    PROV_GROQ       = 10;
    PROV_GROK       = 11;
    PROV_OPENROUTER = 12;
    PROV_WHISPER    = 13;
    PROV_VLLM       = 14;
    PROV_TENSORRT   = 15;
    PROV_ONNX       = 16;
    PROV_COUNT      = 17;
}

fn provider_is_local(prov) {
    if (prov == PROV_OLLAMA) { return 1; }
    if (prov == PROV_LLAMACPP) { return 1; }
    if (prov == PROV_SYNAPSE) { return 1; }
    if (prov == PROV_LMSTUDIO) { return 1; }
    if (prov == PROV_LOCALAI) { return 1; }
    if (prov == PROV_WHISPER) { return 1; }
    if (prov == PROV_VLLM) { return 1; }
    if (prov == PROV_TENSORRT) { return 1; }
    if (prov == PROV_ONNX) { return 1; }
    return 0;
}

fn provider_name(prov) {
    if (prov == PROV_OLLAMA) { return "ollama"; }
    if (prov == PROV_LLAMACPP) { return "llamacpp"; }
    if (prov == PROV_SYNAPSE) { return "synapse"; }
    if (prov == PROV_LMSTUDIO) { return "lmstudio"; }
    if (prov == PROV_LOCALAI) { return "localai"; }
    if (prov == PROV_OPENAI) { return "openai"; }
    if (prov == PROV_ANTHROPIC) { return "anthropic"; }
    if (prov == PROV_DEEPSEEK) { return "deepseek"; }
    if (prov == PROV_MISTRAL) { return "mistral"; }
    if (prov == PROV_GOOGLE) { return "google"; }
    if (prov == PROV_GROQ) { return "groq"; }
    if (prov == PROV_GROK) { return "grok"; }
    if (prov == PROV_OPENROUTER) { return "openrouter"; }
    if (prov == PROV_WHISPER) { return "whisper"; }
    if (prov == PROV_VLLM) { return "vllm"; }
    if (prov == PROV_TENSORRT) { return "tensorrt"; }
    if (prov == PROV_ONNX) { return "onnx"; }
    return "unknown";
}

# ----------------------------------------------------------------
# Per-provider token estimation (mirrors src/lib/compact.cyr).
# Chars-per-token ratio scaled by 10 (3.8 -> 38) since there are no floats.
# ----------------------------------------------------------------

var CHARS_PER_TOKEN_X10 = 40;

fn chars_per_token_x10(prov) {
    if (prov == PROV_OPENAI) { return 38; }
    if (prov == PROV_DEEPSEEK) { return 38; }
    if (prov == PROV_MISTRAL) { return 38; }
    if (prov == PROV_GROQ) { return 38; }
    if (prov == PROV_GROK) { return 38; }
    if (prov == PROV_OPENROUTER) { return 38; }
    if (prov == PROV_ANTHROPIC) { return 35; }
    if (prov == PROV_OLLAMA) { return 37; }
    if (prov == PROV_LLAMACPP) { return 37; }
    if (prov == PROV_LMSTUDIO) { return 37; }
    if (prov == PROV_LOCALAI) { return 37; }
    return 40;
}

fn estimate_tokens(messages, msg_len, cpt_x10) {
    var ratio = cpt_x10;
    if (ratio < 1) { ratio = CHARS_PER_TOKEN_X10; }
    return msg_len * 10 / ratio;
}

# ----------------------------------------------------------------
# Generic request header (mirrors src/lib/http_client.cyr).
# Used by the provider-lifecycle forwarders (GET/POST/DELETE).
# ----------------------------------------------------------------
fn _build_req_header(buf, method, path, host, body_len) {
    var pos = 0;
    memcpy(buf + pos, method, strlen(method)); pos = pos + strlen(method);
    store8(buf + pos, 32); pos = pos + 1;
    memcpy(buf + pos, path, strlen(path)); pos = pos + strlen(path);
    memcpy(buf + pos, " HTTP/1.0", 9); pos = pos + 9;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Host: ", 6); pos = pos + 6;
    memcpy(buf + pos, host, strlen(host)); pos = pos + strlen(host);
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Type: application/json", 29); pos = pos + 29;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Connection: close", 17); pos = pos + 17;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Length: ", 16); pos = pos + 16;
    var cl_buf = alloc(32);
    var cl_len = fmt_int_buf(body_len, cl_buf);
    memcpy(buf + pos, cl_buf, cl_len); pos = pos + cl_len;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    return pos;
}

# ================================================================
# Routing strategy
# ================================================================

enum Strategy {
    STRAT_PRIORITY       = 0;
    STRAT_ROUND_ROBIN    = 1;
    STRAT_LOWEST_LATENCY = 2;
    STRAT_DIRECT         = 3;
}

# ================================================================
# Provider route — heap-allocated struct
# Layout: provider(8) priority(8) patterns_ptr(8) patterns_count(8)
#         enabled(8) base_url(8) api_key(8) rate_limit_rpm(8)
# Total: 64 bytes
# ================================================================

enum RouteField {
    ROUTE_SIZE          = 64;
    ROUTE_PROVIDER      = 0;
    ROUTE_PRIORITY      = 8;
    ROUTE_PATTERNS      = 16;
    ROUTE_PATTERNS_N    = 24;
    ROUTE_ENABLED       = 32;
    ROUTE_BASE_URL      = 40;
    ROUTE_API_KEY       = 48;
    ROUTE_RATE_LIMIT    = 56;
}

fn route_new(prov, priority, base_url) {
    var r = alloc(ROUTE_SIZE);
    store64(r + ROUTE_PROVIDER, prov);
    store64(r + ROUTE_PRIORITY, priority);
    store64(r + ROUTE_PATTERNS, 0);
    store64(r + ROUTE_PATTERNS_N, 0);
    store64(r + ROUTE_ENABLED, 1);
    store64(r + ROUTE_BASE_URL, base_url);
    store64(r + ROUTE_API_KEY, 0);
    store64(r + ROUTE_RATE_LIMIT, 0);
    return r;
}

fn route_provider(r) { return load64(r + ROUTE_PROVIDER); }
fn route_priority(r) { return load64(r + ROUTE_PRIORITY); }
fn route_enabled(r) { return load64(r + ROUTE_ENABLED); }
fn route_base_url(r) { return load64(r + ROUTE_BASE_URL); }

fn route_set_enabled(r, v) { store64(r + ROUTE_ENABLED, v); return 0; }

# Set model patterns as array of cstrings
fn route_set_patterns(r, patterns, count) {
    store64(r + ROUTE_PATTERNS, patterns);
    store64(r + ROUTE_PATTERNS_N, count);
    return 0;
}

# Check if a route matches a model name
fn route_matches_model(r, model) {
    var count = load64(r + ROUTE_PATTERNS_N);
    if (count == 0) { return 1; }  # wildcard — matches all
    var arr = load64(r + ROUTE_PATTERNS);
    var i = 0;
    while (i < count) {
        var pattern = load64(arr + i * 8);
        var plen = strlen(pattern);
        # Check for trailing wildcard
        if (plen > 0 && load8(pattern + plen - 1) == 42) {
            # '*' = 42; prefix match
            if (memeq(model, pattern, plen - 1) == 1) { return 1; }
        } else {
            if (streq(model, pattern) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Find the first enabled route for a provider type (mirrors
# handlers.cyr _router_find_provider, parameterized by routes array).
fn _find_provider_route(routes, count, prov) {
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            if (route_provider(r) == prov) { return r; }
        }
        i = i + 1;
    }
    return 0;
}

# Exact-key response-cache key (mirror of handlers.cyr _cache_key).
fn _cache_key(model, body_ptr, body_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\n");
    var bb = alloc(body_len + 1);
    memcpy(bb, body_ptr, body_len);
    store8(bb + body_len, 0);
    str_builder_add_cstr(sb, bb);
    var s = str_builder_build(sb);
    return sha256_hex(str_cstr(s), str_len(s));
}

fn _ckey(model, body) {
    return _cache_key(model, body, strlen(body));
}

# Canonical warming body (mirror of handlers.cyr _warming_body).
fn _warming_body(model, prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"messages\":[{\"role\":\"user\",\"content\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    return str_builder_build(sb);
}

# Whitespace compression (mirror of compression.cyr).
fn _compress_is_ws(c) {
    if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; }
    return 0;
}

fn compress_ws_json(ptr, len) {
    var out = str_builder_new();
    var i = 0;
    var in_str = 0;
    var is_val = 0;
    var prev_sig = 0;
    var pending = 0;
    var emitted = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (in_str == 0) {
            str_builder_add_byte(out, c);
            if (c == 34) {
                in_str = 1;
                is_val = 0;
                if (prev_sig == 58) { is_val = 1; }
                pending = 0;
                emitted = 0;
            } else {
                if (_compress_is_ws(c) == 0) { prev_sig = c; }
            }
            i = i + 1;
        } else {
            if (c == 92) {
                var nx = 0;
                if (i + 1 < len) { nx = load8(ptr + i + 1); }
                if (nx == 110 || nx == 116 || nx == 114) {
                    if (is_val == 1) {
                        pending = 1;
                    } else {
                        str_builder_add_byte(out, c);
                        str_builder_add_byte(out, nx);
                    }
                    i = i + 2;
                    continue;
                }
                if (is_val == 1) {
                    if (emitted == 1 && pending == 1) { str_builder_add_byte(out, 32); }
                    pending = 0;
                    emitted = 1;
                }
                str_builder_add_byte(out, c);
                if (i + 1 < len) { str_builder_add_byte(out, nx); }
                i = i + 2;
                continue;
            }
            if (c == 34) {
                str_builder_add_byte(out, c);
                in_str = 0;
                is_val = 0;
                i = i + 1;
                continue;
            }
            if (is_val == 1) {
                if (_compress_is_ws(c) == 1) {
                    pending = 1;
                } else {
                    if (emitted == 1 && pending == 1) { str_builder_add_byte(out, 32); }
                    str_builder_add_byte(out, c);
                    emitted = 1;
                    pending = 0;
                }
            } else {
                str_builder_add_byte(out, c);
            }
            i = i + 1;
        }
    }
    return str_cstr(str_builder_build(out));
}

# Compress a cstr JSON literal, return the collapsed cstr.
fn _compress(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return compress_ws_json(b, n);
}

# Per-token pricing (mirror of pricing.cyr).
var _pricing_tbl = 0;
var _pricing_n = 0;

fn _pricing_add(arr, idx, key, in_s, out_s) {
    var e = arr + idx * 24;
    store64(e, key);
    store64(e + 8, in_s);
    store64(e + 16, out_s);
    return 0;
}

fn _pricing_init() {
    if (_pricing_tbl != 0) { return 0; }
    var arr = alloc(16 * 24);
    _pricing_add(arr, 0, "claude-opus-4", 15000, 75000);
    _pricing_add(arr, 1, "claude-sonnet-4", 3000, 15000);
    _pricing_add(arr, 2, "claude-3.5-haiku", 800, 4000);
    _pricing_add(arr, 3, "claude-3-5-haiku", 800, 4000);
    _pricing_add(arr, 4, "gpt-4o", 2500, 10000);
    _pricing_add(arr, 5, "gpt-4o-mini", 150, 600);
    _pricing_add(arr, 6, "o1", 15000, 60000);
    _pricing_add(arr, 7, "o3-mini", 1100, 4400);
    _pricing_add(arr, 8, "deepseek-chat", 270, 1100);
    _pricing_add(arr, 9, "deepseek-coder", 140, 280);
    _pricing_add(arr, 10, "deepseek-reasoner", 550, 2190);
    _pricing_add(arr, 11, "grok-3", 3000, 15000);
    _pricing_add(arr, 12, "grok-3-mini", 300, 500);
    _pricing_add(arr, 13, "llama-3.3-70b", 590, 790);
    _pricing_add(arr, 14, "llama-3.1-8b", 50, 80);
    _pricing_add(arr, 15, "gemini-2.0-flash", 100, 400);
    _pricing_tbl = arr;
    _pricing_n = 16;
    return 0;
}

fn _pricing_fallback(prov, out) {
    var in_s = 0;
    var out_s = 0;
    if (provider_is_local(prov) == 0) {
        if (prov == PROV_ANTHROPIC) { in_s = 3000; out_s = 15000; }
        if (prov == PROV_OPENAI) { in_s = 2500; out_s = 10000; }
        if (prov == PROV_DEEPSEEK) { in_s = 270; out_s = 1100; }
        if (prov == PROV_GROQ) { in_s = 590; out_s = 790; }
        if (prov == PROV_GROK) { in_s = 3000; out_s = 15000; }
        if (prov == PROV_GOOGLE) { in_s = 100; out_s = 400; }
        if (prov == PROV_MISTRAL) { in_s = 2000; out_s = 6000; }
        if (prov == PROV_OPENROUTER) { in_s = 2500; out_s = 10000; }
    }
    store64(out, in_s);
    store64(out + 8, out_s);
    return 0;
}

fn pricing_lookup(model, prov, out) {
    _pricing_init();
    var ml = strlen(model);
    var i = 0;
    while (i < _pricing_n) {
        var e = _pricing_tbl + i * 24;
        if (streq(model, load64(e)) == 1) {
            store64(out, load64(e + 8));
            store64(out + 8, load64(e + 16));
            return 0;
        }
        i = i + 1;
    }
    var best = 0 - 1;
    var best_len = 0;
    i = 0;
    while (i < _pricing_n) {
        var e = _pricing_tbl + i * 24;
        var key = load64(e);
        var kl = strlen(key);
        if (kl <= ml) {
            if (memeq(model, key, kl) == 1) {
                if (kl > best_len) {
                    best_len = kl;
                    best = i;
                }
            }
        }
        i = i + 1;
    }
    if (best >= 0) {
        var be = _pricing_tbl + best * 24;
        store64(out, load64(be + 8));
        store64(out + 8, load64(be + 16));
        return 0;
    }
    _pricing_fallback(prov, out);
    return 0;
}

fn estimate_cost_micro(model, prov, in_tok, out_tok) {
    var px = alloc(16);
    pricing_lookup(model, prov, px);
    return in_tok * load64(px) / 1000 + out_tok * load64(px + 8) / 1000;
}

# Model metadata + capability filter (mirror of metadata.cyr).
enum ModelTier {
    TIER_ECONOMY   = 0;
    TIER_STANDARD  = 1;
    TIER_PREMIUM   = 2;
    TIER_REASONING = 3;
}

var _meta_tbl = 0;
var _meta_n = 0;

fn _meta_add(arr, idx, key, ctx, tier, vision, tools, sys) {
    var e = arr + idx * 48;
    store64(e, key);
    store64(e + 8, ctx);
    store64(e + 16, tier);
    store64(e + 24, vision);
    store64(e + 32, tools);
    store64(e + 40, sys);
    return 0;
}

fn _meta_init() {
    if (_meta_tbl != 0) { return 0; }
    var arr = alloc(16 * 48);
    _meta_add(arr, 0, "claude-opus-4", 200000, TIER_PREMIUM, 1, 1, 1);
    _meta_add(arr, 1, "claude-sonnet-4", 200000, TIER_STANDARD, 1, 1, 1);
    _meta_add(arr, 2, "claude-3.5-haiku", 200000, TIER_ECONOMY, 0, 1, 1);
    _meta_add(arr, 3, "claude-3-5-haiku", 200000, TIER_ECONOMY, 0, 1, 1);
    _meta_add(arr, 4, "gpt-4o", 128000, TIER_STANDARD, 1, 1, 1);
    _meta_add(arr, 5, "gpt-4o-mini", 128000, TIER_ECONOMY, 1, 1, 1);
    _meta_add(arr, 6, "o1", 200000, TIER_REASONING, 1, 1, 1);
    _meta_add(arr, 7, "o3-mini", 200000, TIER_REASONING, 0, 1, 1);
    _meta_add(arr, 8, "deepseek-chat", 64000, TIER_ECONOMY, 0, 1, 1);
    _meta_add(arr, 9, "deepseek-coder", 64000, TIER_ECONOMY, 0, 1, 1);
    _meta_add(arr, 10, "deepseek-reasoner", 64000, TIER_REASONING, 0, 1, 1);
    _meta_add(arr, 11, "grok-3", 131072, TIER_PREMIUM, 0, 1, 1);
    _meta_add(arr, 12, "grok-3-mini", 131072, TIER_STANDARD, 0, 1, 1);
    _meta_add(arr, 13, "llama-3.3-70b", 128000, TIER_STANDARD, 0, 1, 1);
    _meta_add(arr, 14, "llama-3.1-8b", 128000, TIER_ECONOMY, 0, 0, 1);
    _meta_add(arr, 15, "gemini-2.0-flash", 1048576, TIER_ECONOMY, 1, 1, 1);
    _meta_tbl = arr;
    _meta_n = 16;
    return 0;
}

fn _meta_copy(e, out) {
    store64(out, load64(e + 8));
    store64(out + 8, load64(e + 16));
    store64(out + 16, load64(e + 24));
    store64(out + 24, load64(e + 32));
    store64(out + 32, load64(e + 40));
    return 0;
}

fn metadata_lookup(model, out) {
    _meta_init();
    var ml = strlen(model);
    var i = 0;
    while (i < _meta_n) {
        var e = _meta_tbl + i * 48;
        if (streq(model, load64(e)) == 1) {
            _meta_copy(e, out);
            return 1;
        }
        i = i + 1;
    }
    var best = 0 - 1;
    var best_len = 0;
    i = 0;
    while (i < _meta_n) {
        var e = _meta_tbl + i * 48;
        var key = load64(e);
        var kl = strlen(key);
        if (kl <= ml) {
            if (memeq(model, key, kl) == 1) {
                if (kl > best_len) {
                    best_len = kl;
                    best = i;
                }
            }
        }
        i = i + 1;
    }
    if (best >= 0) {
        _meta_copy(_meta_tbl + best * 48, out);
        return 1;
    }
    return 0;
}

fn classify_complexity(in_tok, uses_tools, has_vision) {
    if (has_vision == 1) { return TIER_STANDARD; }
    if (uses_tools == 1 && in_tok > 2000) { return TIER_STANDARD; }
    if (in_tok > 10000) { return TIER_STANDARD; }
    return TIER_ECONOMY;
}

fn meets_requirements(meta, min_tier, has_vision, uses_tools, has_system, total_tokens) {
    var ctx = load64(meta);
    var tier = load64(meta + 8);
    var vision = load64(meta + 16);
    var tools = load64(meta + 24);
    var sys = load64(meta + 32);
    if (tier < min_tier) { return 0; }
    if (has_vision == 1 && vision == 0) { return 0; }
    if (uses_tools == 1 && tools == 0) { return 0; }
    if (has_system == 1 && sys == 0) { return 0; }
    if (total_tokens > ctx) { return 0; }
    return 1;
}

# Semantic cache (mirror of semantic.cyr).
var _sem_enabled = 1;
var _sem_threshold = 850;
var _sem_max_search = 0;
var _sem_entries = 0;

fn _isqrt(n) {
    if (n < 2) { return n; }
    var x = n;
    var y = (x + 1) / 2;
    while (y < x) {
        x = y;
        y = (x + n / x) / 2;
    }
    return x;
}

fn cosine_x1000(a, b, n) {
    if (n <= 0) { return 0; }
    var dot = 0;
    var ma = 0;
    var mb = 0;
    var i = 0;
    while (i < n) {
        var av = load64(a + i * 8);
        var bv = load64(b + i * 8);
        dot = dot + av * bv;
        ma = ma + av * av;
        mb = mb + bv * bv;
        i = i + 1;
    }
    if (ma == 0 || mb == 0) { return 0; }
    var denom = _isqrt(ma) * _isqrt(mb);
    if (denom == 0) { return 0; }
    return dot * 1000 / denom;
}

fn semantic_insert(key, vec_ptr, n) {
    if (_sem_enabled == 0) { return 0; }
    if (_sem_entries == 0) { _sem_entries = vec_new(); }
    var e = alloc(24);
    store64(e, key);
    store64(e + 8, vec_ptr);
    store64(e + 16, n);
    vec_push(_sem_entries, e);
    return 0;
}

fn semantic_find(query_vec, n) {
    if (_sem_enabled == 0) { return 0; }
    if (_sem_entries == 0) { return 0; }
    var count = vec_len(_sem_entries);
    var best_key = 0;
    var best_score = _sem_threshold;
    var i = 0;
    while (i < count) {
        if (_sem_max_search > 0 && i >= _sem_max_search) {
            i = count;
        } else {
            var e = vec_get(_sem_entries, i);
            if (load64(e + 16) == n) {
                var score = cosine_x1000(query_vec, load64(e + 8), n);
                if (score > best_score) {
                    best_score = score;
                    best_key = load64(e);
                }
            }
            i = i + 1;
        }
    }
    return best_key;
}

fn _sem_is_digit(c) {
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

fn _sem_parse_num(buf, start, len) {
    var i = start;
    var neg = 0;
    if (i < len && load8(buf + i) == 45) {
        neg = 1;
        i = i + 1;
    }
    var int_part = 0;
    while (i < len && _sem_is_digit(load8(buf + i)) == 1) {
        int_part = int_part * 10 + (load8(buf + i) - 48);
        i = i + 1;
    }
    var frac = 0;
    var frac_div = 1;
    if (i < len && load8(buf + i) == 46) {
        i = i + 1;
        while (i < len && _sem_is_digit(load8(buf + i)) == 1) {
            if (frac_div < 10000000) {
                frac = frac * 10 + (load8(buf + i) - 48);
                frac_div = frac_div * 10;
            }
            i = i + 1;
        }
    }
    var val = int_part * 10000 + frac * 10000 / frac_div;
    if (i < len && (load8(buf + i) == 101 || load8(buf + i) == 69)) {
        i = i + 1;
        var esign = 1;
        if (i < len && load8(buf + i) == 45) { esign = 0 - 1; i = i + 1; }
        if (i < len && load8(buf + i) == 43) { i = i + 1; }
        var exp = 0;
        while (i < len && _sem_is_digit(load8(buf + i)) == 1) {
            exp = exp * 10 + (load8(buf + i) - 48);
            i = i + 1;
        }
        var k = 0;
        while (k < exp) {
            if (esign > 0) { val = val * 10; } else { val = val / 10; }
            k = k + 1;
        }
    }
    if (neg == 1) { val = 0 - val; }
    var r = alloc(16);
    store64(r, val);
    store64(r + 8, i);
    return r;
}

fn _sem_find(buf, len, needle, nlen) {
    if (nlen == 0) { return 0 - 1; }
    var i = 0;
    while (i + nlen <= len) {
        if (memeq(buf + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

fn semantic_parse_embedding(buf, len, out_n) {
    var pos = _sem_find(buf, len, "\"embedding\"", 11);
    if (pos < 0) {
        store64(out_n, 0);
        return 0;
    }
    var i = pos + 11;
    while (i < len && load8(buf + i) != 91) { i = i + 1; }
    if (i >= len) {
        store64(out_n, 0);
        return 0;
    }
    i = i + 1;
    var cap = 4096;
    var vec = alloc(cap * 8);
    var n = 0;
    while (i < len) {
        var c = load8(buf + i);
        if (c == 32 || c == 44 || c == 10 || c == 13 || c == 9) {
            i = i + 1;
        } else {
            if (c == 93) {
                i = len;
            } else {
                var fr = _sem_parse_num(buf, i, len);
                if (n < cap) {
                    store64(vec + n * 8, load64(fr));
                    n = n + 1;
                }
                i = load64(fr + 8);
            }
        }
    }
    store64(out_n, n);
    return vec;
}

# Build an int vector from N values for tests.
fn _vec2(x, y) {
    var v = alloc(16);
    store64(v, x);
    store64(v + 8, y);
    return v;
}

# Extract the raw tools array span (mirror of handlers.cyr _extract_tools).
fn _extract_tools(body_ptr, body_len) {
    var i = 0;
    while (i + 9 < body_len) {
        if (memeq(body_ptr + i, "\"tools\":", 8) == 1) {
            var j = i + 8;
            while (j < body_len && load8(body_ptr + j) == 32) { j = j + 1; }
            if (j < body_len && load8(body_ptr + j) == 91) {
                var depth = 1;
                var start = j;
                j = j + 1;
                while (j < body_len && depth > 0) {
                    var ch = load8(body_ptr + j);
                    if (ch == 91) { depth = depth + 1; }
                    if (ch == 93) { depth = depth - 1; }
                    if (ch == 34) {
                        j = j + 1;
                        while (j < body_len) {
                            if (load8(body_ptr + j) == 34) { break; }
                            if (load8(body_ptr + j) == 92) { j = j + 1; }
                            j = j + 1;
                        }
                    }
                    j = j + 1;
                }
                var len = j - start;
                if (len <= 2) { return 0; }
                var result = alloc(16);
                store64(result, body_ptr + start);
                store64(result + 8, len);
                return result;
            }
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

# Extract tools from a cstr body literal, return the span as a cstr (or 0).
fn _etools(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    var r = _extract_tools(b, n);
    if (r == 0) { return 0; }
    var p = load64(r);
    var l = load64(r + 8);
    var o = alloc(l + 1);
    memcpy(o, p, l);
    store8(o + l, 0);
    return o;
}

# Stale tool-pair prune (mirror of compression.cyr).
var _CMP_KEEP_RECENT = 3;

fn _cmp_span_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123 || ch == 91) { depth = depth + 1; }
            if (ch == 125 || ch == 93) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

fn _cmp_substr(p, plen, needle, nlen) {
    if (nlen == 0) { return 0 - 1; }
    var i = 0;
    while (i + nlen <= plen) {
        if (memeq(p + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# Mirror of src/lib/mcp.cyr's _hoosh_tool_echo — bote tool handler ABI
# fn(args_cstr, claims) -> result_cstr. Echoes args as MCP text content.
fn _mcp_echo(args, claims) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    if (args != 0) { _json_emit_escaped(sb, args); }
    str_builder_add_cstr(sb, "\"}],\"isError\":false}");
    return str_data(str_builder_build(sb));
}

# Mirror of src/lib/batch.cyr _batch_extract_requests — locate the raw
# "requests" array (incl. brackets) in a request body. Returns [ptr,len] or 0.
fn _t_batch_extract_requests(body_ptr, body_len) {
    var i = 0;
    while (i < body_len - 11) {
        if (memeq(body_ptr + i, "\"requests\":", 11) == 1) {
            i = i + 11;
            while (i < body_len && load8(body_ptr + i) == 32) { i = i + 1; }
            if (i < body_len && load8(body_ptr + i) == 91) {
                var depth = 1;
                var start = i;
                i = i + 1;
                while (i < body_len && depth > 0) {
                    var ch = load8(body_ptr + i);
                    if (ch == 34) {
                        i = i + 1;
                        while (i < body_len) {
                            if (load8(body_ptr + i) == 34) { break; }
                            if (load8(body_ptr + i) == 92) { i = i + 1; }
                            i = i + 1;
                        }
                    } else {
                        if (ch == 91) { depth = depth + 1; }
                        if (ch == 93) { depth = depth - 1; }
                    }
                    i = i + 1;
                }
                var out = alloc(16);
                store64(out, body_ptr + start);
                store64(out + 8, i - start);
                return out;
            }
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

# Mirror of src/lib/batch.cyr _batch_split — split the array (incl. brackets)
# into top-level object slices. String-escape + nesting aware.
fn _t_batch_split(arr_ptr, arr_len) {
    var items = vec_new();
    var i = 0;
    while (i < arr_len && load8(arr_ptr + i) != 91) { i = i + 1; }
    if (i >= arr_len) { return items; }
    i = i + 1;
    var depth = 0;
    var start = 0 - 1;
    while (i < arr_len) {
        var ch = load8(arr_ptr + i);
        if (ch == 34) {
            i = i + 1;
            while (i < arr_len) {
                var c2 = load8(arr_ptr + i);
                if (c2 == 92) { i = i + 2; } else {
                    if (c2 == 34) { break; }
                    i = i + 1;
                }
            }
            i = i + 1;
        } else {
            if (ch == 123 || ch == 91) {
                if (depth == 0 && start < 0) { start = i; }
                depth = depth + 1;
                i = i + 1;
            } else {
                if (ch == 125 || ch == 93) {
                    depth = depth - 1;
                    i = i + 1;
                    if (depth < 0) { break; }
                    if (depth == 0 && start >= 0) {
                        var slc = alloc(16);
                        store64(slc, arr_ptr + start);
                        store64(slc + 8, i - start);
                        vec_push(items, slc);
                        start = 0 - 1;
                    }
                } else {
                    i = i + 1;
                }
            }
        }
    }
    return items;
}

# Mirror of src/lib/batch.cyr _batch_is_async — detects top-level "async":true.
fn _t_batch_is_async(body, len) {
    var i = 0;
    while (i < len - 7) {
        if (memeq(body + i, "\"async\"", 7) == 1) {
            var j = i + 7;
            while (j < len && (load8(body + j) == 32 || load8(body + j) == 58)) { j = j + 1; }
            if (j + 4 <= len && memeq(body + j, "true", 4) == 1) { return 1; }
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

# Mirror of src/lib/batch.cyr _batch_status_name.
fn _t_batch_status_name(s) {
    if (s == 0) { return "queued"; }
    if (s == 1) { return "running"; }
    if (s == 2) { return "completed"; }
    return "cancelled";
}

# Mirror of src/lib/batch.cyr's lane-pool core (single-threaded, no spin) — the
# CAS allocate/free over a fixed slot array. lanes = alloc(7*8) of 0/1.
fn _t_lane_acquire(lanes, n) {
    var i = 0;
    while (i < n) {
        if (atomic_cas(lanes + i * 8, 0, 1) == 1) { return i + 1; }
        i = i + 1;
    }
    return 0;
}
fn _t_lane_release(lanes, lane) {
    atomic_store(lanes + (lane - 1) * 8, 0);
    return 0;
}

# Mirror of src/lib/metrics.cyr _lat_bound + the bucket-find loop.
fn _t_lat_bound(i) {
    if (i == 0) { return 5; }
    if (i == 1) { return 10; }
    if (i == 2) { return 25; }
    if (i == 3) { return 50; }
    if (i == 4) { return 100; }
    if (i == 5) { return 250; }
    if (i == 6) { return 500; }
    if (i == 7) { return 1000; }
    if (i == 8) { return 2500; }
    if (i == 9) { return 5000; }
    return 10000;
}
fn _t_lat_bucket(ms) {
    var b = 0;
    while (b < 11 && ms > _t_lat_bound(b)) { b = b + 1; }
    return b;
}

# Mirror of src/lib/trace.cyr trace_extract — incoming traceparent header.
fn _t_trace_ci_eq(a, pat, n) {
    var i = 0;
    while (i < n) {
        var ca = load8(a + i);
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (ca != load8(pat + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}
fn _t_trace_extract(buf, buf_len) {
    var i = 0;
    while (i < buf_len - 12) {
        if (i == 0 || load8(buf + i - 1) == 10) {
            if (_t_trace_ci_eq(buf + i, "traceparent:", 12) == 1) {
                var j = i + 12;
                while (j < buf_len && (load8(buf + j) == 32 || load8(buf + j) == 9)) { j = j + 1; }
                var s = j;
                while (j < buf_len && load8(buf + j) != 13 && load8(buf + j) != 10) { j = j + 1; }
                var n = j - s;
                if (n <= 0 || n > 200) { return 0; }
                var out = alloc(n + 1);
                memcpy(out, buf + s, n);
                store8(out + n, 0);
                return out;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Mirror of src/lib/otlp.cyr _otlp_path — path component of an http URL.
fn _t_otlp_path(url) {
    var i = 7;
    while (load8(url + i) != 0) {
        if (load8(url + i) == 47) { return url + i; }
        i = i + 1;
    }
    return "/v1/traces";
}

# Mirror of src/lib/handlers.cyr _hoosh_req_from_str (REQ_* values inlined:
# none=0 gpu=1 tpu=2 gaudi=3 aws-neuron=4 gpu-or-tpu=5 any-accelerator=6, -1=bad).
fn _t_req_from_str(s) {
    if (streq(s, "none") == 1) { return 0; }
    if (streq(s, "gpu") == 1) { return 1; }
    if (streq(s, "tpu") == 1) { return 2; }
    if (streq(s, "gaudi") == 1) { return 3; }
    if (streq(s, "aws-neuron") == 1) { return 4; }
    if (streq(s, "gpu-or-tpu") == 1) { return 5; }
    if (streq(s, "any-accelerator") == 1) { return 6; }
    return 0 - 1;
}

# Mirror of src/lib/config.cyr strategy_from_str (STRAT_* values inlined:
# priority=0 round-robin=1 lowest-latency=2 direct=3).
fn _t_strategy_from_str(s) {
    if (streq(s, "round-robin") == 1 || streq(s, "roundrobin") == 1) { return 1; }
    if (streq(s, "lowest-latency") == 1 || streq(s, "lowest_latency") == 1) { return 2; }
    if (streq(s, "direct") == 1) { return 3; }
    return 0;
}

# Mirror of src/lib/router.cyr lowest-latency pick (untried = 0 latency = explore,
# else lowest EMA wins). `lats` is a vec of i64 latencies (0 = untried). Returns
# the index of the chosen candidate.
fn _t_ll_pick(lats) {
    var n = vec_len(lats);
    var best = 0;
    var best_lat = 0x7FFFFFFFFFFFFFFF;
    var k = 0;
    while (k < n) {
        var lat = vec_get(lats, k);
        if (lat < best_lat) { best = k; best_lat = lat; }
        k = k + 1;
    }
    return best;
}

# Mirror of src/lib/otlp.cyr _otlp_attr_int — OTLP/JSON int attribute (string val).
fn _t_otlp_attr_int(sb, k, v) {
    str_builder_add_cstr(sb, "{\"key\":\"");
    str_builder_add_cstr(sb, k);
    str_builder_add_cstr(sb, "\",\"value\":{\"intValue\":\"");
    str_builder_add_int(sb, v);
    str_builder_add_cstr(sb, "\"}}");
    return 0;
}

# Mirror of src/lib/pool.cyr work-queue ring (FIFO + wrap-around), minus the
# mutex (single-threaded test of the ring logic).
var _T_WQ_MAX = 4;
var _t_wq_ring = 0;
var _t_wq_head = 0;
var _t_wq_count = 0;
fn _t_wq_init() {
    _t_wq_ring = alloc(_T_WQ_MAX * 8);
    _t_wq_head = 0;
    _t_wq_count = 0;
    return 0;
}
fn _t_wq_push(job) {
    if (_t_wq_count >= _T_WQ_MAX) { return 0; }
    store64(_t_wq_ring + ((_t_wq_head + _t_wq_count) % _T_WQ_MAX) * 8, job);
    _t_wq_count = _t_wq_count + 1;
    return 1;
}
fn _t_wq_pop() {
    if (_t_wq_count == 0) { return 0; }
    var j = load64(_t_wq_ring + (_t_wq_head % _T_WQ_MAX) * 8);
    _t_wq_head = (_t_wq_head + 1) % _T_WQ_MAX;
    _t_wq_count = _t_wq_count - 1;
    return j;
}

# ── 2.5.2 request-path fidelity mirrors ──
# Mirror of src/lib/types.cyr GEN_UNSET / _sb_add_milli / _sb_add_sampling.
var _T_GEN_UNSET = 0 - 1;

fn _t_sb_add_milli(sb, v) {
    str_builder_add_int(sb, v / 1000);
    var frac = v % 1000;
    if (frac == 0) { return 0; }
    str_builder_add_cstr(sb, ".");
    if (frac < 100) { str_builder_add_cstr(sb, "0"); }
    if (frac < 10) { str_builder_add_cstr(sb, "0"); }
    while (frac % 10 == 0) { frac = frac / 10; }
    str_builder_add_int(sb, frac);
    return 0;
}

fn _t_milli_str(v) {
    var sb = str_builder_new();
    _t_sb_add_milli(sb, v);
    return str_cstr(str_builder_build(sb));
}

# Mirror of src/lib/handlers.cyr _req_num_milli — raw-scan a top-level numeric
# field to a x1000-scaled int, GEN_UNSET when absent.
fn _t_req_num_milli(body_ptr, body_len, key, keylen) {
    var i = 0;
    while (i + keylen < body_len) {
        if (memeq(body_ptr + i, key, keylen) == 1) {
            var j = i + keylen;
            while (j < body_len && load8(body_ptr + j) == 32) { j = j + 1; }
            var neg = 0;
            if (j < body_len && load8(body_ptr + j) == 45) {
                neg = 1;
                j = j + 1;
            }
            var ip = 0;
            var digits = 0;
            while (j < body_len) {
                var c = load8(body_ptr + j) & 0xFF;
                if (c < 48 || c > 57) { break; }
                ip = ip * 10 + (c - 48);
                digits = digits + 1;
                j = j + 1;
            }
            if (digits == 0) { return _T_GEN_UNSET; }
            var frac = 0;
            var scale = 100;
            if (j < body_len && load8(body_ptr + j) == 46) {
                j = j + 1;
                while (j < body_len && scale > 0) {
                    var fc = load8(body_ptr + j) & 0xFF;
                    if (fc < 48 || fc > 57) { break; }
                    frac = frac + (fc - 48) * scale;
                    scale = scale / 10;
                    j = j + 1;
                }
            }
            var v = ip * 1000 + frac;
            if (neg == 1) { return 0 - v; }
            return v;
        }
        i = i + 1;
    }
    return _T_GEN_UNSET;
}

# Mirror of src/lib/handlers.cyr _json_array_count — objects at depth 1.
fn _t_json_array_count(ptr, len) {
    var n = 0;
    var depth = 0;
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i) & 0xFF;
        if (c == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(ptr + i) == 34) { break; }
                if (load8(ptr + i) == 92) { i = i + 1; }
                i = i + 1;
            }
            i = i + 1;
            continue;
        }
        if (c == 123 || c == 91) {
            if (depth == 1 && c == 123) { n = n + 1; }
            depth = depth + 1;
        }
        if (c == 125 || c == 93) { depth = depth - 1; }
        i = i + 1;
    }
    return n;
}

# Mirror of src/main.cyr _requires_post — POST-only (body-taking) paths.
fn _t_requires_post(path) {
    if (streq(path, "/v1/chat/completions") == 1) { return 1; }
    if (streq(path, "/v1/embeddings") == 1) { return 1; }
    if (streq(path, "/v1/batch") == 1) { return 1; }
    if (streq(path, "/v1/tools/call") == 1) { return 1; }
    return 0;
}

# Mirror of src/lib/config.cyr _config_str_array — TOML string-array parse
# into up to `max` cstrs at `out`, returning the count.
fn _t_config_str_array(raw, out, max) {
    var n = strlen(raw);
    var count = 0;
    var i = 0;
    while (i < n && count < max) {
        var c = load8(raw + i);
        if (c == 91 || c == 93 || c == 44 || c == 32 || c == 34) {
            i = i + 1;
        } else {
            var s = i;
            while (i < n) {
                c = load8(raw + i);
                if (c == 34 || c == 44 || c == 93) { break; }
                i = i + 1;
            }
            var elen = i - s;
            if (elen > 0) {
                var e = alloc(elen + 1);
                memcpy(e, raw + s, elen);
                store8(e + elen, 0);
                store64(out + count * 8, e);
                count = count + 1;
            }
        }
    }
    return count;
}

# Mirror of src/lib/http_server.cyr _hdr_ci_eq / req_content_length.
fn _t_hdr_ci_eq(a, b, n) {
    var i = 0;
    while (i < n) {
        var ca = load8(a + i) & 0xFF;
        var cb = load8(b + i) & 0xFF;
        if (ca >= 65 && ca <= 90) { ca = ca + 32; }
        if (cb >= 65 && cb <= 90) { cb = cb + 32; }
        if (ca != cb) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn _t_req_content_length(buf, len) {
    var i = 0;
    while (i < len - 3) {
        if (load8(buf + i) == 13 && load8(buf + i + 1) == 10) {
            if (load8(buf + i + 2) == 13 && load8(buf + i + 3) == 10) { return 0; }
        }
        if (i + 15 < len && _t_hdr_ci_eq(buf + i, "content-length:", 15) == 1) {
            var j = i + 15;
            while (j < len && load8(buf + j) == 32) { j = j + 1; }
            var v = 0;
            while (j < len) {
                var c = load8(buf + j) & 0xFF;
                if (c < 48 || c > 57) { break; }
                v = v * 10 + (c - 48);
                j = j + 1;
            }
            return v;
        }
        i = i + 1;
    }
    return 0;
}

# Mirror of src/lib/config.cyr bind_addr_str — packed network-order IPv4 to
# dotted quad (octets are LSB-first).
fn _t_bind_addr_str(addr) {
    var sb = str_builder_new();
    str_builder_add_int(sb, addr & 0xFF);
    str_builder_add_cstr(sb, ".");
    str_builder_add_int(sb, (addr >> 8) & 0xFF);
    str_builder_add_cstr(sb, ".");
    str_builder_add_int(sb, (addr >> 16) & 0xFF);
    str_builder_add_cstr(sb, ".");
    str_builder_add_int(sb, (addr >> 24) & 0xFF);
    return str_cstr(str_builder_build(sb));
}

fn _cmp_str_field(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 34) {
                j = j + 1;
                var vs = j;
                while (j < len) {
                    if (load8(p + j) == 34) {
                        if (load8(p + j - 1) != 92) { break; }
                    }
                    j = j + 1;
                }
                var r = alloc(16);
                store64(r, p + vs);
                store64(r + 8, j - vs);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _cmp_is_role(field, role, rolelen) {
    if (field == 0) { return 0; }
    if (load64(field + 8) != rolelen) { return 0; }
    if (memeq(load64(field), role, rolelen) == 1) { return 1; }
    return 0;
}

fn _cmp_collect_ids(objp, objl, out) {
    var tc = _cmp_substr(objp, objl, "\"tool_calls\"", 12);
    if (tc < 0) { return 0; }
    var i = tc + 12;
    while (i < objl && load8(objp + i) != 91) { i = i + 1; }
    if (i >= objl) { return 0; }
    var arrend = _cmp_span_end(objp, objl, i);
    var j = i;
    while (j + 6 <= arrend) {
        if (memeq(objp + j, "\"id\":\"", 6) == 1) {
            var vs = j + 6;
            var ve = vs;
            while (ve < arrend && load8(objp + ve) != 34) {
                if (load8(objp + ve) == 92) { ve = ve + 1; }
                ve = ve + 1;
            }
            var idspan = alloc(16);
            store64(idspan, objp + vs);
            store64(idspan + 8, ve - vs);
            vec_push(out, idspan);
            j = ve;
        }
        j = j + 1;
    }
    return 0;
}

fn _cmp_id_in(ids, ptr, len) {
    var n = vec_len(ids);
    var i = 0;
    while (i < n) {
        var e = vec_get(ids, i);
        if (load64(e + 8) == len) {
            if (memeq(load64(e), ptr, len) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

fn prune_tool_pairs(msg_ptr, msg_len) {
    var spans = vec_new();
    var tc_idx = vec_new();
    var i = 0;
    while (i < msg_len && load8(msg_ptr + i) != 91) { i = i + 1; }
    i = i + 1;
    while (i < msg_len) {
        var ch = load8(msg_ptr + i);
        if (ch == 32 || ch == 44 || ch == 10 || ch == 13 || ch == 9) {
            i = i + 1;
        } else {
            if (ch != 123) {
                i = msg_len;
            } else {
                var s = i;
                var e = _cmp_span_end(msg_ptr, msg_len, i);
                var span = alloc(24);
                store64(span, s);
                store64(span + 8, e);
                store64(span + 16, 0);
                vec_push(spans, span);
                var objp = msg_ptr + s;
                var objl = e - s;
                var role = _cmp_str_field(objp, objl, "role", 4);
                if (_cmp_is_role(role, "assistant", 9) == 1) {
                    if (_cmp_substr(objp, objl, "\"tool_calls\"", 12) >= 0) {
                        vec_push(tc_idx, vec_len(spans) - 1);
                    }
                }
                i = e;
            }
        }
    }
    var total_tc = vec_len(tc_idx);
    if (total_tc <= _CMP_KEEP_RECENT) {
        var orig = alloc(msg_len + 1);
        memcpy(orig, msg_ptr, msg_len);
        store8(orig + msg_len, 0);
        return orig;
    }
    var stale_count = total_tc - _CMP_KEEP_RECENT;
    var stale_ids = vec_new();
    var k = 0;
    while (k < stale_count) {
        var sidx = vec_get(tc_idx, k);
        var sp = vec_get(spans, sidx);
        store64(sp + 16, 1);
        _cmp_collect_ids(msg_ptr + load64(sp), load64(sp + 8) - load64(sp), stale_ids);
        k = k + 1;
    }
    var n = vec_len(spans);
    var m = 0;
    while (m < n) {
        var sp2 = vec_get(spans, m);
        if (load64(sp2 + 16) == 0) {
            var op = msg_ptr + load64(sp2);
            var ol = load64(sp2 + 8) - load64(sp2);
            var role2 = _cmp_str_field(op, ol, "role", 4);
            if (_cmp_is_role(role2, "tool", 4) == 1) {
                var tcid = _cmp_str_field(op, ol, "tool_call_id", 12);
                if (tcid != 0) {
                    if (_cmp_id_in(stale_ids, load64(tcid), load64(tcid + 8)) == 1) {
                        store64(sp2 + 16, 1);
                    }
                }
            }
        }
        m = m + 1;
    }
    var sb = str_builder_new();
    str_builder_add_byte(sb, 91);
    var first = 1;
    var q = 0;
    while (q < n) {
        var sp3 = vec_get(spans, q);
        if (load64(sp3 + 16) == 0) {
            if (first == 0) { str_builder_add_byte(sb, 44); }
            var ms = load64(sp3);
            var ml = load64(sp3 + 8) - ms;
            var mb = alloc(ml + 1);
            memcpy(mb, msg_ptr + ms, ml);
            store8(mb + ml, 0);
            str_builder_add_cstr(sb, mb);
            first = 0;
        }
        q = q + 1;
    }
    str_builder_add_byte(sb, 93);
    return str_cstr(str_builder_build(sb));
}

# Prune a cstr messages-array literal; return the pruned cstr.
fn _prune(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return prune_tool_pairs(b, n);
}

# ================================================================
# DLP scanner — mirror of src/lib/dlp.cyr (PII/secret byte matchers).
# Enabled by default here so the matchers are exercised directly.
# ================================================================

enum DlpClass {
    CLASS_PUBLIC       = 0;
    CLASS_INTERNAL     = 1;
    CLASS_CONFIDENTIAL = 2;
    CLASS_RESTRICTED   = 3;
}

var _dlp_enabled = 1;
var _dlp_default_level = 0;

fn _dlp_is_digit(c) {
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

fn _dlp_is_upper(c) {
    if (c >= 65 && c <= 90) { return 1; }
    return 0;
}

fn _dlp_is_lower(c) {
    if (c >= 97 && c <= 122) { return 1; }
    return 0;
}

fn _dlp_is_alpha(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_lower(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_alnum(c) {
    if (_dlp_is_alpha(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_upper_alnum(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_word(c) {
    if (_dlp_is_alnum(c) == 1 || c == 95) { return 1; }
    return 0;
}

fn _dlp_bound_before(t, i) {
    if (i == 0) { return 1; }
    if (_dlp_is_word(load8(t + i - 1)) == 0) { return 1; }
    return 0;
}

fn _dlp_bound_after(t, e, len) {
    if (e >= len) { return 1; }
    if (_dlp_is_word(load8(t + e)) == 0) { return 1; }
    return 0;
}

fn _dlp_digits_n(t, i, len, n) {
    if (i + n > len) { return 0; }
    var k = 0;
    while (k < n) {
        if (_dlp_is_digit(load8(t + i + k)) == 0) { return 0; }
        k = k + 1;
    }
    return 1;
}

fn _dlp_match_ssn_at(t, i, len) {
    if (i + 11 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (load8(t + i + 3) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 2) == 0) { return 0; }
    if (load8(t + i + 6) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 7, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 11, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_phone_sep(c) {
    if (c == 45 || c == 46 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_phone_at(t, i, len) {
    if (i + 12 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 3)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 7)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 8, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 12, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_cc_sep(c) {
    if (c == 45 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_cc_at(t, i, len) {
    if (_dlp_digits_n(t, i, len, 4) == 0) { return 0; }
    var p = i + 4;
    var g = 1;
    while (g < 4) {
        if (p < len && _dlp_is_cc_sep(load8(t + p)) == 1) { p = p + 1; }
        if (_dlp_digits_n(t, p, len, 4) == 0) { return 0; }
        p = p + 4;
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_ipv4_group(t, p, len) {
    if (p >= len) { return 0 - 1; }
    if (_dlp_is_digit(load8(t + p)) == 0) { return 0 - 1; }
    var n = 1;
    p = p + 1;
    while (n < 3 && p < len && _dlp_is_digit(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    return p;
}

fn _dlp_match_ipv4_at(t, i, len) {
    var p = _dlp_ipv4_group(t, i, len);
    if (p < 0) { return 0; }
    var g = 1;
    while (g < 4) {
        if (p >= len) { return 0; }
        if (load8(t + p) != 46) { return 0; }
        p = p + 1;
        p = _dlp_ipv4_group(t, p, len);
        if (p < 0) { return 0; }
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_apikey_prefix(t, i, len) {
    if (i + 3 <= len) {
        var c0 = load8(t + i);
        if (c0 == 115 || c0 == 112) {
            if (load8(t + i + 1) == 107 && load8(t + i + 2) == 45) {
                return i + 3;
            }
        }
    }
    if (i + 6 <= len) {
        if (load8(t + i) == 97 && load8(t + i + 1) == 112 && load8(t + i + 2) == 105) {
            var p = i + 3;
            if (p < len && (load8(t + p) == 95 || load8(t + p) == 45)) { p = p + 1; }
            if (p + 3 <= len) {
                if (load8(t + p) == 107 && load8(t + p + 1) == 101 && load8(t + p + 2) == 121) {
                    p = p + 3;
                    var sc = 0;
                    var more = 1;
                    while (more == 1 && sc < 5 && p < len) {
                        var sep = load8(t + p);
                        if (sep == 61 || sep == 58 || sep == 32) {
                            p = p + 1;
                            sc = sc + 1;
                        } else {
                            more = 0;
                        }
                    }
                    if (sc >= 1) { return p; }
                }
            }
        }
    }
    return 0 - 1;
}

fn _dlp_match_apikey_at(t, i, len) {
    var p = _dlp_apikey_prefix(t, i, len);
    if (p < 0) { return 0; }
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 20) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_match_aws_at(t, i, len) {
    if (i + 20 > len) { return 0; }
    if (load8(t + i) != 65 || load8(t + i + 1) != 75) { return 0; }
    if (load8(t + i + 2) != 73 || load8(t + i + 3) != 65) { return 0; }
    var k = 0;
    while (k < 16) {
        if (_dlp_is_upper_alnum(load8(t + i + 4 + k)) == 0) { return 0; }
        k = k + 1;
    }
    if (_dlp_bound_after(t, i + 20, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_gh_third(c) {
    if (c == 112 || c == 111 || c == 117 || c == 115 || c == 114) { return 1; }
    return 0;
}

fn _dlp_match_github_at(t, i, len) {
    if (i + 4 > len) { return 0; }
    if (load8(t + i) != 103 || load8(t + i + 1) != 104) { return 0; }
    if (_dlp_is_gh_third(load8(t + i + 2)) == 0) { return 0; }
    if (load8(t + i + 3) != 95) { return 0; }
    var p = i + 4;
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 36) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_email_local(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 95 || c == 37 || c == 43 || c == 45) { return 1; }
    return 0;
}

fn _dlp_is_email_domain(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 45) { return 1; }
    return 0;
}

fn _dlp_has_email(t, len) {
    var i = 0;
    while (i < len) {
        if (load8(t + i) == 64) {
            if (i >= 1 && _dlp_is_email_local(load8(t + i - 1)) == 1) {
                var p = i + 1;
                var seen = 0;
                while (p < len && _dlp_is_email_domain(load8(t + p)) == 1) {
                    if (load8(t + p) == 46) {
                        if (seen == 1) {
                            var q = p + 1;
                            var ac = 0;
                            while (q < len && _dlp_is_alpha(load8(t + q)) == 1) {
                                ac = ac + 1;
                                q = q + 1;
                            }
                            if (ac >= 2) { return 1; }
                        }
                    } else {
                        seen = 1;
                    }
                    p = p + 1;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn dlp_scan_level(t, len) {
    if (_dlp_enabled == 0) { return _dlp_default_level; }
    if (len == 0) { return _dlp_default_level; }
    var level = _dlp_default_level;
    var i = 0;
    while (i < len) {
        if (_dlp_bound_before(t, i) == 1) {
            if (_dlp_match_ssn_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_cc_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_apikey_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_aws_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_github_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_phone_at(t, i, len) == 1) {
                if (level < CLASS_CONFIDENTIAL) { level = CLASS_CONFIDENTIAL; }
            }
            if (_dlp_match_ipv4_at(t, i, len) == 1) {
                if (level < CLASS_INTERNAL) { level = CLASS_INTERNAL; }
            }
        }
        i = i + 1;
    }
    if (level < CLASS_INTERNAL) {
        if (_dlp_has_email(t, len) == 1) { level = CLASS_INTERNAL; }
    }
    return level;
}

# Scan a cstr literal and return its classification level.
fn _dlp_test(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return dlp_scan_level(b, n);
}

# ================================================================
# Remote transport helpers — mirror of src/lib/provider.cyr. Pure
# string/parse logic for the https:// (sandhi/TLS) forward path.
# ================================================================

fn route_is_remote(route) {
    var base = route_base_url(route);
    if (base == 0) { return 0; }
    if (memeq(base, "https", 5) == 1) { return 1; }
    return 0;
}

fn _provider_path(route) {
    if (route_provider(route) == PROV_OLLAMA) { return "/api/chat"; }
    if (route_provider(route) == PROV_ANTHROPIC) { return "/v1/messages"; }
    return "/v1/chat/completions";
}

# Whitespace-tolerant JSON field scanners — mirror of src/lib/provider.cyr.
fn _json_value_pos(body, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(body + i) == 34) {
            if (memeq(body + i + 1, key, keylen) == 1) {
                if (load8(body + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(body + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 9) { j = j + 1; continue; }
                        if (c == 10) { j = j + 1; continue; }
                        if (c == 13) { j = j + 1; continue; }
                        break;
                    }
                    if (j < len) {
                        if (load8(body + j) == 58) {
                            j = j + 1;
                            while (j < len) {
                                var d = load8(body + j);
                                if (d == 32) { j = j + 1; continue; }
                                if (d == 9) { j = j + 1; continue; }
                                if (d == 10) { j = j + 1; continue; }
                                if (d == 13) { j = j + 1; continue; }
                                break;
                            }
                            return j;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

fn _json_extract_str(body, len, key, keylen) {
    if (body == 0) { return ""; }
    if (len == 0) { return ""; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return ""; }
    if (p >= len) { return ""; }
    if (load8(body + p) != 34) { return ""; }
    var start = p + 1;
    var j = start;
    while (j < len) {
        if (load8(body + j) == 34) {
            if (load8(body + j - 1) == 92) { j = j + 1; continue; }
            break;
        }
        j = j + 1;
    }
    var tlen = j - start;
    var text = alloc(tlen + 1);
    memcpy(text, body + start, tlen);
    store8(text + tlen, 0);
    return text;
}

fn _json_extract_int(body, len, key, keylen) {
    if (body == 0) { return 0; }
    if (len == 0) { return 0; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return 0; }
    return atoi(body + p);
}

fn ollama_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "content", 7);
}

fn anthropic_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "text", 4);
}

fn extract_anthropic_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "input_tokens", 12);
    var comp = _json_extract_int(body, blen, "output_tokens", 13);
    return prompt * 0x100000000 + comp;
}

fn _provider_url(base, path) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, path);
    return str_cstr(str_builder_build(sb));
}

fn _bearer_value(key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Bearer ");
    str_builder_add_cstr(sb, key);
    return str_cstr(str_builder_build(sb));
}

fn extract_openai_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "prompt_tokens", 13);
    var comp = _json_extract_int(body, blen, "completion_tokens", 17);
    return prompt * 0x100000000 + comp;
}

# Anthropic system-message hoist helpers — mirror of src/lib/provider.cyr.
fn _json_obj_str_field(p, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(p + i) == 34) {
            if (memeq(p + i + 1, key, keylen) == 1) {
                if (load8(p + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(p + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 58) { j = j + 1; continue; }
                        break;
                    }
                    if (j >= len) { return 0; }
                    if (load8(p + j) != 34) { return 0; }
                    j = j + 1;
                    var vs = j;
                    while (j < len) {
                        if (load8(p + j) == 34) {
                            if (load8(p + j - 1) == 92) { j = j + 1; continue; }
                            break;
                        }
                        j = j + 1;
                    }
                    var r = alloc(16);
                    store64(r, p + vs);
                    store64(r + 8, j - vs);
                    return r;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _obj_is_system(p, len) {
    var rf = _json_obj_str_field(p, len, "role", 4);
    if (rf == 0) { return 0; }
    if (load64(rf + 8) != 6) { return 0; }
    if (memeq(load64(rf), "system", 6) == 1) { return 1; }
    return 0;
}

fn _json_obj_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123) { depth = depth + 1; }
            if (ch == 91) { depth = depth + 1; }
            if (ch == 93) { depth = depth - 1; }
            if (ch == 125) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

# Tool conversion helpers (mirror of provider.cyr).
fn _json_span_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123 || ch == 91) { depth = depth + 1; }
            if (ch == 125 || ch == 93) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

fn _json_obj_obj_span(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 123) {
                var end = _json_obj_end(p, len, j);
                var r = alloc(16);
                store64(r, p + j);
                store64(r + 8, end - j);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _json_arr_span(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 91) {
                var end = _json_span_end(p, len, j);
                var r = alloc(16);
                store64(r, p + j);
                store64(r + 8, end - j);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _json_esc_span(sb, ptr, len) {
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (c == 34) { str_builder_putc(sb, 92); str_builder_putc(sb, 34); }
        if (c == 92) { str_builder_putc(sb, 92); str_builder_putc(sb, 92); }
        if (c == 10) { str_builder_putc(sb, 92); str_builder_putc(sb, 110); }
        if (c == 13) { str_builder_putc(sb, 92); str_builder_putc(sb, 114); }
        if (c == 9) { str_builder_putc(sb, 92); str_builder_putc(sb, 116); }
        if (c >= 32 && c != 34 && c != 92) { str_builder_putc(sb, c); }
        i = i + 1;
    }
    return 0;
}

fn _emit_tool_call(sb, id_p, id_l, nm_p, nm_l, args_p, args_l) {
    str_builder_add_cstr(sb, "{\"id\":\"");
    str_builder_add(sb, str_new(id_p, id_l));
    str_builder_add_cstr(sb, "\",\"type\":\"function\",\"function\":{\"name\":\"");
    str_builder_add(sb, str_new(nm_p, nm_l));
    str_builder_add_cstr(sb, "\",\"arguments\":\"");
    if (args_l > 0) { _json_esc_span(sb, args_p, args_l); } else { str_builder_add_cstr(sb, "{}"); }
    str_builder_add_cstr(sb, "\"}}");
    return 0;
}

fn _tools_convert(tools_raw, tools_len, schema_key) {
    var sb = str_builder_new();
    str_builder_putc(sb, '[');
    var first = 1;
    var i = 0;
    while (i < tools_len && load8(tools_raw + i) != 91) { i = i + 1; }
    i = i + 1;
    while (i < tools_len) {
        var ch = load8(tools_raw + i);
        if (ch == 32 || ch == 44 || ch == 10 || ch == 13 || ch == 9) {
            i = i + 1;
        } else {
            if (ch != 123) {
                i = tools_len;
            } else {
                var obj_end = _json_obj_end(tools_raw, tools_len, i);
                var func = _json_obj_obj_span(tools_raw + i, obj_end - i, "function", 8);
                if (func != 0) {
                    var fptr = load64(func);
                    var flen = load64(func + 8);
                    var nm = _json_obj_str_field(fptr, flen, "name", 4);
                    var ds = _json_obj_str_field(fptr, flen, "description", 11);
                    var pm = _json_obj_obj_span(fptr, flen, "parameters", 10);
                    if (nm != 0) {
                        if (first == 0) { str_builder_putc(sb, ','); }
                        str_builder_add_cstr(sb, "{\"name\":\"");
                        str_builder_add(sb, str_new(load64(nm), load64(nm + 8)));
                        str_builder_add_cstr(sb, "\",\"description\":\"");
                        if (ds != 0) {
                            str_builder_add(sb, str_new(load64(ds), load64(ds + 8)));
                        }
                        str_builder_add_cstr(sb, "\",\"");
                        str_builder_add_cstr(sb, schema_key);
                        str_builder_add_cstr(sb, "\":");
                        if (pm != 0) {
                            str_builder_add(sb, str_new(load64(pm), load64(pm + 8)));
                        } else {
                            str_builder_add_cstr(sb, "{}");
                        }
                        str_builder_putc(sb, '}');
                        first = 0;
                    }
                }
                i = obj_end;
            }
        }
    }
    str_builder_putc(sb, ']');
    return str_cstr(str_builder_build(sb));
}

fn _anthropic_tool_calls(rb, rbl) {
    var cspan = _json_arr_span(rb, rbl, "content", 7);
    if (cspan == 0) { return 0; }
    var cp = load64(cspan);
    var cl = load64(cspan + 8);
    var sb = str_builder_new();
    str_builder_putc(sb, '[');
    var first = 1;
    var i = 1;
    while (i < cl) {
        var ch = load8(cp + i);
        if (ch == 123) {
            var oe = _json_span_end(cp, cl, i);
            var ol = oe - i;
            var tf = _json_obj_str_field(cp + i, ol, "type", 4);
            if (tf != 0) {
                if (load64(tf + 8) == 8 && memeq(load64(tf), "tool_use", 8) == 1) {
                    var idf = _json_obj_str_field(cp + i, ol, "id", 2);
                    var nmf = _json_obj_str_field(cp + i, ol, "name", 4);
                    var inf = _json_obj_obj_span(cp + i, ol, "input", 5);
                    if (idf != 0 && nmf != 0) {
                        if (first == 0) { str_builder_putc(sb, ','); }
                        var ap = 0;
                        var al = 0;
                        if (inf != 0) { ap = load64(inf); al = load64(inf + 8); }
                        _emit_tool_call(sb, load64(idf), load64(idf + 8),
                        load64(nmf), load64(nmf + 8), ap, al);
                        first = 0;
                    }
                }
            }
            i = oe;
        } else {
            i = i + 1;
        }
    }
    str_builder_putc(sb, ']');
    if (first == 1) { return 0; }
    return str_cstr(str_builder_build(sb));
}

# Convert a cstr OpenAI-tools literal; return the converted cstr.
fn _conv(s, key) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return _tools_convert(b, n, key);
}

# Parse Anthropic tool_use from a cstr response literal; return tool_calls cstr.
fn _antc(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return _anthropic_tool_calls(b, n);
}

# Mirror of src/lib/provider.cyr _json_unesc_span — reverse JSON string-escaping
# so an OpenAI `arguments` STRING becomes a literal JSON object for `input`.
fn _json_unesc_span(sb, ptr, len) {
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (c == 92) {
            if (i + 1 < len) {
                var n = load8(ptr + i + 1);
                if (n == 34) { str_builder_putc(sb, 34); i = i + 2; continue; }
                if (n == 92) { str_builder_putc(sb, 92); i = i + 2; continue; }
                str_builder_putc(sb, 92); i = i + 1; continue;
            }
        }
        str_builder_putc(sb, c);
        i = i + 1;
    }
    return 0;
}

fn _build_anthropic_body_x(model, messages_raw, messages_len, stream) {
    var sys_sb = str_builder_new();
    var msgs_sb = str_builder_new();
    str_builder_putc(msgs_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var keep = 1;
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
                keep = 0;
            }
        }
        if (keep == 1) {
            # Tool-continuation translation (mirror of src/lib/provider.cyr):
            # assistant `tool_calls` -> content[] of tool_use blocks; `role:"tool"`
            # -> a user message with a tool_result block; else verbatim.
            var mp = messages_raw + obj_start;
            var tcspan = _json_arr_span(mp, obj_len, "tool_calls", 10);
            var is_tool = 0;
            var rolef = _json_obj_str_field(mp, obj_len, "role", 4);
            if (rolef != 0) {
                if (load64(rolef + 8) == 4) {
                    if (memeq(load64(rolef), "tool", 4) == 1) { is_tool = 1; }
                }
            }
            if (tcspan != 0) {
                if (first == 0) { str_builder_putc(msgs_sb, ','); }
                str_builder_add_cstr(msgs_sb, "{\"role\":\"assistant\",\"content\":[");
                var bf = 1;
                var cf2 = _json_obj_str_field(mp, obj_len, "content", 7);
                if (cf2 != 0) {
                    if (load64(cf2 + 8) > 0) {
                        str_builder_add_cstr(msgs_sb, "{\"type\":\"text\",\"text\":\"");
                        str_builder_add(msgs_sb, str_new(load64(cf2), load64(cf2 + 8)));
                        str_builder_add_cstr(msgs_sb, "\"}");
                        bf = 0;
                    }
                }
                var tcp = load64(tcspan);
                var tcl = load64(tcspan + 8);
                var k = 1;
                while (k < tcl) {
                    if (load8(tcp + k) == 123) {
                        var toe = _json_span_end(tcp, tcl, k);
                        var tol = toe - k;
                        var idf = _json_obj_str_field(tcp + k, tol, "id", 2);
                        var fspan = _json_obj_obj_span(tcp + k, tol, "function", 8);
                        if (idf != 0) {
                            if (fspan != 0) {
                                var fp = load64(fspan);
                                var fl = load64(fspan + 8);
                                var nmf = _json_obj_str_field(fp, fl, "name", 4);
                                var argf = _json_obj_str_field(fp, fl, "arguments", 9);
                                if (nmf != 0) {
                                    if (bf == 0) { str_builder_putc(msgs_sb, ','); }
                                    str_builder_add_cstr(msgs_sb, "{\"type\":\"tool_use\",\"id\":\"");
                                    str_builder_add(msgs_sb, str_new(load64(idf), load64(idf + 8)));
                                    str_builder_add_cstr(msgs_sb, "\",\"name\":\"");
                                    str_builder_add(msgs_sb, str_new(load64(nmf), load64(nmf + 8)));
                                    str_builder_add_cstr(msgs_sb, "\",\"input\":");
                                    if (argf != 0) {
                                        if (load64(argf + 8) > 0) {
                                            _json_unesc_span(msgs_sb, load64(argf), load64(argf + 8));
                                        } else {
                                            str_builder_add_cstr(msgs_sb, "{}");
                                        }
                                    } else {
                                        str_builder_add_cstr(msgs_sb, "{}");
                                    }
                                    str_builder_putc(msgs_sb, '}');
                                    bf = 0;
                                }
                            }
                        }
                        k = toe;
                    } else {
                        k = k + 1;
                    }
                }
                str_builder_add_cstr(msgs_sb, "]}");
                first = 0;
                keep = 0;
            }
            if (keep == 1) {
                if (is_tool == 1) {
                    var tidf = _json_obj_str_field(mp, obj_len, "tool_call_id", 12);
                    var trc = _json_obj_str_field(mp, obj_len, "content", 7);
                    if (first == 0) { str_builder_putc(msgs_sb, ','); }
                    str_builder_add_cstr(msgs_sb, "{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"tool_use_id\":\"");
                    if (tidf != 0) { str_builder_add(msgs_sb, str_new(load64(tidf), load64(tidf + 8))); }
                    str_builder_add_cstr(msgs_sb, "\",\"content\":\"");
                    if (trc != 0) { str_builder_add(msgs_sb, str_new(load64(trc), load64(trc + 8))); }
                    str_builder_add_cstr(msgs_sb, "\"}]}");
                    first = 0;
                    keep = 0;
                }
            }
            if (keep == 1) {
                if (first == 0) { str_builder_putc(msgs_sb, ','); }
                str_builder_add(msgs_sb, str_new(mp, obj_len));
                first = 0;
            }
        }
        i = obj_end;
    }
    str_builder_putc(msgs_sb, ']');

    var body = str_builder_new();
    str_builder_add_cstr(body, "{\"model\":\"");
    str_builder_add_cstr(body, model);
    str_builder_add_cstr(body, "\",\"max_tokens\":4096,");
    if (stream == 1) {
        str_builder_add_cstr(body, "\"stream\":true,");
    }
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"system\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\",");
    }
    str_builder_add_cstr(body, "\"messages\":");
    str_builder_add(body, str_builder_build(msgs_sb));
    str_builder_putc(body, '}');
    return str_cstr(str_builder_build(body));
}

fn _build_anthropic_body(model, messages_raw, messages_len) {
    return _build_anthropic_body_x(model, messages_raw, messages_len, 0);
}

# Gemini shaping helpers — mirror of src/lib/provider.cyr.
fn _build_gemini_body(messages_raw, messages_len) {
    var sys_sb = str_builder_new();
    var contents_sb = str_builder_new();
    str_builder_putc(contents_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
            }
        } else {
            if (cf != 0) {
                var role = "user";
                var rf = _json_obj_str_field(messages_raw + obj_start, obj_len, "role", 4);
                if (rf != 0) {
                    if (load64(rf + 8) == 9) {
                        if (memeq(load64(rf), "assistant", 9) == 1) { role = "model"; }
                    }
                }
                if (first == 0) { str_builder_putc(contents_sb, ','); }
                str_builder_add_cstr(contents_sb, "{\"role\":\"");
                str_builder_add_cstr(contents_sb, role);
                str_builder_add_cstr(contents_sb, "\",\"parts\":[{\"text\":\"");
                str_builder_add(contents_sb, str_new(load64(cf), load64(cf + 8)));
                str_builder_add_cstr(contents_sb, "\"}]}");
                first = 0;
            }
        }
        i = obj_end;
    }
    str_builder_putc(contents_sb, ']');

    var body = str_builder_new();
    str_builder_putc(body, '{');
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"systemInstruction\":{\"parts\":[{\"text\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\"}]},");
    }
    str_builder_add_cstr(body, "\"contents\":");
    str_builder_add(body, str_builder_build(contents_sb));
    str_builder_putc(body, '}');
    return str_cstr(str_builder_build(body));
}

fn gemini_extract_text(resp_body, resp_len) {
    return anthropic_extract_text(resp_body, resp_len);
}

fn extract_gemini_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "promptTokenCount", 16);
    var comp = _json_extract_int(body, blen, "candidatesTokenCount", 20);
    return prompt * 0x100000000 + comp;
}

fn _gemini_url(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":generateContent");
    if (key != 0) {
        str_builder_add_cstr(sb, "?key=");
        str_builder_add_cstr(sb, key);
    }
    return str_cstr(str_builder_build(sb));
}

fn _gemini_url_stream(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":streamGenerateContent?alt=sse");
    if (key != 0) {
        str_builder_add_cstr(sb, "&key=");
        str_builder_add_cstr(sb, key);
    }
    return str_cstr(str_builder_build(sb));
}

# ================================================================
# Router — priority-sorted route list + selection
# Layout: routes_ptr(8) route_count(8) strategy(8) rr_index(8) latencies_ptr(8)
# Total: 40 bytes
# ================================================================

enum RouterField {
    ROUTER_SIZE      = 40;
    ROUTER_ROUTES    = 0;
    ROUTER_COUNT     = 8;
    ROUTER_STRATEGY  = 16;
    ROUTER_RR_IDX    = 24;
    ROUTER_LATENCIES = 32;
}

fn router_new(routes, count, strategy) {
    var rt = alloc(ROUTER_SIZE);
    store64(rt + ROUTER_ROUTES, routes);
    store64(rt + ROUTER_COUNT, count);
    store64(rt + ROUTER_STRATEGY, strategy);
    store64(rt + ROUTER_RR_IDX, 0);
    store64(rt + ROUTER_LATENCIES, map_new());
    # Sort by priority (insertion sort — small N)
    var i = 1;
    while (i < count) {
        var key = load64(routes + i * 8);
        var kp = route_priority(key);
        var j = i - 1;
        while (j >= 0) {
            if (route_priority(load64(routes + j * 8)) <= kp) { break; }
            store64(routes + (j + 1) * 8, load64(routes + j * 8));
            j = j - 1;
        }
        store64(routes + (j + 1) * 8, key);
        i = i + 1;
    }
    return rt;
}

# Select best provider for a model. Returns route ptr or 0 (not found).
fn router_select(rt, model) {
    var routes = load64(rt + ROUTER_ROUTES);
    var count = load64(rt + ROUTER_COUNT);
    var strategy = load64(rt + ROUTER_STRATEGY);

    # Build candidates list (enabled + matches model)
    var cand = alloc(count * 8);
    var cn = 0;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1 && route_matches_model(r, model) == 1) {
            store64(cand + cn * 8, r);
            cn = cn + 1;
        }
        i = i + 1;
    }

    if (cn == 0) { return 0; }

    if (strategy == STRAT_PRIORITY || strategy == STRAT_DIRECT) {
        return load64(cand);
    }

    if (strategy == STRAT_ROUND_ROBIN) {
        var idx = load64(rt + ROUTER_RR_IDX);
        store64(rt + ROUTER_RR_IDX, idx + 1);
        return load64(cand + (idx % cn) * 8);
    }

    if (strategy == STRAT_LOWEST_LATENCY) {
        var lat_map = load64(rt + ROUTER_LATENCIES);
        var best = load64(cand);
        var best_lat = 0x7FFFFFFFFFFFFFFF;
        var j = 0;
        while (j < cn) {
            var c = load64(cand + j * 8);
            var url = route_base_url(c);
            var lat = map_get(lat_map, url);
            if (lat == 0) { lat = 0x7FFFFFFFFFFFFFFF; }
            if (lat < best_lat) {
                best = c;
                best_lat = lat;
            }
            j = j + 1;
        }
        return best;
    }

    return load64(cand);
}

fn router_report_latency(rt, base_url, latency_ms) {
    var lat_map = load64(rt + ROUTER_LATENCIES);
    var old = map_get(lat_map, base_url);
    if (old == 0) {
        map_set(lat_map, base_url, latency_ms);
    } else {
        # EMA: (old * 7 + new * 3) / 10
        var avg = (old * 7 + latency_ms * 3) / 10;
        map_set(lat_map, base_url, avg);
    }
    return 0;
}

# ================================================================
# Token pool
# Layout: name(8) capacity(8) used(8) reserved(8)
# Total: 32 bytes
# ================================================================

enum PoolField {
    POOL_SIZE     = 32;
    POOL_NAME     = 0;
    POOL_CAPACITY = 8;
    POOL_USED     = 16;
    POOL_RESERVED = 24;
}

fn pool_new(name, capacity) {
    var p = alloc(POOL_SIZE);
    store64(p + POOL_NAME, name);
    store64(p + POOL_CAPACITY, capacity);
    store64(p + POOL_USED, 0);
    store64(p + POOL_RESERVED, 0);
    return p;
}

fn pool_name(p) { return load64(p + POOL_NAME); }
fn pool_capacity(p) { return load64(p + POOL_CAPACITY); }
fn pool_used(p) { return load64(p + POOL_USED); }
fn pool_reserved(p) { return load64(p + POOL_RESERVED); }

fn pool_available(p) {
    var cap = load64(p + POOL_CAPACITY);
    var used = load64(p + POOL_USED);
    var resv = load64(p + POOL_RESERVED);
    var taken = used + resv;
    if (taken > cap) { return 0; }
    return cap - taken;
}

fn pool_can_reserve(p, tokens) {
    if (pool_available(p) >= tokens) { return 1; }
    return 0;
}

fn pool_reserve(p, tokens) {
    if (pool_can_reserve(p, tokens) == 0) { return 0; }
    store64(p + POOL_RESERVED, load64(p + POOL_RESERVED) + tokens);
    return 1;
}

fn pool_commit(p, reserved, actual) {
    var resv = load64(p + POOL_RESERVED);
    if (resv >= reserved) {
        store64(p + POOL_RESERVED, resv - reserved);
    } else {
        store64(p + POOL_RESERVED, 0);
    }
    store64(p + POOL_USED, load64(p + POOL_USED) + actual);
    return 0;
}

fn pool_release(p, tokens) {
    var resv = load64(p + POOL_RESERVED);
    if (resv >= tokens) {
        store64(p + POOL_RESERVED, resv - tokens);
    } else {
        store64(p + POOL_RESERVED, 0);
    }
    return 0;
}

# ================================================================
# Token budget — hashmap of pools by name
# ================================================================

fn budget_new() { return map_new(); }

fn budget_add_pool(bgt, p) {
    map_set(bgt, pool_name(p), p);
    return 0;
}

fn budget_get_pool(bgt, name) {
    return map_get(bgt, name);
}

fn budget_check(bgt, name, tokens) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    return pool_can_reserve(p, tokens);
}

fn budget_reserve(bgt, name, tokens) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    return pool_reserve(p, tokens);
}

fn budget_report(bgt, name, reserved, actual) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    pool_commit(p, reserved, actual);
    return 0;
}

# ================================================================
# Cache — hashmap with TTL (simplified: no TTL eviction in test,
#          tests TTL separately via chrono timestamps)
# Layout: entries(8) max_entries(8) hits(8) misses(8) evictions(8) enabled(8)
# Total: 48 bytes
# ================================================================

enum CacheField {
    CACHE_SIZE        = 48;
    CACHE_ENTRIES     = 0;
    CACHE_MAX         = 8;
    CACHE_HITS        = 16;
    CACHE_MISSES      = 24;
    CACHE_EVICTIONS   = 32;
    CACHE_ENABLED     = 40;
}

fn cache_new(max_entries, enabled) {
    var c = alloc(CACHE_SIZE);
    store64(c + CACHE_ENTRIES, map_new());
    store64(c + CACHE_MAX, max_entries);
    store64(c + CACHE_HITS, 0);
    store64(c + CACHE_MISSES, 0);
    store64(c + CACHE_EVICTIONS, 0);
    store64(c + CACHE_ENABLED, enabled);
    return c;
}

fn cache_get(c, key) {
    if (load64(c + CACHE_ENABLED) == 0) { return 0; }
    var entries = load64(c + CACHE_ENTRIES);
    var val = map_get(entries, key);
    if (val == 0) {
        store64(c + CACHE_MISSES, load64(c + CACHE_MISSES) + 1);
        return 0;
    }
    store64(c + CACHE_HITS, load64(c + CACHE_HITS) + 1);
    return val;
}

fn cache_insert(c, key, value) {
    if (load64(c + CACHE_ENABLED) == 0) { return 0; }
    var entries = load64(c + CACHE_ENTRIES);
    var max = load64(c + CACHE_MAX);
    # Evict if at capacity (simple: just count eviction, hashmap handles it)
    if (map_count(entries) >= max) {
        store64(c + CACHE_EVICTIONS, load64(c + CACHE_EVICTIONS) + 1);
    }
    map_set(entries, key, value);
    return 0;
}

fn cache_len(c) {
    return map_count(load64(c + CACHE_ENTRIES));
}

fn cache_clear(c) {
    store64(c + CACHE_ENTRIES, map_new());
    return 0;
}

fn cache_hits(c) { return load64(c + CACHE_HITS); }
fn cache_misses(c) { return load64(c + CACHE_MISSES); }
fn cache_evictions(c) { return load64(c + CACHE_EVICTIONS); }

# ================================================================
# Cost tracker — pricing lookup + accumulation
# ================================================================

# Pricing in microdollars per million tokens (avoids f64)
# e.g. $2.50/M = 2500000 microdollars/M
enum Pricing {
    # OpenAI
    PRICE_GPT4O_IN       = 2500000;
    PRICE_GPT4O_OUT      = 10000000;
    PRICE_GPT4O_MINI_IN  = 150000;
    PRICE_GPT4O_MINI_OUT = 600000;
    # Anthropic
    PRICE_OPUS_IN        = 15000000;
    PRICE_OPUS_OUT       = 75000000;
    PRICE_SONNET_IN      = 3000000;
    PRICE_SONNET_OUT     = 15000000;
    # DeepSeek
    PRICE_DSCHAT_IN      = 270000;
    PRICE_DSCHAT_OUT     = 1100000;
    # Grok
    PRICE_GROK3_IN       = 3000000;
    PRICE_GROK3_OUT      = 15000000;
    # Local providers
    PRICE_LOCAL_IN       = 0;
    PRICE_LOCAL_OUT      = 0;
}

# Lookup pricing: returns (input_microdollars_per_M, output_microdollars_per_M)
# packed as: input * 0x100000000 + output (since both fit in 32 bits)
fn pricing_lookup(model, prov) {
    if (provider_is_local(prov) == 1) { return 0; }
    if (streq(model, "gpt-4o") == 1) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    if (streq(model, "gpt-4o-mini") == 1) { return PRICE_GPT4O_MINI_IN * 0x100000000 + PRICE_GPT4O_MINI_OUT; }
    if (streq(model, "claude-opus-4") == 1) { return PRICE_OPUS_IN * 0x100000000 + PRICE_OPUS_OUT; }
    if (streq(model, "claude-sonnet-4") == 1) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (streq(model, "deepseek-chat") == 1) { return PRICE_DSCHAT_IN * 0x100000000 + PRICE_DSCHAT_OUT; }
    if (streq(model, "grok-3") == 1) { return PRICE_GROK3_IN * 0x100000000 + PRICE_GROK3_OUT; }
    # Prefix match — check if model starts with a known base
    if (memeq(model, "claude-sonnet-4", 15) == 1) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (memeq(model, "claude-opus-4", 13) == 1) { return PRICE_OPUS_IN * 0x100000000 + PRICE_OPUS_OUT; }
    if (memeq(model, "gpt-4o", 6) == 1) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    # Fallback per provider
    if (prov == PROV_ANTHROPIC) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (prov == PROV_OPENAI) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    if (prov == PROV_DEEPSEEK) { return PRICE_DSCHAT_IN * 0x100000000 + PRICE_DSCHAT_OUT; }
    return 0;
}

fn pricing_input(packed) { return packed / 0x100000000; }
fn pricing_output(packed) { return packed % 0x100000000; }

# Cost for a request in microdollars
fn cost_calculate(model, prov, prompt_tokens, completion_tokens) {
    var p = pricing_lookup(model, prov);
    var inp = pricing_input(p);
    var out = pricing_output(p);
    # cost = tokens * price_per_M / 1_000_000
    var cost = prompt_tokens * inp / 1000000 + completion_tokens * out / 1000000;
    return cost;
}

# Cost tracker — hashmap of provider:url -> record
# Record layout: total_input(8) total_output(8) total_cost(8) requests(8) = 32 bytes
enum CostField {
    COST_REC_SIZE   = 32;
    COST_REC_INPUT  = 0;
    COST_REC_OUTPUT = 8;
    COST_REC_COST   = 16;
    COST_REC_REQS   = 24;
}

fn cost_tracker_new() { return map_new(); }

fn cost_tracker_record(tracker, prov, model, prompt_tok, comp_tok) {
    var cost = cost_calculate(model, prov, prompt_tok, comp_tok);
    var pname = provider_name(prov);
    var rec = map_get(tracker, pname);
    if (rec == 0) {
        rec = alloc(COST_REC_SIZE);
        store64(rec + COST_REC_INPUT, 0);
        store64(rec + COST_REC_OUTPUT, 0);
        store64(rec + COST_REC_COST, 0);
        store64(rec + COST_REC_REQS, 0);
        map_set(tracker, pname, rec);
    }
    store64(rec + COST_REC_INPUT, load64(rec + COST_REC_INPUT) + prompt_tok);
    store64(rec + COST_REC_OUTPUT, load64(rec + COST_REC_OUTPUT) + comp_tok);
    store64(rec + COST_REC_COST, load64(rec + COST_REC_COST) + cost);
    store64(rec + COST_REC_REQS, load64(rec + COST_REC_REQS) + 1);
    return cost;
}

# ================================================================
# Queue — simple priority queue (5 tiers)
# Uses a vec per tier, dequeue scans highest first
# ================================================================

enum QueuePriority {
    PRI_CRITICAL   = 0;
    PRI_HIGH       = 1;
    PRI_NORMAL     = 2;
    PRI_LOW        = 3;
    PRI_BACKGROUND = 4;
    PRI_TIERS      = 5;
}

# Queue item: model(8) pool(8) request_id(8) = 24 bytes
enum QItem {
    QITEM_SIZE   = 24;
    QITEM_MODEL  = 0;
    QITEM_POOL   = 8;
    QITEM_ID     = 16;
}

fn queue_new() {
    # 5 tiers, each a vec
    var q = alloc(PRI_TIERS * 8);
    var i = 0;
    while (i < PRI_TIERS) {
        store64(q + i * 8, vec_new());
        i = i + 1;
    }
    return q;
}

fn queue_enqueue(q, model, pool, request_id, priority) {
    var item = alloc(QITEM_SIZE);
    store64(item + QITEM_MODEL, model);
    store64(item + QITEM_POOL, pool);
    store64(item + QITEM_ID, request_id);
    var tier = load64(q + priority * 8);
    vec_push(tier, item);
    return 0;
}

# Returns item ptr or 0 if empty
fn queue_dequeue(q) {
    var i = 0;
    while (i < PRI_TIERS) {
        var tier = load64(q + i * 8);
        if (vec_len(tier) > 0) {
            var item = vec_get(tier, 0);
            vec_remove(tier, 0);
            return item;
        }
        i = i + 1;
    }
    return 0;
}

fn queue_len(q) {
    var total = 0;
    var i = 0;
    while (i < PRI_TIERS) {
        total = total + vec_len(load64(q + i * 8));
        i = i + 1;
    }
    return total;
}

fn queue_is_empty(q) {
    if (queue_len(q) == 0) { return 1; }
    return 0;
}

# Audit entry layout
enum AuditField {
    AE_SIZE = 64;
    AE_ID = 0; AE_EVENT = 8; AE_MSG = 16; AE_PROV = 24;
    AE_MODEL = 32; AE_HASH = 40; AE_SIG = 48; AE_PREV = 56;
}

# 2.5.0: copy of _req_reasoning_effort (handlers.cyr) — the raw byte scan mapping OpenAI reasoning_effort to an
# Anthropic thinking effort level (1=low/2=medium/3=high/0=none). A raw scan, NOT json_get, because clients put
# reasoning_effort AFTER the nested `messages` array, which hoosh's flat json_parse cannot reach.
fn _req_reasoning_effort(body_ptr, body_len) {
    var i = 0;
    while (i + 19 < body_len) {
        if (memeq(body_ptr + i, "\"reasoning_effort\":", 19) == 1) {
            var j = i + 19;
            while (j < body_len && load8(body_ptr + j) == 32) { j = j + 1; }
            if (j < body_len && load8(body_ptr + j) == 34) {
                var p = body_ptr + j + 1;
                var rem = body_len - j - 1;
                if (rem > 3 && memeq(p, "low", 3) == 1 && load8(p + 3) == 34) { return 1; }
                if (rem > 6 && memeq(p, "medium", 6) == 1 && load8(p + 6) == 34) { return 2; }
                if (rem > 4 && memeq(p, "high", 4) == 1 && load8(p + 4) == 34) { return 3; }
            }
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# TESTS
# ================================================================

fn main() {
    alloc_init();

    # ── reasoning_effort parse (2.5.0) — CRUCIALLY, must find the key AFTER the nested messages array ─────
    test_group("reasoning_effort");
    var _rb1 = "{\"model\":\"m\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}],\"reasoning_effort\":\"high\",\"stream\":true}";
    assert_eq(_req_reasoning_effort(_rb1, strlen(_rb1)), 3, "reasoning_effort AFTER messages -> high(3) (raw scan, not json_get)");
    var _rb2 = "{\"reasoning_effort\":\"medium\",\"messages\":[{\"role\":\"user\",\"content\":\"x\"}]}";
    assert_eq(_req_reasoning_effort(_rb2, strlen(_rb2)), 2, "reasoning_effort before messages -> medium(2)");
    var _rb3 = "{\"reasoning_effort\": \"low\"}";
    assert_eq(_req_reasoning_effort(_rb3, strlen(_rb3)), 1, "reasoning_effort with a space -> low(1)");
    var _rb4 = "{\"model\":\"m\",\"messages\":[{\"role\":\"user\",\"content\":\"hi\"}]}";
    assert_eq(_req_reasoning_effort(_rb4, strlen(_rb4)), 0, "no reasoning_effort -> 0 (thinking off)");
    var _rb5 = "{\"reasoning_effort\":\"bogus\"}";
    assert_eq(_req_reasoning_effort(_rb5, strlen(_rb5)), 0, "unknown effort value -> 0");

    # ── Error types ──────────────────────────────────────────────
    test_group("error_types");

    assert_eq(error_http_status(ERR_MODEL_NOT_FOUND), 404, "model_not_found -> 404");
    assert_eq(error_http_status(ERR_NO_PROVIDER), 404, "no_provider -> 404");
    assert_eq(error_http_status(ERR_RATE_LIMITED), 429, "rate_limited -> 429");
    assert_eq(error_http_status(ERR_BUDGET_EXCEEDED), 429, "budget_exceeded -> 429");
    assert_eq(error_http_status(ERR_TIMEOUT), 408, "timeout -> 408");
    assert_eq(error_http_status(ERR_PROVIDER), 500, "provider -> 500");
    assert_eq(error_http_status(ERR_CACHE), 500, "cache -> 500");
    assert_eq(error_http_status(ERR_DLP_BLOCKED), 403, "dlp -> 403");
    assert_eq(error_http_status(ERR_HTTP), 502, "http -> 502");
    assert_eq(error_http_status(ERR_INTERNAL), 500, "internal -> 500");

    assert(error_is_retryable(ERR_RATE_LIMITED) == 1, "rate_limited retryable");
    assert(error_is_retryable(ERR_TIMEOUT) == 1, "timeout retryable");
    assert(error_is_retryable(ERR_PROVIDER) == 1, "provider retryable");
    assert(error_is_retryable(ERR_MODEL_NOT_FOUND) == 0, "model_not_found not retryable");
    assert(error_is_retryable(ERR_BUDGET_EXCEEDED) == 0, "budget not retryable");
    assert(error_is_retryable(ERR_DLP_BLOCKED) == 0, "dlp not retryable");

    assert_streq(error_code_str(ERR_MODEL_NOT_FOUND), "model_not_found", "code_str model");
    assert_streq(error_code_str(ERR_NO_PROVIDER), "no_provider", "code_str no_prov");
    assert_streq(error_code_str(ERR_RATE_LIMITED), "rate_limit_exceeded", "code_str rate");
    assert_streq(error_code_str(ERR_BUDGET_EXCEEDED), "budget_exceeded", "code_str budget");
    assert_streq(error_code_str(ERR_TIMEOUT), "timeout", "code_str timeout");
    assert_streq(error_code_str(ERR_INTERNAL), "internal_error", "code_str internal");

    # ── Provider types ───────────────────────────────────────────
    test_group("provider_types");

    assert_eq(PROV_COUNT, 17, "17 provider types");
    assert(provider_is_local(PROV_OLLAMA) == 1, "ollama is local");
    assert(provider_is_local(PROV_LLAMACPP) == 1, "llamacpp is local");
    assert(provider_is_local(PROV_SYNAPSE) == 1, "synapse is local");
    assert(provider_is_local(PROV_LMSTUDIO) == 1, "lmstudio is local");
    assert(provider_is_local(PROV_LOCALAI) == 1, "localai is local");
    assert(provider_is_local(PROV_WHISPER) == 1, "whisper is local");
    assert(provider_is_local(PROV_OPENAI) == 0, "openai is remote");
    assert(provider_is_local(PROV_ANTHROPIC) == 0, "anthropic is remote");
    assert(provider_is_local(PROV_DEEPSEEK) == 0, "deepseek is remote");
    assert(provider_is_local(PROV_GROQ) == 0, "groq is remote");
    assert(provider_is_local(PROV_VLLM) == 1, "vllm is local");
    assert(provider_is_local(PROV_TENSORRT) == 1, "tensorrt is local");
    assert(provider_is_local(PROV_ONNX) == 1, "onnx is local");

    assert_streq(provider_name(PROV_OLLAMA), "ollama", "name ollama");
    assert_streq(provider_name(PROV_OPENAI), "openai", "name openai");
    assert_streq(provider_name(PROV_ANTHROPIC), "anthropic", "name anthropic");
    assert_streq(provider_name(PROV_VLLM), "vllm", "name vllm");
    assert_streq(provider_name(PROV_TENSORRT), "tensorrt", "name tensorrt");
    assert_streq(provider_name(PROV_ONNX), "onnx", "name onnx");

    # ── Router: priority routing ──────────────────────────────────
    test_group("router_priority");

    var pats1 = alloc(8);
    store64(pats1, "llama*");
    var pats2 = alloc(8);
    store64(pats2, "gpt-*");

    var r1 = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_patterns(r1, pats1, 1);
    var r2 = route_new(PROV_OPENAI, 2, "https://api.openai.com");
    route_set_patterns(r2, pats2, 1);

    var routes = alloc(16);
    store64(routes, r1);
    store64(routes + 8, r2);

    var rt = router_new(routes, 2, STRAT_PRIORITY);

    var sel = router_select(rt, "llama3");
    assert(sel != 0, "priority: llama3 found");
    assert_eq(route_provider(sel), PROV_OLLAMA, "priority: llama3 -> ollama");

    sel = router_select(rt, "gpt-4o");
    assert(sel != 0, "priority: gpt-4o found");
    assert_eq(route_provider(sel), PROV_OPENAI, "priority: gpt-4o -> openai");

    sel = router_select(rt, "claude-sonnet");
    assert_eq(sel, 0, "priority: claude-sonnet not found");

    # ── Router: wildcard route ────────────────────────────────────
    test_group("router_wildcard");

    var wr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    var wroutes = alloc(8);
    store64(wroutes, wr);
    var wrt = router_new(wroutes, 1, STRAT_PRIORITY);
    assert(router_select(wrt, "anything") != 0, "wildcard matches anything");

    # ── Router: disabled route skipped ────────────────────────────
    test_group("router_disabled");

    var dr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_enabled(dr, 0);
    var droutes = alloc(8);
    store64(droutes, dr);
    var drt = router_new(droutes, 1, STRAT_PRIORITY);
    assert_eq(router_select(drt, "llama3"), 0, "disabled route skipped");

    # ── Router: round robin ───────────────────────────────────────
    test_group("router_round_robin");

    var rr1 = route_new(PROV_OLLAMA, 1, "http://ollama");
    var rr2 = route_new(PROV_LLAMACPP, 1, "http://llamacpp");
    var rroutes = alloc(16);
    store64(rroutes, rr1);
    store64(rroutes + 8, rr2);
    var rrrt = router_new(rroutes, 2, STRAT_ROUND_ROBIN);

    var first = route_provider(router_select(rrrt, "llama3"));
    var second = route_provider(router_select(rrrt, "llama3"));
    assert(first != second, "round robin alternates");

    # ── Router: lowest latency ────────────────────────────────────
    test_group("router_lowest_latency");

    var ll1 = route_new(PROV_OLLAMA, 2, "http://ollama");
    var ll2 = route_new(PROV_LLAMACPP, 1, "http://llamacpp");
    var llroutes = alloc(16);
    store64(llroutes, ll1);
    store64(llroutes + 8, ll2);
    var llrt = router_new(llroutes, 2, STRAT_LOWEST_LATENCY);
    router_report_latency(llrt, "http://llamacpp", 500);
    router_report_latency(llrt, "http://ollama", 50);

    sel = router_select(llrt, "any");
    assert_eq(route_provider(sel), PROV_OLLAMA, "lowest latency picks fastest");

    # ── Router: latency EMA ───────────────────────────────────────
    test_group("router_latency_ema");

    var ema_r = route_new(PROV_OLLAMA, 1, "http://localhost");
    var ema_routes = alloc(8);
    store64(ema_routes, ema_r);
    var ema_rt = router_new(ema_routes, 1, STRAT_LOWEST_LATENCY);
    router_report_latency(ema_rt, "http://localhost", 100);
    router_report_latency(ema_rt, "http://localhost", 200);
    # EMA: (100*7 + 200*3)/10 = 130
    var lat_map = load64(ema_rt + ROUTER_LATENCIES);
    assert_eq(map_get(lat_map, "http://localhost"), 130, "latency EMA 130");
    router_report_latency(ema_rt, "http://localhost", 50);
    # EMA: (130*7 + 50*3)/10 = 106
    assert_eq(map_get(lat_map, "http://localhost"), 106, "latency EMA 106");

    # ── Router: exact model match ─────────────────────────────────
    test_group("router_exact_match");

    var expats = alloc(8);
    store64(expats, "llama3.2:latest");
    var exr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_patterns(exr, expats, 1);
    var exroutes = alloc(8);
    store64(exroutes, exr);
    var exrt = router_new(exroutes, 1, STRAT_PRIORITY);
    assert(router_select(exrt, "llama3.2:latest") != 0, "exact match found");
    assert_eq(router_select(exrt, "llama3.2"), 0, "partial exact no match");

    # ── Router: multiple model patterns ───────────────────────────
    test_group("router_multi_patterns");

    var mpats = alloc(16);
    store64(mpats, "llama*");
    store64(mpats + 8, "mistral*");
    var mpr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_patterns(mpr, mpats, 2);
    var mproutes = alloc(8);
    store64(mproutes, mpr);
    var mprt = router_new(mproutes, 1, STRAT_PRIORITY);
    assert(router_select(mprt, "llama3") != 0, "multi: llama3 matches");
    assert(router_select(mprt, "mistral-7b") != 0, "multi: mistral-7b matches");
    assert_eq(router_select(mprt, "gpt-4o"), 0, "multi: gpt-4o no match");

    # ── Token pool basic ──────────────────────────────────────────
    test_group("token_pool");

    var tp = pool_new("test", 1000);
    assert_eq(pool_available(tp), 1000, "pool initial available");
    assert(pool_reserve(tp, 400) == 1, "pool reserve 400");
    assert_eq(pool_available(tp), 600, "pool available after reserve");
    pool_commit(tp, 400, 350);
    assert_eq(pool_used(tp), 350, "pool used after commit");
    assert_eq(pool_reserved(tp), 0, "pool reserved after commit");
    assert_eq(pool_available(tp), 650, "pool available after commit");

    # ── Token pool over budget ────────────────────────────────────
    test_group("token_pool_over_budget");

    var op = pool_new("small", 100);
    assert(pool_can_reserve(op, 200) == 0, "cannot reserve over capacity");

    # ── Token pool release ────────────────────────────────────────
    test_group("token_pool_release");

    var rp = pool_new("release", 1000);
    pool_reserve(rp, 500);
    pool_release(rp, 500);
    assert_eq(pool_reserved(rp), 0, "reserved 0 after release");
    assert_eq(pool_available(rp), 1000, "available restored after release");

    # ── Budget multi-pool ─────────────────────────────────────────
    test_group("budget_multi_pool");

    var bgt = budget_new();
    budget_add_pool(bgt, pool_new("default", 10000));
    budget_add_pool(bgt, pool_new("agent-1", 5000));
    assert(budget_check(bgt, "default", 8000) == 1, "default can reserve 8k");
    assert(budget_check(bgt, "agent-1", 8000) == 0, "agent-1 cannot reserve 8k");
    assert(budget_check(bgt, "nonexistent", 1) == 0, "nonexistent pool fails");

    # ── Budget reserve + report ───────────────────────────────────
    test_group("budget_reserve_report");

    var bgt2 = budget_new();
    budget_add_pool(bgt2, pool_new("pool", 1000));
    assert(budget_reserve(bgt2, "pool", 500) == 1, "budget reserve 500");
    budget_report(bgt2, "pool", 500, 420);
    var bp = budget_get_pool(bgt2, "pool");
    assert_eq(pool_used(bp), 420, "budget used 420");
    assert_eq(pool_reserved(bp), 0, "budget reserved 0");

    # ── Cache basic ───────────────────────────────────────────────
    test_group("cache");

    var ca = cache_new(1000, 1);
    cache_insert(ca, "key1", 42);
    assert_eq(cache_get(ca, "key1"), 42, "cache get hit");
    assert_eq(cache_get(ca, "missing"), 0, "cache get miss");
    assert_eq(cache_hits(ca), 1, "cache 1 hit");
    assert_eq(cache_misses(ca), 1, "cache 1 miss");

    # ── Cache disabled ────────────────────────────────────────────
    test_group("cache_disabled");

    var cd = cache_new(1000, 0);
    cache_insert(cd, "key", 99);
    assert_eq(cache_get(cd, "key"), 0, "disabled cache returns 0");

    # ── Cache clear ───────────────────────────────────────────────
    test_group("cache_clear");

    var cc = cache_new(1000, 1);
    cache_insert(cc, "a", 1);
    cache_insert(cc, "b", 2);
    assert_eq(cache_len(cc), 2, "cache len 2");
    cache_clear(cc);
    assert_eq(cache_len(cc), 0, "cache len 0 after clear");

    # ── Cost tracker: local free ──────────────────────────────────
    test_group("cost_tracker");

    assert_eq(cost_calculate("anything", PROV_OLLAMA, 1000, 500), 0, "local provider free");
    assert_eq(cost_calculate("anything", PROV_LLAMACPP, 1000, 500), 0, "llamacpp free");
    assert_eq(cost_calculate("anything", PROV_SYNAPSE, 1000, 500), 0, "synapse free");

    # ── Cost tracker: known model pricing ─────────────────────────
    test_group("cost_pricing");

    # gpt-4o: $2.5M input, $10M output → for 1M tokens input only = $2.50 = 2500000 microdollars
    var gpt_cost = cost_calculate("gpt-4o", PROV_OPENAI, 1000000, 0);
    assert_eq(gpt_cost, 2500000, "gpt-4o 1M input = $2.50");

    # ── Cost tracker: prefix match ────────────────────────────────
    test_group("cost_prefix");

    var sonnet_cost = cost_calculate("claude-sonnet-4-20250514", PROV_ANTHROPIC, 1000000, 0);
    assert_eq(sonnet_cost, 3000000, "claude-sonnet-4 prefix match = $3.00");

    # ── Cost tracker: accumulation ────────────────────────────────
    test_group("cost_accumulation");

    var ct = cost_tracker_new();
    cost_tracker_record(ct, PROV_OPENAI, "gpt-4o", 100, 50);
    cost_tracker_record(ct, PROV_OPENAI, "gpt-4o", 100, 50);
    var rec = map_get(ct, "openai");
    assert(rec != 0, "openai record exists");
    assert_eq(load64(rec + COST_REC_REQS), 2, "2 requests accumulated");
    assert_eq(load64(rec + COST_REC_INPUT), 200, "200 input tokens");
    assert_eq(load64(rec + COST_REC_OUTPUT), 100, "100 output tokens");

    # ── Cost tracker: separate providers ──────────────────────────
    test_group("cost_separate_providers");

    var ct2 = cost_tracker_new();
    cost_tracker_record(ct2, PROV_OPENAI, "gpt-4o", 100, 50);
    cost_tracker_record(ct2, PROV_ANTHROPIC, "claude-sonnet-4", 100, 50);
    assert(map_get(ct2, "openai") != 0, "openai record");
    assert(map_get(ct2, "anthropic") != 0, "anthropic record");

    # ── Queue: priority ordering ──────────────────────────────────
    test_group("queue_priority");

    var q = queue_new();
    queue_enqueue(q, "llama3", "default", "req-1", PRI_NORMAL);
    queue_enqueue(q, "gpt-4o", "default", "req-2", PRI_CRITICAL);

    var item = queue_dequeue(q);
    assert(item != 0, "dequeue item 1");
    assert_streq(load64(item + QITEM_ID), "req-2", "critical first");

    item = queue_dequeue(q);
    assert(item != 0, "dequeue item 2");
    assert_streq(load64(item + QITEM_ID), "req-1", "normal second");

    # ── Queue: empty returns 0 ────────────────────────────────────
    test_group("queue_empty");

    var eq = queue_new();
    assert_eq(queue_dequeue(eq), 0, "empty queue returns 0");
    assert(queue_is_empty(eq) == 1, "queue is empty");

    # ── Queue: len tracking ───────────────────────────────────────
    test_group("queue_len");

    var lq = queue_new();
    assert_eq(queue_len(lq), 0, "initial len 0");
    queue_enqueue(lq, "m", "p", "r1", PRI_NORMAL);
    assert_eq(queue_len(lq), 1, "len 1 after enqueue");
    queue_enqueue(lq, "m", "p", "r2", PRI_HIGH);
    assert_eq(queue_len(lq), 2, "len 2");
    queue_dequeue(lq);
    assert_eq(queue_len(lq), 1, "len 1 after dequeue");
    queue_dequeue(lq);
    assert_eq(queue_len(lq), 0, "len 0 after drain");

    # ── Queue: all 5 tiers ────────────────────────────────────────
    test_group("queue_all_tiers");

    var tq = queue_new();
    queue_enqueue(tq, "m", "p", "normal", PRI_NORMAL);
    queue_enqueue(tq, "m", "p", "background", PRI_BACKGROUND);
    queue_enqueue(tq, "m", "p", "critical", PRI_CRITICAL);
    queue_enqueue(tq, "m", "p", "low", PRI_LOW);
    queue_enqueue(tq, "m", "p", "high", PRI_HIGH);

    assert_eq(queue_len(tq), 5, "5 items queued");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "critical", "tier: critical first");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "high", "tier: high second");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "normal", "tier: normal third");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "low", "tier: low fourth");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "background", "tier: background last");
    assert(queue_is_empty(tq) == 1, "queue empty after drain");

    # ── Queue: same priority FIFO ─────────────────────────────────
    test_group("queue_fifo");

    var fq = queue_new();
    queue_enqueue(fq, "m", "p", "first", PRI_NORMAL);
    queue_enqueue(fq, "m", "p", "second", PRI_NORMAL);
    queue_enqueue(fq, "m", "p", "third", PRI_NORMAL);
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "first", "fifo: first");
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "second", "fifo: second");
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "third", "fifo: third");

    # ================================================================
    # HEALTH MODULE — failure counting, threshold, recovery
    # ================================================================

    # Health state layout: is_healthy(8) consecutive_failures(8) last_error(8) = 24
    # Health map: hashmap keyed by provider name -> health state ptr

    # ── Health: map starts empty ──────────────────────────────────
    test_group("health_map_empty");

    var hmap = map_new();
    assert_eq(map_size(hmap), 0, "health map starts empty");

    # ── Health: insert and lookup ─────────────────────────────────
    test_group("health_insert_lookup");

    var hs = alloc(24);
    store64(hs, 1);      # is_healthy = true
    store64(hs + 8, 0);  # consecutive_failures = 0
    store64(hs + 16, 0); # last_error = null
    map_set(hmap, "ollama:localhost:11434", hs);
    assert_eq(map_size(hmap), 1, "health map has 1 entry");
    var got = map_get(hmap, "ollama:localhost:11434");
    assert(got != 0, "health entry found");
    assert_eq(load64(got), 1, "entry is healthy");

    # ── Health: threshold constant ────────────────────────────────
    test_group("health_threshold");

    var UNHEALTHY_THRESHOLD = 3;
    assert_eq(UNHEALTHY_THRESHOLD, 3, "threshold is 3");

    # ── Health: handle_check_failure state machine ────────────────
    test_group("health_failure_fsm");

    # Simulate handle_check_failure: increment failures, check threshold
    var hmap2 = map_new();
    var hkey = "ollama:localhost:11434";

    # First failure — no prior entry, starts at 1
    var prev = map_get(hmap2, hkey);
    var failures = 1;
    if (prev != 0) { failures = load64(prev + 8) + 1; }
    var new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs1 = alloc(24);
    store64(hs1, new_healthy);
    store64(hs1 + 8, failures);
    store64(hs1 + 16, "timeout");
    map_set(hmap2, hkey, hs1);

    var e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "1st failure: still healthy");
    assert_eq(load64(e + 8), 1, "1st failure: count=1");
    assert_streq(load64(e + 16), "timeout", "1st failure: error preserved");

    # Second failure
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs2 = alloc(24);
    store64(hs2, new_healthy);
    store64(hs2 + 8, failures);
    store64(hs2 + 16, "second");
    map_set(hmap2, hkey, hs2);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "2nd failure: still healthy");
    assert_eq(load64(e + 8), 2, "2nd failure: count=2");

    # Third failure — crosses threshold
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs3 = alloc(24);
    store64(hs3, new_healthy);
    store64(hs3 + 8, failures);
    store64(hs3 + 16, "third strike");
    map_set(hmap2, hkey, hs3);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 0, "3rd failure: now unhealthy");
    assert_eq(load64(e + 8), 3, "3rd failure: count=3");
    assert_streq(load64(e + 16), "third strike", "3rd failure: error msg");

    # Fourth failure — stays unhealthy
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs4 = alloc(24);
    store64(hs4, new_healthy);
    store64(hs4 + 8, failures);
    store64(hs4 + 16, "fourth");
    map_set(hmap2, hkey, hs4);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 0, "4th failure: still unhealthy");
    assert_eq(load64(e + 8), 4, "4th failure: count=4");

    # ── Health: recovery ──────────────────────────────────────────
    test_group("health_recovery");

    # Simulate recovery (health check passes)
    var hs_recover = alloc(24);
    store64(hs_recover, 1);     # is_healthy = true
    store64(hs_recover + 8, 0); # consecutive_failures = 0
    store64(hs_recover + 16, 0);
    map_set(hmap2, hkey, hs_recover);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "recovered: healthy");
    assert_eq(load64(e + 8), 0, "recovered: failures=0");

    # One failure after recovery — should be healthy (1 < 3)
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_post = alloc(24);
    store64(hs_post, new_healthy);
    store64(hs_post + 8, failures);
    store64(hs_post + 16, "post-recovery fail");
    map_set(hmap2, hkey, hs_post);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "post-recovery: still healthy");
    assert_eq(load64(e + 8), 1, "post-recovery: count=1");

    # ── Health: multiple providers independent ────────────────────
    test_group("health_multi_provider");

    var hmap3 = map_new();
    var hk_a = "ollama:host-a";
    var hk_b = "openai:api.openai.com";

    # Fail provider A 3 times → unhealthy
    var i = 0;
    while (i < 3) {
        prev = map_get(hmap3, hk_a);
        failures = 1;
        if (prev != 0) { failures = load64(prev + 8) + 1; }
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_a = alloc(24);
        store64(hs_a, new_healthy);
        store64(hs_a + 8, failures);
        store64(hs_a + 16, "err");
        map_set(hmap3, hk_a, hs_a);
        i = i + 1;
    }

    # Fail provider B once → still healthy
    var hs_b = alloc(24);
    store64(hs_b, 1);
    store64(hs_b + 8, 1);
    store64(hs_b + 16, "err");
    map_set(hmap3, hk_b, hs_b);

    assert_eq(load64(map_get(hmap3, hk_a)), 0, "provider A unhealthy");
    assert_eq(load64(map_get(hmap3, hk_b)), 1, "provider B still healthy");
    assert_eq(load64(map_get(hmap3, hk_a) + 8), 3, "A: 3 failures");
    assert_eq(load64(map_get(hmap3, hk_b) + 8), 1, "B: 1 failure");

    # ── Health: overwrite entry ───────────────────────────────────
    test_group("health_overwrite");

    var hmap4 = map_new();
    var hk = "ollama:localhost";
    var hs_h = alloc(24);
    store64(hs_h, 1);
    store64(hs_h + 8, 0);
    store64(hs_h + 16, 0);
    map_set(hmap4, hk, hs_h);
    assert_eq(load64(map_get(hmap4, hk)), 1, "initially healthy");

    var hs_u = alloc(24);
    store64(hs_u, 0);
    store64(hs_u + 8, 5);
    store64(hs_u + 16, "down");
    map_set(hmap4, hk, hs_u);
    assert_eq(load64(map_get(hmap4, hk)), 0, "overwritten to unhealthy");
    assert_eq(load64(map_get(hmap4, hk) + 8), 5, "overwritten failures=5");
    assert_eq(map_size(hmap4), 1, "still 1 entry after overwrite");

    # ── Health: boundary test (threshold-1 vs threshold) ──────────
    test_group("health_boundary");

    var hmap5 = map_new();
    var hk5 = "test:boundary";
    # Seed at threshold-2 failures
    var hs_seed = alloc(24);
    store64(hs_seed, 1);
    store64(hs_seed + 8, UNHEALTHY_THRESHOLD - 2);
    store64(hs_seed + 16, 0);
    map_set(hmap5, hk5, hs_seed);

    # One more failure → threshold-1, still healthy
    prev = map_get(hmap5, hk5);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_b1 = alloc(24);
    store64(hs_b1, new_healthy);
    store64(hs_b1 + 8, failures);
    store64(hs_b1 + 16, "still ok");
    map_set(hmap5, hk5, hs_b1);
    e = map_get(hmap5, hk5);
    assert_eq(load64(e), 1, "boundary: threshold-1 still healthy");
    assert_eq(load64(e + 8), UNHEALTHY_THRESHOLD - 1, "boundary: count=threshold-1");

    # One more → exactly at threshold, unhealthy
    prev = map_get(hmap5, hk5);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_b2 = alloc(24);
    store64(hs_b2, new_healthy);
    store64(hs_b2 + 8, failures);
    store64(hs_b2 + 16, "now bad");
    map_set(hmap5, hk5, hs_b2);
    e = map_get(hmap5, hk5);
    assert_eq(load64(e), 0, "boundary: at threshold unhealthy");
    assert_eq(load64(e + 8), UNHEALTHY_THRESHOLD, "boundary: count=threshold");

    # ── Health: rapid recovery cycle ──────────────────────────────
    test_group("health_rapid_cycle");

    var hmap6 = map_new();
    var hk6 = "test:cycle";

    # Cycle 1: drive to unhealthy
    i = 0;
    while (i < UNHEALTHY_THRESHOLD) {
        prev = map_get(hmap6, hk6);
        failures = 1;
        if (prev != 0) { failures = load64(prev + 8) + 1; }
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_c = alloc(24);
        store64(hs_c, new_healthy);
        store64(hs_c + 8, failures);
        store64(hs_c + 16, "fail");
        map_set(hmap6, hk6, hs_c);
        i = i + 1;
    }
    assert_eq(load64(map_get(hmap6, hk6)), 0, "cycle1: unhealthy");

    # Recover
    var hs_rec = alloc(24);
    store64(hs_rec, 1);
    store64(hs_rec + 8, 0);
    store64(hs_rec + 16, 0);
    map_set(hmap6, hk6, hs_rec);

    # Cycle 2: drive to unhealthy again
    i = 0;
    while (i < UNHEALTHY_THRESHOLD) {
        prev = map_get(hmap6, hk6);
        failures = load64(prev + 8) + 1;
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_c2 = alloc(24);
        store64(hs_c2, new_healthy);
        store64(hs_c2 + 8, failures);
        store64(hs_c2 + 16, "fail again");
        map_set(hmap6, hk6, hs_c2);
        i = i + 1;
    }
    assert_eq(load64(map_get(hmap6, hk6)), 0, "cycle2: unhealthy again");
    assert_eq(load64(map_get(hmap6, hk6) + 8), UNHEALTHY_THRESHOLD, "cycle2: count=threshold");

    # ================================================================
    # RATE LIMITER — sliding window RPM
    # ================================================================

    # Rate limiter: map of provider -> { max_rpm(8), count(8) }
    # Simplified: no time window in test, just count-based

    test_group("rate_limit_unconfigured");

    var rl_map = map_new();
    # Unconfigured provider always allowed
    assert_eq(map_get(rl_map, "unknown"), 0, "unconfigured returns 0 (no limit)");

    test_group("rate_limit_within");

    # Configure "test" with max_rpm=5
    # Rate limit record: max_rpm(8) current_count(8) = 16 bytes
    var rl_rec = alloc(16);
    store64(rl_rec, 5);     # max_rpm = 5
    store64(rl_rec + 8, 0); # current_count = 0
    map_set(rl_map, "test", rl_rec);

    # 5 requests within limit
    i = 0;
    var all_ok = 1;
    while (i < 5) {
        var rec = map_get(rl_map, "test");
        var count = load64(rec + 8);
        var max = load64(rec);
        if (count >= max) { all_ok = 0; }
        store64(rec + 8, count + 1);
        i = i + 1;
    }
    assert(all_ok == 1, "5 requests within limit allowed");

    test_group("rate_limit_exceeded");

    # 6th request should be rejected
    var rl_chk = map_get(rl_map, "test");
    var rl_chk_cnt = load64(rl_chk + 8);
    var rl_chk_max = load64(rl_chk);
    assert(rl_chk_cnt >= rl_chk_max, "6th request: count >= max_rpm");

    test_group("rate_limit_independent");

    # Different providers are independent
    var rl_a = alloc(16);
    store64(rl_a, 1);
    store64(rl_a + 8, 0);
    var rl_b = alloc(16);
    store64(rl_b, 1);
    store64(rl_b + 8, 0);
    map_set(rl_map, "prov_a", rl_a);
    map_set(rl_map, "prov_b", rl_b);

    # Use up prov_a's limit
    var ra = map_get(rl_map, "prov_a");
    store64(ra + 8, 1);

    # prov_b should still be allowed
    var rb = map_get(rl_map, "prov_b");
    assert(load64(rb + 8) < load64(rb), "prov_b still has capacity");
    assert(load64(ra + 8) >= load64(ra), "prov_a exhausted");

    # ================================================================
