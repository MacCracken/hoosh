    assert(budget_check(bgt, "agent-1", 8000) == 0, "agent-1 cannot reserve 8k");
    assert(budget_check(bgt, "nonexistent", 1) == 0, "nonexistent pool fails");

    # ── Budget reserve + report ───────────────────────────────────
    test_group("budget_reserve_report");

    var bgt2 = budget_new();
    budget_add_pool(bgt2, pool_new("pool", 1000));
    assert(budget_reserve(bgt2, "pool", 500) == 1, "budget reserve 500");
    budget_report(bgt2, "pool", 500, 420);
    var bp = budget_get_pool(bgt2, "pool");
    assert_eq(pool_used(bp), 420, "budget used 420");
    assert_eq(pool_reserved(bp), 0, "budget reserved 0");

    # ── Cache basic ───────────────────────────────────────────────
    test_group("cache");

    var ca = cache_new(1000, 1);
    cache_insert(ca, "key1", 42);
    assert_eq(cache_get(ca, "key1"), 42, "cache get hit");
    assert_eq(cache_get(ca, "missing"), 0, "cache get miss");
    assert_eq(cache_hits(ca), 1, "cache 1 hit");
    assert_eq(cache_misses(ca), 1, "cache 1 miss");

    # ── Cache disabled ────────────────────────────────────────────
    test_group("cache_disabled");

    var cd = cache_new(1000, 0);
    cache_insert(cd, "key", 99);
    assert_eq(cache_get(cd, "key"), 0, "disabled cache returns 0");

    # ── Cache clear ───────────────────────────────────────────────
    test_group("cache_clear");

    var cc = cache_new(1000, 1);
    cache_insert(cc, "a", 1);
    cache_insert(cc, "b", 2);
    assert_eq(cache_len(cc), 2, "cache len 2");
    cache_clear(cc);
    assert_eq(cache_len(cc), 0, "cache len 0 after clear");

    # ── Cost tracker: local free ──────────────────────────────────
    test_group("cost_tracker");

    assert_eq(cost_calculate("anything", PROV_OLLAMA, 1000, 500), 0, "local provider free");
    assert_eq(cost_calculate("anything", PROV_LLAMACPP, 1000, 500), 0, "llamacpp free");
    assert_eq(cost_calculate("anything", PROV_SYNAPSE, 1000, 500), 0, "synapse free");

    # ── Cost tracker: known model pricing ─────────────────────────
    test_group("cost_pricing");

    # gpt-4o: $2.5M input, $10M output → for 1M tokens input only = $2.50 = 2500000 microdollars
    var gpt_cost = cost_calculate("gpt-4o", PROV_OPENAI, 1000000, 0);
    assert_eq(gpt_cost, 2500000, "gpt-4o 1M input = $2.50");

    # ── Cost tracker: prefix match ────────────────────────────────
    test_group("cost_prefix");

    var sonnet_cost = cost_calculate("claude-sonnet-4-20250514", PROV_ANTHROPIC, 1000000, 0);
    assert_eq(sonnet_cost, 3000000, "claude-sonnet-4 prefix match = $3.00");

    # ── Cost tracker: accumulation ────────────────────────────────
    test_group("cost_accumulation");

    var ct = cost_tracker_new();
    cost_tracker_record(ct, PROV_OPENAI, "gpt-4o", 100, 50);
    cost_tracker_record(ct, PROV_OPENAI, "gpt-4o", 100, 50);
    var rec = map_get(ct, "openai");
    assert(rec != 0, "openai record exists");
    assert_eq(load64(rec + COST_REC_REQS), 2, "2 requests accumulated");
    assert_eq(load64(rec + COST_REC_INPUT), 200, "200 input tokens");
    assert_eq(load64(rec + COST_REC_OUTPUT), 100, "100 output tokens");

    # ── Cost tracker: separate providers ──────────────────────────
    test_group("cost_separate_providers");

    var ct2 = cost_tracker_new();
    cost_tracker_record(ct2, PROV_OPENAI, "gpt-4o", 100, 50);
    cost_tracker_record(ct2, PROV_ANTHROPIC, "claude-sonnet-4", 100, 50);
    assert(map_get(ct2, "openai") != 0, "openai record");
    assert(map_get(ct2, "anthropic") != 0, "anthropic record");

    # ── Queue: priority ordering ──────────────────────────────────
    test_group("queue_priority");

    var q = queue_new();
    queue_enqueue(q, "llama3", "default", "req-1", PRI_NORMAL);
    queue_enqueue(q, "gpt-4o", "default", "req-2", PRI_CRITICAL);

    var item = queue_dequeue(q);
    assert(item != 0, "dequeue item 1");
    assert_streq(load64(item + QITEM_ID), "req-2", "critical first");

    item = queue_dequeue(q);
    assert(item != 0, "dequeue item 2");
    assert_streq(load64(item + QITEM_ID), "req-1", "normal second");

    # ── Queue: empty returns 0 ────────────────────────────────────
    test_group("queue_empty");

    var eq = queue_new();
    assert_eq(queue_dequeue(eq), 0, "empty queue returns 0");
    assert(queue_is_empty(eq) == 1, "queue is empty");

    # ── Queue: len tracking ───────────────────────────────────────
    test_group("queue_len");

    var lq = queue_new();
    assert_eq(queue_len(lq), 0, "initial len 0");
    queue_enqueue(lq, "m", "p", "r1", PRI_NORMAL);
    assert_eq(queue_len(lq), 1, "len 1 after enqueue");
    queue_enqueue(lq, "m", "p", "r2", PRI_HIGH);
    assert_eq(queue_len(lq), 2, "len 2");
    queue_dequeue(lq);
    assert_eq(queue_len(lq), 1, "len 1 after dequeue");
    queue_dequeue(lq);
    assert_eq(queue_len(lq), 0, "len 0 after drain");

    # ── Queue: all 5 tiers ────────────────────────────────────────
    test_group("queue_all_tiers");

    var tq = queue_new();
    queue_enqueue(tq, "m", "p", "normal", PRI_NORMAL);
    queue_enqueue(tq, "m", "p", "background", PRI_BACKGROUND);
    queue_enqueue(tq, "m", "p", "critical", PRI_CRITICAL);
    queue_enqueue(tq, "m", "p", "low", PRI_LOW);
    queue_enqueue(tq, "m", "p", "high", PRI_HIGH);

    assert_eq(queue_len(tq), 5, "5 items queued");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "critical", "tier: critical first");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "high", "tier: high second");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "normal", "tier: normal third");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "low", "tier: low fourth");
    assert_streq(load64(queue_dequeue(tq) + QITEM_ID), "background", "tier: background last");
    assert(queue_is_empty(tq) == 1, "queue empty after drain");

    # ── Queue: same priority FIFO ─────────────────────────────────
    test_group("queue_fifo");

    var fq = queue_new();
    queue_enqueue(fq, "m", "p", "first", PRI_NORMAL);
    queue_enqueue(fq, "m", "p", "second", PRI_NORMAL);
    queue_enqueue(fq, "m", "p", "third", PRI_NORMAL);
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "first", "fifo: first");
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "second", "fifo: second");
    assert_streq(load64(queue_dequeue(fq) + QITEM_ID), "third", "fifo: third");

    # ================================================================
    # HEALTH MODULE — failure counting, threshold, recovery
    # ================================================================

    # Health state layout: is_healthy(8) consecutive_failures(8) last_error(8) = 24
    # Health map: hashmap keyed by provider name -> health state ptr

    # ── Health: map starts empty ──────────────────────────────────
    test_group("health_map_empty");

    var hmap = map_new();
    assert_eq(map_size(hmap), 0, "health map starts empty");

    # ── Health: insert and lookup ─────────────────────────────────
    test_group("health_insert_lookup");

    var hs = alloc(24);
    store64(hs, 1);      # is_healthy = true
    store64(hs + 8, 0);  # consecutive_failures = 0
    store64(hs + 16, 0); # last_error = null
    map_set(hmap, "ollama:localhost:11434", hs);
    assert_eq(map_size(hmap), 1, "health map has 1 entry");
    var got = map_get(hmap, "ollama:localhost:11434");
    assert(got != 0, "health entry found");
    assert_eq(load64(got), 1, "entry is healthy");

    # ── Health: threshold constant ────────────────────────────────
    test_group("health_threshold");

    var UNHEALTHY_THRESHOLD = 3;
    assert_eq(UNHEALTHY_THRESHOLD, 3, "threshold is 3");

    # ── Health: handle_check_failure state machine ────────────────
    test_group("health_failure_fsm");

    # Simulate handle_check_failure: increment failures, check threshold
    var hmap2 = map_new();
    var hkey = "ollama:localhost:11434";

    # First failure — no prior entry, starts at 1
    var prev = map_get(hmap2, hkey);
    var failures = 1;
    if (prev != 0) { failures = load64(prev + 8) + 1; }
    var new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs1 = alloc(24);
    store64(hs1, new_healthy);
    store64(hs1 + 8, failures);
    store64(hs1 + 16, "timeout");
    map_set(hmap2, hkey, hs1);

    var e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "1st failure: still healthy");
    assert_eq(load64(e + 8), 1, "1st failure: count=1");
    assert_streq(load64(e + 16), "timeout", "1st failure: error preserved");

    # Second failure
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs2 = alloc(24);
    store64(hs2, new_healthy);
    store64(hs2 + 8, failures);
    store64(hs2 + 16, "second");
    map_set(hmap2, hkey, hs2);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "2nd failure: still healthy");
    assert_eq(load64(e + 8), 2, "2nd failure: count=2");

    # Third failure — crosses threshold
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs3 = alloc(24);
    store64(hs3, new_healthy);
    store64(hs3 + 8, failures);
    store64(hs3 + 16, "third strike");
    map_set(hmap2, hkey, hs3);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 0, "3rd failure: now unhealthy");
    assert_eq(load64(e + 8), 3, "3rd failure: count=3");
    assert_streq(load64(e + 16), "third strike", "3rd failure: error msg");

    # Fourth failure — stays unhealthy
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs4 = alloc(24);
    store64(hs4, new_healthy);
    store64(hs4 + 8, failures);
    store64(hs4 + 16, "fourth");
    map_set(hmap2, hkey, hs4);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 0, "4th failure: still unhealthy");
    assert_eq(load64(e + 8), 4, "4th failure: count=4");

    # ── Health: recovery ──────────────────────────────────────────
    test_group("health_recovery");

    # Simulate recovery (health check passes)
    var hs_recover = alloc(24);
    store64(hs_recover, 1);     # is_healthy = true
    store64(hs_recover + 8, 0); # consecutive_failures = 0
    store64(hs_recover + 16, 0);
    map_set(hmap2, hkey, hs_recover);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "recovered: healthy");
    assert_eq(load64(e + 8), 0, "recovered: failures=0");

    # One failure after recovery — should be healthy (1 < 3)
    prev = map_get(hmap2, hkey);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_post = alloc(24);
    store64(hs_post, new_healthy);
    store64(hs_post + 8, failures);
    store64(hs_post + 16, "post-recovery fail");
    map_set(hmap2, hkey, hs_post);

    e = map_get(hmap2, hkey);
    assert_eq(load64(e), 1, "post-recovery: still healthy");
    assert_eq(load64(e + 8), 1, "post-recovery: count=1");

    # ── Health: multiple providers independent ────────────────────
    test_group("health_multi_provider");

    var hmap3 = map_new();
    var hk_a = "ollama:host-a";
    var hk_b = "openai:api.openai.com";

    # Fail provider A 3 times → unhealthy
    var i = 0;
    while (i < 3) {
        prev = map_get(hmap3, hk_a);
        failures = 1;
        if (prev != 0) { failures = load64(prev + 8) + 1; }
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_a = alloc(24);
        store64(hs_a, new_healthy);
        store64(hs_a + 8, failures);
        store64(hs_a + 16, "err");
        map_set(hmap3, hk_a, hs_a);
        i = i + 1;
    }

    # Fail provider B once → still healthy
    var hs_b = alloc(24);
    store64(hs_b, 1);
    store64(hs_b + 8, 1);
    store64(hs_b + 16, "err");
    map_set(hmap3, hk_b, hs_b);

    assert_eq(load64(map_get(hmap3, hk_a)), 0, "provider A unhealthy");
    assert_eq(load64(map_get(hmap3, hk_b)), 1, "provider B still healthy");
    assert_eq(load64(map_get(hmap3, hk_a) + 8), 3, "A: 3 failures");
    assert_eq(load64(map_get(hmap3, hk_b) + 8), 1, "B: 1 failure");

    # ── Health: overwrite entry ───────────────────────────────────
    test_group("health_overwrite");

    var hmap4 = map_new();
    var hk = "ollama:localhost";
    var hs_h = alloc(24);
    store64(hs_h, 1);
    store64(hs_h + 8, 0);
    store64(hs_h + 16, 0);
    map_set(hmap4, hk, hs_h);
    assert_eq(load64(map_get(hmap4, hk)), 1, "initially healthy");

    var hs_u = alloc(24);
    store64(hs_u, 0);
    store64(hs_u + 8, 5);
    store64(hs_u + 16, "down");
    map_set(hmap4, hk, hs_u);
    assert_eq(load64(map_get(hmap4, hk)), 0, "overwritten to unhealthy");
    assert_eq(load64(map_get(hmap4, hk) + 8), 5, "overwritten failures=5");
    assert_eq(map_size(hmap4), 1, "still 1 entry after overwrite");

    # ── Health: boundary test (threshold-1 vs threshold) ──────────
    test_group("health_boundary");

    var hmap5 = map_new();
    var hk5 = "test:boundary";
    # Seed at threshold-2 failures
    var hs_seed = alloc(24);
    store64(hs_seed, 1);
    store64(hs_seed + 8, UNHEALTHY_THRESHOLD - 2);
    store64(hs_seed + 16, 0);
    map_set(hmap5, hk5, hs_seed);

    # One more failure → threshold-1, still healthy
    prev = map_get(hmap5, hk5);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_b1 = alloc(24);
    store64(hs_b1, new_healthy);
    store64(hs_b1 + 8, failures);
    store64(hs_b1 + 16, "still ok");
    map_set(hmap5, hk5, hs_b1);
    e = map_get(hmap5, hk5);
    assert_eq(load64(e), 1, "boundary: threshold-1 still healthy");
    assert_eq(load64(e + 8), UNHEALTHY_THRESHOLD - 1, "boundary: count=threshold-1");

    # One more → exactly at threshold, unhealthy
    prev = map_get(hmap5, hk5);
    failures = load64(prev + 8) + 1;
    new_healthy = 0;
    if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
    var hs_b2 = alloc(24);
    store64(hs_b2, new_healthy);
    store64(hs_b2 + 8, failures);
    store64(hs_b2 + 16, "now bad");
    map_set(hmap5, hk5, hs_b2);
    e = map_get(hmap5, hk5);
    assert_eq(load64(e), 0, "boundary: at threshold unhealthy");
    assert_eq(load64(e + 8), UNHEALTHY_THRESHOLD, "boundary: count=threshold");

    # ── Health: rapid recovery cycle ──────────────────────────────
    test_group("health_rapid_cycle");

    var hmap6 = map_new();
    var hk6 = "test:cycle";

    # Cycle 1: drive to unhealthy
    i = 0;
    while (i < UNHEALTHY_THRESHOLD) {
        prev = map_get(hmap6, hk6);
        failures = 1;
        if (prev != 0) { failures = load64(prev + 8) + 1; }
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_c = alloc(24);
        store64(hs_c, new_healthy);
        store64(hs_c + 8, failures);
        store64(hs_c + 16, "fail");
        map_set(hmap6, hk6, hs_c);
        i = i + 1;
    }
    assert_eq(load64(map_get(hmap6, hk6)), 0, "cycle1: unhealthy");

    # Recover
    var hs_rec = alloc(24);
    store64(hs_rec, 1);
    store64(hs_rec + 8, 0);
    store64(hs_rec + 16, 0);
    map_set(hmap6, hk6, hs_rec);

    # Cycle 2: drive to unhealthy again
    i = 0;
    while (i < UNHEALTHY_THRESHOLD) {
        prev = map_get(hmap6, hk6);
        failures = load64(prev + 8) + 1;
        new_healthy = 0;
        if (failures < UNHEALTHY_THRESHOLD) { new_healthy = 1; }
        var hs_c2 = alloc(24);
        store64(hs_c2, new_healthy);
        store64(hs_c2 + 8, failures);
        store64(hs_c2 + 16, "fail again");
        map_set(hmap6, hk6, hs_c2);
        i = i + 1;
    }
    assert_eq(load64(map_get(hmap6, hk6)), 0, "cycle2: unhealthy again");
    assert_eq(load64(map_get(hmap6, hk6) + 8), UNHEALTHY_THRESHOLD, "cycle2: count=threshold");

    # ================================================================
    # RATE LIMITER — sliding window RPM
    # ================================================================

    # Rate limiter: map of provider -> { max_rpm(8), count(8) }
    # Simplified: no time window in test, just count-based

    test_group("rate_limit_unconfigured");

    var rl_map = map_new();
    # Unconfigured provider always allowed
    assert_eq(map_get(rl_map, "unknown"), 0, "unconfigured returns 0 (no limit)");

    test_group("rate_limit_within");

    # Configure "test" with max_rpm=5
    # Rate limit record: max_rpm(8) current_count(8) = 16 bytes
    var rl_rec = alloc(16);
    store64(rl_rec, 5);     # max_rpm = 5
    store64(rl_rec + 8, 0); # current_count = 0
    map_set(rl_map, "test", rl_rec);

    # 5 requests within limit
    i = 0;
    var all_ok = 1;
    while (i < 5) {
        var rec = map_get(rl_map, "test");
        var count = load64(rec + 8);
        var max = load64(rec);
        if (count >= max) { all_ok = 0; }
        store64(rec + 8, count + 1);
        i = i + 1;
    }
    assert(all_ok == 1, "5 requests within limit allowed");

    test_group("rate_limit_exceeded");

    # 6th request should be rejected
    var rl_chk = map_get(rl_map, "test");
    var rl_chk_cnt = load64(rl_chk + 8);
    var rl_chk_max = load64(rl_chk);
    assert(rl_chk_cnt >= rl_chk_max, "6th request: count >= max_rpm");

    test_group("rate_limit_independent");

    # Different providers are independent
    var rl_a = alloc(16);
    store64(rl_a, 1);
    store64(rl_a + 8, 0);
    var rl_b = alloc(16);
    store64(rl_b, 1);
    store64(rl_b + 8, 0);
    map_set(rl_map, "prov_a", rl_a);
    map_set(rl_map, "prov_b", rl_b);

    # Use up prov_a's limit
    var ra = map_get(rl_map, "prov_a");
    store64(ra + 8, 1);

    # prov_b should still be allowed
    var rb = map_get(rl_map, "prov_b");
    assert(load64(rb + 8) < load64(rb), "prov_b still has capacity");
    assert(load64(ra + 8) >= load64(ra), "prov_a exhausted");

    # ================================================================
