    test_group("metrics");

    # Metrics record: requests(8) prompt_tokens(8) completion_tokens(8) = 24
    var metrics = alloc(24);
    store64(metrics, 0);
    store64(metrics + 8, 0);
    store64(metrics + 16, 0);

    # Record a request
    store64(metrics, load64(metrics) + 1);
    store64(metrics + 8, load64(metrics + 8) + 100);
    store64(metrics + 16, load64(metrics + 16) + 50);

    assert_eq(load64(metrics), 1, "metrics: 1 request");
    assert_eq(load64(metrics + 8), 100, "metrics: 100 prompt tokens");
    assert_eq(load64(metrics + 16), 50, "metrics: 50 completion tokens");

    # Record another
    store64(metrics, load64(metrics) + 1);
    store64(metrics + 8, load64(metrics + 8) + 200);
    store64(metrics + 16, load64(metrics + 16) + 75);

    assert_eq(load64(metrics), 2, "metrics: 2 requests");
    assert_eq(load64(metrics + 8), 300, "metrics: 300 prompt tokens");
    assert_eq(load64(metrics + 16), 125, "metrics: 125 completion tokens");

    # Gauge: providers configured
    var providers_gauge = 0;
    providers_gauge = 14;
    assert_eq(providers_gauge, 14, "metrics: gauge set to 14");

    # ================================================================
    # PROVIDER REGISTRY — register, dedup, lookup
    # ================================================================

    test_group("registry_empty");

    var reg = map_new();
    assert_eq(map_size(reg), 0, "registry starts empty");

    test_group("registry_register");

    # Register ollama
    map_set(reg, "ollama:localhost:11434", PROV_OLLAMA);
    assert_eq(map_size(reg), 1, "registry has 1 after register");
    assert_eq(map_get(reg, "ollama:localhost:11434"), PROV_OLLAMA, "registry: ollama found");

    test_group("registry_dedup");

    # Same key again — should not increase count
    map_set(reg, "ollama:localhost:11434", PROV_OLLAMA);
    assert_eq(map_size(reg), 1, "registry: dedup same key");

    test_group("registry_multiple");

    map_set(reg, "llamacpp:localhost:8080", PROV_LLAMACPP);
    assert_eq(map_size(reg), 2, "registry: 2 providers");

    # Different URL for same type = different entry
    map_set(reg, "ollama:other-host:11434", PROV_OLLAMA);
    assert_eq(map_size(reg), 3, "registry: 3 entries (same type diff url)");

    test_group("registry_get_missing");

    assert_eq(map_get(reg, "whisper:localhost:9999"), 0, "registry: missing returns 0");

    # ================================================================
    # ROUTER EXTRAS �� direct routing, cost tracker reset
    # ================================================================

    test_group("router_direct");

    var dir1 = route_new(PROV_OLLAMA, 1, "http://localhost");
    var dir2 = route_new(PROV_LLAMACPP, 2, "http://localhost2");
    var dir_routes = alloc(16);
    store64(dir_routes, dir1);
    store64(dir_routes + 8, dir2);
    var dir_rt = router_new(dir_routes, 2, STRAT_DIRECT);
    sel = router_select(dir_rt, "any-model");
    assert_eq(route_provider(sel), PROV_OLLAMA, "direct picks first");

