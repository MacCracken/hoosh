# hoosh.tcyr — hoosh gateway tests (Wave 1: pure logic, no I/O)
# Tests: error types, router, token budget, cache, cost tracker, audit chain, queue
#
# Run: cyrius test tests/hoosh.tcyr
#   or: cyrius build tests/hoosh.tcyr /tmp/hoosh_test && /tmp/hoosh_test

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/chrono.cyr"
include "lib/freelist.cyr"
include "lib/ct.cyr"
include "lib/sigil.cyr"
include "lib/toml.cyr"
include "lib/json.cyr"
include "lib/syscalls.cyr"
include "lib/assert.cyr"
include "lib/sakshi.cyr"
include "src/lib/logging.cyr"

# ================================================================
# Error types — error code + HTTP status mapping
# ================================================================

# Error codes (enum — zero gvar cost)
enum HooshErr {
    ERR_PROVIDER       = 1;
    ERR_MODEL_NOT_FOUND = 2;
    ERR_RATE_LIMITED   = 3;
    ERR_BUDGET_EXCEEDED = 4;
    ERR_NO_PROVIDER    = 5;
    ERR_TIMEOUT        = 6;
    ERR_CACHE          = 7;
    ERR_DLP_BLOCKED    = 8;
    ERR_HTTP           = 9;
    ERR_INTERNAL       = 10;
}

fn error_http_status(code) {
    if (code == ERR_MODEL_NOT_FOUND || code == ERR_NO_PROVIDER) { return 404; }
    if (code == ERR_RATE_LIMITED || code == ERR_BUDGET_EXCEEDED) { return 429; }
    if (code == ERR_TIMEOUT) { return 408; }
    if (code == ERR_DLP_BLOCKED) { return 403; }
    if (code == ERR_CACHE || code == ERR_PROVIDER) { return 500; }
    if (code == ERR_HTTP) { return 502; }
    return 500;
}

fn error_is_retryable(code) {
    if (code == ERR_RATE_LIMITED || code == ERR_TIMEOUT) { return 1; }
    if (code == ERR_PROVIDER || code == ERR_CACHE) { return 1; }
    return 0;
}

fn error_code_str(code) {
    if (code == ERR_MODEL_NOT_FOUND) { return "model_not_found"; }
    if (code == ERR_NO_PROVIDER) { return "no_provider"; }
    if (code == ERR_RATE_LIMITED) { return "rate_limit_exceeded"; }
    if (code == ERR_BUDGET_EXCEEDED) { return "budget_exceeded"; }
    if (code == ERR_TIMEOUT) { return "timeout"; }
    if (code == ERR_CACHE) { return "cache_error"; }
    if (code == ERR_PROVIDER) { return "provider_error"; }
    if (code == ERR_DLP_BLOCKED) { return "content_blocked"; }
    if (code == ERR_HTTP) { return "upstream_error"; }
    return "internal_error";
}

# ================================================================
# Provider types
# ================================================================

enum Provider {
    PROV_OLLAMA     = 0;
    PROV_LLAMACPP   = 1;
    PROV_SYNAPSE    = 2;
    PROV_LMSTUDIO   = 3;
    PROV_LOCALAI    = 4;
    PROV_OPENAI     = 5;
    PROV_ANTHROPIC  = 6;
    PROV_DEEPSEEK   = 7;
    PROV_MISTRAL    = 8;
    PROV_GOOGLE     = 9;
    PROV_GROQ       = 10;
    PROV_GROK       = 11;
    PROV_OPENROUTER = 12;
    PROV_WHISPER    = 13;
    PROV_COUNT      = 14;
}

fn provider_is_local(prov) {
    if (prov == PROV_OLLAMA) { return 1; }
    if (prov == PROV_LLAMACPP) { return 1; }
    if (prov == PROV_SYNAPSE) { return 1; }
    if (prov == PROV_LMSTUDIO) { return 1; }
    if (prov == PROV_LOCALAI) { return 1; }
    if (prov == PROV_WHISPER) { return 1; }
    return 0;
}

fn provider_name(prov) {
    if (prov == PROV_OLLAMA) { return "ollama"; }
    if (prov == PROV_LLAMACPP) { return "llamacpp"; }
    if (prov == PROV_SYNAPSE) { return "synapse"; }
    if (prov == PROV_LMSTUDIO) { return "lmstudio"; }
    if (prov == PROV_LOCALAI) { return "localai"; }
    if (prov == PROV_OPENAI) { return "openai"; }
    if (prov == PROV_ANTHROPIC) { return "anthropic"; }
    if (prov == PROV_DEEPSEEK) { return "deepseek"; }
    if (prov == PROV_MISTRAL) { return "mistral"; }
    if (prov == PROV_GOOGLE) { return "google"; }
    if (prov == PROV_GROQ) { return "groq"; }
    if (prov == PROV_GROK) { return "grok"; }
    if (prov == PROV_OPENROUTER) { return "openrouter"; }
    if (prov == PROV_WHISPER) { return "whisper"; }
    return "unknown";
}

# ----------------------------------------------------------------
# Per-provider token estimation (mirrors src/lib/compact.cyr).
# Chars-per-token ratio scaled by 10 (3.8 -> 38) since there are no floats.
# ----------------------------------------------------------------

var CHARS_PER_TOKEN_X10 = 40;

fn chars_per_token_x10(prov) {
    if (prov == PROV_OPENAI) { return 38; }
    if (prov == PROV_DEEPSEEK) { return 38; }
    if (prov == PROV_MISTRAL) { return 38; }
    if (prov == PROV_GROQ) { return 38; }
    if (prov == PROV_GROK) { return 38; }
    if (prov == PROV_OPENROUTER) { return 38; }
    if (prov == PROV_ANTHROPIC) { return 35; }
    if (prov == PROV_OLLAMA) { return 37; }
    if (prov == PROV_LLAMACPP) { return 37; }
    if (prov == PROV_LMSTUDIO) { return 37; }
    if (prov == PROV_LOCALAI) { return 37; }
    return 40;
}

fn estimate_tokens(messages, msg_len, cpt_x10) {
    var ratio = cpt_x10;
    if (ratio < 1) { ratio = CHARS_PER_TOKEN_X10; }
    return msg_len * 10 / ratio;
}

# ----------------------------------------------------------------
# Generic request header (mirrors src/lib/http_client.cyr).
# Used by the provider-lifecycle forwarders (GET/POST/DELETE).
# ----------------------------------------------------------------
fn _build_req_header(buf, method, path, host, body_len) {
    var pos = 0;
    memcpy(buf + pos, method, strlen(method)); pos = pos + strlen(method);
    store8(buf + pos, 32); pos = pos + 1;
    memcpy(buf + pos, path, strlen(path)); pos = pos + strlen(path);
    memcpy(buf + pos, " HTTP/1.0", 9); pos = pos + 9;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Host: ", 6); pos = pos + 6;
    memcpy(buf + pos, host, strlen(host)); pos = pos + strlen(host);
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Type: application/json", 29); pos = pos + 29;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Connection: close", 17); pos = pos + 17;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Length: ", 16); pos = pos + 16;
    var cl_buf = alloc(32);
    var cl_len = fmt_int_buf(body_len, cl_buf);
    memcpy(buf + pos, cl_buf, cl_len); pos = pos + cl_len;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    return pos;
}

# ================================================================
# Routing strategy
# ================================================================

enum Strategy {
    STRAT_PRIORITY       = 0;
    STRAT_ROUND_ROBIN    = 1;
    STRAT_LOWEST_LATENCY = 2;
    STRAT_DIRECT         = 3;
}

# ================================================================
# Provider route — heap-allocated struct
# Layout: provider(8) priority(8) patterns_ptr(8) patterns_count(8)
#         enabled(8) base_url(8) api_key(8) rate_limit_rpm(8)
# Total: 64 bytes
# ================================================================

enum RouteField {
    ROUTE_SIZE          = 64;
    ROUTE_PROVIDER      = 0;
    ROUTE_PRIORITY      = 8;
    ROUTE_PATTERNS      = 16;
    ROUTE_PATTERNS_N    = 24;
    ROUTE_ENABLED       = 32;
    ROUTE_BASE_URL      = 40;
    ROUTE_API_KEY       = 48;
    ROUTE_RATE_LIMIT    = 56;
}

fn route_new(prov, priority, base_url) {
    var r = alloc(ROUTE_SIZE);
    store64(r + ROUTE_PROVIDER, prov);
    store64(r + ROUTE_PRIORITY, priority);
    store64(r + ROUTE_PATTERNS, 0);
    store64(r + ROUTE_PATTERNS_N, 0);
    store64(r + ROUTE_ENABLED, 1);
    store64(r + ROUTE_BASE_URL, base_url);
    store64(r + ROUTE_API_KEY, 0);
    store64(r + ROUTE_RATE_LIMIT, 0);
    return r;
}

fn route_provider(r) { return load64(r + ROUTE_PROVIDER); }
fn route_priority(r) { return load64(r + ROUTE_PRIORITY); }
fn route_enabled(r) { return load64(r + ROUTE_ENABLED); }
fn route_base_url(r) { return load64(r + ROUTE_BASE_URL); }

fn route_set_enabled(r, v) { store64(r + ROUTE_ENABLED, v); return 0; }

# Set model patterns as array of cstrings
fn route_set_patterns(r, patterns, count) {
    store64(r + ROUTE_PATTERNS, patterns);
    store64(r + ROUTE_PATTERNS_N, count);
    return 0;
}

# Check if a route matches a model name
fn route_matches_model(r, model) {
    var count = load64(r + ROUTE_PATTERNS_N);
    if (count == 0) { return 1; }  # wildcard — matches all
    var arr = load64(r + ROUTE_PATTERNS);
    var i = 0;
    while (i < count) {
        var pattern = load64(arr + i * 8);
        var plen = strlen(pattern);
        # Check for trailing wildcard
        if (plen > 0 && load8(pattern + plen - 1) == 42) {
            # '*' = 42; prefix match
            if (memeq(model, pattern, plen - 1) == 1) { return 1; }
        } else {
            if (streq(model, pattern) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Find the first enabled route for a provider type (mirrors
# handlers.cyr _router_find_provider, parameterized by routes array).
fn _find_provider_route(routes, count, prov) {
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            if (route_provider(r) == prov) { return r; }
        }
        i = i + 1;
    }
    return 0;
}

# Exact-key response-cache key (mirror of handlers.cyr _cache_key).
fn _cache_key(model, body_ptr, body_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\n");
    var bb = alloc(body_len + 1);
    memcpy(bb, body_ptr, body_len);
    store8(bb + body_len, 0);
    str_builder_add_cstr(sb, bb);
    var s = str_builder_build(sb);
    return sha256_hex(str_cstr(s), str_len(s));
}

fn _ckey(model, body) {
    return _cache_key(model, body, strlen(body));
}

# Canonical warming body (mirror of handlers.cyr _warming_body).
fn _warming_body(model, prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"messages\":[{\"role\":\"user\",\"content\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    return str_builder_build(sb);
}

# ================================================================
# DLP scanner — mirror of src/lib/dlp.cyr (PII/secret byte matchers).
# Enabled by default here so the matchers are exercised directly.
# ================================================================

enum DlpClass {
    CLASS_PUBLIC       = 0;
    CLASS_INTERNAL     = 1;
    CLASS_CONFIDENTIAL = 2;
    CLASS_RESTRICTED   = 3;
}

var _dlp_enabled = 1;
var _dlp_default_level = 0;

fn _dlp_is_digit(c) {
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

fn _dlp_is_upper(c) {
    if (c >= 65 && c <= 90) { return 1; }
    return 0;
}

fn _dlp_is_lower(c) {
    if (c >= 97 && c <= 122) { return 1; }
    return 0;
}

fn _dlp_is_alpha(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_lower(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_alnum(c) {
    if (_dlp_is_alpha(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_upper_alnum(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_word(c) {
    if (_dlp_is_alnum(c) == 1 || c == 95) { return 1; }
    return 0;
}

fn _dlp_bound_before(t, i) {
    if (i == 0) { return 1; }
    if (_dlp_is_word(load8(t + i - 1)) == 0) { return 1; }
    return 0;
}

fn _dlp_bound_after(t, e, len) {
    if (e >= len) { return 1; }
    if (_dlp_is_word(load8(t + e)) == 0) { return 1; }
    return 0;
}

fn _dlp_digits_n(t, i, len, n) {
    if (i + n > len) { return 0; }
    var k = 0;
    while (k < n) {
        if (_dlp_is_digit(load8(t + i + k)) == 0) { return 0; }
        k = k + 1;
    }
    return 1;
}

fn _dlp_match_ssn_at(t, i, len) {
    if (i + 11 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (load8(t + i + 3) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 2) == 0) { return 0; }
    if (load8(t + i + 6) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 7, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 11, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_phone_sep(c) {
    if (c == 45 || c == 46 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_phone_at(t, i, len) {
    if (i + 12 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 3)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 7)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 8, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 12, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_cc_sep(c) {
    if (c == 45 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_cc_at(t, i, len) {
    if (_dlp_digits_n(t, i, len, 4) == 0) { return 0; }
    var p = i + 4;
    var g = 1;
    while (g < 4) {
        if (p < len && _dlp_is_cc_sep(load8(t + p)) == 1) { p = p + 1; }
        if (_dlp_digits_n(t, p, len, 4) == 0) { return 0; }
        p = p + 4;
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_ipv4_group(t, p, len) {
    if (p >= len) { return 0 - 1; }
    if (_dlp_is_digit(load8(t + p)) == 0) { return 0 - 1; }
    var n = 1;
    p = p + 1;
    while (n < 3 && p < len && _dlp_is_digit(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    return p;
}

fn _dlp_match_ipv4_at(t, i, len) {
    var p = _dlp_ipv4_group(t, i, len);
    if (p < 0) { return 0; }
    var g = 1;
    while (g < 4) {
        if (p >= len) { return 0; }
        if (load8(t + p) != 46) { return 0; }
        p = p + 1;
        p = _dlp_ipv4_group(t, p, len);
        if (p < 0) { return 0; }
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_apikey_prefix(t, i, len) {
    if (i + 3 <= len) {
        var c0 = load8(t + i);
        if (c0 == 115 || c0 == 112) {
            if (load8(t + i + 1) == 107 && load8(t + i + 2) == 45) {
                return i + 3;
            }
        }
    }
    if (i + 6 <= len) {
        if (load8(t + i) == 97 && load8(t + i + 1) == 112 && load8(t + i + 2) == 105) {
            var p = i + 3;
            if (p < len && (load8(t + p) == 95 || load8(t + p) == 45)) { p = p + 1; }
            if (p + 3 <= len) {
                if (load8(t + p) == 107 && load8(t + p + 1) == 101 && load8(t + p + 2) == 121) {
                    p = p + 3;
                    var sc = 0;
                    var more = 1;
                    while (more == 1 && sc < 5 && p < len) {
                        var sep = load8(t + p);
                        if (sep == 61 || sep == 58 || sep == 32) {
                            p = p + 1;
                            sc = sc + 1;
                        } else {
                            more = 0;
                        }
                    }
                    if (sc >= 1) { return p; }
                }
            }
        }
    }
    return 0 - 1;
}

fn _dlp_match_apikey_at(t, i, len) {
    var p = _dlp_apikey_prefix(t, i, len);
    if (p < 0) { return 0; }
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 20) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_match_aws_at(t, i, len) {
    if (i + 20 > len) { return 0; }
    if (load8(t + i) != 65 || load8(t + i + 1) != 75) { return 0; }
    if (load8(t + i + 2) != 73 || load8(t + i + 3) != 65) { return 0; }
    var k = 0;
    while (k < 16) {
        if (_dlp_is_upper_alnum(load8(t + i + 4 + k)) == 0) { return 0; }
        k = k + 1;
    }
    if (_dlp_bound_after(t, i + 20, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_gh_third(c) {
    if (c == 112 || c == 111 || c == 117 || c == 115 || c == 114) { return 1; }
    return 0;
}

fn _dlp_match_github_at(t, i, len) {
    if (i + 4 > len) { return 0; }
    if (load8(t + i) != 103 || load8(t + i + 1) != 104) { return 0; }
    if (_dlp_is_gh_third(load8(t + i + 2)) == 0) { return 0; }
    if (load8(t + i + 3) != 95) { return 0; }
    var p = i + 4;
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 36) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_email_local(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 95 || c == 37 || c == 43 || c == 45) { return 1; }
    return 0;
}

fn _dlp_is_email_domain(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 45) { return 1; }
    return 0;
}

fn _dlp_has_email(t, len) {
    var i = 0;
    while (i < len) {
        if (load8(t + i) == 64) {
            if (i >= 1 && _dlp_is_email_local(load8(t + i - 1)) == 1) {
                var p = i + 1;
                var seen = 0;
                while (p < len && _dlp_is_email_domain(load8(t + p)) == 1) {
                    if (load8(t + p) == 46) {
                        if (seen == 1) {
                            var q = p + 1;
                            var ac = 0;
                            while (q < len && _dlp_is_alpha(load8(t + q)) == 1) {
                                ac = ac + 1;
                                q = q + 1;
                            }
                            if (ac >= 2) { return 1; }
                        }
                    } else {
                        seen = 1;
                    }
                    p = p + 1;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn dlp_scan_level(t, len) {
    if (_dlp_enabled == 0) { return _dlp_default_level; }
    if (len == 0) { return _dlp_default_level; }
    var level = _dlp_default_level;
    var i = 0;
    while (i < len) {
        if (_dlp_bound_before(t, i) == 1) {
            if (_dlp_match_ssn_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_cc_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_apikey_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_aws_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_github_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_phone_at(t, i, len) == 1) {
                if (level < CLASS_CONFIDENTIAL) { level = CLASS_CONFIDENTIAL; }
            }
            if (_dlp_match_ipv4_at(t, i, len) == 1) {
                if (level < CLASS_INTERNAL) { level = CLASS_INTERNAL; }
            }
        }
        i = i + 1;
    }
    if (level < CLASS_INTERNAL) {
        if (_dlp_has_email(t, len) == 1) { level = CLASS_INTERNAL; }
    }
    return level;
}

# Scan a cstr literal and return its classification level.
fn _dlp_test(s) {
    var n = strlen(s);
    var b = alloc(n + 1);
    memcpy(b, s, n);
    return dlp_scan_level(b, n);
}

# ================================================================
# Remote transport helpers — mirror of src/lib/provider.cyr. Pure
# string/parse logic for the https:// (sandhi/TLS) forward path.
# ================================================================

fn route_is_remote(route) {
    var base = route_base_url(route);
    if (base == 0) { return 0; }
    if (memeq(base, "https", 5) == 1) { return 1; }
    return 0;
}

fn _provider_path(route) {
    if (route_provider(route) == PROV_OLLAMA) { return "/api/chat"; }
    if (route_provider(route) == PROV_ANTHROPIC) { return "/v1/messages"; }
    return "/v1/chat/completions";
}

# Whitespace-tolerant JSON field scanners — mirror of src/lib/provider.cyr.
fn _json_value_pos(body, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(body + i) == 34) {
            if (memeq(body + i + 1, key, keylen) == 1) {
                if (load8(body + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(body + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 9) { j = j + 1; continue; }
                        if (c == 10) { j = j + 1; continue; }
                        if (c == 13) { j = j + 1; continue; }
                        break;
                    }
                    if (j < len) {
                        if (load8(body + j) == 58) {
                            j = j + 1;
                            while (j < len) {
                                var d = load8(body + j);
                                if (d == 32) { j = j + 1; continue; }
                                if (d == 9) { j = j + 1; continue; }
                                if (d == 10) { j = j + 1; continue; }
                                if (d == 13) { j = j + 1; continue; }
                                break;
                            }
                            return j;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

fn _json_extract_str(body, len, key, keylen) {
    if (body == 0) { return ""; }
    if (len == 0) { return ""; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return ""; }
    if (p >= len) { return ""; }
    if (load8(body + p) != 34) { return ""; }
    var start = p + 1;
    var j = start;
    while (j < len) {
        if (load8(body + j) == 34) {
            if (load8(body + j - 1) == 92) { j = j + 1; continue; }
            break;
        }
        j = j + 1;
    }
    var tlen = j - start;
    var text = alloc(tlen + 1);
    memcpy(text, body + start, tlen);
    store8(text + tlen, 0);
    return text;
}

fn _json_extract_int(body, len, key, keylen) {
    if (body == 0) { return 0; }
    if (len == 0) { return 0; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return 0; }
    return atoi(body + p);
}

fn ollama_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "content", 7);
}

fn anthropic_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "text", 4);
}

fn extract_anthropic_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "input_tokens", 12);
    var comp = _json_extract_int(body, blen, "output_tokens", 13);
    return prompt * 0x100000000 + comp;
}

fn _provider_url(base, path) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, path);
    return str_cstr(str_builder_build(sb));
}

fn _bearer_value(key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Bearer ");
    str_builder_add_cstr(sb, key);
    return str_cstr(str_builder_build(sb));
}

fn extract_openai_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "prompt_tokens", 13);
    var comp = _json_extract_int(body, blen, "completion_tokens", 17);
    return prompt * 0x100000000 + comp;
}

# Anthropic system-message hoist helpers — mirror of src/lib/provider.cyr.
fn _json_obj_str_field(p, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(p + i) == 34) {
            if (memeq(p + i + 1, key, keylen) == 1) {
                if (load8(p + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(p + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 58) { j = j + 1; continue; }
                        break;
                    }
                    if (j >= len) { return 0; }
                    if (load8(p + j) != 34) { return 0; }
                    j = j + 1;
                    var vs = j;
                    while (j < len) {
                        if (load8(p + j) == 34) {
                            if (load8(p + j - 1) == 92) { j = j + 1; continue; }
                            break;
                        }
                        j = j + 1;
                    }
                    var r = alloc(16);
                    store64(r, p + vs);
                    store64(r + 8, j - vs);
                    return r;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn _obj_is_system(p, len) {
    var rf = _json_obj_str_field(p, len, "role", 4);
    if (rf == 0) { return 0; }
    if (load64(rf + 8) != 6) { return 0; }
    if (memeq(load64(rf), "system", 6) == 1) { return 1; }
    return 0;
}

fn _json_obj_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123) { depth = depth + 1; }
            if (ch == 91) { depth = depth + 1; }
            if (ch == 93) { depth = depth - 1; }
            if (ch == 125) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

fn _build_anthropic_body_x(model, messages_raw, messages_len, stream) {
    var sys_sb = str_builder_new();
    var msgs_sb = str_builder_new();
    str_builder_putc(msgs_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var keep = 1;
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
                keep = 0;
            }
        }
        if (keep == 1) {
            if (first == 0) { str_builder_putc(msgs_sb, ','); }
            str_builder_add(msgs_sb, str_new(messages_raw + obj_start, obj_len));
            first = 0;
        }
        i = obj_end;
    }
    str_builder_putc(msgs_sb, ']');

    var body = str_builder_new();
    str_builder_add_cstr(body, "{\"model\":\"");
    str_builder_add_cstr(body, model);
    str_builder_add_cstr(body, "\",\"max_tokens\":4096,");
    if (stream == 1) {
        str_builder_add_cstr(body, "\"stream\":true,");
    }
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"system\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\",");
    }
    str_builder_add_cstr(body, "\"messages\":");
    str_builder_add(body, str_builder_build(msgs_sb));
    str_builder_putc(body, '}');
    return str_cstr(str_builder_build(body));
}

fn _build_anthropic_body(model, messages_raw, messages_len) {
    return _build_anthropic_body_x(model, messages_raw, messages_len, 0);
}

# Gemini shaping helpers — mirror of src/lib/provider.cyr.
fn _build_gemini_body(messages_raw, messages_len) {
    var sys_sb = str_builder_new();
    var contents_sb = str_builder_new();
    str_builder_putc(contents_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
            }
        } else {
            if (cf != 0) {
                var role = "user";
                var rf = _json_obj_str_field(messages_raw + obj_start, obj_len, "role", 4);
                if (rf != 0) {
                    if (load64(rf + 8) == 9) {
                        if (memeq(load64(rf), "assistant", 9) == 1) { role = "model"; }
                    }
                }
                if (first == 0) { str_builder_putc(contents_sb, ','); }
                str_builder_add_cstr(contents_sb, "{\"role\":\"");
                str_builder_add_cstr(contents_sb, role);
                str_builder_add_cstr(contents_sb, "\",\"parts\":[{\"text\":\"");
                str_builder_add(contents_sb, str_new(load64(cf), load64(cf + 8)));
                str_builder_add_cstr(contents_sb, "\"}]}");
                first = 0;
            }
        }
        i = obj_end;
    }
    str_builder_putc(contents_sb, ']');

    var body = str_builder_new();
    str_builder_putc(body, '{');
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"systemInstruction\":{\"parts\":[{\"text\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\"}]},");
    }
    str_builder_add_cstr(body, "\"contents\":");
    str_builder_add(body, str_builder_build(contents_sb));
    str_builder_putc(body, '}');
    return str_cstr(str_builder_build(body));
}

fn gemini_extract_text(resp_body, resp_len) {
    return anthropic_extract_text(resp_body, resp_len);
}

fn extract_gemini_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "promptTokenCount", 16);
    var comp = _json_extract_int(body, blen, "candidatesTokenCount", 20);
    return prompt * 0x100000000 + comp;
}

fn _gemini_url(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":generateContent");
    if (key != 0) {
        str_builder_add_cstr(sb, "?key=");
        str_builder_add_cstr(sb, key);
    }
    return str_cstr(str_builder_build(sb));
}

fn _gemini_url_stream(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":streamGenerateContent?alt=sse");
    if (key != 0) {
        str_builder_add_cstr(sb, "&key=");
        str_builder_add_cstr(sb, key);
    }
    return str_cstr(str_builder_build(sb));
}

# ================================================================
# Router — priority-sorted route list + selection
# Layout: routes_ptr(8) route_count(8) strategy(8) rr_index(8) latencies_ptr(8)
# Total: 40 bytes
# ================================================================

enum RouterField {
    ROUTER_SIZE      = 40;
    ROUTER_ROUTES    = 0;
    ROUTER_COUNT     = 8;
    ROUTER_STRATEGY  = 16;
    ROUTER_RR_IDX    = 24;
    ROUTER_LATENCIES = 32;
}

fn router_new(routes, count, strategy) {
    var rt = alloc(ROUTER_SIZE);
    store64(rt + ROUTER_ROUTES, routes);
    store64(rt + ROUTER_COUNT, count);
    store64(rt + ROUTER_STRATEGY, strategy);
    store64(rt + ROUTER_RR_IDX, 0);
    store64(rt + ROUTER_LATENCIES, map_new());
    # Sort by priority (insertion sort — small N)
    var i = 1;
    while (i < count) {
        var key = load64(routes + i * 8);
        var kp = route_priority(key);
        var j = i - 1;
        while (j >= 0) {
            if (route_priority(load64(routes + j * 8)) <= kp) { break; }
            store64(routes + (j + 1) * 8, load64(routes + j * 8));
            j = j - 1;
        }
        store64(routes + (j + 1) * 8, key);
        i = i + 1;
    }
    return rt;
}

# Select best provider for a model. Returns route ptr or 0 (not found).
fn router_select(rt, model) {
    var routes = load64(rt + ROUTER_ROUTES);
    var count = load64(rt + ROUTER_COUNT);
    var strategy = load64(rt + ROUTER_STRATEGY);

    # Build candidates list (enabled + matches model)
    var cand = alloc(count * 8);
    var cn = 0;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1 && route_matches_model(r, model) == 1) {
            store64(cand + cn * 8, r);
            cn = cn + 1;
        }
        i = i + 1;
    }

    if (cn == 0) { return 0; }

    if (strategy == STRAT_PRIORITY || strategy == STRAT_DIRECT) {
        return load64(cand);
    }

    if (strategy == STRAT_ROUND_ROBIN) {
        var idx = load64(rt + ROUTER_RR_IDX);
        store64(rt + ROUTER_RR_IDX, idx + 1);
        return load64(cand + (idx % cn) * 8);
    }

    if (strategy == STRAT_LOWEST_LATENCY) {
        var lat_map = load64(rt + ROUTER_LATENCIES);
        var best = load64(cand);
        var best_lat = 0x7FFFFFFFFFFFFFFF;
        var j = 0;
        while (j < cn) {
            var c = load64(cand + j * 8);
            var url = route_base_url(c);
            var lat = map_get(lat_map, url);
            if (lat == 0) { lat = 0x7FFFFFFFFFFFFFFF; }
            if (lat < best_lat) {
                best = c;
                best_lat = lat;
            }
            j = j + 1;
        }
        return best;
    }

    return load64(cand);
}

fn router_report_latency(rt, base_url, latency_ms) {
    var lat_map = load64(rt + ROUTER_LATENCIES);
    var old = map_get(lat_map, base_url);
    if (old == 0) {
        map_set(lat_map, base_url, latency_ms);
    } else {
        # EMA: (old * 7 + new * 3) / 10
        var avg = (old * 7 + latency_ms * 3) / 10;
        map_set(lat_map, base_url, avg);
    }
    return 0;
}

# ================================================================
# Token pool
# Layout: name(8) capacity(8) used(8) reserved(8)
# Total: 32 bytes
# ================================================================

enum PoolField {
    POOL_SIZE     = 32;
    POOL_NAME     = 0;
    POOL_CAPACITY = 8;
    POOL_USED     = 16;
    POOL_RESERVED = 24;
}

fn pool_new(name, capacity) {
    var p = alloc(POOL_SIZE);
    store64(p + POOL_NAME, name);
    store64(p + POOL_CAPACITY, capacity);
    store64(p + POOL_USED, 0);
    store64(p + POOL_RESERVED, 0);
    return p;
}

fn pool_name(p) { return load64(p + POOL_NAME); }
fn pool_capacity(p) { return load64(p + POOL_CAPACITY); }
fn pool_used(p) { return load64(p + POOL_USED); }
fn pool_reserved(p) { return load64(p + POOL_RESERVED); }

fn pool_available(p) {
    var cap = load64(p + POOL_CAPACITY);
    var used = load64(p + POOL_USED);
    var resv = load64(p + POOL_RESERVED);
    var taken = used + resv;
    if (taken > cap) { return 0; }
    return cap - taken;
}

fn pool_can_reserve(p, tokens) {
    if (pool_available(p) >= tokens) { return 1; }
    return 0;
}

fn pool_reserve(p, tokens) {
    if (pool_can_reserve(p, tokens) == 0) { return 0; }
    store64(p + POOL_RESERVED, load64(p + POOL_RESERVED) + tokens);
    return 1;
}

fn pool_commit(p, reserved, actual) {
    var resv = load64(p + POOL_RESERVED);
    if (resv >= reserved) {
        store64(p + POOL_RESERVED, resv - reserved);
    } else {
        store64(p + POOL_RESERVED, 0);
    }
    store64(p + POOL_USED, load64(p + POOL_USED) + actual);
    return 0;
}

fn pool_release(p, tokens) {
    var resv = load64(p + POOL_RESERVED);
    if (resv >= tokens) {
        store64(p + POOL_RESERVED, resv - tokens);
    } else {
        store64(p + POOL_RESERVED, 0);
    }
    return 0;
}

# ================================================================
# Token budget — hashmap of pools by name
# ================================================================

fn budget_new() { return map_new(); }

fn budget_add_pool(bgt, p) {
    map_set(bgt, pool_name(p), p);
    return 0;
}

fn budget_get_pool(bgt, name) {
    return map_get(bgt, name);
}

fn budget_check(bgt, name, tokens) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    return pool_can_reserve(p, tokens);
}

fn budget_reserve(bgt, name, tokens) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    return pool_reserve(p, tokens);
}

fn budget_report(bgt, name, reserved, actual) {
    var p = map_get(bgt, name);
    if (p == 0) { return 0; }
    pool_commit(p, reserved, actual);
    return 0;
}

# ================================================================
# Cache — hashmap with TTL (simplified: no TTL eviction in test,
#          tests TTL separately via chrono timestamps)
# Layout: entries(8) max_entries(8) hits(8) misses(8) evictions(8) enabled(8)
# Total: 48 bytes
# ================================================================

enum CacheField {
    CACHE_SIZE        = 48;
    CACHE_ENTRIES     = 0;
    CACHE_MAX         = 8;
    CACHE_HITS        = 16;
    CACHE_MISSES      = 24;
    CACHE_EVICTIONS   = 32;
    CACHE_ENABLED     = 40;
}

fn cache_new(max_entries, enabled) {
    var c = alloc(CACHE_SIZE);
    store64(c + CACHE_ENTRIES, map_new());
    store64(c + CACHE_MAX, max_entries);
    store64(c + CACHE_HITS, 0);
    store64(c + CACHE_MISSES, 0);
    store64(c + CACHE_EVICTIONS, 0);
    store64(c + CACHE_ENABLED, enabled);
    return c;
}

fn cache_get(c, key) {
    if (load64(c + CACHE_ENABLED) == 0) { return 0; }
    var entries = load64(c + CACHE_ENTRIES);
    var val = map_get(entries, key);
    if (val == 0) {
        store64(c + CACHE_MISSES, load64(c + CACHE_MISSES) + 1);
        return 0;
    }
    store64(c + CACHE_HITS, load64(c + CACHE_HITS) + 1);
    return val;
}

fn cache_insert(c, key, value) {
    if (load64(c + CACHE_ENABLED) == 0) { return 0; }
    var entries = load64(c + CACHE_ENTRIES);
    var max = load64(c + CACHE_MAX);
    # Evict if at capacity (simple: just count eviction, hashmap handles it)
    if (map_count(entries) >= max) {
        store64(c + CACHE_EVICTIONS, load64(c + CACHE_EVICTIONS) + 1);
    }
    map_set(entries, key, value);
    return 0;
}

fn cache_len(c) {
    return map_count(load64(c + CACHE_ENTRIES));
}

fn cache_clear(c) {
    store64(c + CACHE_ENTRIES, map_new());
    return 0;
}

fn cache_hits(c) { return load64(c + CACHE_HITS); }
fn cache_misses(c) { return load64(c + CACHE_MISSES); }
fn cache_evictions(c) { return load64(c + CACHE_EVICTIONS); }

# ================================================================
# Cost tracker — pricing lookup + accumulation
# ================================================================

# Pricing in microdollars per million tokens (avoids f64)
# e.g. $2.50/M = 2500000 microdollars/M
enum Pricing {
    # OpenAI
    PRICE_GPT4O_IN       = 2500000;
    PRICE_GPT4O_OUT      = 10000000;
    PRICE_GPT4O_MINI_IN  = 150000;
    PRICE_GPT4O_MINI_OUT = 600000;
    # Anthropic
    PRICE_OPUS_IN        = 15000000;
    PRICE_OPUS_OUT       = 75000000;
    PRICE_SONNET_IN      = 3000000;
    PRICE_SONNET_OUT     = 15000000;
    # DeepSeek
    PRICE_DSCHAT_IN      = 270000;
    PRICE_DSCHAT_OUT     = 1100000;
    # Grok
    PRICE_GROK3_IN       = 3000000;
    PRICE_GROK3_OUT      = 15000000;
    # Local providers
    PRICE_LOCAL_IN       = 0;
    PRICE_LOCAL_OUT      = 0;
}

# Lookup pricing: returns (input_microdollars_per_M, output_microdollars_per_M)
# packed as: input * 0x100000000 + output (since both fit in 32 bits)
fn pricing_lookup(model, prov) {
    if (provider_is_local(prov) == 1) { return 0; }
    if (streq(model, "gpt-4o") == 1) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    if (streq(model, "gpt-4o-mini") == 1) { return PRICE_GPT4O_MINI_IN * 0x100000000 + PRICE_GPT4O_MINI_OUT; }
    if (streq(model, "claude-opus-4") == 1) { return PRICE_OPUS_IN * 0x100000000 + PRICE_OPUS_OUT; }
    if (streq(model, "claude-sonnet-4") == 1) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (streq(model, "deepseek-chat") == 1) { return PRICE_DSCHAT_IN * 0x100000000 + PRICE_DSCHAT_OUT; }
    if (streq(model, "grok-3") == 1) { return PRICE_GROK3_IN * 0x100000000 + PRICE_GROK3_OUT; }
    # Prefix match — check if model starts with a known base
    if (memeq(model, "claude-sonnet-4", 15) == 1) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (memeq(model, "claude-opus-4", 13) == 1) { return PRICE_OPUS_IN * 0x100000000 + PRICE_OPUS_OUT; }
    if (memeq(model, "gpt-4o", 6) == 1) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    # Fallback per provider
    if (prov == PROV_ANTHROPIC) { return PRICE_SONNET_IN * 0x100000000 + PRICE_SONNET_OUT; }
    if (prov == PROV_OPENAI) { return PRICE_GPT4O_IN * 0x100000000 + PRICE_GPT4O_OUT; }
    if (prov == PROV_DEEPSEEK) { return PRICE_DSCHAT_IN * 0x100000000 + PRICE_DSCHAT_OUT; }
    return 0;
}

fn pricing_input(packed) { return packed / 0x100000000; }
fn pricing_output(packed) { return packed % 0x100000000; }

# Cost for a request in microdollars
fn cost_calculate(model, prov, prompt_tokens, completion_tokens) {
    var p = pricing_lookup(model, prov);
    var inp = pricing_input(p);
    var out = pricing_output(p);
    # cost = tokens * price_per_M / 1_000_000
    var cost = prompt_tokens * inp / 1000000 + completion_tokens * out / 1000000;
    return cost;
}

# Cost tracker — hashmap of provider:url -> record
# Record layout: total_input(8) total_output(8) total_cost(8) requests(8) = 32 bytes
enum CostField {
    COST_REC_SIZE   = 32;
    COST_REC_INPUT  = 0;
    COST_REC_OUTPUT = 8;
    COST_REC_COST   = 16;
    COST_REC_REQS   = 24;
}

fn cost_tracker_new() { return map_new(); }

fn cost_tracker_record(tracker, prov, model, prompt_tok, comp_tok) {
    var cost = cost_calculate(model, prov, prompt_tok, comp_tok);
    var pname = provider_name(prov);
    var rec = map_get(tracker, pname);
    if (rec == 0) {
        rec = alloc(COST_REC_SIZE);
        store64(rec + COST_REC_INPUT, 0);
        store64(rec + COST_REC_OUTPUT, 0);
        store64(rec + COST_REC_COST, 0);
        store64(rec + COST_REC_REQS, 0);
        map_set(tracker, pname, rec);
    }
    store64(rec + COST_REC_INPUT, load64(rec + COST_REC_INPUT) + prompt_tok);
    store64(rec + COST_REC_OUTPUT, load64(rec + COST_REC_OUTPUT) + comp_tok);
    store64(rec + COST_REC_COST, load64(rec + COST_REC_COST) + cost);
    store64(rec + COST_REC_REQS, load64(rec + COST_REC_REQS) + 1);
    return cost;
}

# ================================================================
# Queue — simple priority queue (5 tiers)
# Uses a vec per tier, dequeue scans highest first
# ================================================================

enum QueuePriority {
    PRI_CRITICAL   = 0;
    PRI_HIGH       = 1;
    PRI_NORMAL     = 2;
    PRI_LOW        = 3;
    PRI_BACKGROUND = 4;
    PRI_TIERS      = 5;
}

# Queue item: model(8) pool(8) request_id(8) = 24 bytes
enum QItem {
    QITEM_SIZE   = 24;
    QITEM_MODEL  = 0;
    QITEM_POOL   = 8;
    QITEM_ID     = 16;
}

fn queue_new() {
    # 5 tiers, each a vec
    var q = alloc(PRI_TIERS * 8);
    var i = 0;
    while (i < PRI_TIERS) {
        store64(q + i * 8, vec_new());
        i = i + 1;
    }
    return q;
}

fn queue_enqueue(q, model, pool, request_id, priority) {
    var item = alloc(QITEM_SIZE);
    store64(item + QITEM_MODEL, model);
    store64(item + QITEM_POOL, pool);
    store64(item + QITEM_ID, request_id);
    var tier = load64(q + priority * 8);
    vec_push(tier, item);
    return 0;
}

# Returns item ptr or 0 if empty
fn queue_dequeue(q) {
    var i = 0;
    while (i < PRI_TIERS) {
        var tier = load64(q + i * 8);
        if (vec_len(tier) > 0) {
            var item = vec_get(tier, 0);
            vec_remove(tier, 0);
            return item;
        }
        i = i + 1;
    }
    return 0;
}

fn queue_len(q) {
    var total = 0;
    var i = 0;
    while (i < PRI_TIERS) {
        total = total + vec_len(load64(q + i * 8));
        i = i + 1;
    }
    return total;
}

fn queue_is_empty(q) {
    if (queue_len(q) == 0) { return 1; }
    return 0;
}

# Audit entry layout
enum AuditField {
    AE_SIZE = 64;
    AE_ID = 0; AE_EVENT = 8; AE_MSG = 16; AE_PROV = 24;
    AE_MODEL = 32; AE_HASH = 40; AE_SIG = 48; AE_PREV = 56;
}

# ================================================================
# TESTS
# ================================================================

fn main() {
    alloc_init();

    # ── Error types ──────────────────────────────────────────────
    test_group("error_types");

    assert_eq(error_http_status(ERR_MODEL_NOT_FOUND), 404, "model_not_found -> 404");
    assert_eq(error_http_status(ERR_NO_PROVIDER), 404, "no_provider -> 404");
    assert_eq(error_http_status(ERR_RATE_LIMITED), 429, "rate_limited -> 429");
    assert_eq(error_http_status(ERR_BUDGET_EXCEEDED), 429, "budget_exceeded -> 429");
    assert_eq(error_http_status(ERR_TIMEOUT), 408, "timeout -> 408");
    assert_eq(error_http_status(ERR_PROVIDER), 500, "provider -> 500");
    assert_eq(error_http_status(ERR_CACHE), 500, "cache -> 500");
    assert_eq(error_http_status(ERR_DLP_BLOCKED), 403, "dlp -> 403");
    assert_eq(error_http_status(ERR_HTTP), 502, "http -> 502");
    assert_eq(error_http_status(ERR_INTERNAL), 500, "internal -> 500");

    assert(error_is_retryable(ERR_RATE_LIMITED) == 1, "rate_limited retryable");
    assert(error_is_retryable(ERR_TIMEOUT) == 1, "timeout retryable");
    assert(error_is_retryable(ERR_PROVIDER) == 1, "provider retryable");
    assert(error_is_retryable(ERR_MODEL_NOT_FOUND) == 0, "model_not_found not retryable");
    assert(error_is_retryable(ERR_BUDGET_EXCEEDED) == 0, "budget not retryable");
    assert(error_is_retryable(ERR_DLP_BLOCKED) == 0, "dlp not retryable");

    assert_streq(error_code_str(ERR_MODEL_NOT_FOUND), "model_not_found", "code_str model");
    assert_streq(error_code_str(ERR_NO_PROVIDER), "no_provider", "code_str no_prov");
    assert_streq(error_code_str(ERR_RATE_LIMITED), "rate_limit_exceeded", "code_str rate");
    assert_streq(error_code_str(ERR_BUDGET_EXCEEDED), "budget_exceeded", "code_str budget");
    assert_streq(error_code_str(ERR_TIMEOUT), "timeout", "code_str timeout");
    assert_streq(error_code_str(ERR_INTERNAL), "internal_error", "code_str internal");

    # ── Provider types ───────────────────────────────────────────
    test_group("provider_types");

    assert_eq(PROV_COUNT, 14, "14 provider types");
    assert(provider_is_local(PROV_OLLAMA) == 1, "ollama is local");
    assert(provider_is_local(PROV_LLAMACPP) == 1, "llamacpp is local");
    assert(provider_is_local(PROV_SYNAPSE) == 1, "synapse is local");
    assert(provider_is_local(PROV_LMSTUDIO) == 1, "lmstudio is local");
    assert(provider_is_local(PROV_LOCALAI) == 1, "localai is local");
    assert(provider_is_local(PROV_WHISPER) == 1, "whisper is local");
    assert(provider_is_local(PROV_OPENAI) == 0, "openai is remote");
    assert(provider_is_local(PROV_ANTHROPIC) == 0, "anthropic is remote");
    assert(provider_is_local(PROV_DEEPSEEK) == 0, "deepseek is remote");
    assert(provider_is_local(PROV_GROQ) == 0, "groq is remote");

    assert_streq(provider_name(PROV_OLLAMA), "ollama", "name ollama");
    assert_streq(provider_name(PROV_OPENAI), "openai", "name openai");
    assert_streq(provider_name(PROV_ANTHROPIC), "anthropic", "name anthropic");

    # ── Router: priority routing ──────────────────────────────────
    test_group("router_priority");

    var pats1 = alloc(8);
    store64(pats1, "llama*");
    var pats2 = alloc(8);
    store64(pats2, "gpt-*");

    var r1 = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_patterns(r1, pats1, 1);
    var r2 = route_new(PROV_OPENAI, 2, "https://api.openai.com");
    route_set_patterns(r2, pats2, 1);

    var routes = alloc(16);
    store64(routes, r1);
    store64(routes + 8, r2);

    var rt = router_new(routes, 2, STRAT_PRIORITY);

    var sel = router_select(rt, "llama3");
    assert(sel != 0, "priority: llama3 found");
    assert_eq(route_provider(sel), PROV_OLLAMA, "priority: llama3 -> ollama");

    sel = router_select(rt, "gpt-4o");
    assert(sel != 0, "priority: gpt-4o found");
    assert_eq(route_provider(sel), PROV_OPENAI, "priority: gpt-4o -> openai");

    sel = router_select(rt, "claude-sonnet");
    assert_eq(sel, 0, "priority: claude-sonnet not found");

    # ── Router: wildcard route ────────────────────────────────────
    test_group("router_wildcard");

    var wr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    var wroutes = alloc(8);
    store64(wroutes, wr);
    var wrt = router_new(wroutes, 1, STRAT_PRIORITY);
    assert(router_select(wrt, "anything") != 0, "wildcard matches anything");

    # ── Router: disabled route skipped ────────────────────────────
    test_group("router_disabled");

    var dr = route_new(PROV_OLLAMA, 1, "http://localhost:11434");
    route_set_enabled(dr, 0);
    var droutes = alloc(8);
    store64(droutes, dr);
