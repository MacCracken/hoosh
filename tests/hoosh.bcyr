# hoosh.bcyr — hoosh gateway benchmarks (Wave 1: pure logic)
# Benchmarks: routing, token budget, cache, cost, queue
#
# Run: cyrius bench tests/hoosh.bcyr
#   or: cyrius build tests/hoosh.bcyr /tmp/hoosh_bench && /tmp/hoosh_bench

include "lib/string.cyr"
include "lib/fmt.cyr"
include "lib/alloc.cyr"
include "lib/vec.cyr"
include "lib/str.cyr"
include "lib/io.cyr"
include "lib/hashmap.cyr"
include "lib/fnptr.cyr"
include "lib/bench.cyr"
include "lib/chrono.cyr"
include "lib/syscalls.cyr"
include "src/vendor/bote-core.cyr"

# ================================================================
# Inline all types from the test file (same definitions)
# These will be factored into src/ modules during the actual port
# ================================================================

# Mirror of src/lib/batch.cyr _batch_split for the batch-parse bench.
# Mirror of src/lib/metrics.cyr latency bucket-find (per-forward cost).
fn _bench_lat_bound(i) {
    if (i == 0) { return 5; }
    if (i == 1) { return 10; }
    if (i == 2) { return 25; }
    if (i == 3) { return 50; }
    if (i == 4) { return 100; }
    if (i == 5) { return 250; }
    if (i == 6) { return 500; }
    if (i == 7) { return 1000; }
    if (i == 8) { return 2500; }
    if (i == 9) { return 5000; }
    return 10000;
}
fn _bench_lat_bucket(ms) {
    var b = 0;
    while (b < 11 && ms > _bench_lat_bound(b)) { b = b + 1; }
    return b;
}

fn _bench_batch_split(arr_ptr, arr_len) {
    var items = vec_new();
    var i = 0;
    while (i < arr_len && load8(arr_ptr + i) != 91) { i = i + 1; }
    if (i >= arr_len) { return items; }
    i = i + 1;
    var depth = 0;
    var start = 0 - 1;
    while (i < arr_len) {
        var ch = load8(arr_ptr + i);
        if (ch == 34) {
            i = i + 1;
            while (i < arr_len) {
                var c2 = load8(arr_ptr + i);
                if (c2 == 92) { i = i + 2; } else {
                    if (c2 == 34) { break; }
                    i = i + 1;
                }
            }
            i = i + 1;
        } else {
            if (ch == 123 || ch == 91) {
                if (depth == 0 && start < 0) { start = i; }
                depth = depth + 1;
                i = i + 1;
            } else {
                if (ch == 125 || ch == 93) {
                    depth = depth - 1;
                    i = i + 1;
                    if (depth < 0) { break; }
                    if (depth == 0 && start >= 0) {
                        var slc = alloc(16);
                        store64(slc, arr_ptr + start);
                        store64(slc + 8, i - start);
                        vec_push(items, slc);
                        start = 0 - 1;
                    }
                } else {
                    i = i + 1;
                }
            }
        }
    }
    return items;
}

# Mirror of src/lib/mcp.cyr's bote_echo handler for the MCP benches.
fn _bench_mcp_echo(args, claims) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"content\":[{\"type\":\"text\",\"text\":\"");
    if (args != 0) { _json_emit_escaped(sb, args); }
    str_builder_add_cstr(sb, "\"}],\"isError\":false}");
    return str_data(str_builder_build(sb));
}

# Provider types
enum Provider {
    PROV_OLLAMA     = 0;
    PROV_LLAMACPP   = 1;
    PROV_SYNAPSE    = 2;
    PROV_LMSTUDIO   = 3;
    PROV_LOCALAI    = 4;
    PROV_OPENAI     = 5;
    PROV_ANTHROPIC  = 6;
    PROV_DEEPSEEK   = 7;
    PROV_MISTRAL    = 8;
    PROV_GOOGLE     = 9;
    PROV_GROQ       = 10;
    PROV_GROK       = 11;
    PROV_OPENROUTER = 12;
    PROV_WHISPER    = 13;
    PROV_COUNT      = 14;
}

fn provider_is_local(prov) {
    if (prov == PROV_OLLAMA || prov == PROV_LLAMACPP || prov == PROV_SYNAPSE) { return 1; }
    if (prov == PROV_LMSTUDIO || prov == PROV_LOCALAI || prov == PROV_WHISPER) { return 1; }
    return 0;
}

fn provider_name(prov) {
    if (prov == PROV_OLLAMA) { return "ollama"; }
    if (prov == PROV_LLAMACPP) { return "llamacpp"; }
    if (prov == PROV_OPENAI) { return "openai"; }
    if (prov == PROV_ANTHROPIC) { return "anthropic"; }
    if (prov == PROV_DEEPSEEK) { return "deepseek"; }
    return "unknown";
}

# Route struct
enum RouteField {
    ROUTE_SIZE       = 64;
    ROUTE_PROVIDER   = 0;
    ROUTE_PRIORITY   = 8;
    ROUTE_PATTERNS   = 16;
    ROUTE_PATTERNS_N = 24;
    ROUTE_ENABLED    = 32;
    ROUTE_BASE_URL   = 40;
}

fn route_new(prov, priority, base_url) {
    var r = alloc(ROUTE_SIZE);
    store64(r + ROUTE_PROVIDER, prov);
    store64(r + ROUTE_PRIORITY, priority);
    store64(r + ROUTE_PATTERNS, 0);
    store64(r + ROUTE_PATTERNS_N, 0);
    store64(r + ROUTE_ENABLED, 1);
    store64(r + ROUTE_BASE_URL, base_url);
    return r;
}

fn route_provider(r) { return load64(r + ROUTE_PROVIDER); }
fn route_priority(r) { return load64(r + ROUTE_PRIORITY); }
fn route_enabled(r) { return load64(r + ROUTE_ENABLED); }
fn route_base_url(r) { return load64(r + ROUTE_BASE_URL); }

fn route_set_patterns(r, patterns, count) {
    store64(r + ROUTE_PATTERNS, patterns);
    store64(r + ROUTE_PATTERNS_N, count);
    return 0;
}

fn route_matches_model(r, model) {
    var count = load64(r + ROUTE_PATTERNS_N);
    if (count == 0) { return 1; }
    var arr = load64(r + ROUTE_PATTERNS);
    var i = 0;
    while (i < count) {
        var pattern = load64(arr + i * 8);
        var plen = strlen(pattern);
        if (plen > 0 && load8(pattern + plen - 1) == 42) {
            if (memeq(model, pattern, plen - 1) == 1) { return 1; }
        } else {
            if (streq(model, pattern) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Per-provider token estimation (mirrors src/lib/compact.cyr).
var CHARS_PER_TOKEN_X10 = 40;

fn chars_per_token_x10(prov) {
    if (prov == PROV_OPENAI) { return 38; }
    if (prov == PROV_DEEPSEEK) { return 38; }
    if (prov == PROV_MISTRAL) { return 38; }
    if (prov == PROV_GROQ) { return 38; }
    if (prov == PROV_GROK) { return 38; }
    if (prov == PROV_OPENROUTER) { return 38; }
    if (prov == PROV_ANTHROPIC) { return 35; }
    if (prov == PROV_OLLAMA) { return 37; }
    if (prov == PROV_LLAMACPP) { return 37; }
    if (prov == PROV_LMSTUDIO) { return 37; }
    if (prov == PROV_LOCALAI) { return 37; }
    return 40;
}

fn estimate_tokens(messages, msg_len, cpt_x10) {
    var ratio = cpt_x10;
    if (ratio < 1) { ratio = CHARS_PER_TOKEN_X10; }
    return msg_len * 10 / ratio;
}

# DLP scanner (mirror of src/lib/dlp.cyr) — for the scan benchmark.
enum DlpClass {
    CLASS_PUBLIC       = 0;
    CLASS_INTERNAL     = 1;
    CLASS_CONFIDENTIAL = 2;
    CLASS_RESTRICTED   = 3;
}

var _dlp_enabled = 1;
var _dlp_default_level = 0;

fn _dlp_is_digit(c) {
    if (c >= 48 && c <= 57) { return 1; }
    return 0;
}

fn _dlp_is_upper(c) {
    if (c >= 65 && c <= 90) { return 1; }
    return 0;
}

fn _dlp_is_lower(c) {
    if (c >= 97 && c <= 122) { return 1; }
    return 0;
}

fn _dlp_is_alpha(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_lower(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_alnum(c) {
    if (_dlp_is_alpha(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_upper_alnum(c) {
    if (_dlp_is_upper(c) == 1 || _dlp_is_digit(c) == 1) { return 1; }
    return 0;
}

fn _dlp_is_word(c) {
    if (_dlp_is_alnum(c) == 1 || c == 95) { return 1; }
    return 0;
}

fn _dlp_bound_before(t, i) {
    if (i == 0) { return 1; }
    if (_dlp_is_word(load8(t + i - 1)) == 0) { return 1; }
    return 0;
}

fn _dlp_bound_after(t, e, len) {
    if (e >= len) { return 1; }
    if (_dlp_is_word(load8(t + e)) == 0) { return 1; }
    return 0;
}

fn _dlp_digits_n(t, i, len, n) {
    if (i + n > len) { return 0; }
    var k = 0;
    while (k < n) {
        if (_dlp_is_digit(load8(t + i + k)) == 0) { return 0; }
        k = k + 1;
    }
    return 1;
}

fn _dlp_match_ssn_at(t, i, len) {
    if (i + 11 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (load8(t + i + 3) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 2) == 0) { return 0; }
    if (load8(t + i + 6) != 45) { return 0; }
    if (_dlp_digits_n(t, i + 7, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 11, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_phone_sep(c) {
    if (c == 45 || c == 46 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_phone_at(t, i, len) {
    if (i + 12 > len) { return 0; }
    if (_dlp_digits_n(t, i, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 3)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 4, len, 3) == 0) { return 0; }
    if (_dlp_is_phone_sep(load8(t + i + 7)) == 0) { return 0; }
    if (_dlp_digits_n(t, i + 8, len, 4) == 0) { return 0; }
    if (_dlp_bound_after(t, i + 12, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_cc_sep(c) {
    if (c == 45 || c == 32) { return 1; }
    return 0;
}

fn _dlp_match_cc_at(t, i, len) {
    if (_dlp_digits_n(t, i, len, 4) == 0) { return 0; }
    var p = i + 4;
    var g = 1;
    while (g < 4) {
        if (p < len && _dlp_is_cc_sep(load8(t + p)) == 1) { p = p + 1; }
        if (_dlp_digits_n(t, p, len, 4) == 0) { return 0; }
        p = p + 4;
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_ipv4_group(t, p, len) {
    if (p >= len) { return 0 - 1; }
    if (_dlp_is_digit(load8(t + p)) == 0) { return 0 - 1; }
    var n = 1;
    p = p + 1;
    while (n < 3 && p < len && _dlp_is_digit(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    return p;
}

fn _dlp_match_ipv4_at(t, i, len) {
    var p = _dlp_ipv4_group(t, i, len);
    if (p < 0) { return 0; }
    var g = 1;
    while (g < 4) {
        if (p >= len) { return 0; }
        if (load8(t + p) != 46) { return 0; }
        p = p + 1;
        p = _dlp_ipv4_group(t, p, len);
        if (p < 0) { return 0; }
        g = g + 1;
    }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_apikey_prefix(t, i, len) {
    if (i + 3 <= len) {
        var c0 = load8(t + i);
        if (c0 == 115 || c0 == 112) {
            if (load8(t + i + 1) == 107 && load8(t + i + 2) == 45) {
                return i + 3;
            }
        }
    }
    if (i + 6 <= len) {
        if (load8(t + i) == 97 && load8(t + i + 1) == 112 && load8(t + i + 2) == 105) {
            var p = i + 3;
            if (p < len && (load8(t + p) == 95 || load8(t + p) == 45)) { p = p + 1; }
            if (p + 3 <= len) {
                if (load8(t + p) == 107 && load8(t + p + 1) == 101 && load8(t + p + 2) == 121) {
                    p = p + 3;
                    var sc = 0;
                    var more = 1;
                    while (more == 1 && sc < 5 && p < len) {
                        var sep = load8(t + p);
                        if (sep == 61 || sep == 58 || sep == 32) {
                            p = p + 1;
                            sc = sc + 1;
                        } else {
                            more = 0;
                        }
                    }
                    if (sc >= 1) { return p; }
                }
            }
        }
    }
    return 0 - 1;
}

fn _dlp_match_apikey_at(t, i, len) {
    var p = _dlp_apikey_prefix(t, i, len);
    if (p < 0) { return 0; }
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 20) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_match_aws_at(t, i, len) {
    if (i + 20 > len) { return 0; }
    if (load8(t + i) != 65 || load8(t + i + 1) != 75) { return 0; }
    if (load8(t + i + 2) != 73 || load8(t + i + 3) != 65) { return 0; }
    var k = 0;
    while (k < 16) {
        if (_dlp_is_upper_alnum(load8(t + i + 4 + k)) == 0) { return 0; }
        k = k + 1;
    }
    if (_dlp_bound_after(t, i + 20, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_gh_third(c) {
    if (c == 112 || c == 111 || c == 117 || c == 115 || c == 114) { return 1; }
    return 0;
}

fn _dlp_match_github_at(t, i, len) {
    if (i + 4 > len) { return 0; }
    if (load8(t + i) != 103 || load8(t + i + 1) != 104) { return 0; }
    if (_dlp_is_gh_third(load8(t + i + 2)) == 0) { return 0; }
    if (load8(t + i + 3) != 95) { return 0; }
    var p = i + 4;
    var n = 0;
    while (p < len && _dlp_is_alnum(load8(t + p)) == 1) {
        p = p + 1;
        n = n + 1;
    }
    if (n < 36) { return 0; }
    if (_dlp_bound_after(t, p, len) == 0) { return 0; }
    return 1;
}

fn _dlp_is_email_local(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 95 || c == 37 || c == 43 || c == 45) { return 1; }
    return 0;
}

fn _dlp_is_email_domain(c) {
    if (_dlp_is_alnum(c) == 1) { return 1; }
    if (c == 46 || c == 45) { return 1; }
    return 0;
}

fn _dlp_has_email(t, len) {
    var i = 0;
    while (i < len) {
        if (load8(t + i) == 64) {
            if (i >= 1 && _dlp_is_email_local(load8(t + i - 1)) == 1) {
                var p = i + 1;
                var seen = 0;
                while (p < len && _dlp_is_email_domain(load8(t + p)) == 1) {
                    if (load8(t + p) == 46) {
                        if (seen == 1) {
                            var q = p + 1;
                            var ac = 0;
                            while (q < len && _dlp_is_alpha(load8(t + q)) == 1) {
                                ac = ac + 1;
                                q = q + 1;
                            }
                            if (ac >= 2) { return 1; }
                        }
                    } else {
                        seen = 1;
                    }
                    p = p + 1;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn dlp_scan_level(t, len) {
    if (_dlp_enabled == 0) { return _dlp_default_level; }
    if (len == 0) { return _dlp_default_level; }
    var level = _dlp_default_level;
    var i = 0;
    while (i < len) {
        if (_dlp_bound_before(t, i) == 1) {
            if (_dlp_match_ssn_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_cc_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_apikey_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_aws_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_github_at(t, i, len) == 1) { return CLASS_RESTRICTED; }
            if (_dlp_match_phone_at(t, i, len) == 1) {
                if (level < CLASS_CONFIDENTIAL) { level = CLASS_CONFIDENTIAL; }
            }
            if (_dlp_match_ipv4_at(t, i, len) == 1) {
                if (level < CLASS_INTERNAL) { level = CLASS_INTERNAL; }
            }
        }
        i = i + 1;
    }
    if (level < CLASS_INTERNAL) {
        if (_dlp_has_email(t, len) == 1) { level = CLASS_INTERNAL; }
    }
    return level;
}

# Router
enum RouterField {
    ROUTER_SIZE      = 40;
    ROUTER_ROUTES    = 0;
    ROUTER_COUNT     = 8;
    ROUTER_STRATEGY  = 16;
    ROUTER_RR_IDX    = 24;
    ROUTER_LATENCIES = 32;
}

enum Strategy {
    STRAT_PRIORITY       = 0;
    STRAT_ROUND_ROBIN    = 1;
    STRAT_LOWEST_LATENCY = 2;
    STRAT_DIRECT         = 3;
}

fn router_new(routes, count, strategy) {
    var rt = alloc(ROUTER_SIZE);
    store64(rt + ROUTER_ROUTES, routes);
    store64(rt + ROUTER_COUNT, count);
    store64(rt + ROUTER_STRATEGY, strategy);
    store64(rt + ROUTER_RR_IDX, 0);
    store64(rt + ROUTER_LATENCIES, map_new());
    var i = 1;
    while (i < count) {
        var key = load64(routes + i * 8);
        var kp = route_priority(key);
        var j = i - 1;
        while (j >= 0) {
            if (route_priority(load64(routes + j * 8)) <= kp) { break; }
            store64(routes + (j + 1) * 8, load64(routes + j * 8));
            j = j - 1;
        }
        store64(routes + (j + 1) * 8, key);
        i = i + 1;
    }
    return rt;
}

fn router_select(rt, model) {
    var routes = load64(rt + ROUTER_ROUTES);
    var count = load64(rt + ROUTER_COUNT);
    var strategy = load64(rt + ROUTER_STRATEGY);
    var cand = alloc(count * 8);
    var cn = 0;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1 && route_matches_model(r, model) == 1) {
            store64(cand + cn * 8, r);
            cn = cn + 1;
        }
        i = i + 1;
    }
    if (cn == 0) { return 0; }
    if (strategy == STRAT_PRIORITY || strategy == STRAT_DIRECT) { return load64(cand); }
    if (strategy == STRAT_ROUND_ROBIN) {
        var idx = load64(rt + ROUTER_RR_IDX);
        store64(rt + ROUTER_RR_IDX, idx + 1);
        return load64(cand + (idx % cn) * 8);
    }
    return load64(cand);
}

# Token pool
enum PoolField {
    POOL_SIZE = 32; POOL_NAME = 0; POOL_CAPACITY = 8; POOL_USED = 16; POOL_RESERVED = 24;
}

fn pool_new(name, capacity) {
    var p = alloc(POOL_SIZE);
    store64(p + POOL_NAME, name);
    store64(p + POOL_CAPACITY, capacity);
    store64(p + POOL_USED, 0);
    store64(p + POOL_RESERVED, 0);
    return p;
}

fn pool_available(p) {
    var taken = load64(p + POOL_USED) + load64(p + POOL_RESERVED);
    var cap = load64(p + POOL_CAPACITY);
    if (taken > cap) { return 0; }
    return cap - taken;
}

fn pool_reserve(p, tokens) {
    if (pool_available(p) < tokens) { return 0; }
    store64(p + POOL_RESERVED, load64(p + POOL_RESERVED) + tokens);
    return 1;
}

fn pool_commit(p, reserved, actual) {
    var resv = load64(p + POOL_RESERVED);
    if (resv >= reserved) { store64(p + POOL_RESERVED, resv - reserved); }
    else { store64(p + POOL_RESERVED, 0); }
    store64(p + POOL_USED, load64(p + POOL_USED) + actual);
    return 0;
}

# Cache
fn cache_new(max, enabled) {
    var c = alloc(48);
    store64(c, map_new());
    store64(c + 8, max);
    store64(c + 16, 0);
    store64(c + 24, 0);
    store64(c + 32, 0);
    store64(c + 40, enabled);
    return c;
}

fn cache_get(c, key) {
    if (load64(c + 40) == 0) { return 0; }
    var val = map_get(load64(c), key);
    if (val == 0) { store64(c + 24, load64(c + 24) + 1); return 0; }
    store64(c + 16, load64(c + 16) + 1);
    return val;
}

fn cache_insert(c, key, val) {
    if (load64(c + 40) == 0) { return 0; }
    map_set(load64(c), key, val);
    return 0;
}

# Queue
enum QueuePriority {
    PRI_CRITICAL = 0; PRI_HIGH = 1; PRI_NORMAL = 2; PRI_LOW = 3; PRI_BACKGROUND = 4; PRI_TIERS = 5;
}

fn queue_new() {
    var q = alloc(PRI_TIERS * 8);
    var i = 0;
    while (i < PRI_TIERS) { store64(q + i * 8, vec_new()); i = i + 1; }
    return q;
}

fn queue_enqueue(q, model, pool, rid, pri) {
    var item = alloc(24);
    store64(item, model); store64(item + 8, pool); store64(item + 16, rid);
    vec_push(load64(q + pri * 8), item);
    return 0;
}

fn queue_dequeue(q) {
    var i = 0;
    while (i < PRI_TIERS) {
        var tier = load64(q + i * 8);
        if (vec_len(tier) > 0) { var item = vec_get(tier, 0); vec_remove(tier, 0); return item; }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Benchmark globals for callbacks
# ================================================================

var _b_router = 0;
var _b_pool = 0;
var _b_cache = 0;
var _b_queue = 0;

# ================================================================
# BENCHMARKS
# ================================================================

fn main() {
    alloc_init();

    println("=== hoosh benchmarks ===");
    println("");

    # ── Setup: 20-provider router (matches Rust bench) ────────────
    var routes = alloc(20 * 8);
    var i = 0;
    while (i < 20) {
        var prov = i % PROV_COUNT;
        var r = route_new(prov, i + 1, "http://localhost");
        var pats = alloc(8);
        store64(pats, "llama*");
        route_set_patterns(r, pats, 1);
        store64(routes + i * 8, r);
        i = i + 1;
    }
    _b_router = router_new(routes, 20, STRAT_PRIORITY);

    # ── Benchmark: route_select_20_providers ──────────────────────
    var b = bench_new("route_select_20_providers");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        router_select(_b_router, "llama3");
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: route_round_robin_10 ───────────────────────────
    var rr_routes = alloc(10 * 8);
    i = 0;
    while (i < 10) {
        var r = route_new(i % PROV_COUNT, 1, "http://localhost");
        store64(rr_routes + i * 8, r);
        i = i + 1;
    }
    var rr_rt = router_new(rr_routes, 10, STRAT_ROUND_ROBIN);

    b = bench_new("route_round_robin_10");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        router_select(rr_rt, "anything");
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: pool_reserve_commit_cycle ──────────────────────
    b = bench_new("pool_reserve_commit");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        var p = pool_new("bench", 1000000);
        pool_reserve(p, 500);
        pool_commit(p, 500, 420);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: pool_available ─────────────────────────────────
    _b_pool = pool_new("bench", 1000000);
    pool_reserve(_b_pool, 50000);

    b = bench_new("pool_available");
    bench_batch_start(b);
    i = 0;
    while (i < 100000) {
        pool_available(_b_pool);
        i = i + 1;
    }
    bench_batch_stop(b, 100000);
    bench_report(b);

    # ── Benchmark: cache_get_hit ──────────────────────────────────
    _b_cache = cache_new(10000, 1);
    cache_insert(_b_cache, "prompt-hash-1", 42);

    b = bench_new("cache_get_hit");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        cache_get(_b_cache, "prompt-hash-1");
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: cache_get_miss ─────────────────────────────────
    b = bench_new("cache_get_miss");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        cache_get(_b_cache, "nonexistent-key");
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: cache_insert ───────────────────────────────────
    b = bench_new("cache_insert");
    var ci_cache = cache_new(100000, 1);
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        cache_insert(ci_cache, "key", i);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: queue_enqueue_dequeue ──────────────────────────
    b = bench_new("queue_enqueue_dequeue");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        var q = queue_new();
        queue_enqueue(q, "m", "p", "r", PRI_NORMAL);
        queue_dequeue(q);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: queue_priority_sort (5 tiers) ──────────────────
    b = bench_new("queue_5tier_sort");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        var q = queue_new();
        queue_enqueue(q, "m", "p", "n", PRI_NORMAL);
        queue_enqueue(q, "m", "p", "b", PRI_BACKGROUND);
        queue_enqueue(q, "m", "p", "c", PRI_CRITICAL);
        queue_enqueue(q, "m", "p", "l", PRI_LOW);
        queue_enqueue(q, "m", "p", "h", PRI_HIGH);
        queue_dequeue(q);
        queue_dequeue(q);
        queue_dequeue(q);
        queue_dequeue(q);
        queue_dequeue(q);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: route_matches_model (pattern match) ────────────
    var pats = alloc(16);
    store64(pats, "llama*");
    store64(pats + 8, "mistral*");
    var mr = route_new(PROV_OLLAMA, 1, "http://localhost");
    route_set_patterns(mr, pats, 2);

    b = bench_new("route_matches_model");
    bench_batch_start(b);
    i = 0;
    while (i < 100000) {
        route_matches_model(mr, "llama3.2:latest");
        i = i + 1;
    }
    bench_batch_stop(b, 100000);
    bench_report(b);

    # ── Benchmark: estimate_tokens (per-provider, per chat request) ─
    b = bench_new("estimate_tokens_per_provider");
    bench_batch_start(b);
    i = 0;
    while (i < 100000) {
        estimate_tokens(0, 4096, chars_per_token_x10(PROV_ANTHROPIC));
        i = i + 1;
    }
    bench_batch_stop(b, 100000);
    bench_report(b);

    # ── Benchmark: dlp_scan_level on a clean prompt (per-request cost) ─
    var dlp_txt = "Explain how Rust ownership and borrowing interact with lifetimes, and give a short worked example with a function that returns a reference.";
    var dlp_len = strlen(dlp_txt);
    var dlp_buf = alloc(dlp_len + 1);
    memcpy(dlp_buf, dlp_txt, dlp_len);
    b = bench_new("dlp_scan_clean_prompt");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        dlp_scan_level(dlp_buf, dlp_len);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: mcp_tools_list (bote dispatch) ─────────────────
    # Full JSON-RPC parse → dispatch → tools/list result serialize, the
    # per-request cost behind GET /v1/tools/list.
    var mcp_reg = registry_new();
    var mcp_disp = dispatcher_new(mcp_reg);
    var mcp_sch = schema_new("object", vec_new(), vec_new());
    var mcp_td = tool_def_new("bote_echo", "Echo", mcp_sch);
    dispatcher_register_tool(mcp_disp, mcp_td, &_bench_mcp_echo);

    b = bench_new("mcp_tools_list");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        codec_process_message("{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}", mcp_disp, 0);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: mcp_tools_call (bote dispatch + echo) ──────────
    b = bench_new("mcp_tools_call");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        codec_process_message("{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"bote_echo\",\"arguments\":{\"k\":\"v\"}}}", mcp_disp, 0);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: batch_split_16 (POST /v1/batch request parsing) ─
    var barr = "[{\"model\":\"llama3\",\"messages\":[{\"role\":\"user\",\"content\":\"hello world\"}]},{\"model\":\"llama3\",\"messages\":[{\"role\":\"user\",\"content\":\"second\"}]},{\"model\":\"llama3\",\"messages\":[{\"role\":\"user\",\"content\":\"third\"}]},{\"model\":\"llama3\",\"messages\":[{\"role\":\"user\",\"content\":\"fourth\"}]}]";
    var barr_len = strlen(barr);
    b = bench_new("batch_split_4");
    bench_batch_start(b);
    i = 0;
    while (i < 10000) {
        _bench_batch_split(barr, barr_len);
        i = i + 1;
    }
    bench_batch_stop(b, 10000);
    bench_report(b);

    # ── Benchmark: latency_bucket_find (per-forward histogram cost) ─
    b = bench_new("latency_bucket_find");
    bench_batch_start(b);
    i = 0;
    while (i < 100000) {
        _bench_lat_bucket(i % 12000);
        i = i + 1;
    }
    bench_batch_stop(b, 100000);
    bench_report(b);

    println("");
    println("done");
    return 0;
}

var r = main();
sys_exit(r);
