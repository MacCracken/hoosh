# hoosh configuration
# See BENCHMARKS.md for performance data.

[server]
bind = "127.0.0.1"
port = 8088
strategy = "priority"

# Operational logging (stderr). Levels: fatal, error, warn, info, debug, trace.
# Default is info. The CLI banner / `info` / `help` output stays on stdout.
# NOTE: double-bracket form — the parser only honors [[table]] sections today
# (single-bracket support is a queued improvement), matching [[budgets]] below.
[[logging]]
level = "info"

# Durable persistence (opt-in). When `path` is set, the HMAC audit chain and
# token-budget usage are stored in an embedded patra DB and restored on
# startup. Omit this section to run fully in-memory (default).
# [[storage]]
# path = "hoosh.patra"

[cache]
max_entries = 1000
ttl_secs = 300
enabled = true

# Prompt compression — collapse whitespace in message content before sending,
# shaving tokens without changing meaning (runs of spaces/tabs/newlines, incl.
# \n \t \r escapes, become a single space; leading/trailing trimmed). Off by
# default; applied before context compaction when enabled.
# [compression]
# enabled = true

# Cache warming — pre-populate the response cache at startup so common prompts
# are instant before traffic arrives. Each [[warming]] fires one inference at
# startup (synchronous; opt-in). A client hits the warmed entry by POSTing the
# canonical body: {"model":"<model>","messages":[{"role":"user","content":"<prompt>"}]}
# [[warming]]
# model = "gpt-4o-mini"
# prompt = "What is the capital of France?"

# Data Loss Prevention — scans request content for PII/secrets and enforces
# privacy-aware routing. Off by default. When enabled:
#   default_level  classification when nothing matches (public|internal|
#                  confidential|restricted)
# Policy: restricted content (SSN, credit card, API key, AWS/GitHub token) is
# blocked (403); confidential content (US phone) is forced to a local provider
# (blocked if none serves the model); internal (email, IPv4) and public pass.
# [dlp]
# enabled = true
# default_level = "public"

# --- Token budget pools ---

[[budgets]]
name = "default"
capacity = 100000

[[budgets]]
name = "testing"
capacity = 500

# --- Local providers ---

[[providers]]
type = "Ollama"
# base_url = "http://localhost:11434"  # default
priority = 1
models = ["llama*", "mistral*", "qwen*", "phi*", "gemma*"]

# [[providers]]
# type = "LlamaCpp"
# base_url = "http://localhost:8080"
# priority = 2
# models = ["gguf-*"]

# --- Remote providers ---
# Set API keys via environment variables for security.

[[providers]]
type = "OpenAi"
api_key = "$OPENAI_API_KEY"
priority = 10
models = ["gpt-*", "o1-*", "o3-*"]

[[providers]]
type = "Anthropic"
api_key = "$ANTHROPIC_API_KEY"
priority = 10
models = ["claude-*"]

[[providers]]
type = "Google"
api_key = "$GEMINI_API_KEY"
priority = 10
models = ["gemini-*"]

# [[providers]]
# type = "DeepSeek"
# api_key = "$DEEPSEEK_API_KEY"
# priority = 15
# models = ["deepseek-*"]

# [[providers]]
# type = "Groq"
# api_key = "$GROQ_API_KEY"
# priority = 5
# models = ["llama*", "mixtral*"]

