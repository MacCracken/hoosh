# hoosh configuration
# See BENCHMARKS.md for performance data.

[server]
# Listen address. Defaults to 127.0.0.1 (loopback only) when omitted — set
# "0.0.0.0" to serve other hosts, and configure [[auth]] tokens if you do.
bind = "127.0.0.1"
port = 8088
strategy = "priority"   # priority | round-robin | lowest-latency | direct
# Background provider health probing. A route is withdrawn from routing after 3
# consecutive failed probes and restored on the first success. 0 disables it.
health_check_interval_secs = 30

# Per-provider knobs live on each [[providers]] block:
#   max_tokens_limit = 4096   # clamp any request asking for more (0/omit = no cap)
#   rate_limit       = 600    # requests per minute
#   models           = ["llama*", "mistral*"]
#   enabled          = false  # keep the route configured but out of selection

# Hardware detection + placement. disabled_backends skips named ai-hwaccel
# probes. vram_reserve_bytes is held back from placement decisions, so a model
# that fits the card but not what is currently FREE is planned around instead of
# failing at the backend. refresh_interval_secs re-detects periodically (0 =
# detect once at startup); cache_ttl_secs is how stale a snapshot may get before
# a wake actually re-probes — detection shells out, so this bounds subprocesses.
# [hardware]
# disabled_backends = ["cuda", "rocm"]
# vram_reserve_bytes = 2147483648
# refresh_interval_secs = 0
# cache_ttl_secs = 300

# Provider retry with jittered exponential backoff. Permanent failures (a 4xx
# other than 408/429) are not retried. jitter_factor spreads a thundering herd:
# the delay lands in [delay, delay + delay*jitter_factor].
# [[retry]]
# max_retries = 3
# base_delay_ms = 500
# max_delay_ms = 30000
# jitter_factor = 0.5

# Context compaction — trim history to fit the model's context window.
# The budget is (model context window x compaction_threshold); keep_last_messages
# floors the retained tail so a conversation is never stripped to nothing. The
# system message is always preserved.
# [context]
# enabled = true
# compaction_threshold = 0.8
# keep_last_messages = 10

# Cryptographic audit chain (HMAC-SHA256 over a hash chain). OFF by default.
# signing_key is "$NAME"-expandable so the secret stays in the environment; with
# no key hoosh generates a random per-process one and warns — fine for detecting
# tampering within a run, but a chain persisted across restarts needs a real key.
# [audit]
# enabled = true
# signing_key = "$HOOSH_AUDIT_KEY"
# max_entries = 10000

# Bearer-token auth. A LIST — issue a token per consumer and rotate by adding
# the new one before retiring the old. Omit this section entirely and hoosh
# serves unauthenticated (fine on loopback; pair with `bind` above before
# exposing the gateway off-host).
# [[auth]]
# tokens = ["consumer-a-key", "consumer-b-key"]

# Operational logging (stderr). Levels: fatal, error, warn, info, debug, trace.
# Default is info. The CLI banner / `info` / `help` output stays on stdout.
# NOTE: double-bracket form — the parser only honors [[table]] sections today
# (single-bracket support is a queued improvement), matching [[budgets]] below.
[[logging]]
level = "info"

# Durable persistence (opt-in). When `path` is set, the HMAC audit chain and
# token-budget usage are stored in an embedded patra DB and restored on
# startup. Omit this section to run fully in-memory (default).
# [[storage]]
# path = "hoosh.patra"

# OpenTelemetry — export one OTLP/HTTP+JSON span per inference to a collector's
# /v1/traces. Off unless otlp_endpoint is set. The span carries the request's
# traceparent trace-id, so it joins the caller's trace. A background thread
# batches + POSTs every second (non-blocking). Both a local http sidecar and a
# remote https collector (DNS + TLS via sandhi) are supported.
# [[telemetry]]
# otlp_endpoint = "http://localhost:4318/v1/traces"   # or https://collector.example.com/v1/traces
# service_name = "hoosh"

[cache]
max_entries = 1000
ttl_secs = 300     # entry lifetime; 0 disables expiry (entries live until evicted)
enabled = true

# Prompt compression — collapse whitespace in message content before sending,
# shaving tokens without changing meaning (runs of spaces/tabs/newlines, incl.
# \n \t \r escapes, become a single space; leading/trailing trimmed). Off by
# default; applied before context compaction when enabled.
# [compression]
# enabled = true

# Cache warming — pre-populate the response cache at startup so common prompts
# are instant before traffic arrives. Each [[warming]] fires one inference at
# startup (synchronous; opt-in). A client hits the warmed entry by POSTing the
# canonical body: {"model":"<model>","messages":[{"role":"user","content":"<prompt>"}]}
# [[warming]]
# model = "gpt-4o-mini"
# prompt = "What is the capital of France?"

# Semantic cache — on an exact-cache miss, compare the query's embedding to
# stored ones (cosine similarity); a match above `threshold` reuses that
# response. Off by default. `embedding_model` names the model used to embed
# queries; `max_search` caps the scan (0 = unlimited). The chat-path embedding
# round-trip is wired separately; the core (cosine + store + parsing) ships now.
# [semantic_cache]
# enabled = true
# threshold = 0.85
# embedding_model = "text-embedding-3-small"
# max_search = 0

# Data Loss Prevention — scans request content for PII/secrets and enforces
# privacy-aware routing. Off by default. When enabled:
#   default_level  classification when nothing matches (public|internal|
#                  confidential|restricted)
# Policy: restricted content (SSN, credit card, API key, AWS/GitHub token) is
# blocked (403); confidential content (US phone) is forced to a local provider
# (blocked if none serves the model); internal (email, IPv4) and public pass.
# [dlp]
# enabled = true
# default_level = "public"

# --- Token budget pools ---

[[budgets]]
name = "default"
capacity = 100000

[[budgets]]
name = "testing"
capacity = 500

# --- Local providers ---

[[providers]]
type = "Ollama"
base_url = "http://192.168.1.186:11434"  # default
priority = 1
models = ["llama*", "mistral*", "qwen*", "phi*", "gemma*"]

# [[providers]]
# type = "LlamaCpp"
# base_url = "http://localhost:8080"
# priority = 2
# models = ["gguf-*"]

# --- Remote providers ---
# Set API keys via environment variables for security.

[[providers]]
type = "OpenAi"
api_key = "$OPENAI_API_KEY"
priority = 10
models = ["gpt-*", "o1-*", "o3-*"]

[[providers]]
type = "Anthropic"
api_key = "$ANTHROPIC_API_KEY"
priority = 10
models = ["claude-*"]

[[providers]]
type = "Google"
api_key = "$GEMINI_API_KEY"
priority = 10
models = ["gemini-*"]

# [[providers]]
# type = "DeepSeek"
# api_key = "$DEEPSEEK_API_KEY"
# priority = 15
# models = ["deepseek-*"]

# [[providers]]
# type = "Groq"
# api_key = "$GROQ_API_KEY"
# priority = 5
# models = ["llama*", "mixtral*"]

# [[providers]]
# type = "OpenRouter"
# api_key = "$OPENROUTER_API_KEY"
# priority = 20
# models = ["*"]  # catch-all fallback
