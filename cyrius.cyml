[package]
name = "hoosh"
version = "${file:VERSION}"
description = "AI inference gateway — multi-provider LLM routing, token budgets, caching"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.1.31"
repository = "https://github.com/MacCracken/hoosh"

[build]
entry = "src/main.cyr"
output = "build/hoosh"

[deps]
# bayan (6.1.27) is the consolidated bigint + toml + json module — the
# standalone bigint/toml/json snapshot files were merged into it. It must
# precede sigil (sigil references bayan's u256 surface).
stdlib = ["string", "fmt", "alloc", "vec", "str", "io", "fs", "args", "hashmap", "freelist", "bayan", "ct", "keccak", "sigil", "tagged", "http", "net", "chrono", "syscalls", "process", "thread", "thread_local", "sakshi", "patra", "fnptr", "mmap", "dynlib", "fdlopen", "tls", "sandhi", "assert", "bench"]

# Hardware accelerator detection — consumed as the single-file distlib
# bundle (cyrius deps vendors dist/ai-hwaccel.cyr → lib/ai-hwaccel.cyr,
# included from src/main.cyr). Cyrius does not resolve transitive deps,
# so ai-hwaccel's own stdlib needs are already covered by [deps] above.
[deps.ai-hwaccel]
git = "https://github.com/MacCracken/ai-hwaccel"
tag = "2.3.9"
modules = ["dist/ai-hwaccel.cyr"]

# MCP protocol core (bote) — JSON-RPC 2.0 registry/dispatcher, powers
# /v1/tools/list + /v1/tools/call. We consume bote's **core** bundle
# (`[lib.core]`, 9 transport-free modules: error/protocol/jsonx/registry/
# events/audit/dispatch/codec/schema) — the surface for consumers that
# wrap bote's Dispatcher/Registry but supply their own transport, exactly
# hoosh's HTTP server.
#
# NOT consumed via `[deps.bote]`: unlike ai-hwaccel (whose manifest has no
# git sub-deps), bote's manifest declares `[deps.libro]` + `[deps.majra]`
# for its full bundle's `events_majra`/`audit_libro` modules. `cyrius deps`
# recurses into those git sub-deps, vendoring libro/majra → bayan/ganita/
# agnosys and adding them all to the compile set — where the agnos superset
# (agnosys) collides with bote-core's `registry_new` ("last definition
# wins", a correctness hazard) and trips an agnosys slice-include error.
# The core bundle itself is fully self-contained (no includes, no libro/
# majra symbols), so we vendor it directly as `src/vendor/bote-core.cyr`
# (committed; see that file's header for the pinned bote tag) and include
# it from src/main.cyr. Re-sync with `./scripts/sync-bote.sh <tag>`.
#
# majra (2.4.5) — provider event bus pubsub — is vendored the same way at
# src/vendor/majra.cyr (self-contained dist/majra.cyr). Note: majra defines
# ratelimit_new/ratelimit_check that collide by name with src/lib/ratelimit.cyr
# (different arity); harmless — they're dead code in majra's core pubsub, so
# hoosh's win (last-definition). Powers src/lib/events.cyr.
