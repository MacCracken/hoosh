# compression.cyr — mechanical prompt compression.
#
# Port of rust-old/src/context/compression.rs: whitespace collapse
# (compress_ws_json) plus stale tool-call/result pruning (prune_tool_pairs).
#
# Distinct from compact.cyr: compaction DROPS whole messages to fit a token
# budget; compression REWRITES content to shave tokens without changing meaning.
#
# Strategy: collapse runs of whitespace inside JSON string *values* to a single
# space and trim leading/trailing (mirrors collapse_whitespace applied to each
# message's content). JSON keys, structure, and non-whitespace escapes are
# preserved; the whitespace escapes \n \t \r inside values are collapsed too
# (they are whitespace in the decoded text the model sees). Opt-in via
# [compression] in hoosh.cyml.

var _compression_enabled = 0;

fn compression_configure(enabled) {
    _compression_enabled = enabled;
    return 0;
}

fn compression_is_enabled() { return _compression_enabled; }

# space, tab, LF, CR
fn _compress_is_ws(c) {
    if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; }
    return 0;
}

# Collapse whitespace inside JSON string values. Returns a 16-byte (ptr,len)
# struct (same shape as compact_messages).
fn compress_ws_json(ptr, len) {
    var out = str_builder_new();
    var i = 0;
    var in_str = 0;     # inside a "..." string
    var is_val = 0;     # current string sits in value position (after ':')
    var prev_sig = 0;   # last non-whitespace byte seen outside strings
    var pending = 0;    # a collapsed space is pending inside a value string
    var emitted = 0;    # emitted a non-ws byte in the current value string
    while (i < len) {
        var c = load8(ptr + i);
        if (in_str == 0) {
            str_builder_add_byte(out, c);
            if (c == 34) {
                in_str = 1;
                is_val = 0;
                if (prev_sig == 58) { is_val = 1; }
                pending = 0;
                emitted = 0;
            } else {
                if (_compress_is_ws(c) == 0) { prev_sig = c; }
            }
            i = i + 1;
        } else {
            if (c == 92) {
                # escape sequence: peek the next byte
                var nx = 0;
                if (i + 1 < len) { nx = load8(ptr + i + 1); }
                if (nx == 110 || nx == 116 || nx == 114) {
                    # \n \t \r — whitespace in the decoded value
                    if (is_val == 1) {
                        pending = 1;
                    } else {
                        str_builder_add_byte(out, c);
                        str_builder_add_byte(out, nx);
                    }
                    i = i + 2;
                    continue;
                }
                # any other escape (quote, backslash, slash, b, f, unicode): keep
                if (is_val == 1) {
                    if (emitted == 1 && pending == 1) { str_builder_add_byte(out, 32); }
                    pending = 0;
                    emitted = 1;
                }
                str_builder_add_byte(out, c);
                if (i + 1 < len) { str_builder_add_byte(out, nx); }
                i = i + 2;
                continue;
            }
            if (c == 34) {
                str_builder_add_byte(out, c);
                in_str = 0;
                is_val = 0;
                i = i + 1;
                continue;
            }
            if (is_val == 1) {
                if (_compress_is_ws(c) == 1) {
                    pending = 1;
                } else {
                    if (emitted == 1 && pending == 1) { str_builder_add_byte(out, 32); }
                    str_builder_add_byte(out, c);
                    emitted = 1;
                    pending = 0;
                }
            } else {
                str_builder_add_byte(out, c);
            }
            i = i + 1;
        }
    }
    var s = str_builder_build(out);
    var r = alloc(16);
    store64(r, to_cstr(s));
    store64(r + 8, str_len(s));
    return r;
}

# ── Stale tool-pair pruning ──
# Long agentic conversations accumulate tool-call / tool-result pairs that are
# no longer relevant. This drops assistant messages carrying tool_calls (and
# their matching tool-result messages) that fall before the last 3 such turns —
# mirrors prune_stale_tool_pairs in rust-old/src/context/compression.rs. Helpers
# are local so compression.cyr stays self-contained (included before provider).

var _CMP_KEEP_RECENT = 3;

# Index past the close matching the `{`/`[` at start (string-aware).
fn _cmp_span_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123 || ch == 91) { depth = depth + 1; }
            if (ch == 125 || ch == 93) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

# First offset of needle in p[0..plen), or -1.
fn _cmp_substr(p, plen, needle, nlen) {
    if (nlen == 0) { return 0 - 1; }
    var i = 0;
    while (i + nlen <= plen) {
        if (memeq(p + i, needle, nlen) == 1) { return i; }
        i = i + 1;
    }
    return 0 - 1;
}

# String field value (ptr,len) from object p[0..len), or 0. Skips spaces.
fn _cmp_str_field(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 34) {
                j = j + 1;
                var vs = j;
                while (j < len) {
                    if (load8(p + j) == 34) {
                        if (load8(p + j - 1) != 92) { break; }
                    }
                    j = j + 1;
                }
                var r = alloc(16);
                store64(r, p + vs);
                store64(r + 8, j - vs);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if span (ptr,len) byte-equals a "tool" role value.
fn _cmp_is_role(field, role, rolelen) {
    if (field == 0) { return 0; }
    if (load64(field + 8) != rolelen) { return 0; }
    if (memeq(load64(field), role, rolelen) == 1) { return 1; }
    return 0;
}

# Collect each tool_calls[].id value (ptr,len) from an assistant object into out.
fn _cmp_collect_ids(objp, objl, out) {
    var tc = _cmp_substr(objp, objl, "\"tool_calls\"", 12);
    if (tc < 0) { return 0; }
    var i = tc + 12;
    while (i < objl && load8(objp + i) != 91) { i = i + 1; }
    if (i >= objl) { return 0; }
    var arrend = _cmp_span_end(objp, objl, i);
    var j = i;
    while (j + 6 <= arrend) {
        if (memeq(objp + j, "\"id\":\"", 6) == 1) {
            var vs = j + 6;
            var ve = vs;
            while (ve < arrend && load8(objp + ve) != 34) {
                if (load8(objp + ve) == 92) { ve = ve + 1; }
                ve = ve + 1;
            }
            var idspan = alloc(16);
            store64(idspan, objp + vs);
            store64(idspan + 8, ve - vs);
            vec_push(out, idspan);
            j = ve;
        }
        j = j + 1;
    }
    return 0;
}

# True if (ptr,len) matches any id span in the vec.
fn _cmp_id_in(ids, ptr, len) {
    var n = vec_len(ids);
    var i = 0;
    while (i < n) {
        var e = vec_get(ids, i);
        if (load64(e + 8) == len) {
            if (memeq(load64(e), ptr, len) == 1) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Prune stale tool-call/result pairs from a messages array. Returns a 16-byte
# (ptr,len); the original if nothing is pruned.
fn prune_tool_pairs(msg_ptr, msg_len) {
    var spans = vec_new();   # each: (start, end, remove) 24 bytes
    var tc_idx = vec_new();  # indices of assistant-with-tool_calls spans
    var i = 0;
    while (i < msg_len && load8(msg_ptr + i) != 91) { i = i + 1; }
    i = i + 1;
    while (i < msg_len) {
        var ch = load8(msg_ptr + i);
        if (ch == 32 || ch == 44 || ch == 10 || ch == 13 || ch == 9) {
            i = i + 1;
        } else {
            if (ch != 123) {
                i = msg_len;
            } else {
                var s = i;
                var e = _cmp_span_end(msg_ptr, msg_len, i);
                var span = alloc(24);
                store64(span, s);
                store64(span + 8, e);
                store64(span + 16, 0);
                vec_push(spans, span);
                var objp = msg_ptr + s;
                var objl = e - s;
                var role = _cmp_str_field(objp, objl, "role", 4);
                if (_cmp_is_role(role, "assistant", 9) == 1) {
                    if (_cmp_substr(objp, objl, "\"tool_calls\"", 12) >= 0) {
                        vec_push(tc_idx, vec_len(spans) - 1);
                    }
                }
                i = e;
            }
        }
    }
    var total_tc = vec_len(tc_idx);
    if (total_tc <= _CMP_KEEP_RECENT) {
        var orig = alloc(16);
        store64(orig, msg_ptr);
        store64(orig + 8, msg_len);
        return orig;
    }
    var stale_count = total_tc - _CMP_KEEP_RECENT;
    var stale_ids = vec_new();
    var k = 0;
    while (k < stale_count) {
        var sidx = vec_get(tc_idx, k);
        var sp = vec_get(spans, sidx);
        store64(sp + 16, 1);
        _cmp_collect_ids(msg_ptr + load64(sp), load64(sp + 8) - load64(sp), stale_ids);
        k = k + 1;
    }
    # Mark tool-result messages whose tool_call_id is stale.
    var n = vec_len(spans);
    var m = 0;
    while (m < n) {
        var sp2 = vec_get(spans, m);
        if (load64(sp2 + 16) == 0) {
            var op = msg_ptr + load64(sp2);
            var ol = load64(sp2 + 8) - load64(sp2);
            var role2 = _cmp_str_field(op, ol, "role", 4);
            if (_cmp_is_role(role2, "tool", 4) == 1) {
                var tcid = _cmp_str_field(op, ol, "tool_call_id", 12);
                if (tcid != 0) {
                    if (_cmp_id_in(stale_ids, load64(tcid), load64(tcid + 8)) == 1) {
                        store64(sp2 + 16, 1);
                    }
                }
            }
        }
        m = m + 1;
    }
    # Rebuild the array without removed messages.
    var sb = str_builder_new();
    str_builder_add_byte(sb, 91);
    var first = 1;
    var q = 0;
    while (q < n) {
        var sp3 = vec_get(spans, q);
        if (load64(sp3 + 16) == 0) {
            if (first == 0) { str_builder_add_byte(sb, 44); }
            var ms = load64(sp3);
            var ml = load64(sp3 + 8) - ms;
            var mb = alloc(ml + 1);
            memcpy(mb, msg_ptr + ms, ml);
            store8(mb + ml, 0);
            str_builder_add_cstr(sb, mb);
            first = 0;
        }
        q = q + 1;
    }
    str_builder_add_byte(sb, 93);
    var out = str_builder_build(sb);
    var r = alloc(16);
    store64(r, to_cstr(out));
    store64(r + 8, str_len(out));
    return r;
}
