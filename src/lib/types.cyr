# types.cyr — enums, error codes, provider types for hoosh
# All shared constants and type definitions.

var HOOSH_VERSION = "2.5.10";

# ================================================================
# Error types
# ================================================================

enum HooshErr {
    ERR_NONE           = 0;
    ERR_PROVIDER       = 1;
    ERR_MODEL_NOT_FOUND = 2;
    ERR_RATE_LIMITED   = 3;
    ERR_BUDGET_EXCEEDED = 4;
    ERR_NO_PROVIDER    = 5;
    ERR_TIMEOUT        = 6;
    ERR_CACHE          = 7;
    ERR_DLP_BLOCKED    = 8;
    ERR_HTTP           = 9;
    ERR_INTERNAL       = 10;
}

fn error_http_status(code) {
    if (code == ERR_MODEL_NOT_FOUND || code == ERR_NO_PROVIDER) { return 404; }
    if (code == ERR_RATE_LIMITED || code == ERR_BUDGET_EXCEEDED) { return 429; }
    if (code == ERR_TIMEOUT) { return 408; }
    if (code == ERR_DLP_BLOCKED) { return 403; }
    if (code == ERR_CACHE || code == ERR_PROVIDER) { return 500; }
    if (code == ERR_HTTP) { return 502; }
    return 500;
}

fn error_code_str(code) {
    if (code == ERR_MODEL_NOT_FOUND) { return "model_not_found"; }
    if (code == ERR_NO_PROVIDER) { return "no_provider"; }
    if (code == ERR_RATE_LIMITED) { return "rate_limit_exceeded"; }
    if (code == ERR_BUDGET_EXCEEDED) { return "budget_exceeded"; }
    if (code == ERR_TIMEOUT) { return "timeout"; }
    if (code == ERR_CACHE) { return "cache_error"; }
    if (code == ERR_PROVIDER) { return "provider_error"; }
    if (code == ERR_DLP_BLOCKED) { return "content_blocked"; }
    if (code == ERR_HTTP) { return "upstream_error"; }
    return "internal_error";
}

# ================================================================
# Provider types
# ================================================================

enum Provider {
    PROV_OLLAMA     = 0;
    PROV_LLAMACPP   = 1;
    PROV_SYNAPSE    = 2;
    PROV_LMSTUDIO   = 3;
    PROV_LOCALAI    = 4;
    PROV_OPENAI     = 5;
    PROV_ANTHROPIC  = 6;
    PROV_DEEPSEEK   = 7;
    PROV_MISTRAL    = 8;
    PROV_GOOGLE     = 9;
    PROV_GROQ       = 10;
    PROV_GROK       = 11;
    PROV_OPENROUTER = 12;
    PROV_WHISPER    = 13;
    PROV_VLLM       = 14;
    PROV_TENSORRT   = 15;
    PROV_ONNX       = 16;
    PROV_COUNT      = 17;
}

fn provider_is_local(prov) {
    if (prov == PROV_OLLAMA || prov == PROV_LLAMACPP || prov == PROV_SYNAPSE) { return 1; }
    if (prov == PROV_LMSTUDIO || prov == PROV_LOCALAI || prov == PROV_WHISPER) { return 1; }
    if (prov == PROV_VLLM || prov == PROV_TENSORRT || prov == PROV_ONNX) { return 1; }
    return 0;
}

fn provider_name(prov) {
    if (prov == PROV_OLLAMA) { return "ollama"; }
    if (prov == PROV_LLAMACPP) { return "llamacpp"; }
    if (prov == PROV_SYNAPSE) { return "synapse"; }
    if (prov == PROV_LMSTUDIO) { return "lmstudio"; }
    if (prov == PROV_LOCALAI) { return "localai"; }
    if (prov == PROV_OPENAI) { return "openai"; }
    if (prov == PROV_ANTHROPIC) { return "anthropic"; }
    if (prov == PROV_DEEPSEEK) { return "deepseek"; }
    if (prov == PROV_MISTRAL) { return "mistral"; }
    if (prov == PROV_GOOGLE) { return "google"; }
    if (prov == PROV_GROQ) { return "groq"; }
    if (prov == PROV_GROK) { return "grok"; }
    if (prov == PROV_OPENROUTER) { return "openrouter"; }
    if (prov == PROV_WHISPER) { return "whisper"; }
    if (prov == PROV_VLLM) { return "vllm"; }
    if (prov == PROV_TENSORRT) { return "tensorrt"; }
    if (prov == PROV_ONNX) { return "onnx"; }
    return "unknown";
}

fn _to_lower(s) {
    var len = strlen(s);
    var out = alloc(len + 1);
    var i = 0;
    while (i < len) {
        var c = load8(s + i);
        if (c >= 65) { if (c <= 90) { c = c + 32; } }
        store8(out + i, c);
        i = i + 1;
    }
    store8(out + len, 0);
    return out;
}

fn provider_parse(name) {
    var lname = _to_lower(name);
    if (streq(lname, "ollama") == 1) { return PROV_OLLAMA; }
    if (streq(lname, "llamacpp") == 1) { return PROV_LLAMACPP; }
    if (streq(lname, "synapse") == 1) { return PROV_SYNAPSE; }
    if (streq(lname, "lmstudio") == 1) { return PROV_LMSTUDIO; }
    if (streq(lname, "localai") == 1) { return PROV_LOCALAI; }
    if (streq(lname, "openai") == 1) { return PROV_OPENAI; }
    if (streq(lname, "anthropic") == 1) { return PROV_ANTHROPIC; }
    if (streq(lname, "deepseek") == 1) { return PROV_DEEPSEEK; }
    if (streq(lname, "mistral") == 1) { return PROV_MISTRAL; }
    if (streq(lname, "google") == 1) { return PROV_GOOGLE; }
    if (streq(lname, "groq") == 1) { return PROV_GROQ; }
    if (streq(lname, "grok") == 1) { return PROV_GROK; }
    if (streq(lname, "openrouter") == 1) { return PROV_OPENROUTER; }
    if (streq(lname, "whisper") == 1) { return PROV_WHISPER; }
    if (streq(lname, "vllm") == 1) { return PROV_VLLM; }
    if (streq(lname, "tensorrt") == 1) { return PROV_TENSORRT; }
    if (streq(lname, "tensorrt-llm") == 1) { return PROV_TENSORRT; }
    if (streq(lname, "trtllm") == 1) { return PROV_TENSORRT; }
    if (streq(lname, "onnx") == 1) { return PROV_ONNX; }
    if (streq(lname, "onnxruntime") == 1) { return PROV_ONNX; }
    return 0 - 1;
}

fn provider_default_url(prov) {
    if (prov == PROV_OLLAMA) { return "http://localhost:11434"; }
    if (prov == PROV_LLAMACPP) { return "http://localhost:8080"; }
    if (prov == PROV_SYNAPSE) { return "http://localhost:7860"; }
    if (prov == PROV_LMSTUDIO) { return "http://localhost:1234"; }
    if (prov == PROV_LOCALAI) { return "http://localhost:8080"; }
    if (prov == PROV_OPENAI) { return "https://api.openai.com"; }
    if (prov == PROV_ANTHROPIC) { return "https://api.anthropic.com"; }
    if (prov == PROV_DEEPSEEK) { return "https://api.deepseek.com"; }
    if (prov == PROV_MISTRAL) { return "https://api.mistral.ai"; }
    if (prov == PROV_GOOGLE) { return "https://generativelanguage.googleapis.com"; }
    # Groq's OpenAI-compatible surface lives under /openai — without the prefix
    # every request builds https://api.groq.com/v1/chat/completions and 404s.
    # rust-old had this right (provider/groq.rs:21); the port dropped it.
    if (prov == PROV_GROQ) { return "https://api.groq.com/openai"; }
    if (prov == PROV_GROK) { return "https://api.x.ai"; }
    if (prov == PROV_OPENROUTER) { return "https://openrouter.ai/api"; }
    if (prov == PROV_VLLM) { return "http://localhost:8000"; }
    if (prov == PROV_TENSORRT) { return "http://localhost:8000"; }
    if (prov == PROV_ONNX) { return "http://localhost:8000"; }
    return "http://localhost:8080";
}

# ================================================================
# Routing strategy
# ================================================================

enum Strategy {
    STRAT_PRIORITY       = 0;
    STRAT_ROUND_ROBIN    = 1;
    STRAT_LOWEST_LATENCY = 2;
    STRAT_DIRECT         = 3;
}

# ================================================================
# Per-request generation options (2.5.2)
# ================================================================
#
# Sampling knobs + the 2.5.0 thinking effort, carried as ONE pointer through
# retry_forward -> provider_forward -> the body builders. Before 2.5.2 only
# `effort` was threaded (as a bare i64) and temperature/top_p/max_tokens were
# dropped on the floor — a client asking for temperature 0 silently got the
# provider default. hoosh is multi-threaded, so these are strictly per-request;
# a global would race.
#
#   +0  effort      0 none | 1 low | 2 medium | 3 high
#   +8  max_tokens  0 = unset (leave it to the provider default)
#   +16 temp_milli  GEN_UNSET = unset, else temperature x1000 (0..2000)
#   +24 top_p_milli GEN_UNSET = unset, else top_p x1000 (0..1000)
#
# Cyrius carries no floats here, so the fractional params are scaled ints and
# re-rendered by _sb_add_milli on the way out.
var GEN_UNSET = 0 - 1;

fn genopts_new(effort, max_tokens, temp_milli, top_p_milli) {
    var g = alloc(32);
    store64(g, effort);
    store64(g + 8, max_tokens);
    store64(g + 16, temp_milli);
    store64(g + 24, top_p_milli);
    return g;
}

# Accessors tolerate a 0 pointer so any caller that has no options (batch
# lifecycle paths, the CLI one-shot) keeps the pre-2.5.2 behavior.
fn gen_effort(g) {
    if (g == 0) { return 0; }
    return load64(g);
}

fn gen_max_tokens(g) {
    if (g == 0) { return 0; }
    return load64(g + 8);
}

fn gen_temp(g) {
    if (g == 0) { return GEN_UNSET; }
    return load64(g + 16);
}

fn gen_top_p(g) {
    if (g == 0) { return GEN_UNSET; }
    return load64(g + 24);
}

# Emit a x1000-scaled value as a JSON number: 700 -> "0.7", 50 -> "0.05",
# 1000 -> "1", 1500 -> "1.5". Trailing zeros trimmed so the wire form matches
# what a client would have sent.
fn _sb_add_milli(sb, v) {
    str_builder_add_int(sb, v / 1000);
    var frac = v % 1000;
    if (frac == 0) { return 0; }
    str_builder_add_cstr(sb, ".");
    if (frac < 100) { str_builder_add_cstr(sb, "0"); }
    if (frac < 10) { str_builder_add_cstr(sb, "0"); }
    while (frac % 10 == 0) { frac = frac / 10; }
    str_builder_add_int(sb, frac);
    return 0;
}

# Append the sampling fields a request actually set. Each is prefixed with a
# comma, so the caller must have emitted at least one field.
#
# `ollama` selects Ollama's NATIVE /api/chat shape, which nests the knobs under
# `options` and calls the output cap `num_predict`. Ollama ignores the
# OpenAI-style top-level fields entirely, so emitting those for an ollama route
# silently dropped every sampling param (2.5.2 forwarded them but Ollama — the
# flagship local provider — never saw them).
fn _sb_add_sampling(sb, gen, ollama) {
    var mt = gen_max_tokens(gen);
    var tp = gen_temp(gen);
    var pp = gen_top_p(gen);
    if (mt <= 0 && tp == GEN_UNSET && pp == GEN_UNSET) { return 0; }

    if (ollama == 1) {
        str_builder_add_cstr(sb, ",\"options\":{");
        var first = 1;
        if (tp != GEN_UNSET) {
            str_builder_add_cstr(sb, "\"temperature\":");
            _sb_add_milli(sb, tp);
            first = 0;
        }
        if (pp != GEN_UNSET) {
            if (first == 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "\"top_p\":");
            _sb_add_milli(sb, pp);
            first = 0;
        }
        if (mt > 0) {
            if (first == 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "\"num_predict\":");
            str_builder_add_int(sb, mt);
        }
        str_builder_add_cstr(sb, "}");
        return 0;
    }

    if (mt > 0) {
        str_builder_add_cstr(sb, ",\"max_tokens\":");
        str_builder_add_int(sb, mt);
    }
    if (tp != GEN_UNSET) {
        str_builder_add_cstr(sb, ",\"temperature\":");
        _sb_add_milli(sb, tp);
    }
    if (pp != GEN_UNSET) {
        str_builder_add_cstr(sb, ",\"top_p\":");
        _sb_add_milli(sb, pp);
    }
    return 0;
}

# ================================================================
# Provider forward outcome (2.5.3)
# ================================================================
#
# A success is a pointer (> 0). 0 is a RETRYABLE failure — connect error,
# timeout, 429, 5xx. FWD_PERMANENT is a failure retrying cannot fix (4xx other
# than 408/429): rust-old gated its backoff on HooshError::is_retryable
# (provider/retry.rs:64), while the port retried everything and burned the full
# schedule on requests that could never succeed.
var FWD_PERMANENT = 0 - 2;

fn status_retryable(st) {
    if (st == 408 || st == 429) { return 1; }
    if (st >= 500) { return 1; }
    if (st >= 400) { return 0; }
    return 1;
}
