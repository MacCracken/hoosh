# http_client.cyr — HTTP POST client for forwarding to provider backends
# Uses raw TCP sockets with proper CRLF byte construction

# Generic request header for an arbitrary method (GET/POST/DELETE/...).
# method must be a cstr like "POST" or "DELETE"; a single space follows it.
fn _build_req_header(buf, method, path, host, body_len) {
    var pos = 0;
    memcpy(buf + pos, method, strlen(method)); pos = pos + strlen(method);
    store8(buf + pos, 32); pos = pos + 1;
    memcpy(buf + pos, path, strlen(path)); pos = pos + strlen(path);
    memcpy(buf + pos, " HTTP/1.0", 9); pos = pos + 9;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Host: ", 6); pos = pos + 6;
    memcpy(buf + pos, host, strlen(host)); pos = pos + strlen(host);
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Type: application/json", 29); pos = pos + 29;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Connection: close", 17); pos = pos + 17;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Length: ", 16); pos = pos + 16;
    var cl_buf = alloc(32);
    var cl_len = fmt_int_buf(body_len, cl_buf);
    memcpy(buf + pos, cl_buf, cl_len); pos = pos + cl_len;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    var _tp = trace_current_or_new();
    var _tpl = strlen(_tp);
    memcpy(buf + pos, "traceparent: ", 13); pos = pos + 13;
    memcpy(buf + pos, _tp, _tpl); pos = pos + _tpl;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    return pos;
}

fn _build_post_header(buf, path, host, body_len) {
    var pos = 0;
    memcpy(buf + pos, "POST ", 5); pos = pos + 5;
    memcpy(buf + pos, path, strlen(path)); pos = pos + strlen(path);
    memcpy(buf + pos, " HTTP/1.0", 9); pos = pos + 9;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Host: ", 6); pos = pos + 6;
    memcpy(buf + pos, host, strlen(host)); pos = pos + strlen(host);
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Type: application/json", 29); pos = pos + 29;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Connection: close", 17); pos = pos + 17;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    memcpy(buf + pos, "Content-Length: ", 16); pos = pos + 16;
    var cl_buf = alloc(32);
    var cl_len = fmt_int_buf(body_len, cl_buf);
    memcpy(buf + pos, cl_buf, cl_len); pos = pos + cl_len;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    var _tp = trace_current_or_new();
    var _tpl = strlen(_tp);
    memcpy(buf + pos, "traceparent: ", 13); pos = pos + 13;
    memcpy(buf + pos, _tp, _tpl); pos = pos + _tpl;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    store8(buf + pos, 13); store8(buf + pos + 1, 10); pos = pos + 2;
    return pos;
}

# HTTP request to the http:// backend named by base_url, with an arbitrary
# method (GET/POST/DELETE). Connects to the URL's host:port — NOT a hardcoded
# localhost — so LAN/remote http backends (e.g. an Ollama box at 192.168.x.y)
# are reachable. body may be 0 with body_len 0 for bodyless methods. Returns
# _http_parse_response result or 0.
fn http_req_local(method, base_url, path, body, body_len) {
    var fd = sys_socket(2, 1, 0);
    if (fd < 0) { return 0; }
    var host = url_host(base_url);
    var sa = sockaddr_in(host_addr(host), url_port(base_url));
    var cr = sys_connect(fd, sa, 16);
    if (cr < 0) { sys_close(fd); return 0; }
    var hdr = alloc(2048);
    var hlen = _build_req_header(hdr, method, path, host, body_len);
    sys_write(fd, hdr, hlen);
    if (body_len > 0) { sys_write(fd, body, body_len); }
    var rbuf = alloc(131072);
    var total = 0;
    var n = 1;
    while (n > 0) {
        n = sys_read(fd, rbuf + total, 131072 - total);
        if (n > 0) { total = total + n; }
    }
    sys_close(fd);
    if (total == 0) { return 0; }
    return _http_parse_response(rbuf, total);
}

# HTTP POST to the http:// backend named by base_url. Returns
# _http_parse_response result or 0.
fn http_post_local(base_url, path, body, body_len) {
    return http_req_local("POST", base_url, path, body, body_len);
}

# HTTP POST that returns the open fd for streaming reads.
# Caller must skip HTTP headers then read chunks.
# Returns fd (>= 0) or -1 on failure.
fn http_post_stream(base_url, path, body, body_len) {
    var fd = sys_socket(2, 1, 0);
    if (fd < 0) { return 0 - 1; }
    var host = url_host(base_url);
    var sa = sockaddr_in(host_addr(host), url_port(base_url));
    var cr = sys_connect(fd, sa, 16);
    if (cr < 0) { sys_close(fd); return 0 - 1; }
    var hdr = alloc(2048);
    var hlen = _build_post_header(hdr, path, host, body_len);
    sys_write(fd, hdr, hlen);
    sys_write(fd, body, body_len);
    return fd;
}

# Skip HTTP response headers on a streaming fd.
# Returns offset into buf where body starts, or -1.
fn stream_skip_headers(fd, buf, buf_sz) {
    var total = 0;
    while (total < buf_sz - 1) {
        var n = sys_read(fd, buf + total, 1);
        if (n <= 0) { return 0 - 1; }
        total = total + 1;
        if (total >= 4) {
            var b0 = load8(buf + total - 4) == 13;
            var b1 = load8(buf + total - 3) == 10;
            var b2 = load8(buf + total - 2) == 13;
            var b3 = load8(buf + total - 1) == 10;
            if (b0 && b1 && b2 && b3) {
                return total;
            }
        }
    }
    return 0 - 1;
}

# Extract port number from URL like "http://localhost:11434"
fn url_port(url) {
    var i = 7;
    while (load8(url + i) != 0) {
        if (load8(url + i) == 58) { return atoi(url + i + 1); }
        if (load8(url + i) == 47) { return 80; }
        i = i + 1;
    }
    return 80;
}

# Host substring of a plaintext http://host[:port][/path] URL, as a fresh
# cstr. Mirrors url_port's assumption that the scheme is "http://" (7 chars) —
# the local raw-socket path is always plaintext (https routes go via sandhi).
# An empty host falls back to "localhost".
fn url_host(url) {
    var start = 7;                            # past "http://"
    var i = start;
    var c = load8(url + i);
    while (c != 0 && c != 58 && c != 47) {    # stop at ':' (port) or '/' (path)
        i = i + 1;
        c = load8(url + i);
    }
    var len = i - start;
    if (len <= 0) {
        var lh = alloc(10);
        memcpy(lh, "localhost", 9);
        store8(lh + 9, 0);
        return lh;
    }
    var h = alloc(len + 1);
    memcpy(h, url + start, len);
    store8(h + len, 0);
    return h;
}

# Resolve a host cstr to a network-byte-order IPv4 address for sockaddr_in:
# "localhost" -> 127.0.0.1; a dotted-quad literal is parsed directly; any other
# name is resolved via sandhi's DNS. On any miss, fall back to loopback (the
# historical hardcoded target) so a misconfigured host fails cleanly as
# "backend unreachable" rather than dereferencing garbage. The DNS leg only
# runs for non-literal hostnames — bare-IP backends (the common local case)
# never touch it.
fn host_addr(host) {
    if (host == 0) { return 0x0100007F; }
    if (strlen(host) == 9 && memeq(host, "localhost", 9) == 1) { return 0x0100007F; }
    var lit = sandhi_net_parse_ipv4(host);
    if (lit != 0 - 1) { return lit; }
    var dns = sandhi_resolve_ipv4(host);
    if (dns != 0 - 1 && dns != 0) { return dns; }
    return 0x0100007F;
}
