# handlers.cyr — HTTP endpoint handlers for the hoosh API
# Requires: types.cyr, route.cyr, router.cyr, budget.cyr, cache.cyr,
#           metrics.cyr, auth.cyr, http_server.cyr, http_client.cyr,
#           provider.cyr, hardware.cyr

# Globals shared with main
var _audit_entries = 1;

# GET /v1/health
fn handle_health(cfd) {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var healthy = 1;
    if (count > 0) {
        var r = load64(routes);
        var port = url_port(route_base_url(r));
        var fd = sys_socket(2, 1, 0);
        if (fd >= 0) {
            var sa = sockaddr_in(0x0100007F, port);
            var cr = sys_connect(fd, sa, 16);
            if (cr < 0) { healthy = 0; }
            sys_close(fd);
        } else { healthy = 0; }
    }
    if (healthy == 1) {
        var body = "{\"status\":\"ok\"}";
        return http_ok(cfd, body, strlen(body));
    }
    var body = "{\"status\":\"degraded\",\"providers_down\":1}";
    return http_respond(cfd, "503", "Service Unavailable", body, strlen(body));
}

# GET /v1/models
fn handle_models(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"object\":\"list\",\"data\":[");
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var first = 1;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            if (first == 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "{\"id\":\"");
            str_builder_add_cstr(sb, provider_name(route_provider(r)));
            str_builder_add_cstr(sb, "\",\"object\":\"model\",\"owned_by\":\"");
            str_builder_add_cstr(sb, provider_name(route_provider(r)));
            str_builder_add_cstr(sb, "\"}");
            first = 0;
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# Find the first enabled route for a provider type, or 0 if none.
fn _router_find_provider(prov) {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            if (route_provider(r) == prov) { return r; }
        }
        i = i + 1;
    }
    return 0;
}

# GET /api/tags — native Ollama-compatible model listing.
# Emits each enabled route's model patterns in Ollama's tags shape so Ollama
# clients pointed at the gateway can enumerate available models.
fn handle_ollama_tags(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"models\":[");
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var first = 1;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            var pats = load64(r + ROUTE_PATTERNS);
            var pn = load64(r + ROUTE_PATTERNS_N);
            var j = 0;
            while (j < pn) {
                var pat = load64(pats + j * 8);
                if (strlen(pat) > 0) {
                    if (first == 0) { str_builder_add_cstr(sb, ","); }
                    str_builder_add_cstr(sb, "{\"name\":\"");
                    str_builder_add_cstr(sb, pat);
                    str_builder_add_cstr(sb, "\",\"model\":\"");
                    str_builder_add_cstr(sb, pat);
                    str_builder_add_cstr(sb,
                    "\",\"modified_at\":\"\",\"size\":0,\"digest\":\"\",");
                    str_builder_add_cstr(sb, "\"details\":{\"family\":\"");
                    str_builder_add_cstr(sb, provider_name(route_provider(r)));
                    str_builder_add_cstr(sb, "\"}}");
                    first = 0;
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# Build a {"name":"<model>"} body cstr for Ollama pull/delete. Returns a
# 16-byte (ptr,len) struct.
fn _build_name_body(model_cstr) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"name\":\"");
    str_builder_add_cstr(sb, model_cstr);
    str_builder_add_cstr(sb, "\"}");
    var s = str_builder_build(sb);
    var r = alloc(16);
    store64(r, to_cstr(s));
    store64(r + 8, str_len(s));
    return r;
}

# Forward a provider lifecycle response (or a gateway error) to the client.
fn _lifecycle_reply(cfd, resp, what) {
    if (resp == 0) {
        hlog_error("lifecycle: backend unreachable");
        return http_error(cfd, "502", "Bad Gateway", what);
    }
    if (http_status(resp) >= 200) {
        if (http_status(resp) < 300) {
            return http_ok(cfd, http_body(resp), http_body_len(resp));
        }
    }
    hlog_warn("lifecycle: backend returned error status");
    return http_error(cfd, "502", "Bad Gateway", what);
}

# POST /v1/models/pull {"model":"..."} — Ollama pull_model.
fn handle_model_pull(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty request body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var model = json_get(pairs, str_from("model"));
    if (model == 0) { return http_bad_request(cfd, "missing model"); }
    var model_cstr = to_cstr(model);
    if (strlen(model_cstr) == 0) { return http_bad_request(cfd, "empty model"); }
    var route = _router_find_provider(PROV_OLLAMA);
    if (route == 0) {
        return http_error(cfd, "404", "Not Found", "no ollama provider configured");
    }
    var fb = _build_name_body(model_cstr);
    var port = url_port(route_base_url(route));
    var resp = http_req_local("POST", port, "/api/pull",
    load64(fb), load64(fb + 8));
    return _lifecycle_reply(cfd, resp, "ollama pull failed");
}

# POST /v1/models/delete {"model":"..."} — Ollama delete_model.
fn handle_model_delete(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty request body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var model = json_get(pairs, str_from("model"));
    if (model == 0) { return http_bad_request(cfd, "missing model"); }
    var model_cstr = to_cstr(model);
    if (strlen(model_cstr) == 0) { return http_bad_request(cfd, "empty model"); }
    var route = _router_find_provider(PROV_OLLAMA);
    if (route == 0) {
        return http_error(cfd, "404", "Not Found", "no ollama provider configured");
    }
    var fb = _build_name_body(model_cstr);
    var port = url_port(route_base_url(route));
    var resp = http_req_local("DELETE", port, "/api/delete",
    load64(fb), load64(fb + 8));
    return _lifecycle_reply(cfd, resp, "ollama delete failed");
}

# POST /v1/training/status {"job_id":"..."} — Synapse training_status.
fn handle_synapse_training(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty request body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var job = json_get(pairs, str_from("job_id"));
    if (job == 0) { return http_bad_request(cfd, "missing job_id"); }
    var job_cstr = to_cstr(job);
    if (strlen(job_cstr) == 0) { return http_bad_request(cfd, "empty job_id"); }
    var route = _router_find_provider(PROV_SYNAPSE);
    if (route == 0) {
        return http_error(cfd, "404", "Not Found", "no synapse provider configured");
    }
    var psb = str_builder_new();
    str_builder_add_cstr(psb, "/v1/training/");
    str_builder_add_cstr(psb, job_cstr);
    var path = to_cstr(str_builder_build(psb));
    var port = url_port(route_base_url(route));
    var resp = http_req_local("GET", port, path, 0, 0);
    return _lifecycle_reply(cfd, resp, "synapse training status failed");
}

# POST /v1/catalog/sync — Synapse sync_catalog.
fn handle_synapse_sync(cfd) {
    var route = _router_find_provider(PROV_SYNAPSE);
    if (route == 0) {
        return http_error(cfd, "404", "Not Found", "no synapse provider configured");
    }
    var port = url_port(route_base_url(route));
    var resp = http_req_local("POST", port, "/v1/catalog/sync", 0, 0);
    return _lifecycle_reply(cfd, resp, "synapse catalog sync failed");
}

# ── Cache warming ──
# Pre-populate the response cache at startup with operator-configured prompts so
# common requests are instant before traffic arrives. The single-threaded
# runtime has no background task, so this runs synchronously at startup. Each
# entry is a 16-byte (model_cstr, prompt_cstr).

fn warming_add(model, prompt) {
    if (_warming == 0) { _warming = vec_new(); }
    var e = alloc(16);
    store64(e, model);
    store64(e + 8, prompt);
    vec_push(_warming, e);
    return 0;
}

# Canonical compact body a client must POST to hit a warmed entry:
# {"model":"M","messages":[{"role":"user","content":"P"}]}
fn _warming_body(model, prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"messages\":[{\"role\":\"user\",\"content\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    return str_builder_build(sb);
}

# Warm the cache from configured prompts. Returns the count warmed. Skips when
# the cache is disabled, the model has no route, or the key is already cached.
fn warming_run() {
    if (_warming == 0) { return 0; }
    if (_cache == 0) { return 0; }
    if (load64(_cache + CACHE_ENABLED) == 0) { return 0; }
    var n = vec_len(_warming);
    if (n == 0) { return 0; }
    var warmed = 0;
    var i = 0;
    while (i < n) {
        var e = vec_get(_warming, i);
        var model = load64(e);
        var prompt = load64(e + 8);
        var route = router_select(_router, model);
        if (route != 0) {
            var body = _warming_body(model, prompt);
            var key = _cache_key(model, to_cstr(body), str_len(body));
            if (cache_get(_cache, key) == 0) {
                var result = retry_forward(_retry_cfg, route, model, prompt, 0, 0, 0, 0);
                if (result != 0) {
                    var env = _chat_completion_body(model, load64(result),
                    load64(result + 16), load64(result + 24), 0);
                    cache_insert(_cache, key, to_cstr(env));
                    warmed = warmed + 1;
                }
            }
        }
        i = i + 1;
    }
    var lsb = str_builder_new();
    str_builder_add_cstr(lsb, "cache warming: ");
    str_builder_add_int(lsb, warmed);
    str_builder_add_cstr(lsb, "/");
    str_builder_add_int(lsb, n);
    str_builder_add_cstr(lsb, " entries cached");
    hlog_info(to_cstr(str_builder_build(lsb)));
    return warmed;
}

# GET /v1/cache/stats
fn handle_cache_stats(cfd) {
    # _chat_lock: map_count over the entries map races the chat path's
    # cache_insert/evict (map_set/map_delete → rehash) on the pool workers
    # (v2.4.0). Snapshot the four values under the lock, then build unlocked.
    mutex_lock(_chat_lock);
    var entries = map_count(load64(_cache + CACHE_ENTRIES));
    var hits = load64(_cache + CACHE_HITS);
    var misses = load64(_cache + CACHE_MISSES);
    var evictions = load64(_cache + CACHE_EVICTIONS);
    mutex_unlock(_chat_lock);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"entries\":");
    str_builder_add_int(sb, entries);
    str_builder_add_cstr(sb, ",\"hits\":");
    str_builder_add_int(sb, hits);
    str_builder_add_cstr(sb, ",\"misses\":");
    str_builder_add_int(sb, misses);
    str_builder_add_cstr(sb, ",\"evictions\":");
    str_builder_add_int(sb, evictions);
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/tokens/pools
fn handle_token_pools(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"pools\":[");
    # _chat_lock: map_keys/map_get over _budget races a concurrent reload's
    # budget_add_pool (map_set → rehash) and pool-field writes from chat/token
    # reserve/commit on the pool workers (v2.4.0). Hold it for the snapshot.
    mutex_lock(_chat_lock);
    var keys = map_keys(_budget);
    var first = 1;
    var i = 0;
    while (i < vec_len(keys)) {
        var name = vec_get(keys, i);
        var p = map_get(_budget, name);
        if (first == 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "{\"name\":\"");
        str_builder_add_cstr(sb, name);
        str_builder_add_cstr(sb, "\",\"capacity\":");
        str_builder_add_int(sb, load64(p + POOL_CAPACITY));
        str_builder_add_cstr(sb, ",\"used\":");
        str_builder_add_int(sb, load64(p + POOL_USED));
        str_builder_add_cstr(sb, ",\"available\":");
        str_builder_add_int(sb, pool_available(p));
        str_builder_add_cstr(sb, "}");
        first = 0;
        i = i + 1;
    }
    mutex_unlock(_chat_lock);
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/costs
fn handle_costs(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"total_requests\":");
    str_builder_add_int(sb, _met_requests);
    str_builder_add_cstr(sb, ",\"total_prompt_tokens\":");
    str_builder_add_int(sb, _met_prompt_tokens);
    str_builder_add_cstr(sb, ",\"total_completion_tokens\":");
    str_builder_add_int(sb, _met_comp_tokens);
    str_builder_add_cstr(sb, ",\"providers\":[");
    var routes = load64(_router + ROUTER_ROUTES);
    var rcount = load64(_router + ROUTER_COUNT);
    var first = 1;
    var ci = 0;
    while (ci < rcount) {
        var r = load64(routes + ci * 8);
        if (first == 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "{\"provider\":\"");
        str_builder_add_cstr(sb, provider_name(route_provider(r)));
        str_builder_add_cstr(sb, "\",\"base_url\":\"");
        str_builder_add_cstr(sb, route_base_url(r));
        str_builder_add_cstr(sb, "\",\"is_local\":");
        if (provider_is_local(route_provider(r)) == 1) { str_builder_add_cstr(sb, "true"); }
        else { str_builder_add_cstr(sb, "false"); }
        str_builder_add_cstr(sb, "}");
        first = 0;
        ci = ci + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/cost/estimate {model, input_tokens, output_tokens} — per-token cost.
fn handle_cost_estimate(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty request body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var model = json_get(pairs, str_from("model"));
    if (model == 0) { return http_bad_request(cfd, "missing model"); }
    var model_cstr = to_cstr(model);
    var in_tok = 0;
    var it = json_get(pairs, str_from("input_tokens"));
    if (it != 0) { in_tok = str_to_int(it); }
    var out_tok = 0;
    var ot = json_get(pairs, str_from("output_tokens"));
    if (ot != 0) { out_tok = str_to_int(ot); }
    # Provider of the route that serves this model (drives fallback pricing).
    var prov = PROV_OPENAI;
    var route = router_select(_router, model_cstr);
    if (route != 0) { prov = route_provider(route); }
    var micro = estimate_cost_micro(model_cstr, prov, in_tok, out_tok);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model_cstr);
    str_builder_add_cstr(sb, "\",\"input_tokens\":");
    str_builder_add_int(sb, in_tok);
    str_builder_add_cstr(sb, ",\"output_tokens\":");
    str_builder_add_int(sb, out_tok);
    str_builder_add_cstr(sb, ",\"estimated_cost_micro_usd\":");
    str_builder_add_int(sb, micro);
    str_builder_add_cstr(sb, ",\"estimated_cost_usd\":\"");
    pricing_append_usd(sb, micro);
    str_builder_add_cstr(sb, "\"}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# Parse a JSON boolean field (true → 1, absent/false → 0).
fn _req_bool(pairs, key) {
    var v = json_get(pairs, str_from(key));
    if (v == 0) { return 0; }
    if (str_eq_cstr(v, "true") == 1) { return 1; }
    return 0;
}

# POST /v1/cost/recommend — cheapest *capable* model for a request profile.
# Body: {input_tokens, max_output_tokens, uses_tools, has_vision,
# has_system_prompt}. Classifies the request's minimum tier, then among the
# configured exact (non-wildcard) model routes keeps only those whose metadata
# satisfies tier/modality/tool/system/context requirements, and returns the
# cheapest by estimated cost. Models without metadata (or wildcard-only routes)
# are skipped. Mirrors CostOptimizer::recommend.
fn handle_cost_recommend(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty request body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var in_tok = 0;
    var it = json_get(pairs, str_from("input_tokens"));
    if (it != 0) { in_tok = str_to_int(it); }
    var out_tok = 0;
    var ot = json_get(pairs, str_from("max_output_tokens"));
    if (ot != 0) { out_tok = str_to_int(ot); }
    var uses_tools = _req_bool(pairs, "uses_tools");
    var has_vision = _req_bool(pairs, "has_vision");
    var has_system = _req_bool(pairs, "has_system_prompt");
    var min_tier = classify_complexity(in_tok, uses_tools, has_vision);
    var total_tokens = in_tok + out_tok;

    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var best_model = 0;
    var best_prov = 0;
    var best_tier = 0;
    var best_cost = 0x7FFFFFFFFFFFFFFF;
    var meta = alloc(40);
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            var pats = load64(r + ROUTE_PATTERNS);
            var pn = load64(r + ROUTE_PATTERNS_N);
            var j = 0;
            while (j < pn) {
                var pat = load64(pats + j * 8);
                var pl = strlen(pat);
                if (pl > 0 && load8(pat + pl - 1) != 42) {
                    if (metadata_lookup(pat, meta) == 1) {
                        if (meets_requirements(meta, min_tier, has_vision,
                        uses_tools, has_system, total_tokens) == 1) {
                            var c = estimate_cost_micro(pat, route_provider(r),
                            in_tok, out_tok);
                            if (c < best_cost) {
                                best_cost = c;
                                best_model = pat;
                                best_prov = route_provider(r);
                                best_tier = load64(meta + 8);
                            }
                        }
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    if (best_model == 0) {
        return http_error(cfd, "404", "Not Found",
        "no capable exact-model route for this request profile");
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, best_model);
    str_builder_add_cstr(sb, "\",\"provider\":\"");
    str_builder_add_cstr(sb, provider_name(best_prov));
    str_builder_add_cstr(sb, "\",\"tier\":\"");
    str_builder_add_cstr(sb, tier_name(best_tier));
    str_builder_add_cstr(sb, "\",\"required_tier\":\"");
    str_builder_add_cstr(sb, tier_name(min_tier));
    str_builder_add_cstr(sb, "\",\"estimated_cost_micro_usd\":");
    str_builder_add_int(sb, best_cost);
    str_builder_add_cstr(sb, ",\"estimated_cost_usd\":\"");
    pricing_append_usd(sb, best_cost);
    str_builder_add_cstr(sb, "\"}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/health/providers
fn handle_health_providers(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"providers\":[");
    var routes = load64(_router + ROUTER_ROUTES);
    var rcount = load64(_router + ROUTER_COUNT);
    var first = 1;
    var hi = 0;
    while (hi < rcount) {
        var r = load64(routes + hi * 8);
        if (route_enabled(r) == 1) {
            var port = url_port(route_base_url(r));
            var up = 0;
            var fd = sys_socket(2, 1, 0);
            if (fd >= 0) {
                var sa = sockaddr_in(0x0100007F, port);
                var cr = sys_connect(fd, sa, 16);
                if (cr >= 0) { up = 1; }
                sys_close(fd);
            }
            # HealthChanged event on a flip (state per route base_url; stored as
            # up+1 so 0 = never-seen). _chat_lock guards the shared _health_map —
            # concurrent health polls run on different pool workers (v2.4.0).
            var hkey = route_base_url(r);
            var hcur = up + 1;
            mutex_lock(_chat_lock);
            var hprev = map_get(_health_map, hkey);
            map_set(_health_map, hkey, hcur);
            mutex_unlock(_chat_lock);
            if (hprev != 0 && hprev != hcur) {
                event_health_changed(provider_name(route_provider(r)), hkey, up);
            }
            if (first == 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "{\"provider\":\"");
            str_builder_add_cstr(sb, provider_name(route_provider(r)));
            str_builder_add_cstr(sb, "\",\"base_url\":\"");
            str_builder_add_cstr(sb, route_base_url(r));
            str_builder_add_cstr(sb, "\",\"healthy\":");
            if (up == 1) { str_builder_add_cstr(sb, "true"); }
            else { str_builder_add_cstr(sb, "false"); }
            str_builder_add_cstr(sb, "}");
            first = 0;
        }
        hi = hi + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/tokens/check
fn handle_tokens_check(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var pool_name = json_get(pairs, str_from("pool"));
    var tokens_str = json_get(pairs, str_from("tokens"));
    if (pool_name == 0) { return http_bad_request(cfd, "missing 'pool'"); }
    var pname = to_cstr(pool_name);
    var tokens = 0;
    if (tokens_str != 0) { tokens = str_to_int(tokens_str); }
    # _chat_lock guards the shared budget — concurrent with chat reserve/commit
    # and other token handlers on the pool workers (v2.4.0).
    mutex_lock(_chat_lock);
    var p = budget_get_pool(_budget, pname);
    var avail = 0;
    if (p != 0) { avail = pool_available(p); }
    mutex_unlock(_chat_lock);
    if (p == 0) { return http_error(cfd, "404", "Not Found", "token pool not found"); }
    var allowed = 0;
    if (avail >= tokens) { allowed = 1; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"allowed\":");
    if (allowed == 1) { str_builder_add_cstr(sb, "true"); }
    else { str_builder_add_cstr(sb, "false"); }
    str_builder_add_cstr(sb, ",\"available\":");
    str_builder_add_int(sb, avail);
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/tokens/reserve
fn handle_tokens_reserve(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var pool_name = json_get(pairs, str_from("pool"));
    var tokens_str = json_get(pairs, str_from("tokens"));
    if (pool_name == 0) { return http_bad_request(cfd, "missing 'pool'"); }
    var pname = to_cstr(pool_name);
    var tokens = 0;
    if (tokens_str != 0) { tokens = str_to_int(tokens_str); }
    mutex_lock(_chat_lock);
    var reserved = budget_reserve(_budget, pname, tokens);
    var p = budget_get_pool(_budget, pname);
    var avail = 0;
    if (p != 0) { avail = pool_available(p); }
    mutex_unlock(_chat_lock);
    if (p == 0) { return http_error(cfd, "404", "Not Found", "token pool not found"); }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"reserved\":");
    if (reserved == 1) { str_builder_add_cstr(sb, "true"); }
    else { str_builder_add_cstr(sb, "false"); }
    str_builder_add_cstr(sb, ",\"available\":");
    str_builder_add_int(sb, avail);
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/tokens/report
fn handle_tokens_report(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var pool_name = json_get(pairs, str_from("pool"));
    var reserved_str = json_get(pairs, str_from("reserved"));
    var actual_str = json_get(pairs, str_from("actual"));
    if (pool_name == 0) { return http_bad_request(cfd, "missing 'pool'"); }
    var pname = to_cstr(pool_name);
    var reserved = 0;
    var actual = 0;
    if (reserved_str != 0) { reserved = str_to_int(reserved_str); }
    if (actual_str != 0) { actual = str_to_int(actual_str); }
    mutex_lock(_chat_lock);
    var p = budget_get_pool(_budget, pname);
    var used = 0;
    var avail = 0;
    if (p != 0) {
        pool_commit(p, reserved, actual);
        used = load64(p + POOL_USED);
        avail = pool_available(p);
    }
    mutex_unlock(_chat_lock);
    if (p == 0) { return http_error(cfd, "404", "Not Found", "token pool not found"); }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"used\":");
    str_builder_add_int(sb, used);
    str_builder_add_cstr(sb, ",\"available\":");
    str_builder_add_int(sb, avail);
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/audit
fn handle_audit(cfd) {
    if (_audit_chain == 0) {
        return http_error(cfd, "404", "Not Found",
        "audit logging not enabled");
    }
    var sb = str_builder_new();
    audit_json(_audit_chain, sb, 50);
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/health/heartbeat
fn handle_heartbeat(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"nodes\":[");
    var routes = load64(_router + ROUTER_ROUTES);
    var rcount = load64(_router + ROUTER_COUNT);
    var first = 1;
    var hi = 0;
    while (hi < rcount) {
        var r = load64(routes + hi * 8);
        if (route_enabled(r) == 1) {
            if (first == 0) { str_builder_add_cstr(sb, ","); }
            str_builder_add_cstr(sb, "{\"id\":\"");
            str_builder_add_cstr(sb, provider_name(route_provider(r)));
            str_builder_add_cstr(sb, ":");
            str_builder_add_cstr(sb, route_base_url(r));
            str_builder_add_cstr(sb, "\",\"status\":\"online\"}");
            first = 0;
        }
        hi = hi + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/queue/status
fn handle_queue_status(cfd) {
    var body = "{\"pending\":0,\"processing\":0}";
    return http_ok(cfd, body, strlen(body));
}

# GET /v1/hardware
fn handle_hardware(cfd) {
    var sb = str_builder_new();
    hw_summary_json(sb);
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/hardware/placement
fn handle_hw_placement(cfd, body_ptr, body_len) {
    if (body_len == 0) {
        return http_bad_request(cfd, "empty body");
    }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) {
        return http_bad_request(cfd, "invalid JSON");
    }
    var mp_str = json_get(pairs, str_from("model_params"));
    var model_params = 0;
    if (mp_str != 0) { model_params = str_to_int(mp_str); }
    # Also try extracting from model name
    if (model_params == 0) {
        var mn = json_get(pairs, str_from("model"));
        if (mn != 0) {
            model_params = _hoosh_parse_model_params(to_cstr(mn));
        }
    }
    if (model_params == 0) { model_params = 7000000000; }
    var quant = 0;
    var q_str = json_get(pairs, str_from("quantization"));
    if (q_str != 0) {
        var qs = to_cstr(q_str);
        if (streq(qs, "fp16") == 1) { quant = QUANT_FP16; }
        if (streq(qs, "bf16") == 1) { quant = QUANT_BF16; }
        if (streq(qs, "int8") == 1) { quant = QUANT_INT8; }
        if (streq(qs, "int4") == 1) { quant = QUANT_INT4; }
    }
    var sb = str_builder_new();
    hw_placement_json(sb, model_params, quant);
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/hardware/model-format — detect a model's container format from the
# RAW model bytes in the request body (send the file or at least its header; the
# detector reads magic/metadata). No filesystem access (safer than a path arg).
# Returns ai-hwaccel's ModelMetadata JSON {format, param_count, dtype, ...}.
fn handle_hw_model_format(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body (send raw model bytes)"); }
    var m = detect_format_from_bytes(body_ptr, body_len);
    if (m == 0) { return http_bad_request(cfd, "unrecognized model format"); }
    return http_json_ok(cfd, model_meta_to_json(m));
}

# Map a requirement string to the ai-hwaccel REQ_* enum, or -1 if unknown.
fn _hoosh_req_from_str(s) {
    if (streq(s, "none") == 1) { return REQ_NONE; }
    if (streq(s, "gpu") == 1) { return REQ_GPU; }
    if (streq(s, "tpu") == 1) { return REQ_TPU; }
    if (streq(s, "gaudi") == 1) { return REQ_GAUDI; }
    if (streq(s, "aws-neuron") == 1) { return REQ_AWS_NEURON; }
    if (streq(s, "gpu-or-tpu") == 1) { return REQ_GPU_OR_TPU; }
    if (streq(s, "any-accelerator") == 1) { return REQ_ANY_ACCELERATOR; }
    return 0 - 1;
}

# POST /v1/hardware/requirement-match — does the detected hardware satisfy a
# scheduler requirement? Body {requirement: "gpu"|"tpu"|..., min_chips?: N}.
# Reads the immutable hw registry (detected once at startup) — no lock needed.
fn handle_hw_requirement_match(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var req_str = json_get(pairs, str_from("requirement"));
    if (req_str == 0) { return http_bad_request(cfd, "missing 'requirement'"); }
    var req = _hoosh_req_from_str(to_cstr(req_str));
    if (req < 0) { return http_bad_request(cfd, "unknown requirement"); }
    var min_chips = 1;
    var mc_str = json_get(pairs, str_from("min_chips"));
    if (mc_str != 0) { min_chips = str_to_int(mc_str); }
    var hit = 0;
    if (hw_ready() == 1) {
        var np = reg_num_profiles(_hw_registry);
        var i = 0;
        while (i < np && hit == 0) {
            var p = reg_get_profile(_hw_registry, i);
            if (requirement_satisfied(req, min_chips, p) == 1) { hit = p; }
            i = i + 1;
        }
    }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"requirement\":\"");
    str_builder_add_cstr(sb, requirement_name(req));
    str_builder_add_cstr(sb, "\",\"min_chips\":");
    str_builder_add_int(sb, min_chips);
    str_builder_add_cstr(sb, ",\"satisfied\":");
    if (hit != 0) { str_builder_add_cstr(sb, "true"); } else { str_builder_add_cstr(sb, "false"); }
    if (hit != 0) {
        str_builder_add_cstr(sb, ",\"device\":\"");
        str_builder_add_cstr(sb, accel_name(profile_accel_type(hit)));
        str_builder_add_cstr(sb, "\"");
    }
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/hardware/models
fn handle_hw_models(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"models\":[");
    # Check common model sizes
    var sizes = alloc(48);
    store64(sizes, 1000000000);
    store64(sizes + 8, 3000000000);
    store64(sizes + 16, 7000000000);
    store64(sizes + 24, 13000000000);
    store64(sizes + 32, 70000000000);
    store64(sizes + 40, 405000000000);
    var names = alloc(48);
    store64(names, "1B");
    store64(names + 8, "3B");
    store64(names + 16, "7B");
    store64(names + 24, "13B");
    store64(names + 32, "70B");
    store64(names + 40, "405B");
    var first = 1;
    var i = 0;
    while (i < 6) {
        var params = load64(sizes + i * 8);
        var quant = hw_suggest_quant(params);
        var needed = reg_estimate_memory(params, quant);
        var fits = 0;
        var best = hw_best_device();
        if (best != 0) {
            if (needed <= profile_memory_bytes(best)) {
                fits = 1;
            }
        }
        if (first == 0) { str_builder_add_cstr(sb, ","); }
        str_builder_add_cstr(sb, "{\"size\":\"");
        str_builder_add_cstr(sb, load64(names + i * 8));
        str_builder_add_cstr(sb, "\",\"quant\":\"");
        str_builder_add_cstr(sb, quant_name(quant));
        str_builder_add_cstr(sb, "\",\"memory_bytes\":");
        str_builder_add_int(sb, needed);
        str_builder_add_cstr(sb, ",\"fits\":");
        if (fits == 1) {
            str_builder_add_cstr(sb, "true}");
        } else {
            str_builder_add_cstr(sb, "false}");
        }
        first = 0;
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# POST /v1/hardware/cost — cloud instance $ recommendations for a model
# size + quantization (ai-hwaccel cost.cyr; reads data/cloud_pricing.json,
# degrades to empty recommendations if that file is absent).
fn handle_hw_cost(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var mn = json_get(pairs, str_from("model"));
    if (mn == 0) { return http_bad_request(cfd, "missing 'model' (e.g. \"70b\")"); }
    var quant = QUANT_INT8;
    var q_str = json_get(pairs, str_from("quantization"));
    if (q_str != 0) {
        quant = quant_from_str(to_cstr(q_str));
        if (quant < 0) { return http_bad_request(cfd, "invalid quantization (fp32/fp16/bf16/int8/int4)"); }
    }
    return http_json_ok(cfd, cost_to_json(to_cstr(mn), quant));
}

# POST /v1/hardware/training-estimate — training memory breakdown for a
# model size + method + target (ai-hwaccel training.cyr; pure compute).
fn handle_hw_training(cfd, body_ptr, body_len) {
    if (body_len == 0) { return http_bad_request(cfd, "empty body"); }
    var pairs = json_parse(str_new(body_ptr, body_len));
    if (pairs == 0) { return http_bad_request(cfd, "invalid JSON"); }
    var params_m = 0;
    var mn = json_get(pairs, str_from("model"));
    if (mn != 0) { params_m = _hoosh_parse_model_params(to_cstr(mn)) / 1000000; }
    var mp = json_get(pairs, str_from("model_params_m"));
    if (mp != 0) { params_m = str_to_int(mp); }
    if (params_m == 0) { return http_bad_request(cfd, "missing 'model' (e.g. \"7b\") or 'model_params_m'"); }
    var method = TRAIN_LORA;
    var meth_s = json_get(pairs, str_from("method"));
    if (meth_s != 0) {
        method = training_method_from_str(to_cstr(meth_s));
        if (method < 0) {
            var emsg = "invalid 'method' (full/lora/qlora-4bit/qlora-8bit/prefix/dpo/rlhf/distillation)";
            return http_bad_request(cfd, emsg);
        }
    }
    var target = TARGET_GPU;
    var tname = "gpu";
    var tgt_s = json_get(pairs, str_from("target"));
    if (tgt_s != 0) {
        var ts = to_cstr(tgt_s);
        if (streq(ts, "gpu") == 1) { target = TARGET_GPU; tname = "gpu"; }
        elif (streq(ts, "tpu") == 1) { target = TARGET_TPU; tname = "tpu"; }
        elif (streq(ts, "gaudi") == 1) { target = TARGET_GAUDI; tname = "gaudi"; }
        else { return http_bad_request(cfd, "invalid target (gpu/tpu/gaudi)"); }
    }
    var e = estimate_training_memory(params_m, method, target);
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model_params_millions\":");
    str_builder_add_int(sb, params_m);
    str_builder_add_cstr(sb, ",\"method\":\"");
    str_builder_add_cstr(sb, training_method_name(method));
    str_builder_add_cstr(sb, "\",\"target\":\"");
    str_builder_add_cstr(sb, tname);
    str_builder_add_cstr(sb, "\",\"estimate\":");
    training_to_json(sb, e);
    str_builder_add_cstr(sb, "}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /v1/hardware/compatible-models — catalogue models that fit the
# detected accelerator memory at int8 (ai-hwaccel model.cyr; reads
# data/models.json, degrades to empty list if that file is absent).
fn handle_hw_compatible(cfd) {
    var quant = QUANT_INT8;
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"quantization\":\"int8\",\"models\":[");
    var models = load_models();
    if (hw_ready() == 1) {
        if (vec_len(models) > 0) {
            var avail = hw_accel_memory();
            var compat = compatible_with_registry(models, _hw_registry, quant);
            var first = 1;
            var i = 0;
            while (i < vec_len(compat)) {
                var m = vec_get(compat, i);
                if (first == 0) { str_builder_add_cstr(sb, ","); }
                str_builder_add_cstr(sb, "{\"name\":\"");
                str_builder_add_cstr(sb, model_name(m));
                str_builder_add_cstr(sb, "\",\"family\":\"");
                str_builder_add_cstr(sb, model_family(m));
                str_builder_add_cstr(sb, "\",\"params_b\":");
                str_builder_add_int(sb, model_params_b_x1000(m) / 1000);
                str_builder_add_cstr(sb, ",\"headroom_pct\":");
                str_builder_add_int(sb, model_headroom_x100(m, quant, avail) / 100);
                str_builder_add_cstr(sb, "}");
                first = 0;
                i = i + 1;
            }
        }
    }
    str_builder_add_cstr(sb, "]}");
    return http_json_ok(cfd, str_builder_build(sb));
}

# GET /metrics
fn handle_metrics(cfd) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "# HELP hoosh_requests_total Total inference requests\n");
    str_builder_add_cstr(sb, "# TYPE hoosh_requests_total counter\n");
    str_builder_add_cstr(sb, "hoosh_requests_total ");
    str_builder_add_int(sb, _met_requests);
    str_builder_add_cstr(sb, "\n# HELP hoosh_tokens_total Total tokens processed\n");
    str_builder_add_cstr(sb, "# TYPE hoosh_tokens_total counter\n");
    str_builder_add_cstr(sb, "hoosh_tokens_prompt_total ");
    str_builder_add_int(sb, _met_prompt_tokens);
    str_builder_add_cstr(sb, "\nhoosh_tokens_completion_total ");
    str_builder_add_int(sb, _met_comp_tokens);
    str_builder_add_cstr(sb, "\n# HELP hoosh_providers_configured ");
    str_builder_add_cstr(sb, "Number of configured providers\n");
    str_builder_add_cstr(sb, "# TYPE hoosh_providers_configured gauge\n");
    str_builder_add_cstr(sb, "hoosh_providers_configured ");
    str_builder_add_int(sb, _met_providers);
    str_builder_add_cstr(sb, "\n");
    metrics_emit_latency(sb);
    str_builder_add_cstr(sb, "# HELP hoosh_events_published_total Provider events published to the bus\n");
    str_builder_add_cstr(sb, "# TYPE hoosh_events_published_total counter\n");
    str_builder_add_cstr(sb, "hoosh_events_published_total ");
    str_builder_add_int(sb, events_total_published());
    str_builder_add_cstr(sb, "\n");
    var body = str_builder_build(sb);
    var bd = to_cstr(body);
    var cr = make_crlf();
    var hdr = str_builder_new();
    str_builder_add_cstr(hdr, "HTTP/1.1 200 OK");
    str_builder_add_cstr(hdr, cr);
    str_builder_add_cstr(hdr, "Content-Type: text/plain; charset=utf-8");
    str_builder_add_cstr(hdr, cr);
    str_builder_add_cstr(hdr, "Content-Length: ");
    str_builder_add_int(hdr, str_len(body));
    str_builder_add_cstr(hdr, cr);
    str_builder_add_cstr(hdr, cr);
    var hdr_s = str_builder_build(hdr);
    sys_write(cfd, to_cstr(hdr_s), str_len(hdr_s));
    sys_write(cfd, bd, str_len(body));
    return 0;
}

# Validate chat request fields. Returns 0 if valid, error string if not.
fn _validate_chat(pairs, body_ptr, body_len) {
    var model = json_get(pairs, str_from("model"));
    if (model == 0) { return "model field is required"; }
    var mc = to_cstr(model);
    var mlen = strlen(mc);
    if (mlen == 0) { return "model field is required"; }
    if (mlen > 256) { return "invalid model name"; }
    # Check for control chars in model name
    var vi = 0;
    while (vi < mlen) {
        var vc = load8(mc + vi);
        if (vc < 32) { return "invalid model name"; }
        vi = vi + 1;
    }
    # Check messages array exists
    var has_messages = 0;
    vi = 0;
    while (vi < body_len - 11) {
        if (memeq(body_ptr + vi, "\"messages\":", 11) == 1) { has_messages = 1; break; }
        vi = vi + 1;
    }
    var has_prompt = 0;
    if (json_get(pairs, str_from("prompt")) != 0) { has_prompt = 1; }
    if (has_messages == 0) {
        if (has_prompt == 0) { return "messages array is required"; }
    }
    return 0;
}

# Check if request has "stream":true
fn _req_is_stream(body_ptr, body_len) {
    var i = 0;
    while (i < body_len - 13) {
        if (memeq(body_ptr + i, "\"stream\":true", 13) == 1) {
            return 1;
        }
        if (memeq(body_ptr + i, "\"stream\": true", 14) == 1) {
            return 1;
        }
        i = i + 1;
    }
    return 0;
}

# Extract raw "messages" array from request body
# Extract the raw "tools":[...] array span (ptr,len) from a request body, or 0.
# Balanced-bracket scan with JSON string handling (mirrors _extract_messages).
fn _extract_tools(body_ptr, body_len) {
    var i = 0;
    while (i + 9 < body_len) {
        if (memeq(body_ptr + i, "\"tools\":", 8) == 1) {
            var j = i + 8;
            while (j < body_len && load8(body_ptr + j) == 32) { j = j + 1; }
            if (j < body_len && load8(body_ptr + j) == 91) {
                var depth = 1;
                var start = j;
                j = j + 1;
                while (j < body_len && depth > 0) {
                    var ch = load8(body_ptr + j);
                    if (ch == 91) { depth = depth + 1; }
                    if (ch == 93) { depth = depth - 1; }
                    if (ch == 34) {
                        j = j + 1;
                        while (j < body_len) {
                            if (load8(body_ptr + j) == 34) { break; }
                            if (load8(body_ptr + j) == 92) { j = j + 1; }
                            j = j + 1;
                        }
                    }
                    j = j + 1;
                }
                var len = j - start;
                # An empty "[]" is no tools.
                if (len <= 2) { return 0; }
                var result = alloc(16);
                store64(result, body_ptr + start);
                store64(result + 8, len);
                return result;
            }
            return 0;
        }
        i = i + 1;
    }
    return 0;
}

fn _extract_messages(body_ptr, body_len) {
    var mi = 0;
    while (mi < body_len - 12) {
        if (memeq(body_ptr + mi, "\"messages\":", 11) == 1) {
            mi = mi + 11;
            while (mi < body_len) {
                if (load8(body_ptr + mi) != 32) { break; }
                mi = mi + 1;
            }
            if (mi < body_len) {
                if (load8(body_ptr + mi) == 91) {
                    var depth = 1;
                    var ms = mi;
                    mi = mi + 1;
                    while (mi < body_len && depth > 0) {
                        var ch = load8(body_ptr + mi);
                        if (ch == 91) { depth = depth + 1; }
                        if (ch == 93) { depth = depth - 1; }
                        if (ch == 34) {
                            mi = mi + 1;
                            while (mi < body_len) {
                                if (load8(body_ptr + mi) == 34) { break; }
                                if (load8(body_ptr + mi) == 92) {
                                    mi = mi + 1;
                                }
                                mi = mi + 1;
                            }
                        }
                        mi = mi + 1;
                    }
                    # Return packed: ptr * 0x100000000 + len
                    var mlen = mi - ms;
                    var result = alloc(16);
                    store64(result, body_ptr + ms);
                    store64(result + 8, mlen);
                    return result;
                }
            }
            break;
        }
        mi = mi + 1;
    }
    return 0;
}

# Stream one SSE chunk wrapping a content token
fn _sse_chunk(cfd, model, content, content_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"chatcmpl-hoosh\",");
    str_builder_add_cstr(sb, "\"object\":\"chat.completion.chunk\",");
    str_builder_add_cstr(sb, "\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"choices\":[{\"index\":0,");
    str_builder_add_cstr(sb, "\"delta\":{\"content\":\"");
    # Add content (already escaped from provider)
    var cs = str_builder_build(sb);
    var prefix = to_cstr(cs);
    var plen = strlen(prefix);
    var suffix = "\"},\"finish_reason\":null}]}";
    var slen = strlen(suffix);
    var total = plen + content_len + slen;
    var buf = alloc(total + 1);
    memcpy(buf, prefix, plen);
    memcpy(buf + plen, content, content_len);
    memcpy(buf + plen + content_len, suffix, slen);
    store8(buf + total, 0);
    http_sse_event(cfd, buf, total);
    return 0;
}

# Stream one SSE chunk wrapping a tool_calls delta (passed through verbatim).
fn _sse_tool_chunk(cfd, model, tool_calls) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"chatcmpl-hoosh\",");
    str_builder_add_cstr(sb, "\"object\":\"chat.completion.chunk\",");
    str_builder_add_cstr(sb, "\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"choices\":[{\"index\":0,");
    str_builder_add_cstr(sb, "\"delta\":{\"tool_calls\":");
    str_builder_add_cstr(sb, tool_calls);
    str_builder_add_cstr(sb, "},\"finish_reason\":null}]}");
    var s = str_builder_build(sb);
    var d = to_cstr(s);
    http_sse_event(cfd, d, str_len(s));
    return 0;
}

# Send the final SSE stop chunk
fn _sse_stop(cfd, model) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"chatcmpl-hoosh\",");
    str_builder_add_cstr(sb, "\"object\":\"chat.completion.chunk\",");
    str_builder_add_cstr(sb, "\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"choices\":[{\"index\":0,");
    str_builder_add_cstr(sb, "\"delta\":{},");
    str_builder_add_cstr(sb, "\"finish_reason\":\"stop\"}]}");
    var s = str_builder_build(sb);
    var d = to_cstr(s);
    http_sse_event(cfd, d, str_len(s));
    http_sse_done(cfd);
    return 0;
}

# SSE event callback for incremental remote streaming (sandhi_http_stream
# contract: return nonzero to continue, 0 to stop). ctx layout:
#   cfd(8) model(8) provider(8) emitted(8).
# Each event's data is the provider's SSE payload; the per-provider extractor
# (already used on the non-streaming path) pulls the delta text out of it.
# Convert an Anthropic streaming event into an OpenAI tool_call delta and emit
# it. `content_block_start` (tool_use) carries the id+name; `input_json_delta`
# carries incremental `partial_json` argument fragments. Returns 1 if emitted.
fn _emit_anthropic_tool_delta(cfd, model, data, dlen) {
    var is_start = _cmp_substr(data, dlen, "content_block_start", 19) >= 0;
    var is_delta = _cmp_substr(data, dlen, "input_json_delta", 16) >= 0;
    if (is_start == 0 && is_delta == 0) { return 0; }
    var idx = _json_extract_int(data, dlen, "index", 5);
    if (is_start == 1) {
        if (_cmp_substr(data, dlen, "tool_use", 8) < 0) { return 0; }
        var idf = _json_obj_str_field(data, dlen, "id", 2);
        var nmf = _json_obj_str_field(data, dlen, "name", 4);
        if (idf == 0 || nmf == 0) { return 0; }
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "[{\"index\":");
        str_builder_add_int(sb, idx);
        str_builder_add_cstr(sb, ",\"id\":\"");
        str_builder_add(sb, str_new(load64(idf), load64(idf + 8)));
        str_builder_add_cstr(sb, "\",\"type\":\"function\",\"function\":{\"name\":\"");
        str_builder_add(sb, str_new(load64(nmf), load64(nmf + 8)));
        str_builder_add_cstr(sb, "\",\"arguments\":\"\"}}]");
        _sse_tool_chunk(cfd, model, to_cstr(str_builder_build(sb)));
        return 1;
    }
    var pjf = _json_obj_str_field(data, dlen, "partial_json", 12);
    if (pjf == 0) { return 0; }
    var sb2 = str_builder_new();
    str_builder_add_cstr(sb2, "[{\"index\":");
    str_builder_add_int(sb2, idx);
    str_builder_add_cstr(sb2, ",\"function\":{\"arguments\":\"");
    # partial_json is already escaped to fit the event string — emit verbatim.
    str_builder_add(sb2, str_new(load64(pjf), load64(pjf + 8)));
    str_builder_add_cstr(sb2, "\"}}]");
    _sse_tool_chunk(cfd, model, to_cstr(str_builder_build(sb2)));
    return 1;
}

fn _remote_stream_cb(ctx, ev) {
    var data = sandhi_sse_event_data(ev);
    if (data == 0) { return 1; }
    var dlen = strlen(data);
    if (dlen == 0) { return 1; }
    var prov = load64(ctx + 16);
    # OpenAI-compat terminates the stream with a literal `[DONE]` sentinel.
    if (dlen == 6) {
        if (memeq(data, "[DONE]", 6) == 1) { return 0; }
    }
    var txt = 0;
    if (prov == PROV_ANTHROPIC) {
        # content_block_delta carries delta.text; other event types have no
        # "text":"..." and extract to empty (skipped below).
        txt = anthropic_extract_text(data, dlen);
    } else {
        if (prov == PROV_GOOGLE) {
            # candidates[].content.parts[].text
            txt = anthropic_extract_text(data, dlen);
        } else {
            # OpenAI-compat delta: choices[].delta.content
            txt = ollama_extract_text(data, dlen);
        }
    }
    if (strlen(txt) > 0) {
        _sse_chunk(load64(ctx), load64(ctx + 8), txt, strlen(txt));
        store64(ctx + 24, load64(ctx + 24) + 1);
    }
    # Tool-call deltas, converted per provider to OpenAI tool_call delta chunks.
    if (prov == PROV_ANTHROPIC) {
        if (_emit_anthropic_tool_delta(load64(ctx), load64(ctx + 8), data, dlen) == 1) {
            store64(ctx + 24, load64(ctx + 24) + 1);
        }
    } else {
        if (prov == PROV_GOOGLE) {
            # Gemini streams complete functionCall parts; reuse the non-stream
            # converter and emit each as one delta.
            var gtc = _gemini_tool_calls(data, dlen);
            if (gtc != 0) {
                _sse_tool_chunk(load64(ctx), load64(ctx + 8), gtc);
                store64(ctx + 24, load64(ctx + 24) + 1);
            }
        } else {
            # OpenAI-compat tool_call deltas pass straight through.
            var tc = _extract_openai_tool_calls(data, dlen);
            if (tc != 0) {
                _sse_tool_chunk(load64(ctx), load64(ctx + 8), tc);
                store64(ctx + 24, load64(ctx + 24) + 1);
            }
        }
    }
    return 1;
}

# Build the streaming request body for a remote provider. Tools are forwarded on
# all three families; their streaming tool deltas are converted in
# _remote_stream_cb.
fn _remote_stream_body(route, model, msg_raw, msg_len, tools_raw, tools_len) {
    var prov = route_provider(route);
    if (prov == PROV_ANTHROPIC) {
        return _build_anthropic_body_x(model, msg_raw, msg_len, 1, tools_raw, tools_len);
    }
    if (prov == PROV_GOOGLE) {
        return _build_gemini_body(msg_raw, msg_len, tools_raw, tools_len);
    }
    return _build_chat_body_raw_stream(model, msg_raw, msg_len, tools_raw, tools_len);
}

# Build the streaming request URL for a remote provider.
fn _remote_stream_url(route, model) {
    if (route_provider(route) == PROV_GOOGLE) {
        return _gemini_url_stream(route_base_url(route), model, route_api_key(route));
    }
    return _provider_url(route_base_url(route), _provider_path(route));
}

# Streaming handler: proxy NDJSON/SSE from backend to client
fn handle_chat_stream(cfd, route, model, msg_raw, msg_len, tools_raw, tools_len) {
    # Remote (TLS) providers: incremental SSE via sandhi_http_stream, decoding
    # each provider's delta events and re-emitting them as OpenAI SSE chunks.
    # If the stream errors before emitting anything, fall back to the buffered
    # non-streaming path (no second http_sse_begin). Local backends stream
    # token-by-token below.
    if (route_is_remote(route) == 1) {
        http_sse_begin(cfd);
        var sbody = _remote_stream_body(route, model, msg_raw, msg_len,
        tools_raw, tools_len);
        var surl = _remote_stream_url(route, model);
        var hdrs = _provider_headers(route);
        var ctx = alloc(32);
        store64(ctx, cfd);
        store64(ctx + 8, model);
        store64(ctx + 16, route_provider(route));
        store64(ctx + 24, 0);
        var sres = sandhi_http_stream(
        surl, "POST", hdrs, sbody, strlen(sbody),
        &_remote_stream_cb, ctx);
        var emitted = load64(ctx + 24);
        var ok = 0;
        if (sres != 0) {
            if (sandhi_stream_err(sres) == SANDHI_OK) {
                var st = sandhi_stream_status(sres);
                if (st >= 200) { if (st < 300) { ok = 1; } }
            }
        }
        if (ok == 0) {
            # Only safe to fall back when nothing was streamed yet, otherwise
            # the buffered emit would duplicate the partial output.
            if (emitted == 0) {
                var rresult = retry_forward(
                _retry_cfg, route, model, "hello", msg_raw, msg_len,
                tools_raw, tools_len);
                if (rresult != 0) {
                    var rtext = load64(rresult);
                    if (strlen(rtext) > 0) {
                        _sse_chunk(cfd, model, rtext, strlen(rtext));
                    }
                    var rtc = load64(rresult + 32);
                    if (rtc != 0) { _sse_tool_chunk(cfd, model, rtc); }
                    metrics_record(0, load64(rresult + 24));
                }
            }
        } else {
            metrics_record(0, emitted);
        }
        if (_audit_chain != 0) {
            # _chat_lock: audit-chain append may race a background batch worker.
            mutex_lock(_chat_lock);
            audit_record(_audit_chain, "inference.stream", "info",
            "streaming inference (remote)",
            provider_name(route_provider(route)), model);
            mutex_unlock(_chat_lock);
        }
        _sse_stop(cfd, model);
        return 0;
    }

    var bfd = retry_forward_stream(
    _retry_cfg, route, model, msg_raw, msg_len);
    if (bfd < 0) {
        return http_error(cfd, "502", "Bad Gateway",
        "provider backend unreachable");
    }

    http_sse_begin(cfd);

    # Read backend response line by line
    var lbuf = alloc(65536);
    var lpos = 0;
    var is_ollama = (route_provider(route) == PROV_OLLAMA);
    var token_count = 0;

    var rbuf = alloc(4096);
    var done = 0;
    while (done == 0) {
        var n = sys_read(bfd, rbuf, 4096);
        if (n <= 0) { done = 1; break; }
        var ri = 0;
        while (ri < n) {
            var ch = load8(rbuf + ri);
            if (ch == 10) {
                # Complete line in lbuf[0..lpos]
                if (lpos > 0) {
                    store8(lbuf + lpos, 0);
                    if (is_ollama == 1) {
                        # Ollama NDJSON: extract "content"
                        var txt = ollama_extract_text(lbuf, lpos);
                        if (strlen(txt) > 0) {
                            _sse_chunk(cfd, model,
                            txt, strlen(txt));
                            token_count = token_count + 1;
                        }
                    } else {
                        # OpenAI SSE: lines start with "data: "
                        if (lpos > 6) {
                            if (memeq(lbuf, "data: ", 6) == 1) {
                                var dptr = lbuf + 6;
                                var dlen = lpos - 6;
                                if (memeq(dptr, "[DONE]", 6) == 1) {
                                    done = 1;
                                } else {
                                    var txt = ollama_extract_text(
                                    dptr, dlen);
                                    if (strlen(txt) > 0) {
                                        _sse_chunk(cfd, model,
                                        txt, strlen(txt));
                                        token_count = token_count + 1;
                                    }
                                }
                            }
                        }
                    }
                }
                lpos = 0;
            } else {
                if (ch != 13) {
                    if (lpos < 65535) {
                        store8(lbuf + lpos, ch);
                        lpos = lpos + 1;
                    }
                }
            }
            ri = ri + 1;
        }
    }

    _sse_stop(cfd, model);
    sys_close(bfd);
    metrics_record(0, token_count);
    if (_audit_chain != 0) {
        # _chat_lock: audit-chain append may race a background batch worker.
        mutex_lock(_chat_lock);
        audit_record(_audit_chain, "inference.stream",
        "info", "streaming inference", provider_name(route_provider(route)), model);
        mutex_unlock(_chat_lock);
    }
    return 0;
}

# Exact-key response-cache key: sha256-hex over model + the raw request body.
# Identical requests (same model + byte-identical body) collide to one entry;
# this is the exact-key LRU cache (the semantic cache handles similarity).
fn _cache_key(model, body_ptr, body_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\n");
    var bb = alloc(body_len + 1);
    memcpy(bb, body_ptr, body_len);
    store8(bb + body_len, 0);
    str_builder_add_cstr(sb, bb);
    var s = str_builder_build(sb);
    return sha256_hex(to_cstr(s), str_len(s));
}

# Append ptr[0..len) into a str_builder, JSON-escaping it for a string value.
fn _json_escape_into(sb, ptr, len) {
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (c == 34) { str_builder_add_byte(sb, 92); str_builder_add_byte(sb, 34); }
        if (c == 92) { str_builder_add_byte(sb, 92); str_builder_add_byte(sb, 92); }
        if (c == 10) { str_builder_add_byte(sb, 92); str_builder_add_byte(sb, 110); }
        if (c == 13) { str_builder_add_byte(sb, 92); str_builder_add_byte(sb, 114); }
        if (c == 9) { str_builder_add_byte(sb, 92); str_builder_add_byte(sb, 116); }
        if (c >= 32 && c != 34 && c != 92) { str_builder_add_byte(sb, c); }
        i = i + 1;
    }
    return 0;
}

# Embed a query (the request body) via the configured embedding model's provider.
# Returns a 16-byte (vec_ptr, n) of ×10000 fixed-point components, or 0 on any
# failure (so the caller degrades gracefully to a normal forward).
fn _embed_query_body(body_ptr, body_len) {
    var model = semantic_model();
    if (model == 0) { return 0; }
    var route = router_select(_router, model);
    if (route == 0) { return 0; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"input\":\"");
    _json_escape_into(sb, body_ptr, body_len);
    str_builder_add_cstr(sb, "\"}");
    var body = to_cstr(str_builder_build(sb));
    var blen = strlen(body);
    var rb = 0;
    var rbl = 0;
    if (route_is_remote(route) == 1) {
        var url = _provider_url(route_base_url(route), "/v1/embeddings");
        var hdrs = _provider_headers(route);
        var sresp = sandhi_http_post(url, hdrs, body, blen);
        if (sresp == 0) { return 0; }
        if (sandhi_http_err_kind(sresp) != SANDHI_OK) { return 0; }
        var sst = sandhi_http_status(sresp);
        if (sst < 200 || sst >= 300) { return 0; }
        rbl = sandhi_http_body_len(sresp);
        rb = alloc(rbl + 1);
        memcpy(rb, sandhi_http_body(sresp), rbl);
        store8(rb + rbl, 0);
    } else {
        var port = url_port(route_base_url(route));
        var epath = "/v1/embeddings";
        if (route_provider(route) == PROV_OLLAMA) { epath = "/api/embeddings"; }
        var resp = http_post_local(port, epath, body, blen);
        if (resp == 0) { return 0; }
        if (http_status(resp) < 200 || http_status(resp) >= 300) { return 0; }
        rb = http_body(resp);
        rbl = http_body_len(resp);
    }
    var nptr = alloc(8);
    var vec = semantic_parse_embedding(rb, rbl, nptr);
    if (load64(nptr) == 0) { return 0; }
    var r = alloc(16);
    store64(r, vec);
    store64(r + 8, load64(nptr));
    return r;
}

# Build an OpenAI chat.completion response envelope (str). Shared by the live
# chat path and cache warming so a warmed entry is byte-identical to a fresh one.
fn _chat_completion_body(model, resp_text, ptok, ctok, tool_calls) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"id\":\"chatcmpl-hoosh\",");
    str_builder_add_cstr(sb, "\"object\":\"chat.completion\",");
    str_builder_add_cstr(sb, "\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"choices\":[{\"index\":0,");
    str_builder_add_cstr(sb, "\"message\":{\"role\":\"assistant\",");
    str_builder_add_cstr(sb, "\"content\":\"");
    str_builder_add_cstr(sb, resp_text);
    str_builder_add_cstr(sb, "\"");
    if (tool_calls != 0) {
        str_builder_add_cstr(sb, ",\"tool_calls\":");
        str_builder_add_cstr(sb, tool_calls);
        str_builder_add_cstr(sb, "},\"finish_reason\":\"tool_calls\"}],");
    } else {
        str_builder_add_cstr(sb, "},\"finish_reason\":\"stop\"}],");
    }
    str_builder_add_cstr(sb, "\"usage\":{\"prompt_tokens\":");
    str_builder_add_int(sb, ptok);
    str_builder_add_cstr(sb, ",\"completion_tokens\":");
    str_builder_add_int(sb, ctok);
    str_builder_add_cstr(sb, ",\"total_tokens\":");
    str_builder_add_int(sb, ptok + ctok);
    str_builder_add_cstr(sb, "}}");
    return str_builder_build(sb);
}

# POST /v1/chat/completions
# ── Deferred response descriptor ──────────────
# A response that _chat_produce *returns* instead of writing to a socket,
# so a batch worker can collect the body off the accept thread. Layout
# (32 bytes): status cstr(+0), status_text cstr(+8), body cstr(+16),
# body_len(+24). _resp_write replays it through http_respond.
fn _resp_new(status, status_text, body_cstr, body_len) {
    var r = alloc(32);
    store64(r, status);
    store64(r + 8, status_text);
    store64(r + 16, body_cstr);
    store64(r + 24, body_len);
    return r;
}

# Error-response descriptor mirroring http_error / http_bad_request bodies.
fn _resp_err(status, status_text, msg, etype) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"error\":{\"message\":\"");
    str_builder_add_cstr(sb, msg);
    str_builder_add_cstr(sb, "\",\"type\":\"");
    str_builder_add_cstr(sb, etype);
    str_builder_add_cstr(sb, "\"}}");
    var b = str_builder_build(sb);
    return _resp_new(status, status_text, to_cstr(b), str_len(b));
}

fn _resp_write(cfd, r) {
    return http_respond(cfd, load64(r), load64(r + 8), load64(r + 16), load64(r + 24));
}

# ── Chat request preparation (shared by streaming + non-streaming) ─────
# Runs validation, routing, DLP, response/semantic cache, rate limiting,
# budget reservation, and message extraction/compression/compaction. Returns
# a prep record (alloc 104):
#   +0  kind   0 = terminal (a finished _resp descriptor sits at +8),
#              1 = ready (the request should be forwarded; fields below)
#   +8  route / terminal-descriptor   +16 model_cstr   +24 msg_raw
#   +32 msg_raw_len   +40 tools_raw    +48 tools_len    +56 bpool
#   +64 est_tokens    +72 prompt_cstr  +80 ckey         +88 sem_vec  +96 sem_n
# Cache lookups are skipped when is_stream != 0 (matches the prior behavior:
# streaming responses are never cache-served).
fn _chat_prep(body_ptr, body_len, is_stream) {
    var out = alloc(104);
    store64(out, 0);
    if (body_len == 0) {
        store64(out + 8, _resp_err("400", "Bad Request", "empty request body", "invalid_request_error"));
        return out;
    }
    var body_str = str_new(body_ptr, body_len);
    var pairs = json_parse(body_str);
    if (pairs == 0) {
        store64(out + 8, _resp_err("400", "Bad Request", "invalid JSON", "invalid_request_error"));
        return out;
    }
    var verr = _validate_chat(pairs, body_ptr, body_len);
    if (verr != 0) {
        store64(out + 8, _resp_err("400", "Bad Request", verr, "invalid_request_error"));
        return out;
    }
    var model = json_get(pairs, str_from("model"));
    var model_cstr = to_cstr(model);
    var route = router_select(_router, model_cstr);
    if (route == 0) {
        hlog_warn("chat: no provider for requested model");
        store64(out + 8, _resp_err("404", "Not Found", "no provider for model", "server_error"));
        return out;
    }

    # DLP: Restricted -> block; Confidential -> local provider only.
    if (dlp_is_enabled() == 1) {
        var dlp_level = dlp_scan_level(body_ptr, body_len);
        if (dlp_level == CLASS_RESTRICTED) {
            hlog_warn("dlp: restricted content blocked");
            store64(out + 8, _resp_err("403", "Forbidden",
            "request blocked: restricted content detected", "server_error"));
            return out;
        }
        if (dlp_level == CLASS_CONFIDENTIAL) {
            if (provider_is_local(route_provider(route)) == 0) {
                var lroute = router_select_local(_router, model_cstr);
                if (lroute == 0) {
                    hlog_warn("dlp: confidential content, no local provider");
                    store64(out + 8, _resp_err("403", "Forbidden",
                    "request blocked: confidential content requires a local provider",
                    "server_error"));
                    return out;
                }
                hlog_info("dlp: confidential content routed to a local provider");
                route = lroute;
            }
        }
    }

    # Response cache: exact-key then semantic (non-streaming only). A hit is a
    # terminal 200 carrying the cached body verbatim.
    var ckey = 0;
    var sem_vec = 0;
    var sem_n = 0;
    if (is_stream == 0) {
        ckey = _cache_key(model_cstr, body_ptr, body_len);
        var cached = cache_get(_cache, ckey);
        if (cached != 0) {
            hlog_info("chat: response cache hit");
            store64(out + 8, _resp_new("200", "OK", cached, strlen(cached)));
            return out;
        }
        if (semantic_is_enabled() == 1) {
            var emb = _embed_query_body(body_ptr, body_len);
            if (emb != 0) {
                sem_vec = load64(emb);
                sem_n = load64(emb + 8);
                var skey = semantic_find(sem_vec, sem_n);
                if (skey != 0) {
                    var scached = cache_get(_cache, skey);
                    if (scached != 0) {
                        hlog_info("chat: semantic cache hit");
                        store64(out + 8, _resp_new("200", "OK", scached, strlen(scached)));
                        return out;
                    }
                }
            }
        }
    }

    # Rate limit
    var rl = route_rate_limiter(route);
    if (ratelimit_check(rl) == 0) {
        event_rate_limited(provider_name(route_provider(route)));
        store64(out + 8, _resp_err("429", "Too Many Requests", "provider rate limit exceeded", "server_error"));
        return out;
    }

    # Token budget: reserve before inference
    var pool_name = "default";
    var pool_str = json_get(pairs, str_from("pool"));
    if (pool_str != 0) { pool_name = to_cstr(pool_str); }
    var est_tokens = 2048;
    var max_tok_str = json_get(pairs, str_from("max_tokens"));
    if (max_tok_str != 0) { est_tokens = str_to_int(max_tok_str); }
    var bpool = budget_get_pool(_budget, pool_name);
    if (bpool != 0) {
        if (pool_available(bpool) < est_tokens) {
            store64(out + 8, _resp_err("429", "Too Many Requests", "token budget exceeded", "server_error"));
            return out;
        }
        pool_reserve(bpool, est_tokens);
    }

    # Extract messages + optional compression + compaction
    var msgs = _extract_messages(body_ptr, body_len);
    var msg_raw = 0;
    var msg_raw_len = 0;
    if (msgs != 0) {
        msg_raw = load64(msgs);
        msg_raw_len = load64(msgs + 8);
        if (msg_raw_len > 0 && compression_is_enabled() == 1) {
            var compressed = compress_ws_json(msg_raw, msg_raw_len);
            msg_raw = load64(compressed);
            msg_raw_len = load64(compressed + 8);
            var pruned = prune_tool_pairs(msg_raw, msg_raw_len);
            msg_raw = load64(pruned);
            msg_raw_len = load64(pruned + 8);
        }
        if (msg_raw_len > 0) {
            var cpt_x10 = chars_per_token_x10(route_provider(route));
            var compacted = compact_messages(msg_raw, msg_raw_len, est_tokens * 2, cpt_x10);
            msg_raw = load64(compacted);
            msg_raw_len = load64(compacted + 8);
        }
    }

    var prompt_cstr = "hello";
    if (msg_raw == 0) {
        var prompt_val = json_get(pairs, str_from("prompt"));
        if (prompt_val != 0) { prompt_cstr = to_cstr(prompt_val); }
    }

    var tools = _extract_tools(body_ptr, body_len);
    var tools_raw = 0;
    var tools_len = 0;
    if (tools != 0) {
        tools_raw = load64(tools);
        tools_len = load64(tools + 8);
    }

    store64(out, 1);
    store64(out + 8, route);
    store64(out + 16, model_cstr);
    store64(out + 24, msg_raw);
    store64(out + 32, msg_raw_len);
    store64(out + 40, tools_raw);
    store64(out + 48, tools_len);
    store64(out + 56, bpool);
    store64(out + 64, est_tokens);
    store64(out + 72, prompt_cstr);
    store64(out + 80, ckey);
    store64(out + 88, sem_vec);
    store64(out + 96, sem_n);
    return out;
}

# Global chat bookkeeping lock. Held by batch workers around the shared-state
# sections (prep + assemble) so the network forward in between runs concurrently
# — that overlap is the batching throughput win. Initialized in cmd_serve
# (mutex_new); the single-threaded accept path never contends it because the
# batch handler joins all workers before the accept loop resumes, so workers are
# the only concurrent actors. Uncontended elsewhere.
var _chat_lock = 0;

# Forward a prepared (ready) request to its provider. Pure network I/O +
# response parsing — NO shared chat state is mutated here (metrics_record, the
# one global it touches, is atomic), so this runs unlocked/concurrent.
fn _chat_forward(prep) {
    var route = load64(prep + 8);
    var model_cstr = load64(prep + 16);
    var msg_raw = load64(prep + 24);
    var msg_raw_len = load64(prep + 32);
    var tools_raw = load64(prep + 40);
    var tools_len = load64(prep + 48);
    var prompt_cstr = load64(prep + 72);
    return retry_forward(
    _retry_cfg, route, model_cstr, prompt_cstr, msg_raw, msg_raw_len,
    tools_raw, tools_len);
}

# Build the response descriptor from a forward result. Mutates shared state
# (budget commit, audit append, response/semantic cache insert), so batch
# workers must hold _chat_lock around this call.
fn _chat_assemble(prep, result) {
    var route = load64(prep + 8);
    var model_cstr = load64(prep + 16);
    var bpool = load64(prep + 56);
    var est_tokens = load64(prep + 64);
    var ckey = load64(prep + 80);
    var sem_vec = load64(prep + 88);
    var sem_n = load64(prep + 96);

    if (result == 0) {
        if (bpool != 0) { pool_commit(bpool, est_tokens, 0); }
        hlog_error("chat: provider backend unreachable after retries");
        event_inference_failed(provider_name(route_provider(route)), model_cstr, "backend unreachable");
        otlp_enqueue_inference_span(provider_name(route_provider(route)), model_cstr, 0, 0, 0);
        return _resp_err("502", "Bad Gateway", "provider backend unreachable", "server_error");
    }

    var resp_text = load64(result);
    var resp_ptok = load64(result + 16);
    var resp_ctok = load64(result + 24);
    var resp_tool_calls = load64(result + 32);

    if (bpool != 0) {
        pool_commit(bpool, est_tokens, resp_ptok + resp_ctok);
    }

    if (_audit_chain != 0) {
        audit_record(_audit_chain, "inference.request",
        "info", "inference completed",
        provider_name(route_provider(route)), model_cstr);
    }

    var body = _chat_completion_body(model_cstr, resp_text, resp_ptok,
    resp_ctok, resp_tool_calls);
    var body_cstr = to_cstr(body);
    var body_clen = str_len(body);
    if (ckey != 0) { cache_insert(_cache, ckey, body_cstr); }
    if (ckey != 0 && sem_vec != 0) { semantic_insert(ckey, sem_vec, sem_n); }
    return _resp_new("200", "OK", body_cstr, body_clen);
}

# Forward a prepared request and build its descriptor (single-threaded path).
fn _chat_finish(prep) {
    return _chat_assemble(prep, _chat_forward(prep));
}

# Produce a non-streaming chat response descriptor end-to-end, holding
# _chat_lock around the shared-state phases (prep, assemble) and releasing it
# for the network forward. Batch workers call this from their own threads; the
# concurrency lives entirely in the unlocked forward.
fn _chat_produce(body_ptr, body_len) {
    mutex_lock(_chat_lock);
    var prep = _chat_prep(body_ptr, body_len, 0);
    var kind = load64(prep);
    mutex_unlock(_chat_lock);
    if (kind == 0) { return load64(prep + 8); }

    var result = _chat_forward(prep);

    mutex_lock(_chat_lock);
    var desc = _chat_assemble(prep, result);
    mutex_unlock(_chat_lock);
    return desc;
}

# Accept-thread chat handler. Holds _chat_lock around the shared-state phases
# (prep, assemble/commit) exactly like a batch worker, so a /v1/chat/completions
# served on the accept loop is safe while a background async batch's workers run
# concurrently. The network forward / SSE stream runs unlocked. Uncontended when
# no batch is in flight.
fn handle_chat(cfd, body_ptr, body_len) {
    var is_stream = _req_is_stream(body_ptr, body_len);
    mutex_lock(_chat_lock);
    var prep = _chat_prep(body_ptr, body_len, is_stream);
    var kind = load64(prep);
    mutex_unlock(_chat_lock);
    if (kind == 0) {
        return _resp_write(cfd, load64(prep + 8));
    }

    if (is_stream == 1) {
        var route = load64(prep + 8);
        var model_cstr = load64(prep + 16);
        var msg_raw = load64(prep + 24);
        var msg_raw_len = load64(prep + 32);
        var tools_raw = load64(prep + 40);
        var tools_len = load64(prep + 48);
        var bpool = load64(prep + 56);
        var est_tokens = load64(prep + 64);
        if (msg_raw == 0) {
            if (bpool != 0) {
                mutex_lock(_chat_lock);
                pool_commit(bpool, est_tokens, 0);
                mutex_unlock(_chat_lock);
            }
            return http_bad_request(cfd, "streaming requires messages array");
        }
        var sr = handle_chat_stream(
        cfd, route, model_cstr, msg_raw, msg_raw_len, tools_raw, tools_len);
        if (bpool != 0) {
            mutex_lock(_chat_lock);
            pool_commit(bpool, est_tokens, 0);
            mutex_unlock(_chat_lock);
        }
        return sr;
    }

    var result = _chat_forward(prep);
    mutex_lock(_chat_lock);
    var desc = _chat_assemble(prep, result);
    mutex_unlock(_chat_lock);
    return _resp_write(cfd, desc);
}
