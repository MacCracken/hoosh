# metrics.cyr — request/token counters, Prometheus output

var _met_requests = 0;
var _met_prompt_tokens = 0;
var _met_comp_tokens = 0;
var _met_providers = 0;

# Atomic add (CAS loop) — metrics_record runs inside the provider forward,
# which batch workers execute concurrently (outside the chat bookkeeping
# lock). Plain `x = x + d` would lose updates across threads; this does not.
# atomic_cas comes from lib/atomic.cyr (pulled in via lib/alloc.cyr).
fn _met_atomic_add(ptr, delta) {
    var old = load64(ptr);
    while (atomic_cas(ptr, old, old + delta) == 0) { old = load64(ptr); }
    return 0;
}

fn metrics_record(prompt_tok, comp_tok) {
    _met_atomic_add(&_met_requests, 1);
    _met_atomic_add(&_met_prompt_tokens, prompt_tok);
    _met_atomic_add(&_met_comp_tokens, comp_tok);
    return 0;
}

fn metrics_reset() {
    _met_requests = 0;
    _met_prompt_tokens = 0;
    _met_comp_tokens = 0;
    return 0;
}

# ── Per-provider request latency histogram ────────────────
# Prometheus histogram: 11 finite le-buckets (ms) + an implicit +Inf, plus a
# per-provider sum + count. Recorded inside the provider forward, which batch
# workers run concurrently, so the counters are bumped atomically. Storage is
# heap (metrics_latency_init, called at startup): _lat_counts is PROV_COUNT ×
# (NLAT_BUCKETS+1) slots (last slot = overflow > 10 s).
var NLAT_BUCKETS = 11;
var _lat_counts = 0;
var _lat_sum = 0;
var _lat_count = 0;

# Upper bound (ms) of finite bucket i (0..NLAT_BUCKETS-1).
fn _lat_bound(i) {
    if (i == 0) { return 5; }
    if (i == 1) { return 10; }
    if (i == 2) { return 25; }
    if (i == 3) { return 50; }
    if (i == 4) { return 100; }
    if (i == 5) { return 250; }
    if (i == 6) { return 500; }
    if (i == 7) { return 1000; }
    if (i == 8) { return 2500; }
    if (i == 9) { return 5000; }
    return 10000;
}

fn metrics_latency_init() {
    if (_lat_counts != 0) { return 0; }
    _lat_counts = alloc(PROV_COUNT * (NLAT_BUCKETS + 1) * 8);
    _lat_sum = alloc(PROV_COUNT * 8);
    _lat_count = alloc(PROV_COUNT * 8);
    var i = 0;
    while (i < PROV_COUNT * (NLAT_BUCKETS + 1)) { store64(_lat_counts + i * 8, 0); i = i + 1; }
    i = 0;
    while (i < PROV_COUNT) {
        store64(_lat_sum + i * 8, 0);
        store64(_lat_count + i * 8, 0);
        i = i + 1;
    }
    return 0;
}

# Record one provider request latency (ms). Atomic — concurrent batch workers.
fn metrics_record_latency(prov, ms) {
    if (_lat_counts == 0) { return 0; }
    if (prov < 0 || prov >= PROV_COUNT) { return 0; }
    var b = 0;
    while (b < NLAT_BUCKETS && ms > _lat_bound(b)) { b = b + 1; }
    _met_atomic_add(_lat_counts + (prov * (NLAT_BUCKETS + 1) + b) * 8, 1);
    _met_atomic_add(_lat_sum + prov * 8, ms);
    _met_atomic_add(_lat_count + prov * 8, 1);
    return 0;
}

# Append the per-provider latency histogram to a Prometheus exposition builder.
fn metrics_emit_latency(sb) {
    if (_lat_counts == 0) { return 0; }
    var any = 0;
    var p = 0;
    while (p < PROV_COUNT) {
        var cnt = load64(_lat_count + p * 8);
        if (cnt > 0) {
            if (any == 0) {
                str_builder_add_cstr(sb, "# HELP hoosh_provider_latency_ms Provider request latency (ms)\n");
                str_builder_add_cstr(sb, "# TYPE hoosh_provider_latency_ms histogram\n");
                any = 1;
            }
            var name = provider_name(p);
            var cum = 0;
            var i = 0;
            while (i < NLAT_BUCKETS) {
                cum = cum + load64(_lat_counts + (p * (NLAT_BUCKETS + 1) + i) * 8);
                str_builder_add_cstr(sb, "hoosh_provider_latency_ms_bucket{provider=\"");
                str_builder_add_cstr(sb, name);
                str_builder_add_cstr(sb, "\",le=\"");
                str_builder_add_int(sb, _lat_bound(i));
                str_builder_add_cstr(sb, "\"} ");
                str_builder_add_int(sb, cum);
                str_builder_add_cstr(sb, "\n");
                i = i + 1;
            }
            str_builder_add_cstr(sb, "hoosh_provider_latency_ms_bucket{provider=\"");
            str_builder_add_cstr(sb, name);
            str_builder_add_cstr(sb, "\",le=\"+Inf\"} ");
            str_builder_add_int(sb, cnt);
            str_builder_add_cstr(sb, "\nhoosh_provider_latency_ms_sum{provider=\"");
            str_builder_add_cstr(sb, name);
            str_builder_add_cstr(sb, "\"} ");
            str_builder_add_int(sb, load64(_lat_sum + p * 8));
            str_builder_add_cstr(sb, "\nhoosh_provider_latency_ms_count{provider=\"");
            str_builder_add_cstr(sb, name);
            str_builder_add_cstr(sb, "\"} ");
            str_builder_add_int(sb, cnt);
            str_builder_add_cstr(sb, "\n");
        }
        p = p + 1;
    }
    return 0;
}
