# provider.cyr — LLM provider forwarding (Ollama + OpenAI-compatible)
# Handles request building, response parsing, and text/token extraction.
# Requires: types.cyr, route.cyr, http_client.cyr, metrics.cyr

# Build chat request JSON from model + prompt
fn _build_chat_body(model, prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"stream\":false,");
    str_builder_add_cstr(sb, "\"messages\":[{\"role\":\"user\",");
    str_builder_add_cstr(sb, "\"content\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    var s = str_builder_build(sb);
    return to_cstr(s);
}

# Build chat request JSON with raw messages array passthrough
# Append ptr[0..len) as a NUL-terminated cstr into a str_builder.
fn _sb_add_span(sb, ptr, len) {
    var b = alloc(len + 1);
    memcpy(b, ptr, len);
    store8(b + len, 0);
    str_builder_add_cstr(sb, b);
    return 0;
}

fn _build_chat_body_raw(model, messages_raw, messages_len, tools_raw, tools_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"stream\":false,\"messages\":");
    _sb_add_span(sb, messages_raw, messages_len);
    if (tools_raw != 0 && tools_len > 0) {
        str_builder_add_cstr(sb, ",\"tools\":");
        _sb_add_span(sb, tools_raw, tools_len);
    }
    str_builder_add_cstr(sb, "}");
    return to_cstr(str_builder_build(sb));
}

# Build streaming chat body from model + raw messages (+ optional tools).
fn _build_chat_body_raw_stream(model, messages_raw, messages_len, tools_raw, tools_len) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"stream\":true,\"messages\":");
    _sb_add_span(sb, messages_raw, messages_len);
    if (tools_raw != 0 && tools_len > 0) {
        str_builder_add_cstr(sb, ",\"tools\":");
        _sb_add_span(sb, tools_raw, tools_len);
    }
    str_builder_add_cstr(sb, "}");
    return to_cstr(str_builder_build(sb));
}

# Forward to Ollama native API
fn ollama_infer(port, model, prompt) {
    var body = _build_chat_body(model, prompt);
    return http_post_local(port, "/api/chat", body, strlen(body));
}

# Forward to OpenAI-compatible endpoint
fn openai_compat_infer(port, model, prompt) {
    var body = _build_chat_body(model, prompt);
    return http_post_local(port, "/v1/chat/completions", body, strlen(body));
}

# First byte index of the value for the first object key exactly matching
# `"<key>"`, skipping whitespace around the `:`. REST APIs (OpenAI, Gemini)
# pretty-print responses (`"content": "ok"`, `"prompt_tokens": 14`), so the
# colon-and-value can be separated from the key by spaces/newlines; the older
# compact-only needles (`"content":"`) silently missed them. The key is
# quote-anchored on both sides, so `"eval_count"` will not match inside
# `"prompt_eval_count"` (the disambiguation the token scanners did by hand).
# Returns -1 when the key is absent.
fn _json_value_pos(body, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(body + i) == 34) {
            if (memeq(body + i + 1, key, keylen) == 1) {
                if (load8(body + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(body + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 9) { j = j + 1; continue; }
                        if (c == 10) { j = j + 1; continue; }
                        if (c == 13) { j = j + 1; continue; }
                        break;
                    }
                    # Genuine key iff a colon follows. Otherwise this `"<key>"`
                    # was a string *value* equal to the key name (e.g. Anthropic's
                    # `"type":"text"` vs the real `"text":` key) — keep scanning.
                    if (j < len) {
                        if (load8(body + j) == 58) {
                            j = j + 1;
                            while (j < len) {
                                var d = load8(body + j);
                                if (d == 32) { j = j + 1; continue; }
                                if (d == 9) { j = j + 1; continue; }
                                if (d == 10) { j = j + 1; continue; }
                                if (d == 13) { j = j + 1; continue; }
                                break;
                            }
                            return j;
                        }
                    }
                }
            }
        }
        i = i + 1;
    }
    return 0 - 1;
}

# Extract the string value of the first `"<key>"` field (escaped `\"`
# preserved), whitespace-tolerant via _json_value_pos. "" if absent or the
# value is not a JSON string.
fn _json_extract_str(body, len, key, keylen) {
    if (body == 0) { return ""; }
    if (len == 0) { return ""; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return ""; }
    if (p >= len) { return ""; }
    if (load8(body + p) != 34) { return ""; }
    var start = p + 1;
    var j = start;
    while (j < len) {
        if (load8(body + j) == 34) {
            if (load8(body + j - 1) == 92) { j = j + 1; continue; }
            break;
        }
        j = j + 1;
    }
    var tlen = j - start;
    var text = alloc(tlen + 1);
    memcpy(text, body + start, tlen);
    store8(text + tlen, 0);
    return text;
}

# Integer value of the first `"<key>"` field, whitespace-tolerant. 0 if absent.
fn _json_extract_int(body, len, key, keylen) {
    if (body == 0) { return 0; }
    if (len == 0) { return 0; }
    store8(body + len, 0);
    var p = _json_value_pos(body, len, key, keylen);
    if (p < 0) { return 0; }
    return atoi(body + p);
}

# Extract "content":"..." from JSON response body (handles nested objects)
fn ollama_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "content", 7);
}

# Also works for OpenAI-format responses (same "content" field structure)
fn openai_extract_text(resp_body, resp_len) {
    return ollama_extract_text(resp_body, resp_len);
}

# Extract token counts from Ollama response
# Returns packed: prompt_tokens * 0x100000000 + completion_tokens
fn extract_ollama_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "prompt_eval_count", 17);
    var comp = _json_extract_int(body, blen, "eval_count", 10);
    return prompt * 0x100000000 + comp;
}

# Extract token counts from an OpenAI-format response ("usage" object).
# Returns packed: prompt_tokens * 0x100000000 + completion_tokens.
fn extract_openai_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "prompt_tokens", 13);
    var comp = _json_extract_int(body, blen, "completion_tokens", 17);
    return prompt * 0x100000000 + comp;
}

# True if the route targets a remote https endpoint (needs DNS + TLS + auth).
# Local http:// backends keep the raw-socket fast path; https:// routes go
# through sandhi (DNS resolve + TLS + auth headers).
fn route_is_remote(route) {
    var base = route_base_url(route);
    if (base == 0) { return 0; }
    if (memeq(base, "https", 5) == 1) { return 1; }
    return 0;
}

# Chat-completion HTTP path for a provider.
fn _provider_path(route) {
    if (route_provider(route) == PROV_OLLAMA) { return "/api/chat"; }
    if (route_provider(route) == PROV_ANTHROPIC) { return "/v1/messages"; }
    return "/v1/chat/completions";
}

# Scan a JSON object's bytes for a string field `"<key>":"<value>"`. Returns
# an alloc(16) {value_ptr(8), value_len(8)} for the value slice (escaped `\"`
# preserved, quote-skipping mirrors the extractors above), or 0 when the key
# is absent or its value is not a JSON string.
fn _json_obj_str_field(p, len, key, keylen) {
    var i = 0;
    while (i < len - keylen - 1) {
        if (load8(p + i) == 34) {
            if (memeq(p + i + 1, key, keylen) == 1) {
                if (load8(p + i + 1 + keylen) == 34) {
                    var j = i + 2 + keylen;
                    while (j < len) {
                        var c = load8(p + j);
                        if (c == 32) { j = j + 1; continue; }
                        if (c == 58) { j = j + 1; continue; }
                        break;
                    }
                    if (j >= len) { return 0; }
                    if (load8(p + j) != 34) { return 0; }
                    j = j + 1;
                    var vs = j;
                    while (j < len) {
                        if (load8(p + j) == 34) {
                            if (load8(p + j - 1) == 92) { j = j + 1; continue; }
                            break;
                        }
                        j = j + 1;
                    }
                    var r = alloc(16);
                    store64(r, p + vs);
                    store64(r + 8, j - vs);
                    return r;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# True if a JSON object's bytes carry `"role":"system"`.
fn _obj_is_system(p, len) {
    var rf = _json_obj_str_field(p, len, "role", 4);
    if (rf == 0) { return 0; }
    if (load64(rf + 8) != 6) { return 0; }
    if (memeq(load64(rf), "system", 6) == 1) { return 1; }
    return 0;
}

# Index just past the `}` matching the `{` at `start`. String-aware (braces
# and brackets inside JSON strings don't count), escaped `\"` skipped.
fn _json_obj_end(p, len, start) {
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123) { depth = depth + 1; }
            if (ch == 91) { depth = depth + 1; }
            if (ch == 93) { depth = depth - 1; }
            if (ch == 125) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

# Span (ptr,len) of the object value after `"key":{`, or 0 if not found. Keeps
# searching past a same-name match that is a *value* (e.g. "function" appears as
# both the value of "type" and the real object key in an OpenAI tool).
fn _json_obj_obj_span(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 123) {
                var end = _json_obj_end(p, len, j);
                var r = alloc(16);
                store64(r, p + j);
                store64(r + 8, end - j);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Append ptr[0..len) into sb, JSON-escaping it for a string value: `"` and `\`
# plus the control chars \n \r \t (so a pretty-printed args object stays valid
# once stringified). Other control bytes (<32) are dropped.
fn _json_esc_span(sb, ptr, len) {
    var i = 0;
    while (i < len) {
        var c = load8(ptr + i);
        if (c == 34) { str_builder_putc(sb, 92); str_builder_putc(sb, 34); }
        if (c == 92) { str_builder_putc(sb, 92); str_builder_putc(sb, 92); }
        if (c == 10) { str_builder_putc(sb, 92); str_builder_putc(sb, 110); }
        if (c == 13) { str_builder_putc(sb, 92); str_builder_putc(sb, 114); }
        if (c == 9) { str_builder_putc(sb, 92); str_builder_putc(sb, 116); }
        if (c >= 32 && c != 34 && c != 92) { str_builder_putc(sb, c); }
        i = i + 1;
    }
    return 0;
}

# Convert an OpenAI `tools` array to Anthropic/Gemini shape. Each OpenAI tool is
# `{"type":"function","function":{name,description,parameters}}`; we emit
# `{"name","description","<schema_key>":<parameters>}` where schema_key is
# "input_schema" (Anthropic) or "parameters" (Gemini). Returns a cstr array.
fn _tools_convert(tools_raw, tools_len, schema_key) {
    var sb = str_builder_new();
    str_builder_putc(sb, '[');
    var first = 1;
    var i = 0;
    while (i < tools_len && load8(tools_raw + i) != 91) { i = i + 1; }
    i = i + 1;
    while (i < tools_len) {
        var ch = load8(tools_raw + i);
        if (ch == 32 || ch == 44 || ch == 10 || ch == 13 || ch == 9) {
            i = i + 1;
        } else {
            if (ch != 123) {
                i = tools_len;
            } else {
                var obj_end = _json_obj_end(tools_raw, tools_len, i);
                var func = _json_obj_obj_span(tools_raw + i, obj_end - i, "function", 8);
                if (func != 0) {
                    var fptr = load64(func);
                    var flen = load64(func + 8);
                    var nm = _json_obj_str_field(fptr, flen, "name", 4);
                    var ds = _json_obj_str_field(fptr, flen, "description", 11);
                    var pm = _json_obj_obj_span(fptr, flen, "parameters", 10);
                    if (nm != 0) {
                        if (first == 0) { str_builder_putc(sb, ','); }
                        str_builder_add_cstr(sb, "{\"name\":\"");
                        str_builder_add(sb, str_new(load64(nm), load64(nm + 8)));
                        str_builder_add_cstr(sb, "\",\"description\":\"");
                        if (ds != 0) {
                            str_builder_add(sb, str_new(load64(ds), load64(ds + 8)));
                        }
                        str_builder_add_cstr(sb, "\",\"");
                        str_builder_add_cstr(sb, schema_key);
                        str_builder_add_cstr(sb, "\":");
                        if (pm != 0) {
                            str_builder_add(sb, str_new(load64(pm), load64(pm + 8)));
                        } else {
                            str_builder_add_cstr(sb, "{}");
                        }
                        str_builder_putc(sb, '}');
                        first = 0;
                    }
                }
                i = obj_end;
            }
        }
    }
    str_builder_putc(sb, ']');
    return to_cstr(str_builder_build(sb));
}

# Build an Anthropic /v1/messages body. Anthropic requires max_tokens and
# rejects `role:"system"` turns inside `messages`, so system turns are hoisted
# to the top-level `system` field (multiple joined with `\n`); the remaining
# {role,content} turns pass through unchanged. Objects whose content is not a
# plain string are left in `messages` rather than dropped. `stream` adds the
# top-level `"stream":true` flag for the incremental SSE path.
fn _build_anthropic_body_x(model, messages_raw, messages_len, stream, tools_raw, tools_len) {
    var sys_sb = str_builder_new();
    var msgs_sb = str_builder_new();
    str_builder_putc(msgs_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var keep = 1;
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
                keep = 0;
            }
        }
        if (keep == 1) {
            if (first == 0) { str_builder_putc(msgs_sb, ','); }
            str_builder_add(msgs_sb, str_new(messages_raw + obj_start, obj_len));
            first = 0;
        }
        i = obj_end;
    }
    str_builder_putc(msgs_sb, ']');

    var body = str_builder_new();
    str_builder_add_cstr(body, "{\"model\":\"");
    str_builder_add_cstr(body, model);
    str_builder_add_cstr(body, "\",\"max_tokens\":4096,");
    if (stream == 1) {
        str_builder_add_cstr(body, "\"stream\":true,");
    }
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"system\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\",");
    }
    str_builder_add_cstr(body, "\"messages\":");
    str_builder_add(body, str_builder_build(msgs_sb));
    if (tools_raw != 0 && tools_len > 0) {
        str_builder_add_cstr(body, ",\"tools\":");
        str_builder_add_cstr(body, _tools_convert(tools_raw, tools_len, "input_schema"));
    }
    str_builder_putc(body, '}');
    return to_cstr(str_builder_build(body));
}

# Non-streaming Anthropic body (the common case).
fn _build_anthropic_body(model, messages_raw, messages_len, tools_raw, tools_len) {
    return _build_anthropic_body_x(model, messages_raw, messages_len, 0, tools_raw, tools_len);
}

# Anthropic /v1/messages body from a bare prompt (no messages array).
fn _build_anthropic_body_prompt(model, prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"max_tokens\":4096,\"messages\":[{\"role\":\"user\",\"content\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    return to_cstr(str_builder_build(sb));
}

# Extract assistant text from an Anthropic response: content[].text.
# Finds the first "text":"..." and returns the unescaped-boundary slice.
fn anthropic_extract_text(resp_body, resp_len) {
    return _json_extract_str(resp_body, resp_len, "text", 4);
}

# Extract token counts from an Anthropic response usage object.
# Returns packed: input_tokens * 0x100000000 + output_tokens.
fn extract_anthropic_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "input_tokens", 12);
    var comp = _json_extract_int(body, blen, "output_tokens", 13);
    return prompt * 0x100000000 + comp;
}

# Build a Google Gemini :generateContent body from an OpenAI-style messages
# array. role:"system" turns hoist to `systemInstruction` (joined with `\n`);
# the rest become `contents` entries with role mapped (assistant -> "model",
# everything else -> "user") and content wrapped as a single text part. Content
# bytes are already JSON-escaped, so they embed verbatim.
fn _build_gemini_body(messages_raw, messages_len, tools_raw, tools_len) {
    var sys_sb = str_builder_new();
    var contents_sb = str_builder_new();
    str_builder_putc(contents_sb, '[');
    var has_sys = 0;
    var first = 1;
    var i = 0;
    while (i < messages_len) {
        if (load8(messages_raw + i) == 91) { break; }
        i = i + 1;
    }
    i = i + 1;
    while (i < messages_len) {
        var ch = load8(messages_raw + i);
        if (ch == 32) { i = i + 1; continue; }
        if (ch == 44) { i = i + 1; continue; }
        if (ch == 10) { i = i + 1; continue; }
        if (ch == 13) { i = i + 1; continue; }
        if (ch == 9) { i = i + 1; continue; }
        if (ch != 123) { break; }
        var obj_start = i;
        var obj_end = _json_obj_end(messages_raw, messages_len, obj_start);
        var obj_len = obj_end - obj_start;
        var cf = _json_obj_str_field(messages_raw + obj_start, obj_len, "content", 7);
        if (_obj_is_system(messages_raw + obj_start, obj_len) == 1) {
            if (cf != 0) {
                if (has_sys == 1) {
                    str_builder_putc(sys_sb, 92);
                    str_builder_putc(sys_sb, 110);
                }
                str_builder_add(sys_sb, str_new(load64(cf), load64(cf + 8)));
                has_sys = 1;
            }
        } else {
            if (cf != 0) {
                var role = "user";
                var rf = _json_obj_str_field(messages_raw + obj_start, obj_len, "role", 4);
                if (rf != 0) {
                    if (load64(rf + 8) == 9) {
                        if (memeq(load64(rf), "assistant", 9) == 1) { role = "model"; }
                    }
                }
                if (first == 0) { str_builder_putc(contents_sb, ','); }
                str_builder_add_cstr(contents_sb, "{\"role\":\"");
                str_builder_add_cstr(contents_sb, role);
                str_builder_add_cstr(contents_sb, "\",\"parts\":[{\"text\":\"");
                str_builder_add(contents_sb, str_new(load64(cf), load64(cf + 8)));
                str_builder_add_cstr(contents_sb, "\"}]}");
                first = 0;
            }
        }
        i = obj_end;
    }
    str_builder_putc(contents_sb, ']');

    var body = str_builder_new();
    str_builder_putc(body, '{');
    if (has_sys == 1) {
        str_builder_add_cstr(body, "\"systemInstruction\":{\"parts\":[{\"text\":\"");
        str_builder_add(body, str_builder_build(sys_sb));
        str_builder_add_cstr(body, "\"}]},");
    }
    str_builder_add_cstr(body, "\"contents\":");
    str_builder_add(body, str_builder_build(contents_sb));
    if (tools_raw != 0 && tools_len > 0) {
        str_builder_add_cstr(body, ",\"tools\":[{\"functionDeclarations\":");
        str_builder_add_cstr(body, _tools_convert(tools_raw, tools_len, "parameters"));
        str_builder_add_cstr(body, "}]");
    }
    str_builder_putc(body, '}');
    return to_cstr(str_builder_build(body));
}

# Gemini :generateContent body from a bare prompt (single user turn).
fn _build_gemini_body_prompt(prompt) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"contents\":[{\"role\":\"user\",\"parts\":[{\"text\":\"");
    str_builder_add_cstr(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}]}");
    return to_cstr(str_builder_build(sb));
}

# Extract assistant text from a Gemini response: candidates[].content.parts[].text.
# The first "text":"..." is the model output (same shape as Anthropic content).
fn gemini_extract_text(resp_body, resp_len) {
    return anthropic_extract_text(resp_body, resp_len);
}

# Extract token counts from a Gemini response usageMetadata object.
# Returns packed: promptTokenCount * 0x100000000 + candidatesTokenCount.
fn extract_gemini_tokens(body, blen) {
    var prompt = _json_extract_int(body, blen, "promptTokenCount", 16);
    var comp = _json_extract_int(body, blen, "candidatesTokenCount", 20);
    return prompt * 0x100000000 + comp;
}

# base + "/v1beta/models/<model>:generateContent?key=<key>" -> fresh cstr.
# Gemini authenticates via the key query param (no Authorization header).
fn _gemini_url(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":generateContent");
    if (key != 0) {
        str_builder_add_cstr(sb, "?key=");
        str_builder_add_cstr(sb, key);
    }
    return to_cstr(str_builder_build(sb));
}

# Streaming variant: :streamGenerateContent with `alt=sse` so the response is
# an SSE stream of candidate deltas (key stays in the query string).
fn _gemini_url_stream(base, model, key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/v1beta/models/");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, ":streamGenerateContent?alt=sse");
    if (key != 0) {
        str_builder_add_cstr(sb, "&key=");
        str_builder_add_cstr(sb, key);
    }
    return to_cstr(str_builder_build(sb));
}

# base_url + path -> fresh cstr (e.g. "https://api.openai.com/v1/chat/completions")
fn _provider_url(base, path) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, path);
    return to_cstr(str_builder_build(sb));
}

# "Bearer <key>" -> fresh cstr
fn _bearer_value(key) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "Bearer ");
    str_builder_add_cstr(sb, key);
    return to_cstr(str_builder_build(sb));
}

# sandhi header set: Content-Type + per-provider auth. Anthropic uses
# x-api-key + anthropic-version; Google authenticates via the URL key query
# param (no auth header); everything else uses Authorization: Bearer.
fn _provider_headers(route) {
    var h = sandhi_headers_new();
    sandhi_headers_add(h, "Content-Type", "application/json");
    sandhi_headers_add(h, "traceparent", trace_current_or_new());
    var key = route_api_key(route);
    if (key != 0) {
        if (route_provider(route) == PROV_ANTHROPIC) {
            sandhi_headers_add(h, "x-api-key", key);
            sandhi_headers_add(h, "anthropic-version", "2023-06-01");
        } else {
            if (route_provider(route) != PROV_GOOGLE) {
                sandhi_headers_add(h, "Authorization", _bearer_value(key));
            }
        }
    }
    return h;
}

# Forward request to provider and extract text + tokens
# Result: text(8) latency_ms(8) prompt_tok(8) comp_tok(8) = 32 bytes, or 0 on failure
# Index just past the close matching the `{`/`[` at `start` (string-aware).
fn _json_span_end(p, len, start) {
    var close_open = load8(p + start);
    var depth = 0;
    var i = start;
    while (i < len) {
        var ch = load8(p + i);
        if (ch == 34) {
            i = i + 1;
            while (i < len) {
                if (load8(p + i) == 34) {
                    if (load8(p + i - 1) != 92) { break; }
                }
                i = i + 1;
            }
        } else {
            if (ch == 123 || ch == 91) { depth = depth + 1; }
            if (ch == 125 || ch == 93) {
                depth = depth - 1;
                if (depth == 0) { return i + 1; }
            }
        }
        i = i + 1;
    }
    return i;
}

# Span (ptr,len) of the array value after `"key":[`, or 0. Keeps searching past
# a same-name match whose value is not an array.
fn _json_arr_span(p, len, key, keylen) {
    var i = 0;
    while (i + keylen + 2 < len) {
        if (load8(p + i) == 34 && memeq(p + i + 1, key, keylen) == 1
        && load8(p + i + 1 + keylen) == 34) {
            var j = i + 2 + keylen;
            while (j < len && (load8(p + j) == 32 || load8(p + j) == 58)) {
                j = j + 1;
            }
            if (j < len && load8(p + j) == 91) {
                var end = _json_span_end(p, len, j);
                var r = alloc(16);
                store64(r, p + j);
                store64(r + 8, end - j);
                return r;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Emit one OpenAI tool_call object into sb from (id, name, args-object span).
fn _emit_tool_call(sb, id_p, id_l, nm_p, nm_l, args_p, args_l) {
    str_builder_add_cstr(sb, "{\"id\":\"");
    str_builder_add(sb, str_new(id_p, id_l));
    str_builder_add_cstr(sb, "\",\"type\":\"function\",\"function\":{\"name\":\"");
    str_builder_add(sb, str_new(nm_p, nm_l));
    str_builder_add_cstr(sb, "\",\"arguments\":\"");
    if (args_l > 0) { _json_esc_span(sb, args_p, args_l); } else { str_builder_add_cstr(sb, "{}"); }
    str_builder_add_cstr(sb, "\"}}");
    return 0;
}

# Anthropic content[] tool_use blocks → OpenAI tool_calls array (cstr), or 0.
fn _anthropic_tool_calls(rb, rbl) {
    var cspan = _json_arr_span(rb, rbl, "content", 7);
    if (cspan == 0) { return 0; }
    var cp = load64(cspan);
    var cl = load64(cspan + 8);
    var sb = str_builder_new();
    str_builder_putc(sb, '[');
    var first = 1;
    var i = 1;
    while (i < cl) {
        var ch = load8(cp + i);
        if (ch == 123) {
            var oe = _json_span_end(cp, cl, i);
            var ol = oe - i;
            var tf = _json_obj_str_field(cp + i, ol, "type", 4);
            if (tf != 0) {
                if (load64(tf + 8) == 8 && memeq(load64(tf), "tool_use", 8) == 1) {
                    var idf = _json_obj_str_field(cp + i, ol, "id", 2);
                    var nmf = _json_obj_str_field(cp + i, ol, "name", 4);
                    var inf = _json_obj_obj_span(cp + i, ol, "input", 5);
                    if (idf != 0 && nmf != 0) {
                        if (first == 0) { str_builder_putc(sb, ','); }
                        var ap = 0;
                        var al = 0;
                        if (inf != 0) { ap = load64(inf); al = load64(inf + 8); }
                        _emit_tool_call(sb, load64(idf), load64(idf + 8),
                        load64(nmf), load64(nmf + 8), ap, al);
                        first = 0;
                    }
                }
            }
            i = oe;
        } else {
            i = i + 1;
        }
    }
    str_builder_putc(sb, ']');
    if (first == 1) { return 0; }
    return to_cstr(str_builder_build(sb));
}

# Gemini candidates parts[].functionCall → OpenAI tool_calls (cstr), or 0.
fn _gemini_tool_calls(rb, rbl) {
    var sb = str_builder_new();
    str_builder_putc(sb, '[');
    var first = 1;
    var idx = 0;
    var i = 0;
    while (i + 15 < rbl) {
        if (memeq(rb + i, "\"functionCall\":", 15) == 1) {
            var j = i + 15;
            while (j < rbl && load8(rb + j) == 32) { j = j + 1; }
            if (j < rbl && load8(rb + j) == 123) {
                var oe = _json_span_end(rb, rbl, j);
                var ol = oe - j;
                var nmf = _json_obj_str_field(rb + j, ol, "name", 4);
                var argf = _json_obj_obj_span(rb + j, ol, "args", 4);
                if (nmf != 0) {
                    if (first == 0) { str_builder_putc(sb, ','); }
                    var idb = str_builder_new();
                    str_builder_add_cstr(idb, "call_");
                    str_builder_add_int(idb, idx);
                    var idc = to_cstr(str_builder_build(idb));
                    var ap = 0;
                    var al = 0;
                    if (argf != 0) { ap = load64(argf); al = load64(argf + 8); }
                    _emit_tool_call(sb, idc, strlen(idc),
                    load64(nmf), load64(nmf + 8), ap, al);
                    first = 0;
                    idx = idx + 1;
                }
                i = oe;
            } else {
                i = i + 1;
            }
        } else {
            i = i + 1;
        }
    }
    str_builder_putc(sb, ']');
    if (first == 1) { return 0; }
    return to_cstr(str_builder_build(sb));
}

# Extract the raw "tool_calls":[...] array from an OpenAI-compatible response,
# as a NUL-terminated cstr, or 0 if absent. Balanced-bracket scan with string
# handling (mirrors _extract_messages).
fn _extract_openai_tool_calls(rb, rbl) {
    var i = 0;
    while (i + 13 < rbl) {
        if (memeq(rb + i, "\"tool_calls\":", 13) == 1) {
            var j = i + 13;
            while (j < rbl && load8(rb + j) == 32) { j = j + 1; }
            if (j < rbl && load8(rb + j) == 91) {
                var depth = 1;
                var start = j;
                j = j + 1;
                while (j < rbl && depth > 0) {
                    var ch = load8(rb + j);
                    if (ch == 91) { depth = depth + 1; }
                    if (ch == 93) { depth = depth - 1; }
                    if (ch == 34) {
                        j = j + 1;
                        while (j < rbl) {
                            if (load8(rb + j) == 34) { break; }
                            if (load8(rb + j) == 92) { j = j + 1; }
                            j = j + 1;
                        }
                    }
                    j = j + 1;
                }
                var len = j - start;
                # Empty array "[]" carries no calls.
                if (len <= 2) { return 0; }
                var out = alloc(len + 1);
                memcpy(out, rb + start, len);
                store8(out + len, 0);
                return out;
            }
        }
        i = i + 1;
    }
    return 0;
}

fn provider_forward(route, model, prompt, messages_raw, messages_len, tools_raw, tools_len) {
    var _fwd_t0 = clock_now_ns();
    var base = route_base_url(route);
    var is_anthropic = (route_provider(route) == PROV_ANTHROPIC);
    var is_google = (route_provider(route) == PROV_GOOGLE);
    var body = 0;
    if (is_anthropic == 1) {
        if (messages_raw != 0) {
            body = _build_anthropic_body(model, messages_raw, messages_len,
            tools_raw, tools_len);
        } else {
            body = _build_anthropic_body_prompt(model, prompt);
        }
    } else {
        if (is_google == 1) {
            if (messages_raw != 0) {
                body = _build_gemini_body(messages_raw, messages_len,
                tools_raw, tools_len);
            } else {
                body = _build_gemini_body_prompt(prompt);
            }
        } else {
            if (messages_raw != 0) {
                body = _build_chat_body_raw(model, messages_raw, messages_len,
                tools_raw, tools_len);
            } else {
                body = _build_chat_body(model, prompt);
            }
        }
    }
    var blen = strlen(body);
    var path = _provider_path(route);

    var rb = 0;
    var rbl = 0;
    if (route_is_remote(route) == 1) {
        # Remote (TLS) path via sandhi: full URL + DNS + TLS + auth headers.
        # Google builds a model-scoped :generateContent URL with the key as a
        # query param; everyone else joins base + path.
        var url = 0;
        if (is_google == 1) {
            url = _gemini_url(base, model, route_api_key(route));
        } else {
            url = _provider_url(base, path);
        }
        var hdrs = _provider_headers(route);
        var sresp = sandhi_http_post(url, hdrs, body, blen);
        if (sresp == 0) { return 0; }
        if (sandhi_http_err_kind(sresp) != SANDHI_OK) { return 0; }
        var sst = sandhi_http_status(sresp);
        if (sst < 200) { return 0; }
        if (sst >= 300) { return 0; }
        # Copy into a buffer with 1 byte of slack: the extractors below
        # null-terminate in place (store8(buf+len, 0)), and sandhi's body
        # buffer has no guaranteed trailing slack — writing past it corrupts
        # the heap (intermittent crashes).
        rbl = sandhi_http_body_len(sresp);
        rb = alloc(rbl + 1);
        memcpy(rb, sandhi_http_body(sresp), rbl);
        store8(rb + rbl, 0);
    } else {
        # Local path: raw socket to 127.0.0.1:<port>, plaintext.
        var port = url_port(base);
        var resp = http_post_local(port, path, body, blen);
        if (resp == 0) { return 0; }
        if (http_status(resp) < 200) { return 0; }
        if (http_status(resp) >= 300) { return 0; }
        rb = http_body(resp);
        rbl = http_body_len(resp);
    }

    var text = 0;
    var tokens = 0;
    if (is_anthropic == 1) {
        # Anthropic: content[].text + usage.{input,output}_tokens.
        text = anthropic_extract_text(rb, rbl);
        tokens = extract_anthropic_tokens(rb, rbl);
    } else { if (is_google == 1) {
            # Gemini: candidates[].content.parts[].text + usageMetadata counts.
            text = gemini_extract_text(rb, rbl);
            tokens = extract_gemini_tokens(rb, rbl);
        } else {
            text = ollama_extract_text(rb, rbl);
            # Ollama exposes prompt_eval_count/eval_count; OpenAI-compat uses
            # usage.prompt_tokens/completion_tokens. Try Ollama first, fall back.
            tokens = extract_ollama_tokens(rb, rbl);
            if (tokens == 0) { tokens = extract_openai_tokens(rb, rbl); }
        } }
    var ptok = tokens / 0x100000000;
    var ctok = tokens % 0x100000000;
    var _fwd_ms = (clock_now_ns() - _fwd_t0) / 1000000;
    metrics_record(ptok, ctok);
    metrics_record_latency(route_provider(route), _fwd_ms);
    event_inference_completed(provider_name(route_provider(route)), model, _fwd_ms, ptok + ctok);

    # Surface tool calls (slot 32; 0 = none), converting each provider's shape to
    # OpenAI tool_calls.
    var tool_calls = 0;
    if (is_anthropic == 1) {
        tool_calls = _anthropic_tool_calls(rb, rbl);
    } else {
        if (is_google == 1) {
            tool_calls = _gemini_tool_calls(rb, rbl);
        } else {
            tool_calls = _extract_openai_tool_calls(rb, rbl);
        }
    }

    var result = alloc(40);
    store64(result, text);
    store64(result + 8, 0);
    store64(result + 16, ptok);
    store64(result + 24, ctok);
    store64(result + 32, tool_calls);
    return result;
}

# Open a streaming connection to provider.
# Returns backend fd (caller reads chunks + closes).
# Returns -1 on connection failure.
fn provider_forward_stream(route, model, messages_raw, messages_len) {
    # Local-only fast path: raw fd + sys_read can't decrypt TLS. Remote
    # providers stream incrementally via sandhi_http_stream in the handler
    # (handle_chat_stream's remote branch) and never reach here.
    if (route_is_remote(route) == 1) { return 0 - 1; }
    var port = url_port(route_base_url(route));
    var body = _build_chat_body_raw_stream(
    model, messages_raw, messages_len, 0, 0);
    var blen = strlen(body);
    var path = _provider_path(route);
    var fd = http_post_stream(port, path, body, blen);
    if (fd < 0) { return 0 - 1; }
    # Skip HTTP response headers
    var hdr_buf = alloc(4096);
    var skip = stream_skip_headers(fd, hdr_buf, 4096);
    if (skip < 0) { sys_close(fd); return 0 - 1; }
    return fd;
}
