# config.cyr — TOML configuration loader for hoosh.cyml
# Requires: types.cyr, route.cyr, router.cyr, budget.cyr, cache.cyr, metrics.cyr
# Reads: [[server]], [[providers]], [[cache]], [[budgets]], [[auth]]

# Expand a config value: "$NAME" -> getenv("NAME"), so secrets (API keys)
# live in the environment, not in hoosh.cyml. Returns 0 if the env var is
# unset; passes non-"$" values through unchanged.
fn _config_expand_env(value) {
    if (value == 0) { return 0; }
    if (load8(value) == 36) { return getenv(value + 1); }
    return value;
}

fn load_config(path) {
    var sections = toml_parse_file(path);
    if (vec_len(sections) == 0) { return 0; }

    # Parse [[server]] section
    var srv_secs = toml_get_sections(sections, "server");
    if (vec_len(srv_secs) > 0) {
        var srv = toml_section_pairs(vec_get(srv_secs, 0));
        var port_str = toml_get(srv, "port");
        if (port_str != 0) { _http_port = str_to_int(port_str); }
    }

    # Parse [storage] section — opt-in patra persistence (path only)
    var stor_secs = toml_get_sections(sections, "storage");
    if (vec_len(stor_secs) > 0) {
        var sp = toml_section_pairs(vec_get(stor_secs, 0));
        var path_str = toml_get(sp, "path");
        if (path_str != 0) { _storage_path = to_cstr(path_str); }
    }

    # Parse [logging] section — sets the sakshi operational log level
    var log_secs = toml_get_sections(sections, "logging");
    if (vec_len(log_secs) > 0) {
        var lp = toml_section_pairs(vec_get(log_secs, 0));
        var lvl_str = toml_get(lp, "level");
        if (lvl_str != 0) {
            var lvl = hlog_level_from_str(to_cstr(lvl_str));
            if (lvl >= 0) { sakshi_set_level(lvl); }
        }
    }

    # Parse [telemetry] section — OpenTelemetry OTLP/HTTP+JSON export (off by
    # default; enabled when otlp_endpoint is set).
    var tel_secs = toml_get_sections(sections, "telemetry");
    if (vec_len(tel_secs) > 0) {
        var tp = toml_section_pairs(vec_get(tel_secs, 0));
        var ep_str = toml_get(tp, "otlp_endpoint");
        if (ep_str != 0) { _otlp_endpoint = to_cstr(ep_str); }
        var svc_str = toml_get(tp, "service_name");
        if (svc_str != 0) { _otlp_service = to_cstr(svc_str); }
    }

    # Parse [dlp] section — Data Loss Prevention scanner (off by default).
    var dlp_secs = toml_get_sections(sections, "dlp");
    if (vec_len(dlp_secs) > 0) {
        var dp = toml_section_pairs(vec_get(dlp_secs, 0));
        var den_str = toml_get(dp, "enabled");
        var dlvl_str = toml_get(dp, "default_level");
        var den = 0;
        if (den_str != 0) {
            if (str_eq_cstr(den_str, "true") == 1) { den = 1; }
        }
        var dlvl = CLASS_PUBLIC;
        if (dlvl_str != 0) {
            var parsed = dlp_class_from_str(to_cstr(dlvl_str));
            if (parsed >= 0) { dlvl = parsed; }
        }
        dlp_configure(den, dlvl);
    }

    # Parse [semantic_cache] section — embedding-similarity cache (off by default).
    var sem_secs = toml_get_sections(sections, "semantic_cache");
    if (vec_len(sem_secs) > 0) {
        var sp = toml_section_pairs(vec_get(sem_secs, 0));
        var sen_str = toml_get(sp, "enabled");
        var sen = 0;
        if (sen_str != 0) {
            if (str_eq_cstr(sen_str, "true") == 1) { sen = 1; }
        }
        var sthr = 850;
        var sthr_str = toml_get(sp, "threshold");
        if (sthr_str != 0) {
            var ts = to_cstr(sthr_str);
            var fr = _sem_parse_num(ts, 0, strlen(ts));
            sthr = load64(fr) / 10;
        }
        var smodel = 0;
        var smodel_str = toml_get(sp, "embedding_model");
        if (smodel_str != 0) { smodel = to_cstr(smodel_str); }
        var smax = 0;
        var smax_str = toml_get(sp, "max_search");
        if (smax_str != 0) { smax = str_to_int(smax_str); }
        semantic_configure(sen, sthr, smodel, smax);
    }

    # Parse [compression] section — prompt whitespace compression (off by default).
    var comp_secs = toml_get_sections(sections, "compression");
    if (vec_len(comp_secs) > 0) {
        var cmp = toml_section_pairs(vec_get(comp_secs, 0));
        var cmp_en_str = toml_get(cmp, "enabled");
        var cmp_en = 0;
        if (cmp_en_str != 0) {
            if (str_eq_cstr(cmp_en_str, "true") == 1) { cmp_en = 1; }
        }
        compression_configure(cmp_en);
    }

    # Parse [[warming]] sections — cache warming prompts (model + prompt).
    var warm_secs = toml_get_sections(sections, "warming");
    var wi = 0;
    while (wi < vec_len(warm_secs)) {
        var wp = toml_section_pairs(vec_get(warm_secs, wi));
        var wmodel = toml_get(wp, "model");
        var wprompt = toml_get(wp, "prompt");
        if (wmodel != 0 && wprompt != 0) {
            warming_add(to_cstr(wmodel), to_cstr(wprompt));
        }
        wi = wi + 1;
    }

    # Parse [[cache]] section
    var cache_secs = toml_get_sections(sections, "cache");
    if (vec_len(cache_secs) > 0) {
        var cache_p = toml_section_pairs(vec_get(cache_secs, 0));
        var max_str = toml_get(cache_p, "max_entries");
        var enabled_str = toml_get(cache_p, "enabled");
        var max_e = 10000;
        var enabled = 1;
        if (max_str != 0) { max_e = str_to_int(max_str); }
        if (enabled_str != 0) {
            if (str_eq_cstr(enabled_str, "false") == 1) { enabled = 0; }
        }
        _cache = cache_new(max_e, enabled);
    }

    # Parse [[providers]] sections
    var prov_secs = toml_get_sections(sections, "providers");
    var route_count = vec_len(prov_secs);
    if (route_count > 0) {
        var routes = alloc(route_count * 8);
        var ri = 0;
        while (ri < route_count) {
            var pp = toml_section_pairs(vec_get(prov_secs, ri));
            var ptype_str = toml_get(pp, "type");
            var purl_str = toml_get(pp, "base_url");
            var ppri_str = toml_get(pp, "priority");

            var ptype = PROV_OLLAMA;
            if (ptype_str != 0) { ptype = provider_parse(to_cstr(ptype_str)); }
            var purl = provider_default_url(ptype);
            if (purl_str != 0) { purl = to_cstr(purl_str); }
            var ppri = 1;
            if (ppri_str != 0) { ppri = str_to_int(ppri_str); }

            var route = route_new(ptype, ppri, purl);

            # Parse API key — "$NAME" expands from the environment so the
            # secret stays out of hoosh.cyml.
            var apikey_str = toml_get(pp, "api_key");
            if (apikey_str != 0) {
                var apikey = _config_expand_env(to_cstr(apikey_str));
                if (apikey != 0) {
                    store64(route + ROUTE_API_KEY, apikey);
                }
            }

            # Parse rate limit (RPM)
            var rpm_str = toml_get(pp, "rate_limit");
            if (rpm_str != 0) {
                route_set_rate_limit(route, str_to_int(rpm_str));
            }

            # Parse model patterns — TOML array: ["llama*", "mistral*"]
            var models_str = toml_get(pp, "models");
            if (models_str != 0) {
                var ms = to_cstr(models_str);
                var ms_len = strlen(ms);
                var pats = alloc(64);
                var pat_count = 0;
                var pi = 0;
                while (pi < ms_len) {
                    var mc = load8(ms + pi);
                    if (mc == 91 || mc == 93 || mc == 44 || mc == 32 || mc == 34) {
                        pi = pi + 1;
                    } else {
                        var ps = pi;
                        while (pi < ms_len) {
                            mc = load8(ms + pi);
                            if (mc == 34 || mc == 44 || mc == 93) { break; }
                            pi = pi + 1;
                        }
                        var plen = pi - ps;
                        if (plen > 0) {
                            var pat = alloc(plen + 1);
                            memcpy(pat, ms + ps, plen);
                            store8(pat + plen, 0);
                            store64(pats + pat_count * 8, pat);
                            pat_count = pat_count + 1;
                        }
                    }
                }
                if (pat_count > 0) {
                    route_set_patterns(route, pats, pat_count);
                }
            }

            store64(routes + ri * 8, route);
            ri = ri + 1;
        }
        _router = router_new(routes, route_count, STRAT_PRIORITY);
        _met_providers = route_count;
    }

    # Parse [[budgets]] sections
    var bud_secs = toml_get_sections(sections, "budgets");
    var bi = 0;
    while (bi < vec_len(bud_secs)) {
        var bp = toml_section_pairs(vec_get(bud_secs, bi));
        var bname = toml_get(bp, "name");
        var bcap_str = toml_get(bp, "capacity");
        if (bname != 0) {
            if (bcap_str != 0) {
                budget_add_pool(_budget, pool_new(to_cstr(bname), str_to_int(bcap_str)));
            }
        }
        bi = bi + 1;
    }

    # Parse [[retry]] section
    var retry_secs = toml_get_sections(sections, "retry");
    if (vec_len(retry_secs) > 0) {
        var rp = toml_section_pairs(vec_get(retry_secs, 0));
        var mr_str = toml_get(rp, "max_retries");
        var bd_str = toml_get(rp, "base_delay_ms");
        var md_str = toml_get(rp, "max_delay_ms");
        var mr = 3;
        var bd = 500;
        var md = 30000;
        if (mr_str != 0) { mr = str_to_int(mr_str); }
        if (bd_str != 0) { bd = str_to_int(bd_str); }
        if (md_str != 0) { md = str_to_int(md_str); }
        _retry_cfg = retry_config_new(mr, bd, md);
    }

    # Parse [[auth]] section
    var auth_secs = toml_get_sections(sections, "auth");
    if (vec_len(auth_secs) > 0) {
        var auth_p = toml_section_pairs(vec_get(auth_secs, 0));
        var tok_str = toml_get(auth_p, "tokens");
        if (tok_str != 0) {
            vec_push(_auth_tokens, to_cstr(tok_str));
        }
    }

    return 1;
}
