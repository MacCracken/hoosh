# pricing.cyr — per-token LLM API pricing + cost estimation.
#
# Port of the PRICING table + lookup_pricing from rust-old/src/cost/mod.rs.
# (NOT data/cloud_pricing.json — that is cloud GPU $/hour for hardware planning.)
#
# Cyrius has no floats here, so prices are carried scaled by 1000: a price of
# $3.00 per million tokens is stored as 3000. Cost is computed in micro-USD
# (1e-6 USD): cost_micro = tokens * price_scaled / 1000  (since micro-USD =
# tokens * dollars-per-million = tokens * price_scaled/1000).

var _pricing_tbl = 0;
var _pricing_n = 0;

fn _pricing_add(arr, idx, key, in_s, out_s) {
    var e = arr + idx * 24;
    store64(e, key);
    store64(e + 8, in_s);
    store64(e + 16, out_s);
    return 0;
}

# Built-in pricing table (model id -> input/output $/M ×1000). Built once.
fn _pricing_init() {
    if (_pricing_tbl != 0) { return 0; }
    var arr = alloc(16 * 24);
    # Anthropic
    _pricing_add(arr, 0, "claude-opus-4", 15000, 75000);
    _pricing_add(arr, 1, "claude-sonnet-4", 3000, 15000);
    _pricing_add(arr, 2, "claude-3.5-haiku", 800, 4000);
    _pricing_add(arr, 3, "claude-3-5-haiku", 800, 4000);
    # OpenAI
    _pricing_add(arr, 4, "gpt-4o", 2500, 10000);
    _pricing_add(arr, 5, "gpt-4o-mini", 150, 600);
    _pricing_add(arr, 6, "o1", 15000, 60000);
    _pricing_add(arr, 7, "o3-mini", 1100, 4400);
    # DeepSeek
    _pricing_add(arr, 8, "deepseek-chat", 270, 1100);
    _pricing_add(arr, 9, "deepseek-coder", 140, 280);
    _pricing_add(arr, 10, "deepseek-reasoner", 550, 2190);
    # Grok
    _pricing_add(arr, 11, "grok-3", 3000, 15000);
    _pricing_add(arr, 12, "grok-3-mini", 300, 500);
    # Groq-hosted
    _pricing_add(arr, 13, "llama-3.3-70b", 590, 790);
    _pricing_add(arr, 14, "llama-3.1-8b", 50, 80);
    # Google
    _pricing_add(arr, 15, "gemini-2.0-flash", 100, 400);
    _pricing_tbl = arr;
    _pricing_n = 16;
    return 0;
}

# Provider-level fallback when a model is not in the table. Local providers are
# free (0/0). Writes (input_scaled, output_scaled) to out[0], out[8].
fn _pricing_fallback(prov, out) {
    var in_s = 0;
    var out_s = 0;
    if (provider_is_local(prov) == 0) {
        if (prov == PROV_ANTHROPIC) { in_s = 3000; out_s = 15000; }
        if (prov == PROV_OPENAI) { in_s = 2500; out_s = 10000; }
        if (prov == PROV_DEEPSEEK) { in_s = 270; out_s = 1100; }
        if (prov == PROV_GROQ) { in_s = 590; out_s = 790; }
        if (prov == PROV_GROK) { in_s = 3000; out_s = 15000; }
        if (prov == PROV_GOOGLE) { in_s = 100; out_s = 400; }
        if (prov == PROV_MISTRAL) { in_s = 2000; out_s = 6000; }
        if (prov == PROV_OPENROUTER) { in_s = 2500; out_s = 10000; }
    }
    store64(out, in_s);
    store64(out + 8, out_s);
    return 0;
}

# Look up (input_scaled, output_scaled) for a model into out[0],out[8]:
# 1) exact match, 2) longest-prefix match, 3) provider fallback.
fn pricing_lookup(model, prov, out) {
    _pricing_init();
    var ml = strlen(model);
    var i = 0;
    while (i < _pricing_n) {
        var e = _pricing_tbl + i * 24;
        if (streq(model, load64(e)) == 1) {
            store64(out, load64(e + 8));
            store64(out + 8, load64(e + 16));
            return 0;
        }
        i = i + 1;
    }
    var best = 0 - 1;
    var best_len = 0;
    i = 0;
    while (i < _pricing_n) {
        var e = _pricing_tbl + i * 24;
        var key = load64(e);
        var kl = strlen(key);
        if (kl <= ml) {
            if (memeq(model, key, kl) == 1) {
                if (kl > best_len) {
                    best_len = kl;
                    best = i;
                }
            }
        }
        i = i + 1;
    }
    if (best >= 0) {
        var be = _pricing_tbl + best * 24;
        store64(out, load64(be + 8));
        store64(out + 8, load64(be + 16));
        return 0;
    }
    _pricing_fallback(prov, out);
    return 0;
}

# Estimate request cost in micro-USD (1e-6 USD).
fn estimate_cost_micro(model, prov, in_tok, out_tok) {
    var px = alloc(16);
    pricing_lookup(model, prov, px);
    var in_s = load64(px);
    var out_s = load64(px + 8);
    return in_tok * in_s / 1000 + out_tok * out_s / 1000;
}

# Append a micro-USD amount as a 6-decimal USD string ("0.000450").
fn pricing_append_usd(sb, micro) {
    str_builder_add_int(sb, micro / 1000000);
    str_builder_add_cstr(sb, ".");
    var frac = micro % 1000000;
    var d = 100000;
    while (d >= 1) {
        str_builder_add_int(sb, (frac / d) % 10);
        d = d / 10;
    }
    return 0;
}
