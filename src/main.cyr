# hoosh — AI inference gateway
# Multi-provider LLM routing, token budgets, caching, OpenAI-compatible API
#
# Usage:
#   hoosh serve [port]     Start the gateway (default: 8088)
#   hoosh info             System info
#   hoosh version          Show version
#   hoosh help             Show help

# Stdlib auto-included via cyrius.cyml

# ================================================================
# Dependencies (vendored into lib/ by `cyrius deps`)
# ================================================================

include "lib/ai-hwaccel.cyr"

# MCP protocol core (bote 2.7.6) — self-contained JSON-RPC 2.0 registry/
# dispatcher/codec bundle, committed under src/vendor/ rather than pulled
# via [deps.bote] (bote's manifest declares libro/majra git sub-deps that
# cyrius resolves transitively and that collide with the agnos stdlib —
# see cyrius.cyml). Powers /v1/tools/list + /v1/tools/call via src/lib/mcp.cyr.
include "src/vendor/bote-core.cyr"

# majra pub/sub (majra 2.4.7) — provider event bus, self-contained distlib
# bundle committed under src/vendor/ (same rationale as bote-core). Powers the
# event bus in src/lib/events.cyr.
include "src/vendor/majra.cyr"

# ================================================================
# Hoosh modules
# ================================================================

include "src/lib/types.cyr"
include "src/lib/dlp.cyr"
include "src/lib/compression.cyr"
include "src/lib/pricing.cyr"
include "src/lib/metadata.cyr"
include "src/lib/semantic.cyr"
include "src/lib/logging.cyr"
include "src/lib/ratelimit.cyr"
include "src/lib/route.cyr"
include "src/lib/router.cyr"
include "src/lib/budget.cyr"
include "src/lib/cache.cyr"
include "src/lib/metrics.cyr"
include "src/lib/trace.cyr"
include "src/lib/auth.cyr"
include "src/lib/http_server.cyr"
include "src/lib/http_client.cyr"
include "src/lib/provider.cyr"
include "src/lib/compact.cyr"
include "src/lib/audit.cyr"
include "src/lib/storage.cyr"
include "src/lib/retry.cyr"
include "src/lib/hardware.cyr"
include "src/lib/handlers.cyr"
include "src/lib/batch.cyr"
include "src/lib/events.cyr"
include "src/lib/health.cyr"
include "src/lib/otlp.cyr"
include "src/lib/pool.cyr"
include "src/lib/mcp.cyr"
include "src/lib/config.cyr"

# ================================================================
# Server state (globals)
# ================================================================

var _router = 0;
var _budget = 0;
var _cache = 0;
var _health_map = 0;
var _rate_map = 0;
var _auth_tokens = 0;
var _config_path = "hoosh.cyml";   # overridable with -c/--config (2.5.8)
var _http_port = 8088;
# Listen address, packed network-byte-order IPv4. Defaults to LOOPBACK
# (0x0100007F = 127.0.0.1), matching rust-old's ServerConfig.bind default —
# set `[server] bind = "0.0.0.0"` to serve off-host deliberately. Before 2.5.1
# this was hardcoded to INADDR_ANY, exposing an auth-optional gateway on every
# interface even when hoosh.cyml said 127.0.0.1.
var _http_bind = 0x0100007F;
var _retry_cfg = 0;
var _audit_chain = 0;
var _warming = 0;

# ================================================================
# HTTP route dispatch
# ================================================================

# Paths whose handler parses a request body — these are POST-only. Keep in sync
# with the POST section of http_route below; a route missing here simply keeps
# the old verb-agnostic behavior rather than breaking.
fn _requires_post(path) {
    if (streq(path, "/v1/chat/completions") == 1) { return 1; }
    if (streq(path, "/v1/embeddings") == 1) { return 1; }
    if (streq(path, "/v1/batch") == 1) { return 1; }
    if (streq(path, "/v1/tokens/check") == 1) { return 1; }
    if (streq(path, "/v1/tokens/reserve") == 1) { return 1; }
    if (streq(path, "/v1/tokens/report") == 1) { return 1; }
    if (streq(path, "/v1/hardware/placement") == 1) { return 1; }
    if (streq(path, "/v1/hardware/cost") == 1) { return 1; }
    if (streq(path, "/v1/hardware/training-estimate") == 1) { return 1; }
    if (streq(path, "/v1/hardware/model-format") == 1) { return 1; }
    if (streq(path, "/v1/hardware/requirement-match") == 1) { return 1; }
    if (streq(path, "/v1/hardware/simulate") == 1) { return 1; }
    if (streq(path, "/v1/models/pull") == 1) { return 1; }
    if (streq(path, "/v1/models/delete") == 1) { return 1; }
    if (streq(path, "/v1/training/status") == 1) { return 1; }
    if (streq(path, "/v1/cost/estimate") == 1) { return 1; }
    if (streq(path, "/v1/cost/recommend") == 1) { return 1; }
    if (streq(path, "/v1/tools/call") == 1) { return 1; }
    return 0;
}

fn http_route(cfd, method, path, buf, buf_len) {
    hlog_request(method, path);
    # W3C Trace Context: carry the incoming traceparent (or none) for this
    # request so outgoing backend forwards join the trace. Reset per request
    # (the accept thread is reused); the forward generates one if none arrived.
    trace_set(trace_extract(buf, buf_len));
    # CORS preflight
    if (streq(method, "OPTIONS") == 1) {
        var cr = make_crlf();
        var hdr = str_builder_new();
        str_builder_add_cstr(hdr, "HTTP/1.1 204 No Content");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Origin: *");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Methods: GET, POST, OPTIONS");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Headers: Content-Type, Authorization");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, cr);
        var h = str_builder_build(hdr);
        sys_write(cfd, to_cstr(h), str_len(h));
        return 0;
    }

    # Auth check (skip health + metrics)
    if (streq(path, "/v1/health") != 1) {
        if (streq(path, "/metrics") != 1) {
            if (auth_check(buf, buf_len, _auth_tokens) == 0) {
                hlog_warn("auth: rejected request (invalid/missing bearer token)");
                return http_error(cfd, "401", "Unauthorized", "invalid or missing bearer token");
            }
        }
    }

    # Method enforcement (2.5.2). rust-old got this free from axum's
    # get()/post() builders; the flat chain below dispatches on path alone, so a
    # GET to a body-taking route used to reach the handler with no body and
    # answer a confusing 400 ("empty request body") instead of 405.
    #
    # Deliberately one-sided: only the routes that REQUIRE a body are enforced.
    # Gating the GET routes too would turn a POST that works today (the chain
    # ignores the verb, and an ignored body is harmless) into a 405 — a
    # breaking change for consumers, with no correctness win.
    if (streq(method, "POST") != 1) {
        if (_requires_post(path) == 1) {
            hlog_warn("route: body-taking path reached with a non-POST verb");
            return http_method_not_allowed(cfd, "POST");
        }
    }

    # GET routes
    if (streq(path, "/v1/health") == 1) { return handle_health(cfd); }
    if (streq(path, "/v1/health/providers") == 1) { return handle_health_providers(cfd); }
    if (streq(path, "/v1/health/heartbeat") == 1) { return handle_heartbeat(cfd); }
    if (streq(path, "/v1/models") == 1) { return handle_models(cfd); }
    if (streq(path, "/v1/models/catalog") == 1) { return handle_models_catalog(cfd); }
    if (streq(path, "/api/tags") == 1) { return handle_ollama_tags(cfd); }
    if (streq(path, "/v1/costs") == 1) { return handle_costs(cfd); }
    if (streq(path, "/v1/audit") == 1) { return handle_audit(cfd); }
    if (streq(path, "/v1/cache/stats") == 1) { return handle_cache_stats(cfd); }
    if (streq(path, "/v1/tools/list") == 1) { return handle_tools_list(cfd); }
    if (streq(path, "/v1/events/recent") == 1) { return handle_events_recent(cfd); }
    if (streq(path, "/v1/tokens/pools") == 1) { return handle_token_pools(cfd); }
    if (streq(path, "/v1/queue/status") == 1) { return handle_queue_status(cfd); }
    if (streq(path, "/v1/hardware") == 1) { return handle_hardware(cfd); }
    if (streq(path, "/v1/hardware/models") == 1) { return handle_hw_models(cfd); }
    if (streq(path, "/v1/hardware/compatible-models") == 1) { return handle_hw_compatible(cfd); }
    if (streq(path, "/v1/hardware/telemetry") == 1) { return handle_hw_telemetry(cfd); }
    if (streq(path, "/metrics") == 1) { return handle_metrics(cfd); }

    # POST routes
    if (streq(path, "/v1/costs/reset") == 1) {
        # 2.5.6: clearing spend history is an administrative act that destroys
        # billing evidence, so it lands in the audit chain at `warn` — rust-old
        # recorded the same `admin.costs_reset`. _chat_lock guards the record
        # vec the pool workers append to.
        mutex_lock(_chat_lock);
        metrics_reset();
        cost_reset();
        mutex_unlock(_chat_lock);
        if (_audit_chain != 0) {
            audit_record(_audit_chain, "admin.costs_reset",
            "warn", "cost records cleared", "admin", "");
        }
        hlog_warn("admin: cost records cleared");
        var body = "{\"status\":\"reset\"}";
        return http_ok(cfd, body, strlen(body));
    }
    if (streq(path, "/v1/admin/reload") == 1) {
        # _chat_lock serializes the reload with budget/routing readers that also
        # hold it (chat prep/assemble, token handlers). _router is rebuilt as a
        # fresh pointer (atomic swap; lock-free forwarders read old-or-new, both
        # valid — the bump allocator never frees). See [ADR 011].
        mutex_lock(_chat_lock);
        load_config(_config_path);
        mutex_unlock(_chat_lock);
        hlog_info("config reloaded from hoosh.cyml");
        var body = "{\"status\":\"reloaded\"}";
        return http_ok(cfd, body, strlen(body));
    }
    if (streq(path, "/v1/tokens/check") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_check(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/tokens/reserve") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_reserve(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/tokens/report") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_report(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/placement") == 1) {
        var hb = req_parse_body(buf, buf_len);
        return handle_hw_placement(cfd, hb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/cost") == 1) {
        var cb = req_parse_body(buf, buf_len);
        return handle_hw_cost(cfd, cb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/training-estimate") == 1) {
        var trb = req_parse_body(buf, buf_len);
        return handle_hw_training(cfd, trb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/model-format") == 1) {
        var mfb = req_parse_body(buf, buf_len);
        return handle_hw_model_format(cfd, mfb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/requirement-match") == 1) {
        var rmb = req_parse_body(buf, buf_len);
        return handle_hw_requirement_match(cfd, rmb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/simulate") == 1) {
        var smb = req_parse_body(buf, buf_len);
        return handle_hw_simulate(cfd, smb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/embeddings") == 1) {
        var eb = req_parse_body(buf, buf_len);
        var ebl = req_body_len(buf, buf_len);
        if (ebl > 0) {
            # Route through first available provider
            var routes = load64(_router + ROUTER_ROUTES);
            var rcount = load64(_router + ROUTER_COUNT);
            var ei = 0;
            while (ei < rcount) {
                var er = load64(routes + ei * 8);
                if (route_enabled(er) == 1) {
                    var eport = url_port(route_base_url(er));
                    var epath = "/api/embeddings";
                    if (route_provider(er) != PROV_OLLAMA) {
                        epath = "/v1/embeddings";
                    }
                    var eresp = http_post_local(eport, epath, eb, ebl);
                    if (eresp != 0) {
                        if (http_status(eresp) >= 200) {
                            if (http_status(eresp) < 300) {
                                return http_ok(cfd, http_body(eresp), http_body_len(eresp));
                            }
                        }
                    }
                }
                ei = ei + 1;
            }
        }
        hlog_error("embeddings: no backend produced a usable response");
        return http_error(cfd, "502", "Bad Gateway", "embeddings backend unavailable");
    }
    if (streq(path, "/v1/chat/completions") == 1) {
        var body = req_parse_body(buf, buf_len);
        return handle_chat(cfd, body, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/models/pull") == 1) {
        var mpb = req_parse_body(buf, buf_len);
        return handle_model_pull(cfd, mpb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/models/delete") == 1) {
        var mdb = req_parse_body(buf, buf_len);
        return handle_model_delete(cfd, mdb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/training/status") == 1) {
        var tsb = req_parse_body(buf, buf_len);
        return handle_synapse_training(cfd, tsb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/catalog/sync") == 1) {
        return handle_synapse_sync(cfd);
    }
    if (streq(path, "/v1/cost/estimate") == 1) {
        var ceb = req_parse_body(buf, buf_len);
        return handle_cost_estimate(cfd, ceb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/cost/recommend") == 1) {
        var crb = req_parse_body(buf, buf_len);
        return handle_cost_recommend(cfd, crb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/tools/call") == 1) {
        var tcb = req_parse_body(buf, buf_len);
        return handle_tools_call(cfd, tcb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/batch") == 1) {
        var bbb = req_parse_body(buf, buf_len);
        return handle_batch(cfd, bbb, req_body_len(buf, buf_len));
    }
    # /v1/batch/{id}  (GET progress)  and  /v1/batch/{id}/cancel  (POST)
    var plen = strlen(path);
    if (plen > 10) {
        if (memeq(path, "/v1/batch/", 10) == 1) {
            if (plen > 17 && memeq(path + plen - 7, "/cancel", 7) == 1) {
                var idlen = plen - 17;
                var bid = alloc(idlen + 1);
                memcpy(bid, path + 10, idlen);
                store8(bid + idlen, 0);
                return handle_batch_cancel(cfd, bid);
            }
            return handle_batch_get(cfd, path + 10);
        }
    }

    # Root
    if (streq(path, "/") == 1) {
        var rsb = str_builder_new();
        str_builder_add_cstr(rsb, "{\"name\":\"hoosh\",\"version\":\"");
        str_builder_add_cstr(rsb, HOOSH_VERSION);
        str_builder_add_cstr(rsb, "\",\"status\":\"ok\"}");
        var rbody = str_builder_build(rsb);
        var rbd = to_cstr(rbody);
        return http_ok(cfd, rbd, str_len(rbody));
    }

    return http_not_found(cfd);
}

# ================================================================
# Server accept loop
# ================================================================

fn cmd_serve(port) {
    _http_port = port;
    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { println("error: failed to create socket"); return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);

    var br = sock_bind(sfd, _http_bind, _http_port);
    if (is_err_result(br) == 1) { println("error: failed to bind"); return 1; }

    var lr = sock_listen(sfd, 128);
    if (is_err_result(lr) == 1) { println("error: failed to listen"); return 1; }

    # Ignore SIGPIPE (2.4.13): hoosh runs its OWN accept loop and writes SSE chunks with bare `sys_write`
    # (MSG_NOSIGNAL-less), so a client that disconnects MID-STREAM — e.g. thoth's Esc-interrupt aborting a streaming
    # turn — makes the NEXT chunk write raise SIGPIPE, whose default disposition TERMINATES the gateway. That killed
    # hoosh a moment after any interrupted stream, so every following request "failed to connect." sandhi installs
    # this guard inside `sandhi_server_run`, which our hand-rolled loop bypasses; call its proven portable helper
    # (rt_sigaction SIGPIPE→SIG_IGN) once here so a dead peer yields an EPIPE write error instead of a crash.
    _sandhi_server_ignore_sigpipe();

    sys_write(1, "hoosh v", 7);
    sys_write(1, HOOSH_VERSION, strlen(HOOSH_VERSION));
    sys_write(1, " listening on ", 14);
    var baddr = bind_addr_str(_http_bind);
    sys_write(1, baddr, strlen(baddr));
    sys_write(1, ":", 1);
    var pbuf = alloc(32);
    var plen = fmt_int_buf(_http_port, pbuf);
    sys_write(1, pbuf, plen);
    println("");
    sys_write(1, "OpenAI-compatible API: http://localhost:", 40);
    sys_write(1, pbuf, plen);
    println("/v1/chat/completions");
    var rc = load64(_router + ROUTER_COUNT);
    fmt_int(rc);
    println(" provider route(s) configured");
    if (hw_ready() == 1) {
        fmt_int(hw_device_count());
        sys_write(1, " hw device(s), ", 15);
        fmt_int(hw_gpu_count());
        println(" accelerator(s)");
    }

    # Operational startup log (stderr) — banner above stays on stdout.
    store8(pbuf + plen, 0);
    var lsb = str_builder_new();
    str_builder_add_cstr(lsb, "hoosh ");
    str_builder_add_cstr(lsb, HOOSH_VERSION);
    str_builder_add_cstr(lsb, " serving on :");
    str_builder_add_cstr(lsb, pbuf);
    var lmsg = str_builder_build(lsb);
    sakshi_info(str_data(lmsg), str_len(lmsg));

    # Cache warming — synchronously pre-populate the cache before accepting
    # traffic (opt-in via [[warming]] in hoosh.cyml).
    warming_run();

    # MCP tool server — build bote's registry + dispatcher (bote_echo
    # registered) so /v1/tools/list + /v1/tools/call are live on start.
    mcp_init();

    # Chat bookkeeping lock — guards shared state when batch workers run
    # concurrently (POST /v1/batch). Created before the accept loop.
    _chat_lock = mutex_new();

    # Async batch registry + exec lock (POST /v1/batch async, GET /v1/batch/{id}).
    batch_registry_init();

    # Per-provider latency histogram storage (Prometheus /metrics).
    metrics_latency_init();

    # Install the accept thread's thread-local block once (slot 0 = sigil crypto
    # bank, slot 1 = traceparent). Idempotent + shared with the batch path.
    crypto_tls_main_init();

    # Provider event bus (majra pubsub) + recent-events ring (GET /v1/events/recent).
    events_init();

    # OpenTelemetry OTLP exporter — spawns the background export thread if
    # [[telemetry]] otlp_endpoint is configured (no-op otherwise).
    otlp_init();

    # Signals (2.5.8) — MUST precede pool_start so every worker inherits the
    # blocked mask; an unblocked SIGINT delivered to a worker would take the
    # default action and kill the process mid-request.
    signals_init();

    # Unified worker pool (v2.4.0): WORKER_COUNT banked threads drain the work
    # queue. crypto_tls_main_init() above readied the bank scratch; pool_start
    # spawns the workers, each owning a crypto bank. Batch items share this pool.
    pool_start();

    # Background provider health probing (2.5.5) — one bankless thread keeps the
    # per-route health records that router_select consults. Probes once inline
    # first so the earliest requests route on measured state. No-op when
    # [server] health_check_interval_secs = 0.
    health_start();

    # Periodic hardware re-detection (2.5.7) — no-op unless
    # [hardware] refresh_interval_secs is set.
    hw_refresh_start();

    # Accept loop: accept connections and hand each to the pool. All request
    # handling (recv/route/respond/close) runs on the workers, concurrently.
    while (shutdown_requested() == 0) {
        var client = sock_accept(sfd);
        if (is_err_result(client) == 1) { continue; }
        if (shutdown_requested() == 1) {
            # Woken by the self-connect from _sig_thread, or raced with it.
            sock_close(payload(client));
            break;
        }
        wq_push(_job_conn(payload(client)));
    }

    # Graceful shutdown (2.5.8): stop accepting, then let the workers finish
    # what they already took. Requests in flight get to answer instead of having
    # their sockets yanked mid-response.
    sock_close(sfd);
    hlog_info("shutdown: listener closed, draining in-flight requests");
    var waited = 0;
    while (wq_outstanding() > 0 && waited < SHUTDOWN_DRAIN_MS) {
        sleep_ms(10);
        waited = waited + 10;
    }
    if (wq_outstanding() > 0) {
        hlog_warn("shutdown: drain timed out with work still queued");
    }
    hlog_info("shutdown: complete");
    println("");
    println("hoosh: shutdown complete");
    return 0;
}

# ================================================================
# CLI commands
# ================================================================

fn cmd_info() {
    sys_write(1, "hoosh v", 7);
    println(HOOSH_VERSION);
    println("");
    println("AI inference gateway — multi-provider LLM routing");
    println("");
    println("Local providers: ollama, llamacpp, synapse, lmstudio, localai");
    println("Remote providers: openai, anthropic, deepseek, mistral,");
    println("                  groq, grok, openrouter, google");
    println("");
    sys_write(1, "Default port: ", 14);
    fmt_int(_http_port);
    println("");

    # Hardware summary
    if (hw_ready() == 1) {
        sys_write(1, "Devices: ", 9);
        fmt_int(hw_device_count());
        sys_write(1, " (", 2);
        fmt_int(hw_gpu_count());
        println(" accelerator(s))");
        var best = hw_best_device();
        if (best != 0) {
            sys_write(1, "Best device: ", 13);
            println(accel_name(profile_accel_type(best)));
        }
    }
    return 0;
}

fn cmd_models() {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    println("Configured providers:");
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        sys_write(1, "  ", 2);
        var name = provider_name(route_provider(r));
        sys_write(1, name, strlen(name));
        sys_write(1, " @ ", 3);
        var url = route_base_url(r);
        sys_write(1, url, strlen(url));
        if (route_enabled(r) != 1) {
            sys_write(1, " [disabled]", 11);
        }
        println("");
        i = i + 1;
    }
    return 0;
}

fn cmd_health() {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var all_ok = 1;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            var base = route_base_url(r);
            var up = 0;
            var _sr = tcp_socket();
            if (is_ok(_sr) == 1) {
                var fd = payload(_sr);
                var _cr = sock_connect(fd, host_addr(url_host(base)), url_port(base));
                if (is_ok(_cr) == 1) { up = 1; }
                sys_close(fd);
            }
            sys_write(1, "  ", 2);
            var name = provider_name(route_provider(r));
            sys_write(1, name, strlen(name));
            if (up == 1) {
                println(" — ok");
            } else {
                println(" — DOWN");
                all_ok = 0;
            }
        }
        i = i + 1;
    }
    if (all_ok == 1) { return 0; }
    return 1;
}

# Connect-latency micro-benchmark (perf detour): loop N tcp_socket+sock_connect+close
# to <url>'s host:port via net.cyr — the exact connect path cmd_health / the gateway
# use — and report avg connect latency. Isolates the connect from ELF-load/startup so
# the number is comparable across Linux (native) and agnos (QEMU/SLIRP). agnos's
# monotonic clock is 10ms-quantized (uptime_ms), so we time a loop TOTAL over many
# connects and report the per-connect average (washes out the quantization when the
# total >> 10ms).
fn cmd_bench_connect(url, n) {
    if (n <= 0) { n = 2000; }
    var host = url_host(url);
    var addr = host_addr(host);
    var port = url_port(url);
    # Warmup one connect so the timed loop measures steady-state (ARP/route primed,
    # and on agnos the 8-slot conn table warmed), not first-connect setup.
    var w = tcp_socket();
    if (is_ok(w) == 1) { var wf = payload(w); sock_connect(wf, addr, port); sock_close(wf); }
    var ok = 0;
    var t0 = clock_now_ns();
    var i = 0;
    while (i < n) {
        var sr = tcp_socket();
        if (is_ok(sr) == 1) {
            var fd = payload(sr);
            if (is_ok(sock_connect(fd, addr, port)) == 1) { ok = ok + 1; }
            sock_close(fd);
        }
        i = i + 1;
    }
    var t1 = clock_now_ns();
    var total_us = (t1 - t0) / 1000;
    var avg_us = total_us;
    if (n > 0) { avg_us = total_us / n; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "bench: N=");    str_builder_add_int(sb, n);
    str_builder_add_cstr(sb, " ok=");         str_builder_add_int(sb, ok);
    str_builder_add_cstr(sb, " total=");      str_builder_add_int(sb, total_us);
    str_builder_add_cstr(sb, "us avg=");      str_builder_add_int(sb, avg_us);
    str_builder_add_cstr(sb, "us/connect");
    println(to_cstr(str_builder_build(sb)));
    return 0;
}

fn cmd_infer(model, prompt) {
    var route = router_select(_router, model);
    if (route == 0) {
        println("error: no provider for model");
        return 1;
    }
    var result = provider_forward(route, model, prompt, 0, 0, 0, 0, 0);   # 2.5.0: no thinking on CLI infer
    # <= 0 covers both the retryable (0) and permanent (FWD_PERMANENT) failures.
    if (result <= 0) {
        println("error: inference failed");
        return 1;
    }
    var text = load64(result);
    println(text);
    return 0;
}

# ================================================================
# Remote CLI mode — --server <url> (2.5.8)
# ================================================================
#
# rust-old's models/health/infer talked to a RUNNING gateway over HTTP; the port
# only ever read the local config, so there was no way to ask a deployed hoosh
# what it was actually serving. These use the plaintext local client, so
# --server targets an http:// gateway (the usual case: a sidecar or a box on the
# LAN). An https:// gateway would need a crypto bank on this thread.

fn _cli_server_get(url, path) {
    var resp = http_req_local("GET", url, path, 0, 0);
    if (resp == 0) {
        println("error: could not reach the hoosh server");
        return 0;
    }
    if (http_status(resp) < 200 || http_status(resp) >= 300) {
        println("error: server returned a non-2xx status");
        return 0;
    }
    return resp;
}

fn cmd_models_remote(url) {
    var resp = _cli_server_get(url, "/v1/models");
    if (resp == 0) { return 1; }
    sys_write(1, http_body(resp), http_body_len(resp));
    println("");
    return 0;
}

fn cmd_health_remote(url) {
    var resp = _cli_server_get(url, "/v1/health/providers");
    if (resp == 0) { return 1; }
    var b = http_body(resp);
    var bl = http_body_len(resp);
    sys_write(1, b, bl);
    println("");
    # Exit non-zero if any provider is unhealthy, so shell scripts can gate on it.
    var i = 0;
    while (i + 20 < bl) {
        if (memeq(b + i, "\"status\":\"unhealthy\"", 20) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn _cli_infer_body(model, prompt, stream) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"model\":\"");
    str_builder_add_cstr(sb, model);
    str_builder_add_cstr(sb, "\",\"stream\":");
    if (stream == 1) {
        str_builder_add_cstr(sb, "true");
    } else {
        str_builder_add_cstr(sb, "false");
    }
    str_builder_add_cstr(sb, ",\"messages\":[{\"role\":\"user\",\"content\":\"");
    _json_emit_escaped(sb, prompt);
    str_builder_add_cstr(sb, "\"}]}");
    return to_cstr(str_builder_build(sb));
}

fn cmd_infer_remote(url, model, prompt, stream) {
    var body = _cli_infer_body(model, prompt, stream);
    var blen = strlen(body);
    if (stream == 0) {
        var resp = http_post_local(url, "/v1/chat/completions", body, blen);
        if (resp == 0) {
            println("error: could not reach the hoosh server");
            return 1;
        }
        var rb = http_body(resp);
        var rbl = http_body_len(resp);
        if (http_status(resp) < 200 || http_status(resp) >= 300) {
            sys_write(1, rb, rbl);
            println("");
            return 1;
        }
        var text = ollama_extract_text(rb, rbl);
        println(text);
        return 0;
    }
    # Streaming: read SSE frames and print each delta as it lands, so the CLI
    # shows tokens progressively rather than after the whole answer.
    var fd = http_post_stream(url, "/v1/chat/completions", body, blen);
    if (fd < 0) {
        println("error: could not reach the hoosh server");
        return 1;
    }
    var hdr = alloc(4096);
    if (stream_skip_headers(fd, hdr, 4096) < 0) {
        sock_close(fd);
        println("error: malformed streaming response");
        return 1;
    }
    var buf = alloc(65536);
    var acc = 0;
    while (1 == 1) {
        var n = sys_read(fd, buf + acc, 65536 - acc - 1);
        if (n <= 0) { break; }
        store8(buf + acc + n, 0);
        var scan = acc;
        acc = acc + n;
        # Emit the content of each complete `data: {...}` line.
        var i = scan;
        while (i + 6 < acc) {
            if (memeq(buf + i, "data: ", 6) == 1) {
                var j = i + 6;
                var start = j;
                while (j < acc && load8(buf + j) != 10) { j = j + 1; }
                if (j >= acc) { break; }
                var flen = j - start;
                if (flen > 0 && memeq(buf + start, "[DONE]", 6) == 0) {
                    var piece = ollama_extract_text(buf + start, flen);
                    if (strlen(piece) > 0) { sys_write(1, piece, strlen(piece)); }
                }
                i = j;
            }
            i = i + 1;
        }
        # Keep the buffer from filling on a long answer: once consumed, reset.
        if (acc > 60000) { acc = 0; }
    }
    sock_close(fd);
    println("");
    return 0;
}

fn cmd_help() {
    println("hoosh — AI inference gateway");
    println("");
    println("Usage: hoosh <command> [options] [args]");
    println("");
    println("Commands:");
    println("  serve [port]       start the gateway server (default: 8088)");
    println("    -p, --port <n>     listen port");
    println("        --bind <addr>  listen address (default: 127.0.0.1)");
    println("    -c, --config <f>   config file (default: hoosh.cyml)");
    println("  models             list models");
    println("  health             check provider connectivity");
    println("  infer <model> <p>  one-shot inference");
    println("        --stream       stream tokens to stdout as they arrive");
    println("  info               show system information");
    println("  help               show this help");
    println("  version            show version");
    println("");
    println("Options for models / health / infer:");
    println("    --server <url>     query a RUNNING hoosh over HTTP instead of");
    println("                       reading the local config (e.g. http://host:8088)");
    println("");
    println("Environment:");
    println("  HOOSH_LOG            log level: fatal|error|warn|info|debug|trace");
    return 0;
}

# ================================================================
# Process lifecycle — signals (2.5.8)
# ================================================================
#
# SIGINT/SIGTERM shut the gateway down cleanly and SIGHUP reloads the config
# (rust-old server/mod.rs:390-401). Neither existed before: Ctrl-C killed hoosh
# mid-request with the listener still bound, and reloading meant a restart.
#
# Implemented with signalfd rather than a signal HANDLER. A handler would need
# an SA_RESTORER trampoline on Linux x86-64 and could only safely set a flag —
# whereas config reload has to take _chat_lock, which is not async-signal-safe.
# Blocking the signals process-wide and reading them off an fd from a dedicated
# thread turns delivery into an ordinary blocking read, so the work runs in
# normal thread context with locks available. sys_sigprocmask / sys_signalfd are
# the sanctioned wrappers; no raw syscall numbers.
var _shutdown = 0;
var _sigfd = 0 - 1;

# Terminate the whole PROCESS, not just this thread.
#
# The stdlib's sys_exit is SYS_EXIT (60), which on Linux exits only the CALLING
# THREAD despite its "terminate process" comment — with the 7 pool workers plus
# the health/OTLP/signal threads running, returning from main left hoosh alive
# and unkillable-looking after a clean shutdown. It never showed before 2.5.8
# because the accept loop simply never returned. exit_group is the correct call;
# the stdlib has the SYS_EXIT_GROUP constant but no wrapper, so this is hoosh's
# local one — the single place a bare syscall appears, pending an upstream
# sys_exit_group.
fn hoosh_exit_process(code) {
    syscall(SYS_EXIT_GROUP, code);
    return 0;
}
# How long to let queued work finish after the listener closes. Long enough for
# an in-flight inference to answer, short enough that Ctrl-C still feels prompt.
var SHUTDOWN_DRAIN_MS = 5000;

fn shutdown_requested() { return _shutdown; }

fn _sig_thread(arg) {
    # signalfd_siginfo is 128 bytes; ssi_signo is the first u32.
    var buf = alloc(128);
    while (1 == 1) {
        var n = sys_read(_sigfd, buf, 128);
        if (n <= 0) { return 0; }
        var signo = load32(buf);
        if (signo == SIGHUP) {
            hlog_info("signal: SIGHUP — reloading config");
            mutex_lock(_chat_lock);
            var ok = load_config(_config_path);
            mutex_unlock(_chat_lock);
            if (ok == 1) {
                hlog_info("signal: config reloaded");
            } else {
                hlog_warn("signal: config reload failed, keeping the running config");
            }
        } else {
            hlog_info("signal: shutdown requested, draining");
            _shutdown = 1;
            # Nudge the accept loop out of its blocking accept() by connecting to
            # ourselves; it re-checks _shutdown on wake.
            var sfd_r = tcp_socket();
            if (is_ok(sfd_r) == 1) {
                var s = payload(sfd_r);
                net_connect_nb(s, 0x0100007F, _http_port, 500);
                sock_close(s);
            }
            return 0;
        }
    }
    return 0;
}

# Block SIGINT/SIGTERM/SIGHUP and route them to a signalfd read by _sig_thread.
# Must run BEFORE the worker pool spawns so every thread inherits the block —
# an unblocked signal delivered to a worker would take the default action and
# kill the process, which is the behavior being replaced.
fn signals_init() {
    #ifdef CYRIUS_TARGET_LINUX
    var mask = alloc(8);
    store64(mask, (1 << (SIGINT - 1)) | (1 << (SIGTERM - 1)) | (1 << (SIGHUP - 1)));
    if (sys_sigprocmask(SIG_BLOCK, mask, 0) != 0) {
        hlog_warn("signal: could not block signals; Ctrl-C will terminate abruptly");
        return 0;
    }
    _sigfd = sys_signalfd(0 - 1, mask, 0);
    if (_sigfd < 0) {
        # CRITICAL: the signals are blocked but nothing can read them, which
        # would make hoosh ignore SIGINT/SIGTERM entirely — unkillable short of
        # SIGKILL. Unblock and fall back to the default disposition (abrupt
        # termination), which is worse than a clean shutdown but far better than
        # a gateway that cannot be stopped.
        sys_sigprocmask(SIG_UNBLOCK, mask, 0);
        hlog_warn("signal: signalfd unavailable; Ctrl-C will terminate abruptly");
        return 0;
    }
    thread_create(&_sig_thread, 0);
    #endif
    return 0;
}

# ================================================================
# CLI flag parsing (2.5.8)
# ================================================================
#
# Before this, `serve` took a bare positional port and nothing else accepted a
# flag — so bind address, config path, and the `--server` target rust-old
# supported were all unreachable from the command line. Supports
# `--name value`, `--name=value` and short `-p value`.

# Value for `--name` / `-short`, or 0 when absent. `short` may be 0.
fn _flag_val(name, short) {
    var ac = argc();
    var nlen = strlen(name);
    var i = 1;
    while (i < ac) {
        var a = argv(i);
        if (streq(a, name) == 1) {
            if (i + 1 < ac) { return argv(i + 1); }
            return 0;
        }
        if (short != 0 && streq(a, short) == 1) {
            if (i + 1 < ac) { return argv(i + 1); }
            return 0;
        }
        # --name=value
        if (memeq(a, name, nlen) == 1) {
            if (load8(a + nlen) == 61) { return a + nlen + 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Whether a valueless flag is present.
fn _flag_set(name) {
    var ac = argc();
    var i = 1;
    while (i < ac) {
        if (streq(argv(i), name) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

# Nth positional argument after the subcommand (0-based), skipping flags and
# their values. Returns 0 when absent.
fn _positional(n) {
    var ac = argc();
    var seen = 0;
    var i = 2;
    while (i < ac) {
        var a = argv(i);
        if (load8(a) == 45) {
            # A flag. Skip its value too unless it used --name=value form or is
            # one of the known valueless flags.
            if (streq(a, "--stream") == 0) {
                var has_eq = 0;
                var j = 0;
                while (load8(a + j) != 0) {
                    if (load8(a + j) == 61) { has_eq = 1; }
                    j = j + 1;
                }
                if (has_eq == 0) { i = i + 1; }
            }
        } else {
            if (seen == n) { return a; }
            seen = seen + 1;
        }
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();
    args_init();
    sha256_global_init();

    # Native TLS is sandhi's default backend (no build flag needed since
    # cyrius 6.1.21 / sandhi native-default). use_native here is a belt-and-
    # braces assertion: it returns 0 when the native stack is present (the
    # normal case) and -1 only if the binary was built libssl-only via
    # `-D CYRIUS_TLS_LIBSSL` — which routes remote HTTPS through the fdlopen
    # libssl bridge whose brk-malloc + TLS arena SIGSEGVs on repeated requests.
    # Warn loudly in that case rather than failing quietly. See sandhi
    # docs/architecture/004-native-tls-default.md.
    if (sandhi_tls_use_native() != 0) {
        var _w = "WARNING: native TLS backend unavailable — built libssl-only "
        ;
        sys_write(2, _w, strlen(_w));
        var _w2 = "via -D CYRIUS_TLS_LIBSSL. Remote HTTPS runs on the libssl "
        ;
        sys_write(2, _w2, strlen(_w2));
        var _w3 = "bridge, which SIGSEGVs on repeated requests. Rebuild without it.\n"
        ;
        sys_write(2, _w3, strlen(_w3));
    }

    # Initialize state
    _budget = budget_new();
    budget_add_pool(_budget, pool_new("default", 10000000));
    _cache = cache_new(10000, 1, 300);   # 300 s TTL default, matching hoosh.cyml
    _health_map = map_new();
    _rate_map = map_new();
    _auth_tokens = vec_new();
    _retry_cfg = retry_config_default();
    # _audit_chain is built AFTER load_config below, from [audit]. It used to be
    # created here with a key compiled into the binary.

    # Default router: single ollama route
    var default_routes = alloc(8);
    store64(default_routes, route_new(PROV_OLLAMA, 1, "http://localhost:11434"));
    _router = router_new(default_routes, 1, STRAT_PRIORITY);
    _met_providers = 1;

    # Log level from the environment (2.5.8) — the RUST_LOG equivalent. Read
    # before load_config so config-parse problems are logged at the level asked
    # for; [[logging]] level in the file still wins if it sets one.
    var envlvl = getenv("HOOSH_LOG");
    if (envlvl != 0) {
        var lv = hlog_level_from_str(envlvl);
        if (lv >= 0) { sakshi_set_level(lv); }
    }

    # -c/--config (2.5.8): an alternate config file.
    var cfgv = _flag_val("--config", "-c");
    if (cfgv != 0) { _config_path = cfgv; }

    # Install THIS thread's thread-local block (slot 0 = sigil crypto bank,
    # slot 1 = traceparent) before anything can touch it. It used to live inside
    # cmd_serve, so every non-serve path ran with no TLS block — and any code
    # reaching trace_current_or_new() (which every outgoing request header
    # builder does) dereferenced an uninstalled block and SEGFAULTED. That was
    # latent until 2.5.8 gave the CLI a reason to make HTTP requests.
    # CAS-guarded upstream, so cmd_serve calling it again is a no-op.
    crypto_tls_main_init();

    # Load config FIRST (2.5.7): [hardware] disabled_backends has to be known
    # before detection runs, or the backends it names get probed once anyway.
    #
    # 2.5.8: a config that EXISTS but fails to parse is now fatal. Silently
    # falling back to defaults meant a typo'd config started a gateway with no
    # providers, no auth and no budgets — looking healthy while serving nothing
    # the operator asked for. A missing file is still fine (defaults apply).
    if (file_exists(_config_path) == 1) {
        if (load_config(_config_path) != 1) {
            sys_write(2, "error: failed to parse ", 23);
            sys_write(2, _config_path, strlen(_config_path));
            println("");
            return 1;
        }
    }

    # Detect hardware accelerators, honoring [hardware].
    hw_init();

    # Audit chain (2.5.7) — built from [audit] now that config is parsed. 0 when
    # auditing is off, which every audit_record call site already tolerates.
    _audit_chain = audit_chain_from_config();

    # Open persistence (opt-in via [[storage]] path) and restore prior state.
    if (_storage_path != 0) {
        # patra needs the freelist + its own allocator initialized first.
        fl_init();
        patra_init();
        _storage = storage_open(_storage_path);
        if (_storage != 0) {
            var na = storage_restore_audit(_audit_chain);
            var nb = storage_restore_budgets(_budget);
            var ssb = str_builder_new();
            str_builder_add_cstr(ssb, "storage: restored ");
            str_builder_add_int(ssb, na);
            str_builder_add_cstr(ssb, " audit entries, ");
            str_builder_add_int(ssb, nb);
            str_builder_add_cstr(ssb, " budget pools");
            var smsg = str_builder_build(ssb);
            sakshi_info(str_data(smsg), str_len(smsg));
        } else {
            hlog_error("storage: failed to open db; continuing in-memory");
        }
    }

    # CLI
    var ac = argc();
    if (ac < 2) { return cmd_serve(_http_port); }

    var cmd = argv(1);
    if (streq(cmd, "serve") == 1) {
        # --port/-p, else a bare positional port (the pre-2.5.8 form), else config.
        var port = _http_port;
        var pv = _flag_val("--port", "-p");
        if (pv == 0) { pv = _positional(0); }
        if (pv != 0) {
            var pnum = atoi(pv);
            if (pnum > 0) { port = pnum; }
        }
        # --bind overrides [server] bind.
        var bv = _flag_val("--bind", 0);
        if (bv != 0) { _http_bind = host_addr(bv); }
        return cmd_serve(port);
    }
    if (streq(cmd, "models") == 1) {
        var msrv = _flag_val("--server", 0);
        if (msrv != 0) { return cmd_models_remote(msrv); }
        return cmd_models();
    }
    if (streq(cmd, "health") == 1) {
        var hsrv = _flag_val("--server", 0);
        if (hsrv != 0) { return cmd_health_remote(hsrv); }
        return cmd_health();
    }
    if (streq(cmd, "bench") == 1) {
        if (ac < 3) { println("Usage: hoosh bench <url> [count]"); return 1; }
        var bn = 2000;
        if (ac >= 4) { bn = atoi(argv(3)); }
        return cmd_bench_connect(argv(2), bn);
    }
    if (streq(cmd, "infer") == 1) {
        var im = _positional(0);
        var ip = _positional(1);
        if (im == 0 || ip == 0) {
            println("Usage: hoosh infer [--server <url>] [--stream] <model> <prompt>");
            return 1;
        }
        var isrv = _flag_val("--server", 0);
        if (isrv != 0) {
            return cmd_infer_remote(isrv, im, ip, _flag_set("--stream"));
        }
        return cmd_infer(im, ip);
    }
    if (streq(cmd, "info") == 1) { return cmd_info(); }
    if (streq(cmd, "help") == 1) { return cmd_help(); }
    if (streq(cmd, "--help") == 1) { return cmd_help(); }
    if (streq(cmd, "-h") == 1) { return cmd_help(); }
    if (streq(cmd, "version") == 1 || streq(cmd, "--version") == 1) {
        sys_write(1, "hoosh v", 7);
        println(HOOSH_VERSION);
        return 0;
    }

    sys_write(2, "unknown command: ", 17);
    sys_write(2, cmd, strlen(cmd));
    println("");
    return 1;
}

var r = main();
# exit_group, not sys_exit: hoosh is multi-threaded, and SYS_EXIT would retire
# only this thread and leave the process running. See hoosh_exit_process.
hoosh_exit_process(r);
