include "src/lib/hardware.cyr"
include "src/lib/handlers.cyr"
include "src/lib/config.cyr"

# ================================================================
# Server state (globals)
# ================================================================

var _router = 0;
var _budget = 0;
var _cache = 0;
var _health_map = 0;
var _rate_map = 0;
var _cost_map = 0;
var _auth_tokens = 0;
var _config_path = 0;
var _http_port = 8088;
var _retry_cfg = 0;
var _audit_chain = 0;

# ================================================================
# HTTP route dispatch
# ================================================================

fn http_route(cfd, method, path, buf, buf_len) {
    # CORS preflight
    if (streq(method, "OPTIONS") == 1) {
        var cr = make_crlf();
        var hdr = str_builder_new();
        str_builder_add_cstr(hdr, "HTTP/1.1 204 No Content");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Origin: *");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Methods: GET, POST, OPTIONS");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, "Access-Control-Allow-Headers: Content-Type, Authorization");
        str_builder_add_cstr(hdr, cr);
        str_builder_add_cstr(hdr, cr);
        var h = str_builder_build(hdr);
        syscall(SYS_WRITE, cfd, to_cstr(h), str_len(h));
        return 0;
    }

    # Auth check (skip health + metrics)
    if (streq(path, "/v1/health") != 1) {
        if (streq(path, "/metrics") != 1) {
            if (auth_check(buf, buf_len, _auth_tokens) == 0) {
                return http_error(cfd, "401", "Unauthorized", "invalid or missing bearer token");
            }
        }
    }

    # GET routes
    if (streq(path, "/v1/health") == 1) { return handle_health(cfd); }
    if (streq(path, "/v1/health/providers") == 1) { return handle_health_providers(cfd); }
    if (streq(path, "/v1/health/heartbeat") == 1) { return handle_heartbeat(cfd); }
    if (streq(path, "/v1/models") == 1) { return handle_models(cfd); }
    if (streq(path, "/v1/costs") == 1) { return handle_costs(cfd); }
    if (streq(path, "/v1/audit") == 1) { return handle_audit(cfd); }
    if (streq(path, "/v1/cache/stats") == 1) { return handle_cache_stats(cfd); }
    if (streq(path, "/v1/tokens/pools") == 1) { return handle_token_pools(cfd); }
    if (streq(path, "/v1/queue/status") == 1) { return handle_queue_status(cfd); }
    if (streq(path, "/v1/hardware") == 1) { return handle_hardware(cfd); }
    if (streq(path, "/v1/hardware/models") == 1) { return handle_hw_models(cfd); }
    if (streq(path, "/metrics") == 1) { return handle_metrics(cfd); }

    # POST routes
    if (streq(path, "/v1/costs/reset") == 1) {
        metrics_reset();
        var body = "{\"status\":\"reset\"}";
        return http_ok(cfd, body, strlen(body));
    }
    if (streq(path, "/v1/admin/reload") == 1) {
        load_config("hoosh.toml");
        var body = "{\"status\":\"reloaded\"}";
        return http_ok(cfd, body, strlen(body));
    }
    if (streq(path, "/v1/tokens/check") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_check(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/tokens/reserve") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_reserve(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/tokens/report") == 1) {
        var tb = req_parse_body(buf, buf_len);
        return handle_tokens_report(cfd, tb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/hardware/placement") == 1) {
        var hb = req_parse_body(buf, buf_len);
        return handle_hw_placement(cfd, hb, req_body_len(buf, buf_len));
    }
    if (streq(path, "/v1/embeddings") == 1) {
        var eb = req_parse_body(buf, buf_len);
        var ebl = req_body_len(buf, buf_len);
        if (ebl > 0) {
            # Route through first available provider
            var routes = load64(_router + ROUTER_ROUTES);
            var rcount = load64(_router + ROUTER_COUNT);
            var ei = 0;
            while (ei < rcount) {
                var er = load64(routes + ei * 8);
                if (route_enabled(er) == 1) {
                    var eport = url_port(route_base_url(er));
                    var epath = "/api/embeddings";
                    if (route_provider(er) != PROV_OLLAMA) {
                        epath = "/v1/embeddings";
                    }
                    var eresp = http_post_local(eport, epath, eb, ebl);
                    if (eresp != 0) {
                        if (http_status(eresp) >= 200) {
                            if (http_status(eresp) < 300) {
                                return http_ok(cfd, http_body(eresp), http_body_len(eresp));
                            }
                        }
                    }
                }
                ei = ei + 1;
            }
        }
        return http_error(cfd, "502", "Bad Gateway", "embeddings backend unavailable");
    }
    if (streq(path, "/v1/chat/completions") == 1) {
        var body = req_parse_body(buf, buf_len);
        return handle_chat(cfd, body, req_body_len(buf, buf_len));
    }

    # Root
    if (streq(path, "/") == 1) {
        var body = "{\"name\":\"hoosh\",\"version\":\"2.0.0\",\"status\":\"ok\"}";
        return http_ok(cfd, body, strlen(body));
    }

    return http_not_found(cfd);
}

# ================================================================
# Server accept loop
# ================================================================

fn cmd_serve(port) {
    _http_port = port;
    var sfd_r = tcp_socket();
    if (is_err_result(sfd_r) == 1) { println("error: failed to create socket"); return 1; }
    var sfd = payload(sfd_r);
    sock_reuse(sfd);

    var br = sock_bind(sfd, INADDR_ANY(), _http_port);
    if (is_err_result(br) == 1) { println("error: failed to bind"); return 1; }

    var lr = sock_listen(sfd, 128);
    if (is_err_result(lr) == 1) { println("error: failed to listen"); return 1; }

    syscall(1, 1, "hoosh v", 7);
    syscall(1, 1, HOOSH_VERSION, strlen(HOOSH_VERSION));
    syscall(1, 1, " listening on 0.0.0.0:", 22);
    var pbuf = alloc(32);
    var plen = fmt_int_buf(_http_port, pbuf);
    syscall(1, 1, pbuf, plen);
    println("");
    syscall(1, 1, "OpenAI-compatible API: http://localhost:", 40);
    syscall(1, 1, pbuf, plen);
    println("/v1/chat/completions");
    var rc = load64(_router + ROUTER_COUNT);
    fmt_int(rc);
    println(" provider route(s) configured");
    if (hw_ready() == 1) {
        fmt_int(hw_device_count());
        syscall(1, 1, " hw device(s), ", 15);
        fmt_int(hw_gpu_count());
        println(" accelerator(s)");
    }

    while (1 == 1) {
        var client = sock_accept(sfd);
        if (is_err_result(client) == 1) { continue; }
        var cfd = payload(client);
        var req_buf = alloc(65536);
        var recv_r = sock_recv(cfd, req_buf, 65535);
        if (is_err_result(recv_r) == 1) { sock_close(cfd); continue; }
        var req_len = payload(recv_r);
        if (req_len > 0) {
            store8(req_buf + req_len, 0);
            var method = http_parse_method(req_buf, req_len);
            var path = http_parse_path(req_buf, req_len);
            if (path != 0) {
                http_route(cfd, method, path, req_buf, req_len);
            } else {
                http_bad_request(cfd, "malformed request");
            }
        }
        sock_close(cfd);
    }
    return 0;
}

# ================================================================
# CLI commands
# ================================================================

fn cmd_info() {
    syscall(1, 1, "hoosh v", 7);
    println(HOOSH_VERSION);
    println("");
    println("AI inference gateway — multi-provider LLM routing");
    println("");
    println("Local providers: ollama, llamacpp, synapse, lmstudio, localai");
    println("Remote providers: openai, anthropic, deepseek, mistral,");
    println("                  groq, grok, openrouter, google");
    println("");
    syscall(1, 1, "Default port: ", 14);
    fmt_int(_http_port);
    println("");

    # Hardware summary
    if (hw_ready() == 1) {
        syscall(1, 1, "Devices: ", 9);
        fmt_int(hw_device_count());
        syscall(1, 1, " (", 2);
        fmt_int(hw_gpu_count());
        println(" accelerator(s))");
        var best = hw_best_device();
        if (best != 0) {
            syscall(1, 1, "Best device: ", 13);
            println(accel_name(profile_accel_type(best)));
        }
    }
    return 0;
}

fn cmd_models() {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    println("Configured providers:");
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        syscall(1, 1, "  ", 2);
        var name = provider_name(route_provider(r));
        syscall(1, 1, name, strlen(name));
        syscall(1, 1, " @ ", 3);
        var url = route_base_url(r);
        syscall(1, 1, url, strlen(url));
        if (route_enabled(r) != 1) {
            syscall(1, 1, " [disabled]", 11);
        }
        println("");
        i = i + 1;
    }
    return 0;
}

fn cmd_health() {
    var routes = load64(_router + ROUTER_ROUTES);
    var count = load64(_router + ROUTER_COUNT);
    var all_ok = 1;
    var i = 0;
    while (i < count) {
        var r = load64(routes + i * 8);
        if (route_enabled(r) == 1) {
            var port = url_port(route_base_url(r));
            var up = 0;
            var fd = syscall(SYS_SOCKET, 2, 1, 0);
            if (fd >= 0) {
                var sa = sockaddr_in(0x0100007F, port);
                var cr = syscall(SYS_CONNECT, fd, sa, 16);
                if (cr >= 0) { up = 1; }
                syscall(3, fd);
            }
            syscall(1, 1, "  ", 2);
            var name = provider_name(route_provider(r));
            syscall(1, 1, name, strlen(name));
            if (up == 1) {
                println(" — ok");
            } else {
                println(" — DOWN");
                all_ok = 0;
            }
        }
        i = i + 1;
    }
    if (all_ok == 1) { return 0; }
    return 1;
}

fn cmd_infer(model, prompt) {
    var route = router_select(_router, model);
    if (route == 0) {
        println("error: no provider for model");
        return 1;
    }
    var result = provider_forward(route, model, prompt, 0, 0);
    if (result == 0) {
        println("error: inference failed");
        return 1;
    }
    var text = load64(result);
    println(text);
    return 0;
}

fn cmd_help() {
    println("hoosh — AI inference gateway");
    println("");
    println("Usage: hoosh <command> [args]");
    println("");
    println("Commands:");
    println("  serve [port]       start the gateway server (default: 8088)");
    println("  models             list configured providers");
    println("  health             check provider connectivity");
    println("  infer <model> <p>  one-shot inference");
    println("  info               show system information");
    println("  help               show this help");
    println("  version            show version");
    return 0;
}

# ================================================================
# Main
# ================================================================

fn main() {
    alloc_init();
    args_init();
    sha256_global_init();

    # Initialize state
    _budget = budget_new();
    budget_add_pool(_budget, pool_new("default", 10000000));
    _cache = cache_new(10000, 1);
    _health_map = map_new();
    _rate_map = map_new();
    _cost_map = map_new();
    _auth_tokens = vec_new(8);
    _retry_cfg = retry_config_default();
    _audit_chain = audit_chain_new("hoosh-audit-key", 15, 10000);

    # Default router: single ollama route
    var default_routes = alloc(8);
    store64(default_routes, route_new(PROV_OLLAMA, 1, "http://localhost:11434"));
    _router = router_new(default_routes, 1, STRAT_PRIORITY);
    _met_providers = 1;

    # Detect hardware accelerators
    hw_init();

    # Load config
    load_config("hoosh.toml");

    # CLI
    var ac = argc();
    if (ac < 2) { return cmd_serve(_http_port); }

    var cmd = argv(1);
    if (streq(cmd, "serve") == 1) {
        var port = _http_port;
        if (ac >= 3) {
            port = atoi(argv(2));
            if (port <= 0) { port = 8088; }
        }
        return cmd_serve(port);
    }
    if (streq(cmd, "models") == 1) { return cmd_models(); }
    if (streq(cmd, "health") == 1) { return cmd_health(); }
    if (streq(cmd, "infer") == 1) {
        if (ac < 4) {
            println("Usage: hoosh infer <model> <prompt>");
            return 1;
        }
        return cmd_infer(argv(2), argv(3));
    }
    if (streq(cmd, "info") == 1) { return cmd_info(); }
    if (streq(cmd, "help") == 1) { return cmd_help(); }
    if (streq(cmd, "--help") == 1) { return cmd_help(); }
    if (streq(cmd, "-h") == 1) { return cmd_help(); }
    if (streq(cmd, "version") == 1 || streq(cmd, "--version") == 1) {
        syscall(1, 1, "hoosh v", 7);
        println(HOOSH_VERSION);
        return 0;
    }

    syscall(1, 2, "unknown command: ", 17);
    syscall(1, 2, cmd, strlen(cmd));
    println("");
    return 1;
}

var r = main();
syscall(SYS_EXIT, r);
