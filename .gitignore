# Build artifacts — keep the build/ dir tracked (via .gitkeep) so it always
# exists and the compiler drops the binary there, never falling back to the
# repo root. Ignore everything else inside it.
/build/*
!/build/.gitkeep
# Belt-and-suspenders: ignore a stray top-level binary if one is ever produced.
/hoosh

# Cyrius vendored stdlib + deps (cyrius lib sync / cyrius deps vendor these)
/lib/*.cyr

# Editor / IDE
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Debugging
*.pdb
core
core.*
*.core

# Coverage
lcov.info
coverage/

# Environment / secrets
.env
.env.*

# Persistence DB (created at runtime when [[storage]] is enabled)
*.patra

# Model weights (downloaded at runtime, not tracked)
models/
*.bin
*.gguf
*.onnx

# Claude Code
.claude/

# Audio output from TTS
output.wav

# QEMU cores
*.core
